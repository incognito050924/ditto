    {
      "term": "cross_repo",
      "aliases": [],
      "definition": "단일모듈 CodeQL DB 분석에서 형제모듈(로컬 JAR) 의존이 정적으로 해소되지 않아 ImpactGraph.unresolved에 남는 kind. internal_packages의 glob에 매칭돼야 기록되며, 써드파티(Spring/JDK)와 구분된다.",
      "examples": ["kr.co.ecoletree.boxwood.domain.runtime.processing.StructuredErrorInfo (automation-engine이 libs의 domain-model JAR를 참조)"],
      "not_to_be_confused_with": ["journey_unknown", "third-party dependency"],
      "status": "agreed",
      "forbidden_abbreviations": [],
