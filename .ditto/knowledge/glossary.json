    {
      "term": "request",
      "aliases": [],
      "definition": "사용자가 한 말의 원문 또는 그에 가까운 paraphrase. 한 요청에서 여러 work item이 파생될 수 있다.",
      "examples": [],
      "not_to_be_confused_with": ["work item"],
      "status": "agreed",
