      "agreed_at": "2026-05-24T12:00:00+09:00"
    },
    {
      "term": "work item",
      "aliases": [],
      "definition": "DITTO가 추적하는 작업 단위. goal, acceptance criteria, 실행 기록, 검증 evidence, handoff를 포함한다. 식별자: wi_*. task라는 이름은 사용하지 않는다.",
      "examples": ["wi_v01bootstrap", "wi_v01implement"],
      "not_to_be_confused_with": ["task", "issue", "ticket"],
      "status": "agreed",
      "forbidden_abbreviations": ["wi"],
      "agreed_at": "2026-05-24T12:00:00+09:00"
    },
    {
      "term": "run",
      "aliases": [],
      "definition": "한 번의 provider 호출. 한 work item은 여러 run을 가질 수 있다. 식별자: run_*.",
      "examples": ["run_pwdcheck1"],
      "not_to_be_confused_with": ["session", "background task"],
      "status": "agreed",
      "forbidden_abbreviations": [],
      "agreed_at": "2026-05-24T12:00:00+09:00"
    },
    {
      "term": "run manifest",
      "aliases": [],
      "definition": "run의 권위 있는 기록 파일. provider, profile, git state, prompt, stdout/stderr, diff, verifications, unverified 항목을 포함한다.",
