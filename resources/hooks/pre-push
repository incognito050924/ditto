#!/bin/sh
# ditto:managed:pre-push (wi_260629i9c) — installed by `ditto setup` from a
# recipe.yaml that declares a `push_gate`. Do not edit; `ditto setup` rewrites
# this file in place, and `ditto uninstall` removes it (restoring any prior hook).
#
# It runs `ditto push-gate`, which reads git's pre-push refs on stdin, resolves
# the workspace recipe.yaml's push_gate for THIS repo, and runs the gate's
# test_command before allowing a push to a protected branch.
#
# Bypass: set DITTO_SKIP_HOOKS=1 (the sanctioned escape hatch).
set -u

# 1) Sanctioned bypass — leave before resolving/spawning anything.
if [ "${DITTO_SKIP_HOOKS:-}" != "" ]; then
  exit 0
fi

REPO=$(git rev-parse --show-toplevel 2>/dev/null) || REPO=

# 2) ROOT-ONLY trust seam (wi_2606299kn ac-3). `ditto setup` REWRITES the WS_ROOT
#    line below when it installs this hook into a CLONED SUB-REPO: it sets WS_ROOT to
#    the absolute path of the TRUSTED workspace root. Left EMPTY for a normal/root
#    install (REPO itself is the trusted root). The clone-RCE danger this closes:
#      - a cloned sub-repo's OWN recipe.yaml could ship a malicious push_gate
#        test_command — so the gate must resolve the ROOT recipe, not the cwd's. We
#        pass `--workspace-root "$WS_ROOT"` so `ditto push-gate` anchors on the root.
#      - a cloned sub-repo could ship its OWN tracked bin/ditto — so we must NOT
#        blind-prefer REPO/bin/ditto. The TRUSTED repo (below) is the workspace root
#        for a sub-repo install, REPO only for a root install.
WS_ROOT=""

if [ -n "$WS_ROOT" ]; then
  # Sub-repo install: trust the workspace root (NOT the cloned REPO) for both the
  # binary and the recipe; pass the root pointer to the gate.
  TRUSTED_REPO="$WS_ROOT"
  set -- --workspace-root "$WS_ROOT"
else
  # Root/single install: REPO is the trusted root; its bin/ditto is trusted (ditto's
  # own dogfood repo relies on this).
  TRUSTED_REPO="$REPO"
  set --
fi

# 3) Resolve a runnable ditto ROBUSTLY + PORTABLY. ditto's runnable artifact is a
#    portable JS bundle invoked via `bun` (bin/ditto.cmd is `@bun "%~dp0ditto"`;
#    scripts/npx-bootstrap.mjs spawns `bun <bundle>`); the installed PATH `ditto`
#    is a `#!/usr/bin/env bun` launcher. Prefer the TRUSTED repo's ./bin/ditto, else
#    the `ditto` on PATH — never a cloned sub-repo's bin/ditto, never a bare native
#    binary.
if [ -n "$TRUSTED_REPO" ] && [ -f "$TRUSTED_REPO/bin/ditto" ]; then
  if command -v bun >/dev/null 2>&1; then
    set -- bun "$TRUSTED_REPO/bin/ditto" push-gate "$@"
  else
    set -- "$TRUSTED_REPO/bin/ditto" push-gate "$@"
  fi
elif command -v ditto >/dev/null 2>&1; then
  set -- ditto push-gate "$@"
else
  # 4) FAIL-CLOSED: ditto is unresolvable. This is a SAFETY gate, so blocking a
  #    push we cannot evaluate beats silently allowing it (false confidence).
  echo "[ditto] pre-push: ditto not found — no trusted ./bin/ditto and none on PATH." >&2
  echo "        Cannot evaluate the push gate, so the push is BLOCKED. Either:" >&2
  echo "          - install ditto (https://github.com/incognito050924/ditto)," >&2
  echo "          - push a non-protected branch, or" >&2
  echo "          - set DITTO_SKIP_HOOKS=1 to bypass this gate." >&2
  exit 1
fi

# 5) Pipe git's pre-push stdin straight INTO `ditto push-gate` and adopt its exit
#    code (exec preserves this hook's stdin = git's `<localref> <localsha>
#    <remoteref> <remotesha>` lines).
exec "$@"
