# DITTO Windows launcher: check out with CRLF so cmd.exe runs the batch shim
# reliably on Windows. The bundle bin/ditto stays LF — `bun` reads it on any OS.
bin/ditto.cmd text eol=crlf

# WS0-T0 (wi_2607069bk): work item Record committed base `.ditto/work-items/<id>/`.
# record.json is an author-mutated single JSON file — standard 3-way merge (never
# union: union would concatenate two objects into invalid JSON). events/*.json are
# per-event immutable files (one event per file, exclusive create), so two writers
# never touch the same file — no merge driver needed, but pin standard merge too.
.ditto/work-items/**/record.json merge=text
.ditto/work-items/**/events/*.json merge=text
