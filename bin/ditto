    return {
      role: "source",
      host: "codex",
      path,
      exists: content !== null,
      ...content !== null ? { content } : {}
    };
  },
  async loadPermissions(repoRoot) {
    const repoPath = join4(repoRoot, ".codex", "config.toml");
    const repoText = await readTextIfExists(repoPath);
    const inventories = [
      repoText === null ? {
        host: "codex",
        source_file: repoPath,
        status: "missing",
        raw: {},
        unavailable_reason: "codex repo config not found"
