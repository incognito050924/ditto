function commandSegments(cmd) {
  return cmd.split(/\|\||&&|[;&|]/).map((s2) => s2.trim());
}
function leadingCommand(seg) {
  const afterEnv = seg.replace(/^(?:\s*[A-Za-z_]\w*=(?:"[^"]*"|'[^']*'|\S+)\s+)*\s*/, "");
  return afterEnv.split(/\s+/)[0] ?? "";
}
function shellWords(seg) {
  return seg.match(/"[^"]*"|'[^']*'|\S+/g)?.map((w2) => w2.replace(/^(['"])(.*)\1$/, "$2")) ?? [];
}
function isShellEnvAssignment(word) {
  return /^[A-Za-z_]\w*=/.test(word);
}
function basenameCommand(word) {
  return word.replace(/^.*[\\/]/, "");
}
function operativeShellCommand(seg) {
  const words = shellWords(seg);
  let i3 = 0;
  while (i3 < words.length) {
    while (i3 < words.length && isShellEnvAssignment(words[i3] ?? ""))
      i3++;
    const word = words[i3] ?? "";
    if (word === "env") {
      i3++;
      while (i3 < words.length) {
        const current = words[i3] ?? "";
        if (current === "-u" || current === "--unset") {
          i3 += 2;
          continue;
        }
        if (current === "-i" || current === "--ignore-environment" || current.startsWith("-u")) {
          i3++;
          continue;
        }
        if (current.startsWith("-")) {
          i3++;
          continue;
        }
        if (isShellEnvAssignment(current)) {
          i3++;
          continue;
        }
        break;
      }
      continue;
    }
    if (word === "command" || word === "exec" || word === "sudo") {
      i3++;
      while (word === "sudo" && i3 < words.length && (words[i3] ?? "").startsWith("-"))
        i3++;
      continue;
    }
    return basenameCommand(word);
  }
  return "";
}
function shellRunsApplyPatch(cmd) {
  return commandSegments(cmd).some((seg) => operativeShellCommand(seg) === "apply_patch");
}
function isCommandTool(input, toolName) {
  return toolName === "Bash" || input.host === "codex" && toolName === "exec_command";
}
function commandToolInput(input, toolName, toolInput) {
  if (typeof toolInput.command === "string")
    return toolInput.command;
  if (input.host === "codex" && toolName === "exec_command" && typeof toolInput.cmd === "string") {
    return toolInput.cmd;
  }
  return;
}
function segmentTokens(seg) {
  const out = [];
  for (const raw of seg.split(/[\s'"=]+/)) {
    if (raw.length === 0)
      continue;
    const redir = raw.match(/^([0-9]*<)(.*)$/);
    if (redir) {
      out.push("<");
      if (redir[2] && redir[2].length > 0)
        out.push(redir[2]);
    } else {
      out.push(raw);
    }
  }
  return out;
}
function asPath(t3) {
  return t3.startsWith("@") ? t3.slice(1) : t3;
}
function bashSecretExposure(cmd) {
  for (const seg of commandSegments(cmd)) {
    const tokens = segmentTokens(seg);
    if (tokens.length === 0)
      continue;
    const verb = tokens[0] ?? "";
    const args = tokens.slice(1);
    for (let i3 = 0;i3 < args.length; i3++) {
      if (args[i3] === "<") {
        const src2 = args[i3 + 1] ?? "";
        if (isSecretPath(asPath(src2)))
          return asPath(src2);
      }
    }
    if (SEARCH_VERBS.has(verb)) {
      let seenPattern = false;
      for (let i3 = 0;i3 < args.length; i3++) {
        const a4 = args[i3] ?? "";
        if (a4 === "<") {
          i3++;
          continue;
        }
        if (a4.startsWith("-")) {
          if (SEARCH_PATTERN_FLAGS.has(a4))
            i3++;
          continue;
        }
        if (!seenPattern) {
          seenPattern = true;
          continue;
        }
        if (isSecretPath(asPath(a4)))
          return asPath(a4);
      }
      continue;
    }
    const secretToken = args.find((t3) => t3 !== "<" && !t3.startsWith("-") && isSecretPath(asPath(t3)));
    if (secretToken === undefined)
      continue;
    if (METADATA_VERBS.has(verb))
      continue;
    return asPath(secretToken);
  }
  return;
}
function isOutsideRepo(repoRoot, filePath) {
  const resolved = resolve18(repoRoot, filePath);
  const rel = relative19(repoRoot, resolved);
  return rel.startsWith("..") || isAbsolute14(rel);
}
function isClaudeMemoryPath(repoRoot, filePath) {
  const home = process.env.HOME ?? homedir9();
  if (!home)
    return false;
  const slug = resolve18(repoRoot).replace(/[^a-zA-Z0-9]/g, "-");
  const base = resolve18(home, ".claude", "projects", slug, "memory");
  const rel = relative19(base, resolve18(filePath));
  return rel.length > 0 && !rel.startsWith("..") && !isAbsolute14(rel);
}
var WIN_TMP = /(^|[\\/])%temp%([\\/]|$)|(^|[\\/])%tmp%([\\/]|$)|[\\/]appdata[\\/]local[\\/]temp([\\/]|$)|[\\/]windows[\\/]temp([\\/]|$)/i;
function isSystemTmpPath(filePath) {
  if (WIN_TMP.test(filePath))
    return true;
  const resolved = resolve18(filePath);
  for (const root of ["/tmp", "/private/tmp", tmpdir()]) {
    if (!root)
      continue;
    const rel = relative19(resolve18(root), resolved);
    if (rel.length > 0 && !rel.startsWith("..") && !isAbsolute14(rel))
      return true;
  }
  return false;
}
var RM_LITERAL_BLOCK = ["rm -rf /", "rm -rf ~", "rm -rf /*", "rm -rf ~/"];
function isRecursiveForceRm(cmd) {
  if (!/(^|[;&|]\s*)rm\b/.test(cmd))
    return false;
  const hasRecursive = /\s-\w*r/i.test(cmd) || /--recursive\b/.test(cmd);
  const hasForce = /\s-\w*f/i.test(cmd) || /--force\b/.test(cmd);
  return hasRecursive && hasForce;
}
function rmTargets(cmd) {
  const m4 = cmd.match(/\brm\b([^;&|]*)/);
  if (!m4)
    return [];
  return (m4[1] ?? "").trim().split(/\s+/).filter((t3) => t3.length > 0 && !t3.startsWith("-"));
}
var WIN_ROOT = /(^|\s)[a-z]:\\?\*?(\s|$)|\\\\|%systemdrive%|%systemroot%|%userprofile%|%homepath%|%homedrive%|%windir%|%programfiles%/i;
var WIN_REMOVE_CMDS = new Set([
  "rd",
  "rmdir",
  "del",
  "erase",
  "remove-item",
  "ri",
  "rm"
]);
function isWinAbsolute(p2) {
  return /^([a-z]:[\\/]|\\\\|[\\/])/i.test(p2);
}
function winNorm(p2) {
  return p2.replace(/\//g, "\\").replace(/\\+$/, "").toLowerCase();
}
function winInside(child, parent) {
  if (!parent)
    return false;
  const c5 = winNorm(child);
  const par = winNorm(parent);
  return c5 === par || c5.startsWith(`${par}\\`);
}
function winDeleteTargets(seg) {
  return seg.split(/\s+/).map((t3) => t3.replace(/^["']+|["']+$/g, "")).filter((t3) => t3.length > 0 && !t3.startsWith("/") && !t3.startsWith("-") && t3.toLowerCase() !== "format" && !WIN_REMOVE_CMDS.has(t3.toLowerCase()));
}
function windowsDestructiveReason(normalized, home = "") {
  for (const seg of commandSegments(normalized)) {
    const cmd = leadingCommand(seg).toLowerCase();
    if (cmd === "format" && /(^|\s)[a-z]:/i.test(seg)) {
      return "format of a Windows drive";
    }
    if (!WIN_REMOVE_CMDS.has(cmd))
      continue;
    const recursive = /(^|\s)\/s\b/i.test(seg) || /-recurse\b/i.test(seg) && /-force\b/i.test(seg);
    if (!recursive)
      continue;
    if (WIN_ROOT.test(seg)) {
      return "recursive delete of a Windows drive root or system location";
    }
    const outside = winDeleteTargets(seg).find((t3) => isWinAbsolute(t3) && !/[*%]/.test(t3) && !winInside(t3, home));
    if (outside) {
      return "recursive delete of an absolute Windows path outside home";
    }
  }
  return null;
}
function checkDestructive(cmd) {
  const normalized = cmd.replace(/\s+/g, " ").trim();
  if (IS_WIN) {
    const winReason = windowsDestructiveReason(normalized, HOME);
    if (winReason)
      return block2("destructive", winReason);
  }
  if (normalized.replace(/\s/g, "").includes(":(){:|:&};:")) {
    return block2("destructive", "fork bomb");
  }
  if (/\bmkfs\.?\w*/.test(normalized))
    return block2("destructive", "mkfs on a device");
  if (/\bdd\b[^;&|]*\bof=\/dev\//.test(normalized))
    return block2("destructive", "dd to a device");
  if (/>\s*\/dev\/sd/.test(normalized))
    return block2("destructive", "overwrite of a block device");
  if (commandSegments(normalized).filter((seg) => leadingCommand(seg) === "sudo").some((seg) => /\b(rm|dd|mkfs\.?\w*)\b/.test(seg))) {
    return block2("destructive", "sudo with a destructive command");
  }
  const pushSegments = normalized.split(/[;&|]+/).map((seg) => seg.trim()).filter((seg) => /\bgit\b.*\bpush\b/.test(seg));
  if (pushSegments.some((seg) => /(--force-with-lease|--force|(^|\s)-\w*f)/.test(seg) && /\b(main|master)\b/.test(seg))) {
    return block2("destructive", "force-push to a default branch");
  }
  for (const seg of commandSegments(normalized)) {
    if (operativeShellCommand(seg) !== "git")
      continue;
    const words = shellWords(seg);
    if (words.includes("push") && words.includes("--no-verify")) {
      return block2("no-verify-push", "git push --no-verify skips the pre-push test gate");
    }
  }
  if (RM_LITERAL_BLOCK.includes(normalized)) {
    return block2("destructive", "recursive force remove of a root/home path");
  }
  if (isRecursiveForceRm(normalized)) {
    for (const target of rmTargets(normalized)) {
      if (/[$`*]/.test(target))
        continue;
      if (!isAbsolute14(target))
        continue;
      const insideHome = HOME.length > 0 && (target === HOME || target.startsWith(`${HOME}/`));
      if (!insideHome) {
        return block2("destructive", `recursive force remove outside repo/home (${target})`);
      }
    }
  }
  return ALLOW;
}
async function loadArchSpec(repoRoot) {
  try {
    return await readArchitectureSpec(resolve18(repoRoot, ".ditto", "architecture-spec.json"), acgArchitectureSpec);
  } catch {
    return;
  }
}
async function checkForbiddenScope(input, filePath) {
  const raw = input.raw ?? {};
  const sessionId = typeof raw.session_id === "string" ? raw.session_id : undefined;
  if (!sessionId)
    return;
  const workItemId2 = await new SessionPointerStore(input.repoRoot).get(sessionId);
  if (!workItemId2)
    return;
  const contract = await new ChangeContractStore(input.repoRoot).read(workItemId2);
  if (!contract)
    return;
  const repoRel2 = leaseScopeRelPath(input.repoRoot, filePath);
  const archSpec = await loadArchSpec(input.repoRoot);
  if (contract.scope_mode === "whitelist" && contract.allowed_scope.length > 0) {
    const allowed = contract.allowed_scope.some((ref) => scopeRefMatches(ref, repoRel2, archSpec));
    if (!allowed) {
      return block2("tidy-scope", `${repoRel2} is outside this tidy contract's allowed_scope (whitelist: allowed=diff, forbidden=\uADF8\uC678)`);
    }
    return;
  }
  if (contract.forbidden_scope.length === 0)
    return;
  const hit = matchForbiddenScope(contract.forbidden_scope, repoRel2, archSpec);
  if (hit) {
    return block2("forbidden-scope", `${repoRel2} is in this work item's forbidden_scope (${hit.kind}:${hit.ref})`);
  }
  return;
}
function autopilotBypassActive(input) {
  const env2 = input.env ?? {};
  return env2.DITTO_AUTOPILOT_BYPASS === "1" || process.env.DITTO_AUTOPILOT_BYPASS === "1";
}
async function appendBypassRecord(repoRoot, entry) {
  const dir = join70(repoRoot, ".ditto");
  await ensureDir(dir);
  const path = join70(dir, "autopilot-bypass.jsonl");
  const file = Bun.file(path);
  const existing = await file.exists() ? await file.text() : "";
  const prefix = existing.length === 0 || existing.endsWith(`
`) ? existing : `${existing}
`;
  await atomicWriteText(path, `${prefix}${JSON.stringify(entry)}
`);
}
function fileScopeContains(scope, repoRelPath) {
  return scope.some((s2) => scopeRefMatches(/[*?[\]]/.test(s2) ? { kind: "glob", ref: s2 } : { kind: "path", ref: s2 }, repoRelPath));
}
var TESTS_ALLOW_NODE_KINDS = new Set(["implement", "fix", "refactor"]);
function leaseScopeRelPath(repoRoot, filePath, pathImpl = {
  resolve: resolve18,
  relative: relative19,
  sep: sep9
}) {
  const resolved = pathImpl.resolve(repoRoot, filePath);
  const worktree = parseWorktreePath(resolved, pathImpl.sep);
  const scopeRoot = worktree ? localDir(worktree.workspace, "worktrees", worktree.workItemId) : repoRoot;
  return toPosixSeparators(pathImpl.relative(scopeRoot, resolved), pathImpl.sep);
}
async function checkAutopilotLease(input, filePath) {
  if (isOutsideRepo(input.repoRoot, filePath) && isSystemTmpPath(filePath))
    return;
  const raw = input.raw ?? {};
  const sessionId = typeof raw.session_id === "string" ? raw.session_id : undefined;
  if (!sessionId)
    return;
  const workItemId2 = await new SessionPointerStore(input.repoRoot).get(sessionId);
  if (!workItemId2)
    return;
  const aps = new AutopilotStore(input.repoRoot);
  if (!await aps.exists(workItemId2))
    return;
  let graph;
  try {
    graph = await aps.get(workItemId2);
  } catch {
    return;
  }
  const hasNonTerminal = graph.nodes.some((n3) => n3.status === "pending" || n3.status === "running" || n3.status === "blocked");
  if (!hasNonTerminal)
    return;
  const leases = await new ActiveNodeLeaseStore(input.repoRoot).listActive(workItemId2);
  if (leases.length === 0)
    return;
  if (leases.some((l2) => l2.scope_source === "derived"))
    return;
  const repoRel2 = leaseScopeRelPath(input.repoRoot, filePath);
  const inScope = leases.some((l2) => fileScopeContains(l2.file_scope, repoRel2));
  if (inScope)
    return;
  if (repoRel2.startsWith("tests/") && leases.some((l2) => TESTS_ALLOW_NODE_KINDS.has(graph.nodes.find((n3) => n3.id === l2.node_id)?.kind ?? ""))) {
    return;
  }
  if (autopilotBypassActive(input)) {
    await appendBypassRecord(input.repoRoot, {
      ts: new Date().toISOString(),
      session_id: sessionId,
      work_item_id: workItemId2,
      file_path: repoRel2,
      active_leases: leases.map((l2) => l2.node_id)
    });
    return;
  }
  return block2("autopilot-path", `${repoRel2} is outside every active autopilot node's file_scope (${leases.map((l2) => l2.node_id).join(", ")}); edit inside the dispatched node's scope or set DITTO_AUTOPILOT_BYPASS=1`);
}
var preToolUseHandler = async (input) => {
  const raw = input.raw ?? {};
  const toolName = raw.tool_name;
  const toolInput = raw.tool_input ?? {};
  const repoRoot = input.repoRoot;
  if (input.host === "codex" && toolName === "write_stdin") {
    const chars = typeof toolInput.chars === "string" ? toolInput.chars : undefined;
    if (!chars)
      return ALLOW;
    for (const path of parseApplyPatchPaths(chars)) {
      const verdict2 = await checkMutatedPath(input, path);
      if (verdict2)
        return verdict2;
    }
    return ALLOW;
  }
  if (isCommandTool(input, toolName)) {
    const command = commandToolInput(input, toolName, toolInput);
    if (!command)
      return ALLOW;
    if (input.host === "codex" && shellRunsApplyPatch(command)) {
      return block2("apply-patch-bypass", "shell command runs apply_patch outside the Codex apply_patch tool gate");
    }
    const destructive = checkDestructive(command);
    if (destructive.exitCode === 2)
      return destructive;
    const exposed = bashSecretExposure(command);
    if (exposed !== undefined) {
      return block2("secret", `command exposes a secret file (${exposed})`);
    }
    for (const dest of bashWriteTargets(command)) {
      const tmpAllowed = isSystemTmpPath(dest) && !isSecretPath(dest);
      if (isOutsideRepo(repoRoot, dest) && !isClaudeMemoryPath(repoRoot, dest) && !tmpAllowed) {
        return block2("scope-out", `write outside repo (${dest})`);
      }
    }
    const jvm = parseJvmCodeqlCommand(command);
    if (jvm) {
      const spec = await loadArchSpec(repoRoot);
      const sourceRoot = jvm.sourceRoot ? resolve18(repoRoot, jvm.sourceRoot) : repoRoot;
      const guard = await runInternalPackagesGuard({
        language: "java",
        entries: spec?.internal_packages ?? [],
        sourceRoot
      });
      if (guard.decision === "block") {
        return block2("internal-packages", guard.reason);
      }
    }
    return ALLOW;
  }
  if (input.host === "codex" && toolName === "apply_patch") {
    for (const path of mutatedPaths("codex", raw)) {
      const verdict2 = await checkMutatedPath(input, path);
      if (verdict2)
        return verdict2;
    }
    return ALLOW;
  }
  const filePath = typeof toolInput.file_path === "string" ? toolInput.file_path : undefined;
  if (!filePath)
    return ALLOW;
  if (isSecretPath(filePath)) {
    return block2("secret", `access to a secret file (${filePath})`);
  }
  if (toolName === "Write" || toolName === "Edit" || toolName === "MultiEdit") {
    if (isOutsideRepo(repoRoot, filePath) && !isClaudeMemoryPath(repoRoot, filePath) && !isSystemTmpPath(filePath)) {
      return block2("scope-out", `write outside repo (${filePath})`);
    }
    const forbidden = await checkForbiddenScope(input, filePath);
    if (forbidden)
      return forbidden;
    const offPath = await checkAutopilotLease(input, filePath);
    if (offPath)
      return offPath;
  }
  return ALLOW;
};
async function checkMutatedPath(input, filePath) {
  if (isSecretPath(filePath)) {
    return block2("secret", `access to a secret file (${filePath})`);
  }
  if (isOutsideRepo(input.repoRoot, filePath) && !isClaudeMemoryPath(input.repoRoot, filePath) && !isSystemTmpPath(filePath)) {
    return block2("scope-out", `write outside repo (${filePath})`);
  }
  const forbidden = await checkForbiddenScope(input, filePath);
  if (forbidden)
    return forbidden;
  const offPath = await checkAutopilotLease(input, filePath);
  if (offPath)
    return offPath;
  return;
}
function bashWriteTargets(cmd) {
  const P4 = String.fromCharCode(1);
  const spans = [];
  const deheredoc = cmd.replace(/(<<-?\s*(['"]?)([A-Za-z_]\w*)\2[^\n]*)\n[\s\S]*?\n[ \t]*\3(?=\s|$)/g, "$1");
  const skeleton = deheredoc.replace(/'[^']*'|"(?:[^"\\]|\\.)*"/g, (q2) => {
    spans.push(q2.slice(1, -1));
    return `${P4}${spans.length - 1}${P4}`;
  });
  const placeholderRe = new RegExp(`${P4}(\\d+)${P4}`, "g");
  const unquote = (t3) => t3.replace(placeholderRe, (_4, i3) => spans[Number(i3)] ?? "");
  const out = [];
  const push = (raw) => {
    if (!raw)
      return;
    const t3 = unquote(raw);
    if (t3.length === 0 || /[$`*]/.test(t3))
      return;
    out.push(t3);
  };
  for (const m4 of skeleton.matchAll(/>>?\s*([^\s;&|>]+)/g)) {
    const t3 = m4[1];
    if (t3 && !unquote(t3).startsWith("/dev/"))
      push(t3);
  }
  for (const m4 of skeleton.matchAll(/\btee\b\s+(?:-\S+\s+)*([^\s;&|]+)/g)) {
    push(m4[1]);
  }
  for (const m4 of skeleton.matchAll(/\b(?:cp|mv)\b([^;&|]*)/g)) {
    const args = (m4[1] ?? "").trim().split(/\s+/).filter((a4) => a4.length > 0 && !a4.startsWith("-"));
    if (args.length >= 2)
      push(args[args.length - 1]);
  }
  return out;
}

// src/hooks/session-start.ts
import { resolve as resolve20 } from "path";

// src/core/mode-doctor.ts
import { spawnSync } from "child_process";
import { createHash as createHash12 } from "crypto";
import { existsSync as existsSync9, readFileSync as readFileSync5, readdirSync as readdirSync2 } from "fs";
import { homedir as homedir10 } from "os";
import { dirname as dirname15, join as join71, resolve as resolve19 } from "path";
function classifySession(pluginRoot, repoRoot) {
  if (pluginRoot === null)
    return "unknown";
  if (pluginRoot.includes("/plugins/cache/"))
    return "installed";
  if (pluginRoot === repoRoot || pluginRoot.startsWith(`${repoRoot}/`))
    return "dev";
  return "unknown";
}
var ACTION_REASON = {
  none: "installed plugin matches the working tree",
  install: "no installed plugin found",
  reinstall: "installed plugin is behind the pushed source \u2014 marketplace update + reinstall",
  "commit-push-reinstall": "the drift includes local-only work (uncommitted or unpushed) \u2014 commit+push, then reinstall (or load the working tree with --plugin-dir for a quick dogfood)"
};
function resolveMode(inp) {
  const sessionMode = classifySession(inp.pluginRoot, inp.repoRoot);
  const driftSrc = inp.installedPresent && inp.installedSrcStamp !== inp.repoSrcStamp;
  const driftSurface = inp.installedPresent && inp.installedSurfaceStamp !== inp.repoSurfaceStamp;
  const fresh = inp.installedPresent && !driftSrc && !driftSurface;
  let action;
  if (!inp.installedPresent)
    action = "install";
  else if (fresh)
    action = "none";
  else if (inp.repoDirty || inp.repoAhead)
    action = "commit-push-reinstall";
  else
    action = "reinstall";
  return {
    sessionMode,
    installed: { present: inp.installedPresent, version: inp.installedVersion, fresh },
    drift: { src: driftSrc, surface: driftSurface },
    action,
    reason: ACTION_REASON[action]
  };
}
var DOGFOOD_HINT = "bun run dogfood";
function formatModeBanner(report, opts) {
  if (!opts.inDittoRepo)
    return { warn: false, text: "" };
  if (report.sessionMode === "dev") {
    return {
      warn: false,
      text: "\u2713 ditto dogfood mode \u2014 this session runs the working-tree build."
    };
  }
  if (report.sessionMode === "installed") {
    const v2 = report.installed.version ?? "?";
    if (!report.installed.fresh) {
      return {
        warn: true,
        text: `\u26A0 ditto: this session loaded the INSTALLED plugin (v${v2}), STALE vs your working tree \u2014 your edits will NOT take effect here. For ditto development, exit and re-enter with: ${DOGFOOD_HINT} [--host codex]`
      };
    }
    return {
      warn: false,
      text: `ditto: this session loaded the installed plugin (v${v2}). For live edits to ditto, enter with: ${DOGFOOD_HINT} [--host codex]`
    };
  }
  return { warn: false, text: "" };
}
function formatModeHuman(report, inDittoRepo) {
  if (!inDittoRepo) {
    return [
      `ditto mode: session=${report.sessionMode} (not the ditto source repo \u2014 no staleness check)`
    ];
  }
  const inst = report.installed.present ? `present v${report.installed.version ?? "?"}, ${report.installed.fresh ? "fresh" : "STALE"}` : "absent";
  return [
    "ditto mode",
    `  session:   ${report.sessionMode}`,
    `  installed: ${inst}`,
    `  drift:     src=${report.drift.src ? "yes" : "no"} surface=${report.drift.surface ? "yes" : "no"}`,
    `  action:    ${report.action} \u2014 ${report.reason}`
  ];
}
var SURFACE_DIRS = ["agents", "skills", "hooks"];
function listSurfaceFiles(root, rel, out) {
  const dir = join71(root, rel);
  if (!existsSync9(dir))
    return;
  for (const e2 of readdirSync2(dir, { withFileTypes: true })) {
    const childRel = `${rel}/${e2.name}`;
    if (e2.isDirectory())
      listSurfaceFiles(root, childRel, out);
    else if (e2.isFile())
      out.push(childRel);
  }
}
function computeSurfaceStamp(root) {
  const files = [];
  for (const d2 of SURFACE_DIRS)
    listSurfaceFiles(root, d2, files);
  files.sort();
  const h3 = createHash12("sha256");
  for (const rel of files) {
    h3.update(rel);
    h3.update("\x00");
    h3.update(readFileSync5(join71(root, rel)));
    h3.update("\x00");
  }
  return h3.digest("hex");
}
function isDittoSourceRepo(repoRoot) {
  const pkgPath = join71(repoRoot, "package.json");
  if (!existsSync9(pkgPath))
    return false;
  try {
    const pkg = JSON.parse(readFileSync5(pkgPath, "utf8"));
    return pkg.name === "ditto" && existsSync9(join71(repoRoot, "src", "cli", "index.ts"));
  } catch {
    return false;
  }
}
function resolvePluginRoot(env2, argv1) {
  if (env2.CLAUDE_PLUGIN_ROOT)
    return env2.CLAUDE_PLUGIN_ROOT;
  if (argv1 === undefined)
    return null;
  if (argv1.replace(/\\/g, "/").endsWith("/bin/ditto")) {
    return resolve19(dirname15(argv1), "..");
  }
  return null;
}
function readInstalledIdentity(home) {
  const base = join71(home, ".claude", "plugins", "cache", "ditto-local", "ditto");
  const absent = { present: false, version: null, srcStamp: null, surfaceStamp: null };
  if (!existsSync9(base))
    return absent;
  const versions = readdirSync2(base, { withFileTypes: true }).filter((e2) => e2.isDirectory() || e2.isSymbolicLink()).map((e2) => e2.name).sort();
  const version = versions[versions.length - 1];
  if (!version)
    return absent;
  const dir = join71(base, version);
  let srcStamp = null;
  try {
    srcStamp = readEmbeddedStamp(readFileSync5(join71(dir, "bin", "ditto"), "utf8"));
  } catch {
    srcStamp = null;
  }
  const surfaceStamp = existsSync9(dir) ? computeSurfaceStamp(dir) : null;
  return { present: true, version, srcStamp, surfaceStamp };
}
function gitState2(repoRoot) {
  const status = spawnSync("git", ["status", "--porcelain"], { cwd: repoRoot, encoding: "utf8" });
  const dirty = (status.stdout ?? "").trim().length > 0;
  const rev = spawnSync("git", ["rev-list", "--count", "origin/main..HEAD"], {
    cwd: repoRoot,
    encoding: "utf8"
  });
  const ahead = rev.status === 0 && Number.parseInt((rev.stdout ?? "0").trim(), 10) > 0;
  return { dirty, ahead };
}
function collectModeReport(repoRoot, opts = {}) {
  const env2 = opts.env ?? process.env;
  const argv1 = opts.argv1 ?? process.argv[1];
  const home = opts.home ?? homedir10();
  const pluginRoot = resolvePluginRoot(env2, argv1);
  const inDittoRepo = isDittoSourceRepo(repoRoot);
  if (!inDittoRepo) {
    return {
      inDittoRepo: false,
      report: resolveMode({
        pluginRoot,
        repoRoot,
        repoSrcStamp: "",
        repoSurfaceStamp: "",
        installedPresent: false,
        installedVersion: null,
        installedSrcStamp: null,
        installedSurfaceStamp: null,
        repoDirty: false,
        repoAhead: false
      })
    };
  }
  const installed = readInstalledIdentity(home);
  const git = gitState2(repoRoot);
  return {
    inDittoRepo: true,
    report: resolveMode({
      pluginRoot,
      repoRoot,
      repoSrcStamp: computeSourceStamp(repoRoot),
      repoSurfaceStamp: computeSurfaceStamp(repoRoot),
      installedPresent: installed.present,
      installedVersion: installed.version,
      installedSrcStamp: installed.srcStamp,
      installedSurfaceStamp: installed.surfaceStamp,
      repoDirty: git.dirty,
      repoAhead: git.ahead
    })
  };
}

// src/hooks/session-start.ts
init_work_item_store();
init_worktree();
async function maybeBindWorktreeSession(input) {
  const raw = input.raw;
  const cwd = typeof raw?.cwd === "string" ? raw.cwd : undefined;
  const sessionId = typeof raw?.session_id === "string" ? raw.session_id : undefined;
  if (!cwd || !sessionId)
    return;
  const parsed = parseWorktreePath(resolve20(cwd));
  if (parsed === null)
    return;
  const items = new WorkItemStore(input.repoRoot);
  if (!await items.exists(parsed.workItemId)) {
    return `worktree \uACBD\uB85C \uAC19\uC73C\uB098 work item(${parsed.workItemId}) \uBC14\uC778\uB529 \uBABB \uD568 \u2014 \uC218\uB3D9 \uD655\uC778 \uD544\uC694`;
  }
  await new SessionPointerStore(input.repoRoot).set(sessionId, parsed.workItemId);
  return;
}
var sessionStartHandler = async (input) => {
  const bindAdvisory = await maybeBindWorktreeSession(input);
  const { report, inDittoRepo } = collectModeReport(input.repoRoot, { env: input.env });
  const banner = formatModeBanner(report, { inDittoRepo });
  const text = [bindAdvisory, banner.text].filter(Boolean).join(`
`);
  if (!text)
    return { exitCode: 0 };
  return {
    exitCode: 0,
    stdout: JSON.stringify({
      hookSpecificOutput: { hookEventName: "SessionStart", additionalContext: text }
    })
  };
};

