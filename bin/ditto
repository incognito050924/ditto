import { join as join11 } from "path";

// src/core/codeql/relations.ts
import { dirname as dirname4, join as join10 } from "path";

// src/core/codeql/sarif.ts
init_zod();
var region = exports_external.object({
  startLine: exports_external.number().int().optional(),
  startColumn: exports_external.number().int().optional(),
  endLine: exports_external.number().int().optional()
}).passthrough();
var physicalLocation = exports_external.object({
  artifactLocation: exports_external.object({ uri: exports_external.string().optional() }).passthrough().optional(),
  region: region.optional()
}).passthrough();
var location = exports_external.object({
  physicalLocation: physicalLocation.optional(),
  message: exports_external.object({ text: exports_external.string().optional() }).passthrough().optional()
}).passthrough();
var threadFlow = exports_external.object({
  locations: exports_external.array(exports_external.object({ location: location.optional() }).passthrough()).optional()
}).passthrough();
var codeFlow = exports_external.object({ threadFlows: exports_external.array(threadFlow).optional() }).passthrough();
var result = exports_external.object({
  ruleId: exports_external.string().optional(),
  level: exports_external.string().optional(),
  message: exports_external.object({ text: exports_external.string().optional() }).passthrough().optional(),
  locations: exports_external.array(location).optional(),
  codeFlows: exports_external.array(codeFlow).optional()
}).passthrough();
var sarifLog = exports_external.object({
  version: exports_external.string().optional(),
  runs: exports_external.array(exports_external.object({ results: exports_external.array(result).optional() }).passthrough()).optional()
}).passthrough();
function stepFrom(loc) {
  const phys = loc?.physicalLocation;
  const uri = phys?.artifactLocation?.uri;
  if (uri === undefined)
    return null;
  return {
    file: uri,
    startLine: phys?.region?.startLine ?? null,
    message: loc?.message?.text ?? null
  };
}
function parseSarif(input) {
  const raw = typeof input === "string" ? JSON.parse(input) : input;
  const log = sarifLog.parse(raw);
  const findings = [];
  for (const run of log.runs ?? []) {
    for (const res of run.results ?? []) {
      const primary = stepFrom(res.locations?.[0]);
      const dataflow = [];
      for (const flow of res.codeFlows ?? []) {
        for (const tf of flow.threadFlows ?? []) {
          for (const entry of tf.locations ?? []) {
            const step = stepFrom(entry.location);
            if (step)
              dataflow.push(step);
          }
        }
      }
      findings.push({
        ruleId: res.ruleId ?? "<unknown>",
        level: res.level ?? null,
        file: primary?.file ?? null,
        startLine: primary?.startLine ?? null,
        message: res.message?.text ?? null,
        dataflow
      });
    }
  }
  return findings;
}

// src/core/codeql/runner.ts
function codeqlExtractorLanguage(language) {
  return language === "kotlin" ? "java" : language;
}
var NO_BUILD_LANGUAGES = new Set([
  "javascript",
  "python",
  "ruby",
  "actions"
]);
function selectBuildMode(language, buildCommand) {
  if (NO_BUILD_LANGUAGES.has(language))
    return "none";
  return buildCommand ? "manual" : "autobuild";
}
function buildCreateArgs(input) {
  const args = [
    "database",
    "create",
    input.dbPath,
    `--language=${codeqlExtractorLanguage(input.language)}`,
    `--source-root=${input.sourceRoot}`,
    "--overwrite"
  ];
  if (input.buildMode === "manual") {
    if (!input.buildCommand) {
      throw new Error("buildMode 'manual' requires buildCommand");
    }
    args.push(`--command=${input.buildCommand}`);
  } else {
    args.push(`--build-mode=${input.buildMode}`);
  }
  return args;
}
function buildAnalyzeArgs(input) {
  const args = [
    "database",
    "analyze",
    input.dbPath,
    input.suite,
    "--format=sarif-latest",
    `--output=${input.sarifOut}`,
    `--threads=${input.threads ?? 0}`
  ];
  if (input.download)
    args.push("--download");
  return args;
}
function cacheKey(commitSha, language) {
  const shortSha = commitSha.slice(0, 12);
  return `${shortSha}-${language}`;
}
var CODEQL_BINARY = "codeql";
async function runCodeqlAnalysis(input, deps) {
  const buildMode = selectBuildMode(input.language, input.buildCommand);
  const binary = input.binary ?? CODEQL_BINARY;
  if (await deps.fileExists(input.sarifPath)) {
    const cached = await deps.readText(input.sarifPath);
    return {
      findings: parseSarif(cached),
      sarifPath: input.sarifPath,
      fromCache: true,
      buildMode
    };
  }
  const env2 = { set: {}, unset: ["LGTM_INDEX_FILTERS"] };
  const create = deps.spawn({
    binary,
    args: buildCreateArgs({
      dbPath: input.dbPath,
      language: input.language,
      sourceRoot: input.sourceRoot,
      buildMode,
      buildCommand: input.buildCommand
    }),
    repoRoot: input.repoRoot,
    cwd: ".",
    env: env2
  });
  await deps.drain(create.stderr);
  await deps.drain(create.stdout);
  const createDone = await create.completion;
  if (createDone.exit_code !== 0) {
    throw new Error(`codeql database create failed (exit ${createDone.exit_code}${createDone.error ? `: ${createDone.error}` : ""})`);
  }
  const analyze = deps.spawn({
    binary,
    args: buildAnalyzeArgs({
      dbPath: input.dbPath,
      suite: input.suite,
      sarifOut: input.sarifPath,
      threads: input.threads,
      download: input.download
    }),
    repoRoot: input.repoRoot,
    cwd: ".",
    env: env2
  });
  await deps.drain(analyze.stderr);
  await deps.drain(analyze.stdout);
  const analyzeDone = await analyze.completion;
  if (analyzeDone.exit_code !== 0) {
    throw new Error(`codeql database analyze failed (exit ${analyzeDone.exit_code}${analyzeDone.error ? `: ${analyzeDone.error}` : ""})`);
  }
  const sarif = await deps.readText(input.sarifPath);
  return {
    findings: parseSarif(sarif),
    sarifPath: input.sarifPath,
    fromCache: false,
    buildMode
  };
}

// src/core/codeql/relations.ts
var IDENTIFIER = /^[A-Za-z_$][A-Za-z0-9_$]*$/;
function renderQuery(template, symbol, file) {
  if (!IDENTIFIER.test(symbol)) {
    throw new Error(`unsafe symbol for CodeQL query: ${JSON.stringify(symbol)}`);
  }
  let q2 = template.replaceAll("{{SYMBOL}}", symbol);
  if (file !== undefined)
    q2 = q2.replaceAll("{{FILE}}", file.replaceAll('"', ""));
  return q2;
}
var IMPACT_QUERY_JS = `/**
 * @name ditto impact
 * @id ditto/impact-relations
 * @kind table
 */
import javascript

predicate inTargetFile(File f) {
  f.getRelativePath() = "{{FILE}}" or f.getRelativePath().matches("%/{{FILE}}")
}

from string p, int ln, string k
where
  (exists(InvokeExpr ie, Function f |
     f.getName() = "{{SYMBOL}}" and inTargetFile(f.getFile()) and ie.getResolvedCallee() = f
     and p = ie.getFile().getRelativePath() and ln = ie.getLocation().getStartLine()) and k = "value")
  or (exists(ImportSpecifier s | s.getImportedName() = "{{SYMBOL}}" and p = s.getFile().getRelativePath() and ln = s.getLocation().getStartLine()) and k = "import")
  or (exists(LocalTypeAccess t | t.getName() = "{{SYMBOL}}" and p = t.getFile().getRelativePath() and ln = t.getLocation().getStartLine()) and k = "type")
  or (k = "decl" and (
      exists(Function d | d.getName() = "{{SYMBOL}}" and inTargetFile(d.getFile()) and p = d.getFile().getRelativePath() and ln = d.getLocation().getStartLine())
      or exists(ClassDefinition d | d.getName() = "{{SYMBOL}}" and inTargetFile(d.getFile()) and p = d.getFile().getRelativePath() and ln = d.getLocation().getStartLine())
      or exists(InterfaceDefinition d | d.getName() = "{{SYMBOL}}" and inTargetFile(d.getFile()) and p = d.getFile().getRelativePath() and ln = d.getLocation().getStartLine())
  ))
select p, ln, k
`;
var EDGE_QUERY_JS = `/**
 * @name ditto edges
 * @id ditto/edge-relations
 * @kind table
 */
import javascript
from Import imp, string fromPath, string target
where fromPath = imp.getFile().getRelativePath()
  and ({{FILE_FILTER}})
  and (
    target = imp.getImportedModule().getFile().getRelativePath()
    or (not exists(imp.getImportedModule()) and target = imp.getImportedPath().getValue())
  )
select fromPath, target
`;
function renderEdgeQuery(changedFiles, language = "javascript") {
  const files = changedFiles.map((f3) => f3.trim()).filter((f3) => f3.length > 0);
  const filter = files.length === 0 ? "any()" : files.map((f3) => `fromPath = "${f3.replaceAll('"', "")}"`).join(" or ");
  return relationQueries(language).edge.replaceAll("{{FILE_FILTER}}", filter);
}
var SYMBOL_DECL_QUERY_JS = `/**
 * @name ditto symbol decl
 * @id ditto/symbol-decl
 * @kind table
 */
import javascript
from string p
where
  exists(Function d | d.getName() = "{{SYMBOL}}" and p = d.getFile().getRelativePath())
  or exists(ClassDefinition d | d.getName() = "{{SYMBOL}}" and p = d.getFile().getRelativePath())
  or exists(InterfaceDefinition d | d.getName() = "{{SYMBOL}}" and p = d.getFile().getRelativePath())
select p
`;
var IMPACT_QUERY_JAVA = `/**
 * @name ditto impact java
 * @id ditto/impact-relations-java
 * @kind table
 */
import java

predicate inTargetFile(File f) {
  f.getRelativePath() = "{{FILE}}" or f.getRelativePath().matches("%/{{FILE}}")
}

from string p, int ln, string k
where
  (exists(MethodCall mc, Method m |
     m.getName() = "{{SYMBOL}}" and inTargetFile(m.getFile()) and mc.getMethod() = m
     and p = mc.getFile().getRelativePath() and ln = mc.getLocation().getStartLine()) and k = "value")
  or (exists(TypeAccess t, RefType rt |
     rt.getName() = "{{SYMBOL}}" and inTargetFile(rt.getFile()) and t.getType() = rt
     and p = t.getFile().getRelativePath() and ln = t.getLocation().getStartLine()) and k = "type")
  or (k = "decl" and (
      exists(Method d | d.getName() = "{{SYMBOL}}" and inTargetFile(d.getFile()) and p = d.getFile().getRelativePath() and ln = d.getLocation().getStartLine())
      or exists(RefType d | d.getName() = "{{SYMBOL}}" and d.fromSource() and inTargetFile(d.getFile()) and p = d.getFile().getRelativePath() and ln = d.getLocation().getStartLine())
  ))
select p, ln, k
`;
var EDGE_QUERY_JAVA = `/**
 * @name ditto edges java
 * @id ditto/edge-relations-java
