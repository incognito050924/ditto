var LSP_LANG_BY_EXT = {
  ts: "typescript",
  tsx: "typescript",
  mts: "typescript",
  cts: "typescript",
  js: "javascript",
  jsx: "javascript",
  mjs: "javascript",
  cjs: "javascript",
  py: "python",
  pyi: "python",
  go: "go",
  rs: "rust",
  rb: "ruby",
  java: "java",
  kt: "kotlin",
  kts: "kotlin",
  cs: "csharp",
  swift: "swift",
  c: "c",
  h: "c",
  cpp: "cpp",
  cc: "cpp",
  cxx: "cpp",
  hpp: "cpp",
  hh: "cpp",
  hxx: "cpp",
  php: "php",
  scala: "scala",
  sc: "scala",
  dart: "dart",
  lua: "lua",
  r: "r"
};
var LSP_LANGUAGES = new Set(Object.values(LSP_LANG_BY_EXT));
function classifyLspExtensions(extCounts) {
  const byLang = new Map;
  for (const [ext, count] of Object.entries(extCounts)) {
    const lang = LSP_LANG_BY_EXT[ext];
    if (lang)
      byLang.set(lang, (byLang.get(lang) ?? 0) + count);
  }
  return [...byLang.entries()].map(([language, files]) => ({ language, files })).sort((a2, b2) => b2.files - a2.files);
}
async function detectLspLanguages(sourceRoot) {
  return classifyLspExtensions(await countExtensions(sourceRoot));
}
function lspLanguageForPath(filePath) {
  const base = filePath.slice(filePath.lastIndexOf("/") + 1);
  const dot = base.lastIndexOf(".");
  if (dot <= 0)
    return null;
  return LSP_LANG_BY_EXT[base.slice(dot + 1).toLowerCase()] ?? null;
}

