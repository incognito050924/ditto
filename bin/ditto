// src/schemas/adr-id.ts
var SLUG = "[a-z0-9]+(?:-[a-z0-9]+)*";
var DIGITS4 = "\\d{4}";
var DIGITS8 = "\\d{8}";
var ADR_ID_FULL_RE = new RegExp(`^ADR-(?:${DIGITS4}|${DIGITS8}-${SLUG})$`);
var ADR_ID_EXTRACT_RE = new RegExp(`^ADR-(?:${DIGITS8}-${SLUG}|${DIGITS4})`);
var ADR_TITLE_PREFIX_RE = new RegExp(`^ADR-(?:${DIGITS8}-${SLUG}|${DIGITS4}):\\s*`);
var ADR_FILENAME_RE = new RegExp(`^ADR-(?:${DIGITS8}|${DIGITS4})-${SLUG}\\.md$`);
var ADR_SLUG_RE = new RegExp(`^${SLUG}$`);
function adrIdFromFilename(filename) {
  if (!ADR_FILENAME_RE.test(filename))
    return null;
  return filename.match(ADR_ID_EXTRACT_RE)?.[0] ?? null;
}

