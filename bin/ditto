import { isAbsolute as isAbsolute10, resolve as resolve14 } from "path";

// src/schemas/acg-assurance-snapshot.ts
init_zod();
init_common();
var acgSnapshotResult = exports_external.object({
  function_id: exports_external.string().min(1).describe("FitnessFunction.id"),
  outcome: exports_external.enum(["pass", "fail", "skip"]),
  violations: exports_external.number().int().min(0).optional().describe("Violation count (display/trend)"),
  new_violations: exports_external.number().int().min(0).optional().describe("Count not in baseline.snapshot \u2014 delta_only blocking basis"),
  violation_ids: uniqueStringSet("violation_identity set at this point \u2014 enables cross-snapshot delta recompute (OBJ-32)").optional(),
  new_violation_ids: uniqueStringSet("violation_ids not in baseline.snapshot \u2014 legacy vs new, audited mechanically").optional()
}).describe("One fitness function evaluation result at a point in time");
var acgAssuranceSnapshot = exports_external.object({
  schema_version: schemaVersion,
  kind: exports_external.literal("acg.assurance-snapshot.v1"),
  produced_by: acgProducedBy,
  produced_at: isoDateTime,
  at: isoDateTime.describe("Evaluation time"),
  trigger: exports_external.enum(["per_change", "periodic"]),
  change_ref: workItemId.nullable().default(null).describe("per_change \u2192 the work item"),
  results: exports_external.array(acgSnapshotResult).default([])
}).describe("ACG AssuranceSnapshot \u2014 fitness evaluation time-series unit");

// src/acg/fitness/fitness-runner.ts
function normalizeViolationIdentity(v2) {
  const site = v2.enclosing ?? v2.symbol ?? "<top>";
  const path = v2.path ?? "<nopath>";
  return `${v2.rule}@${path}#${site}`;
}
function parseBaselineSet(snapshot) {
  if (!snapshot)
    return new Set;
  return new Set(snapshot.split(/[\n,]/).map((s2) => s2.trim()).filter((s2) => s2.length > 0));
}
function ruleOf(id) {
  const at = id.indexOf("@");
  return at < 0 ? id : id.slice(0, at);
}
function relocationAwareNewIds(current, baseline) {
  const currentSet = new Set(current);
  const disappearedBudget = new Map;
  for (const id of baseline) {
    if (!currentSet.has(id)) {
      disappearedBudget.set(ruleOf(id), (disappearedBudget.get(ruleOf(id)) ?? 0) + 1);
    }
  }
  const newIds = [];
  for (const id of current) {
    if (baseline.has(id))
      continue;
    const rule = ruleOf(id);
    const budget = disappearedBudget.get(rule) ?? 0;
    if (budget > 0) {
      disappearedBudget.set(rule, budget - 1);
      continue;
    }
    newIds.push(id);
  }
  return newIds;
}
function scheduleDecision(fn, ctx) {
  if (ctx.trigger === "periodic") {
    const p = fn.cadence.periodic;
    if (p !== "none" && (!ctx.period || p === ctx.period)) {
      return { run: true, reason: `periodic=${p}` };
    }
    return { run: false, reason: `periodic=${p} does not match ${ctx.period ?? "any"}` };
  }
  if (!fn.cadence.per_change)
    return { run: false, reason: "cadence.per_change=false" };
  if (fn.evaluator.mode === "executed") {
    const sel = fn.evaluator.execution?.selection ?? "per_change";
    if (sel === "periodic")
      return { run: false, reason: "executed selection=periodic (deferred)" };
    if (sel === "per_change")
      return { run: true, reason: "executed selection=per_change (explicit)" };
    if (!ctx.riskKnown) {
      return {
        run: true,
        reason: `executed selection=${sel} but risk unknown \u2192 escalate (fail-closed)`
      };
    }
    if (ctx.risk === "high")
      return { run: true, reason: `executed selection=${sel}, risk=high` };
    return { run: false, reason: `executed selection=${sel}, risk=${ctx.risk ?? "low"} \u2192 defer` };
  }
  return { run: true, reason: `${fn.evaluator.mode} per_change` };
}
function assessDelta(fn, currentIds) {
  const current = [...new Set(currentIds)];
  const baseline = parseBaselineSet(fn.baseline?.snapshot);
  const newIds = relocationAwareNewIds(current, baseline);
  const deltaOnly = fn.baseline?.delta_only === true;
  const blockingIds = deltaOnly ? newIds : current;
  const outcome = fn.on_violation === "block" && blockingIds.length > 0 ? "fail" : "pass";
  return { violation_ids: current, new_violation_ids: newIds, outcome };
}
async function runFitness(functions, ctx, provider) {
  const results = [];
  for (const fn of functions) {
    const decision = scheduleDecision(fn, ctx);
    if (!decision.run) {
      results.push({ function_id: fn.id, outcome: "skip" });
      continue;
    }
    const evald = await provider.evaluate(fn, ctx);
    if (evald.skipped) {
      results.push({ function_id: fn.id, outcome: "skip" });
      continue;
    }
    const delta = assessDelta(fn, evald.violationIds);
    results.push({
      function_id: fn.id,
      outcome: delta.outcome,
      violations: delta.violation_ids.length,
      new_violations: delta.new_violation_ids.length,
      violation_ids: delta.violation_ids,
      new_violation_ids: delta.new_violation_ids
    });
  }
  return acgAssuranceSnapshot.parse({
    schema_version: "0.1.0",
    kind: "acg.assurance-snapshot.v1",
    produced_by: "agent",
    produced_at: ctx.producedAt,
    at: ctx.producedAt,
    trigger: ctx.trigger,
    change_ref: ctx.changeRef ?? null,
    results
  });
}

// src/acg/fitness/codeql-provider.ts
function codeqlFindingToViolation(f3) {
  return { rule: f3.ruleId, path: f3.file ?? undefined };
}
function sarifFindingsToViolationIds(findings) {
  return [...new Set(findings.map((f3) => normalizeViolationIdentity(codeqlFindingToViolation(f3))))];
}
function sarifToViolationIds(sarifText) {
  return sarifFindingsToViolationIds(parseSarif(sarifText));
}

// src/acg/fitness/command-provider.ts
var CODEQL_SARIF_PREFIX = "codeql-sarif:";
function commandProvider(repoRoot) {
  return {
    evaluate: async (fn) => {
      if (fn.evaluator.mode !== "deterministic") {
        return {
          skipped: { reason: `${fn.evaluator.mode} provider not wired (v0: deterministic only)` },
          violationIds: []
        };
      }
      const spec = fn.evaluator.spec;
      if (spec.startsWith(CODEQL_SARIF_PREFIX)) {
        const rel = spec.slice(CODEQL_SARIF_PREFIX.length).trim();
        const sarifPath = isAbsolute10(rel) ? rel : resolve14(repoRoot, rel);
        const file = Bun.file(sarifPath);
        if (!await file.exists()) {
          return {
            skipped: {
              reason: `codeql-sarif source not found: ${sarifPath} (run ditto codeql review first)`
            },
            violationIds: []
          };
        }
        return { violationIds: sarifToViolationIds(await file.text()) };
      }
      const proc = Bun.spawnSync(["sh", "-c", spec], { cwd: repoRoot });
      const out = proc.stdout?.toString() ?? "";
      const violationIds = out.split(`
`).map((s2) => s2.trim()).filter((s2) => s2.length > 0);
      return { violationIds };
    }
  };
}

// src/acg/fitness/drift.ts
init_ditto_paths();
init_fs();
function assessDrift(report, minNewViolations = 0) {
  const concerning = report.functions.filter((f3) => f3.direction === "rising" && f3.cumulative_new_violations >= minNewViolations);
  return {
    concerning,
    min_new_violations: minNewViolations,
    reasons: concerning.map((f3) => `drift: ${f3.function_id} rising (violations ${f3.first_violations}\u2192${f3.last_violations}, +${f3.cumulative_new_violations} new across changes)`)
  };
}
var DIRECTION_RANK = {
  rising: 0,
  flat: 1,
  insufficient: 2,
  falling: 3
};
function computeDrift(snapshots) {
  const byFn = new Map;
  for (const snap of snapshots) {
    for (const r3 of snap.results) {
      const point = {
        at: snap.at,
        change_ref: snap.change_ref ?? null,
        outcome: r3.outcome,
        violations: r3.violations ?? null,
        new_violations: r3.new_violations ?? 0
      };
      const list = byFn.get(r3.function_id);
      if (list)
        list.push(point);
      else
        byFn.set(r3.function_id, [point]);
    }
  }
  const functions = [];
  for (const [function_id, rawPoints] of byFn) {
    const points = [...rawPoints].sort((a2, b2) => a2.at < b2.at ? -1 : a2.at > b2.at ? 1 : 0);
    const withViolations = points.filter((p) => p.violations !== null);
    const first_violations = withViolations[0]?.violations ?? null;
    const last_violations = withViolations[withViolations.length - 1]?.violations ?? null;
    let direction;
    if (withViolations.length < 2 || first_violations === null || last_violations === null) {
      direction = "insufficient";
    } else if (last_violations > first_violations) {
      direction = "rising";
    } else if (last_violations < first_violations) {
      direction = "falling";
    } else {
      direction = "flat";
    }
    functions.push({
      function_id,
      points,
      first_violations,
      last_violations,
      direction,
      cumulative_new_violations: points.reduce((s2, p) => s2 + p.new_violations, 0),
      fail_count: points.filter((p) => p.outcome === "fail").length
    });
  }
  functions.sort((a2, b2) => {
    const r3 = DIRECTION_RANK[a2.direction] - DIRECTION_RANK[b2.direction];
    if (r3 !== 0)
      return r3;
    if (a2.cumulative_new_violations !== b2.cumulative_new_violations) {
      return b2.cumulative_new_violations - a2.cumulative_new_violations;
    }
    return a2.function_id < b2.function_id ? -1 : a2.function_id > b2.function_id ? 1 : 0;
  });
  return { snapshots: snapshots.length, functions };
}
async function loadAssuranceSnapshots(repoRoot) {
  const items = await new WorkItemStore(repoRoot).list();
  const out = [];
  for (const it of items) {
    try {
      out.push(await readJson(localDir(repoRoot, "work-items", it.id, "assurance-snapshot.json"), acgAssuranceSnapshot));
    } catch {}
  }
  return out;
}

// src/acg/fitness/injected-provider.ts
import { isAbsolute as isAbsolute11, resolve as resolve15 } from "path";

// src/schemas/acg-fitness-verdict.ts
init_zod();
init_common();
var acgFitnessVerdictReproducibility = exports_external.object({
