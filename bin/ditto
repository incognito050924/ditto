// src/core/coverage-oracle.ts
init_coverage();
init_work_item();
import { existsSync as existsSync4, readFileSync } from "fs";
import { isAbsolute as isAbsolute4, resolve as resolve5, sep as sep4 } from "path";
function containScopePath(p, repoRoot) {
  if (p.length === 0)
    return { ok: false, detail: "empty scope_path" };
  if (isAbsolute4(p))
    return { ok: false, detail: `absolute scope_path rejected: ${p}` };
  if (p.startsWith(".."))
    return { ok: false, detail: `parent-escaping scope_path rejected: ${p}` };
  if (p.startsWith(":")) {
    return { ok: false, detail: `git pathspec magic rejected: ${p}` };
  }
  const root = resolve5(repoRoot);
  const abs = resolve5(root, p);
  if (abs !== root && !abs.startsWith(root + sep4)) {
    return { ok: false, detail: `scope_path escapes repoRoot: ${p}` };
  }
  return { ok: true, abs };
}
function runAbsenceCheck(pattern, scopePath, repoRoot, opts = {}) {
  if (!isDecidableOraclePattern(pattern)) {
    return {
      kind: "shape_rejected",
      detail: "pattern is not a decidable token (single non-whitespace fixed string within the length cap)"
    };
  }
  const scope = containScopePath(scopePath, repoRoot);
  if (!scope.ok)
    return { kind: "shape_rejected", detail: scope.detail };
  if (!existsSync4(scope.abs)) {
    return { kind: "shape_rejected", detail: `scope_path not found in repo: ${scopePath}` };
  }
  let proc;
  try {
    proc = Bun.spawnSync([opts.gitBin ?? "git", "grep", "-F", "-e", pattern, "--", scopePath], {
      cwd: repoRoot,
      stdout: "pipe",
      stderr: "pipe"
    });
  } catch (err) {
    return { kind: "tool_absent", detail: err instanceof Error ? err.message : String(err) };
  }
  const exit = proc.exitCode;
  if (exit === 1)
    return { kind: "confirmed_absent", exit_code: 1 };
  if (exit === 0)
    return { kind: "refuted_present", exit_code: 0 };
  return {
    kind: "exec_error",
    ...typeof exit === "number" ? { exit_code: exit } : {},
    detail: (proc.stderr?.toString() ?? "").slice(0, 200)
  };
}
function countLines(content) {
  if (content.length === 0)
    return 0;
  const parts = content.split(`
`);
  return content.endsWith(`
`) ? parts.length - 1 : parts.length;
}
function runPresenceCheck(mapsTo, repoRoot) {
  if (!codePointerMapsTo.test(mapsTo)) {
    return {
      kind: "shape_rejected",
      detail: "citation is not a file:line code pointer (codePointerMapsTo grammar)"
    };
  }
  const cut = mapsTo.lastIndexOf(":");
  const filePart = mapsTo.slice(0, cut);
  const lineSpec = mapsTo.slice(cut + 1);
  const m2 = /^(\d+)(?:-(\d+))?$/.exec(lineSpec);
  if (!m2 || m2[1] === undefined) {
    return { kind: "shape_rejected", detail: `suffix "${lineSpec}" is not a checkable line/range` };
  }
  const start = Number(m2[1]);
  const end = m2[2] === undefined ? start : Number(m2[2]);
  if (end < start) {
    return { kind: "shape_rejected", detail: `reversed line range "${lineSpec}"` };
  }
  const contained = containScopePath(filePart, repoRoot);
  if (!contained.ok)
    return { kind: "shape_rejected", detail: contained.detail };
  let content;
  try {
    content = readFileSync(contained.abs, "utf8");
  } catch (err) {
    const code = err.code;
    if (code === "ENOENT") {
      return { kind: "refuted", detail: `cited file does not exist: ${filePart}` };
    }
    return {
      kind: "exec_error",
      detail: `cited file unreadable (${code ?? "unknown"}): ${filePart}`
    };
  }
  const lines = countLines(content);
  if (start >= 1 && end <= lines)
    return { kind: "confirmed" };
  return {
    kind: "refuted",
    detail: `cited line ${lineSpec} does not exist (${filePart} has ${lines} lines)`
  };
}
var RISK_TIER_CATEGORY_IDS = ["injection", "secret-exposure"];
function enforcementTierForCategory(categoryId) {
  if (categoryId === undefined)
    return "advisory";
  const bare = categoryId.startsWith("cov-cat-") ? categoryId.slice("cov-cat-".length) : categoryId;
  return RISK_TIER_CATEGORY_IDS.includes(bare) ? "hard_reject" : "advisory";
}
function isHardRejected(verdict2) {
  return verdict2.tier === "hard_reject" && verdict2.outcome === "refuted";
}
function evaluateOracleClaim(input, repoRoot, opts = {}) {
  const base = {
    claim_id: input.claim_id,
    ...input.category_id !== undefined ? { category_id: input.category_id } : {},
    claim: input.claim,
    tier: enforcementTierForCategory(input.category_id)
  };
  if (input.claim.mode === "presence") {
    const p = runPresenceCheck(input.claim.maps_to, repoRoot);
    switch (p.kind) {
      case "confirmed":
        return { ...base, outcome: "confirmed" };
      case "refuted":
        return { ...base, outcome: "refuted", detail: p.detail };
      case "shape_rejected":
        return {
          ...base,
          outcome: "advisory_unverified",
          advisory_reason: "shape_gate",
          detail: p.detail
        };
      case "exec_error":
        return {
          ...base,
          outcome: "advisory_unverified",
          advisory_reason: "exec_error",
          detail: p.detail
        };
    }
  }
  const r3 = runAbsenceCheck(input.claim.pattern, input.claim.scope_path, repoRoot, opts);
  switch (r3.kind) {
    case "confirmed_absent":
      return { ...base, outcome: "confirmed", exit_code: r3.exit_code };
    case "refuted_present":
      return { ...base, outcome: "refuted", exit_code: r3.exit_code };
    case "shape_rejected":
      return {
        ...base,
        outcome: "advisory_unverified",
        advisory_reason: "shape_gate",
        detail: r3.detail
      };
    case "exec_error":
      return {
        ...base,
        outcome: "advisory_unverified",
        advisory_reason: "exec_error",
        ...r3.exit_code !== undefined ? { exit_code: r3.exit_code } : {},
        ...r3.detail !== undefined ? { detail: r3.detail } : {}
      };
    case "tool_absent":
      return {
        ...base,
        outcome: "advisory_unverified",
        advisory_reason: "tool_absent",
        ...r3.detail !== undefined ? { detail: r3.detail } : {}
      };
  }
}

// src/core/coverage-loop.ts
init_ditto_paths();
init_fs();
init_work_item_store();
function dryCounterPath(repoRoot, workItemId2) {
  return localDir(repoRoot, "runs", workItemId2, "coverage-dry-counter");
}
async function readDryCounter(repoRoot, workItemId2) {
  const file = Bun.file(dryCounterPath(repoRoot, workItemId2));
  if (!await file.exists())
    return 0;
  const n2 = Number.parseInt((await file.text()).trim(), 10);
  return Number.isFinite(n2) && n2 >= 0 ? n2 : 0;
}
async function writeDryCounter(repoRoot, workItemId2, n2) {
  await atomicWriteText(dryCounterPath(repoRoot, workItemId2), String(n2));
}
function oracleProvenancePath(repoRoot, workItemId2) {
  return localDir(repoRoot, "runs", workItemId2, "oracle-provenance.json");
}
async function appendOracleVerdicts(repoRoot, workItemId2, verdicts) {
  const path = oracleProvenancePath(repoRoot, workItemId2);
  const existing = await Bun.file(path).exists() ? await readJson(path, oracleProvenance) : {
    schema_version: "0.1.0",
    work_item_id: workItemId2,
    oracle_verdicts: [],
    labeler_labels: [],
    tally: {
      claims: 0,
      oracle: { confirmed: 0, refuted: 0, advisory_unverified: 0 },
      labeler: { real: 0, fabricated: 0 }
    }
  };
  const byId = new Map(existing.oracle_verdicts.map((v2) => [v2.claim_id, v2]));
  for (const v2 of verdicts)
    byId.set(v2.claim_id, v2);
  const merged = [...byId.values()];
  const count = (outcome) => merged.filter((v2) => v2.outcome === outcome).length;
  await writeJson(path, oracleProvenance, {
    ...existing,
    oracle_verdicts: merged,
    tally: {
      claims: merged.length,
      oracle: {
        confirmed: count("confirmed"),
        refuted: count("refuted"),
        advisory_unverified: count("advisory_unverified")
      },
      labeler: {
        real: existing.labeler_labels.filter((l2) => l2.label === "real").length,
        fabricated: existing.labeler_labels.filter((l2) => l2.label === "fabricated").length
      }
    }
  });
}
function claimDisposition(map, roundNodeId, categoryId) {
  if (categoryId !== undefined) {
    const cat = map.nodes.find((n2) => n2.id === categoryId || n2.id === `${CATEGORY_NODE_PREFIX}${categoryId}`);
    return cat?.disposition ?? DEFAULT_COVERAGE_DISPOSITION;
  }
  let cur = map.nodes.find((n2) => n2.id === roundNodeId);
  while (cur !== undefined) {
    if (cur.disposition !== undefined)
      return cur.disposition;
    const parentId = cur.parent_id;
    cur = parentId === null ? undefined : map.nodes.find((n2) => n2.id === parentId);
  }
  return DEFAULT_COVERAGE_DISPOSITION;
}
function rootNode(label) {
  return {
    id: "cov-root",
    parent_id: null,
    label,
    origin: "seed",
    depth_weight: 1,
    state: "open",
    children: []
  };
}
async function originalIntent(repoRoot, workItemId2) {
  const intents = new IntentStore(repoRoot);
  if (await intents.exists(workItemId2)) {
    return (await intents.get(workItemId2)).goal;
  }
  const items = new WorkItemStore(repoRoot);
  if (await items.exists(workItemId2)) {
    return (await items.get(workItemId2)).title;
  }
  return workItemId2;
}
async function nextCoverageNode(args) {
  const { repoRoot, workItemId: workItemId2 } = args;
  const store = new CoverageStore(repoRoot);
  const taxonomy = await loadFarFieldTaxonomy(repoRoot, () => warnMalformedTaxonomy(repoRoot));
  let map;
  if (await store.exists(workItemId2)) {
    map = await store.getMap(workItemId2);
  } else {
    const intent2 = await originalIntent(repoRoot, workItemId2);
    map = {
      schema_version: "0.1.0",
      work_item_id: workItemId2,
      root_id: "cov-root",
      nodes: args.seedCategories ? farFieldCoverageNodes(intent2, "cov-root", taxonomy, args.relevanceVerdicts) : [rootNode(intent2)],
      ...args.intensity ? { intensity: args.intensity } : {}
    };
    await store.writeMap(workItemId2, map);
    if (args.rawRelevance) {
      const categoryNodes = map.nodes.filter((n2) => n2.id.startsWith(CATEGORY_NODE_PREFIX));
      const skipped = categoryNodes.filter((n2) => n2.state === "out_of_scope").length;
      await store.writeRelevanceProvenance(workItemId2, {
        schema_version: "0.1.0",
        work_item_id: workItemId2,
        judgments: [...args.rawRelevance.judgments],
        refutes: [...args.rawRelevance.refutes],
        tally: {
          seeded: categoryNodes.length,
          skipped,
          relevant: categoryNodes.length - skipped
        }
      });
    }
  }
  const dryCounter = await readDryCounter(repoRoot, workItemId2);
  const tier = args.intensity ?? map.intensity ?? (args.tierInputs ? selectCoverageTier(args.tierInputs) : "standard");
  const sweepAngles = tierDepthBudget(tier).sweepAngles;
  if (isCoverageTerminated(map, dryCounter, coverageDryK(tier))) {
    return { action: "dry", terminated: true };
  }
  const ready = selectReadyCoverageNodes(map);
  const node2 = ready[0];
  const lenses = farFieldLenses(taxonomy);
  if (node2 === undefined) {
    const rootJudge = buildJudgeInput({
      node: map.nodes[0] ?? rootNode(workItemId2),
      originalIntent: await originalIntent(repoRoot, workItemId2),
      crossCuttingConstraints: lenses
    });
    return {
      action: "interrogate",
      node: rootNode(map.nodes[0]?.label ?? workItemId2),
      judgeInput: rootJudge,
      wave: [{ node: rootNode(map.nodes[0]?.label ?? workItemId2), judgeInput: rootJudge }],
      dryProbe: true,
      tier,
      sweepAngles,
      dryCounter
    };
  }
  const intent = await originalIntent(repoRoot, workItemId2);
  const wave = ready.map((n2) => ({
    node: { ...n2 },
    judgeInput: buildJudgeInput({
      node: n2,
      originalIntent: intent,
      crossCuttingConstraints: lenses
    })
  }));
  return {
    action: "interrogate",
    node: wave[0].node,
    judgeInput: wave[0].judgeInput,
    wave,
    tier,
    sweepAngles,
    dryCounter
  };
}
function enforceClose(map, node2, state, signals, reason, residualRisk, oracleVerdicts = []) {
  const reasons = [];
  for (const v2 of oracleVerdicts) {
    if (isHardRejected(v2)) {
      reasons.push(`oracle hard-rejected close of ${node2.id}: risk-tier claim ${v2.claim_id}${v2.category_id !== undefined ? ` (${v2.category_id})` : ""} was refuted against the working tree${v2.detail !== undefined ? ` \u2014 ${v2.detail}` : ""}`);
    }
  }
  const gate2 = coverageClosureGate(map, node2.id, state);
  if (!gate2.pass)
    reasons.push(...gate2.reasons);
  if (node2.id.startsWith(CATEGORY_NODE_PREFIX) && state !== "resolved" && (reason === undefined || reason.trim() === "")) {
    reasons.push(`category ${node2.id} skipped as ${state} without a reason: a category skip must be a recorded, justified decision (ac-2)`);
  }
  if (node2.id.startsWith(CATEGORY_NODE_PREFIX) && state !== "resolved" && (residualRisk === undefined || residualRisk.trim() === "")) {
    reasons.push(`category ${node2.id} skipped as ${state} without a residual_risk: a skip must name the surviving risk it leaves behind, not only why it was skipped`);
  }
  if (state === "resolved" && signals.neutrality === undefined) {
    reasons.push(`neutrality axis required for resolved close of ${node2.id}: axis_signals.neutrality absent`);
  }
  const neutralityOk = signals.neutrality === undefined || COVERAGE_AXIS_MECHANISMS.neutrality.enforce(signals.neutrality);
  if (!neutralityOk) {
    reasons.push(`neutrality axis rejected ${node2.id}: Opponent did not run or verdict blocked`);
  }
  if (signals.balance !== undefined) {
    const balanceOk = COVERAGE_AXIS_MECHANISMS.balance.enforce(node2, signals.balance);
    if (!balanceOk) {
      reasons.push(`balance axis rejected ${node2.id}: achieved depth below depth_weight floor`);
    }
  }
  if (signals.priority !== undefined) {
    const priorityOk = COVERAGE_AXIS_MECHANISMS.priority.enforce(node2, signals.priority);
    if (!priorityOk) {
      reasons.push(`priority axis rejected ${node2.id}: high-priority node still shallow`);
    }
  }
  if (signals.temporalBaseline !== undefined && signals.temporalCurrent !== undefined) {
    const temporalOk = COVERAGE_AXIS_MECHANISMS.temporal.enforce(signals.temporalBaseline, signals.temporalCurrent);
    if (!temporalOk) {
      reasons.push(`temporal axis rejected ${node2.id}: surface diverged from frozen baseline`);
    }
  }
  return reasons;
}
async function recordCoverageRound(args) {
  const { repoRoot, workItemId: workItemId2, payload } = args;
  const store = new CoverageStore(repoRoot);
  let map = await store.getMap(workItemId2);
  const existingIds = new Set(map.nodes.map((n2) => n2.id));
  const children = [...payload.derived_nodes ?? [], ...payload.discovered_nodes ?? []].filter((c3) => !existingIds.has(c3.id));
  for (const child of children) {
    map = addNode(map, {
      id: child.id,
      parent_id: child.parent_id,
      label: child.label,
      origin: child.origin,
      depth_weight: child.depth_weight,
      state: "open",
      children: []
    });
  }
  const prevCounter = await readDryCounter(repoRoot, workItemId2);
  const nextCounter = recordDryRound(prevCounter, {
    admissibleBranchesAdded: payload.admissibleBranchesAdded
  });
  await writeDryCounter(repoRoot, workItemId2, nextCounter);
  let oracleVerdicts = [];
  if (args.oracleClaims !== undefined && args.oracleClaims.length > 0) {
    oracleVerdicts = args.oracleClaims.filter((c3) => claimDisposition(map, payload.node_id, c3.category_id) === "code-verify").map((c3) => evaluateOracleClaim(c3, repoRoot, args.oracleExec ?? {}));
    if (oracleVerdicts.length > 0) {
      await appendOracleVerdicts(repoRoot, workItemId2, oracleVerdicts);
    }
  }
  let closed = false;
  let reasons = [];
  if (payload.close_as !== undefined) {
    const node2 = map.nodes.find((n2) => n2.id === payload.node_id);
    if (node2 === undefined) {
      reasons = [`unknown coverage node id: ${payload.node_id}`];
    } else {
      reasons = enforceClose(map, node2, payload.close_as, payload.axis_signals ?? {}, payload.close_reason, payload.residual_risk, oracleVerdicts);
      if (reasons.length === 0) {
        map = closeNode(map, payload.node_id, payload.close_as, payload.close_reason, payload.residual_risk);
        closed = true;
      }
    }
  }
  await store.writeMap(workItemId2, map);
  const tier = args.intensity ?? map.intensity ?? (args.tierInputs ? selectCoverageTier(args.tierInputs) : "standard");
  if (isCoverageTerminated(map, nextCounter, coverageDryK(tier))) {
    const delta = args.dialogDelta ?? {};
    const closedItems = map.nodes.filter((n2) => n2.state !== "open").map((n2) => ({
      id: n2.id,
      label: n2.label,
      state: n2.state,
      ...n2.close_reason !== undefined ? { close_reason: n2.close_reason } : {},
      ...n2.residual_risk !== undefined ? { residual_risk: n2.residual_risk } : {}
    }));
    const openItems = map.nodes.filter((n2) => n2.state === "open").map((n2) => ({ id: n2.id, label: n2.label, state: n2.state }));
    const stage = args.stage ?? "plan";
    const dialogInput = {
      workItemId: workItemId2,
      userQa: delta.userQa ?? [],
      selfAnswers: delta.selfAnswers ?? [],
      assumptions: delta.assumptions ?? [],
      closedItems: delta.closedItems ?? closedItems,
      openItems: delta.openItems ?? openItems,
      kind: stage === "intent" ? "intent-dialog" : "plan-dialog"
    };
    const markdown = serializePlanDialog(dialogInput);
    if (stage === "intent") {
      await store.writeIntentDialog(workItemId2, markdown);
    } else {
      await store.writePlanDialog(workItemId2, markdown);
    }
    const dialogFile = stage === "intent" ? "intent-dialog.md" : "plan-dialog.md";
    return {
      terminated: true,
      brief: args.brief ?? { interface_changes: [], dod: [], test_scenarios: [] },
      ...args.tierInputs ? { tierInputs: args.tierInputs } : {},
      planDialogPath: `.ditto/local/runs/${workItemId2}/${dialogFile}`
    };
  }
  return { terminated: false, closed, reasons, dryCounter: nextCounter };
}

// src/core/coverage-relevance.ts
function assembleRelevanceVerdicts(judgments, refutes = []) {
  const refuteById = new Map(refutes.map((r3) => [r3.id, r3]));
  return judgments.map((j) => {
    const refute = refuteById.get(j.id);
    if (j.relevant === false && j.reason && j.residual_risk && refute !== undefined && refute.refuted === false) {
      return { id: j.id, relevant: false, reason: j.reason, residual_risk: j.residual_risk };
    }
    return { id: j.id, relevant: true };
  });
}

// src/core/ditto-config.ts
import { mkdir as mkdir3 } from "fs/promises";
import { dirname as dirname9 } from "path";
init_ditto_paths();
async function readDeepInterviewConfigDefaults(repoRoot, onMalformed) {
  const file = Bun.file(localDir(repoRoot, "config.json"));
  if (!await file.exists())
    return {};
  try {
    const parsed = dittoConfig.safeParse(JSON.parse(await file.text()));
    if (!parsed.success) {
      onMalformed?.();
      return {};
    }
    return parsed.data.deep_interview ?? {};
  } catch {
    onMalformed?.();
    return {};
  }
}
async function readGithubConfig(repoRoot, onMalformed) {
  const file = Bun.file(localDir(repoRoot, "config.json"));
  if (!await file.exists())
    return;
  try {
    const parsed = dittoConfig.safeParse(JSON.parse(await file.text()));
    if (!parsed.success) {
      onMalformed?.();
      return;
    }
    return parsed.data.github;
  } catch {
    onMalformed?.();
    return;
  }
}
async function writeGithubConfig(repoRoot, github) {
  const path = localDir(repoRoot, "config.json");
  let existing = {};
  const file = Bun.file(path);
  if (await file.exists()) {
    try {
      const raw = JSON.parse(await file.text());
      if (dittoConfig.safeParse(raw).success && raw !== null && typeof raw === "object") {
        existing = raw;
      }
    } catch {}
  }
  const next = { ...existing, github };
  await mkdir3(dirname9(path), { recursive: true });
  await Bun.write(path, `${JSON.stringify(next, null, 2)}
`);
}
async function seedGithubConfigIfAbsent(repoRoot, github, onMalformed) {
  const file = Bun.file(localDir(repoRoot, "config.json"));
  if (!await file.exists()) {
    await writeGithubConfig(repoRoot, github);
    return { seeded: true, reason: "absent" };
  }
  let parsed;
  try {
    parsed = dittoConfig.safeParse(JSON.parse(await file.text()));
  } catch {
    onMalformed?.();
    return { seeded: false, reason: "malformed" };
  }
  if (!parsed.success) {
    onMalformed?.();
    return { seeded: false, reason: "malformed" };
  }
  if (parsed.data.github !== undefined) {
    return { seeded: false, reason: "existing" };
  }
  await writeGithubConfig(repoRoot, github);
  return { seeded: true, reason: "absent" };
}

