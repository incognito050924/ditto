// src/core/recipe/parse.ts
function parseRecipe(text) {
  let raw;
  try {
    raw = $parse(text);
  } catch (error) {
    return { ok: false, error: `recipe YAML parse failed: ${describe(error)}` };
  }
  const candidate = raw === undefined || raw === null ? {} : raw;
  const parsed = recipe.safeParse(candidate);
  if (!parsed.success) {
    return { ok: false, error: `recipe schema validation failed: ${parsed.error.message}` };
  }
  return { ok: true, recipe: parsed.data };
}
function describe(error) {
  return error instanceof Error ? error.message : String(error);
}

// src/core/recipe/load.ts
var PROJECT_RECIPE_FILENAME = "recipe.yaml";
var BUILTIN_DEFAULT_RECIPE = {};
function definedFields(r3) {
  return Object.fromEntries(Object.entries(r3).filter(([, v2]) => v2 !== undefined));
}
function mergeRecipes(base, override) {
  return { ...base, ...definedFields(override) };
}
function resolveRecipe(sources) {
  return [sources.builtinDefault, sources.project, sources.personal, sources.cli].filter((r3) => r3 !== undefined).reduce((acc, r3) => mergeRecipes(acc, r3), {});
}
async function loadRecipeFile(path, source, onMalformed) {
  const file = Bun.file(path);
  if (!await file.exists()) {
    if (source === "explicit") {
      throw new Error(`recipe not found at explicit path: ${path}`);
    }
    return;
  }
  const result2 = parseRecipe(await file.text());
  if (!result2.ok) {
    if (source === "explicit") {
      throw new Error(`${result2.error} (${path})`);
    }
    onMalformed?.(`${result2.error} (${path})`);
    return;
  }
  return result2.recipe;
}
async function loadResolvedRecipe(repoRoot, cliPath, onMalformed) {
  const project = await loadRecipeFile(join28(repoRoot, PROJECT_RECIPE_FILENAME), "discovered", (m2) => onMalformed?.("project", m2));
  const personal = await loadRecipeFile(localDir(repoRoot, "recipe.yaml"), "discovered", (m2) => onMalformed?.("personal", m2));
  const cli = cliPath === undefined ? undefined : await loadRecipeFile(cliPath, "explicit");
  return resolveRecipe({ cli, personal, project, builtinDefault: BUILTIN_DEFAULT_RECIPE });
}

// src/core/retro-measure.ts
init_memory_store();
function grounded(v2) {
  return typeof v2 === "number" && Number.isFinite(v2);
}
function assembleRetroMetrics(inputs) {
  const outcome = {};
  if (grounded(inputs.coverage))
    outcome.coverage = inputs.coverage;
  if (grounded(inputs.unit_only_closures))
    outcome.unit_only_closures = inputs.unit_only_closures;
  if (grounded(inputs.escape_recurrence))
    outcome.escape_recurrence = inputs.escape_recurrence;
  const metrics = {};
  if (Object.keys(outcome).length > 0)
    metrics.outcome_floor = outcome;
  if (grounded(inputs.post_cost))
    metrics.process_health = { post_cost: inputs.post_cost };
  if (!metrics.outcome_floor && !metrics.process_health) {
    return { no_measurable_signal: true };
  }
  return metrics;
}
function projectRetroNarrative(records) {
  const items = [];
  for (const text of records.unverified)
    items.push({ kind: "unverified", memory_eligible: true, text });
  for (const text of records.residual_risks)
    items.push({ kind: "residual", memory_eligible: true, text });
  for (const text of records.close_reasons)
    items.push({ kind: "close_reason", memory_eligible: true, text });
  for (const text of records.intent_drift)
    items.push({ kind: "intent_drift", memory_eligible: true, text });
  for (const text of records.evidence_refs)
    items.push({ kind: "evidence", memory_eligible: true, text });
  if (records.process_health_note) {
    items.push({ kind: "evidence", memory_eligible: false, text: records.process_health_note });
  }
  return { work_item_id: records.work_item_id, items };
}
function retroMemoryEventId(workItemId2) {
  return `memevt_retro_${sha256Hex(workItemId2).slice(0, 16)}`;
}
function codeSourceIdsForPaths(sources, paths) {
  const wanted = new Set(paths);
  const out = [];
  const seen = new Set;
  for (const s2 of sources) {
    if (s2.source_type !== "code" || !s2.path || !wanted.has(s2.path))
      continue;
    if (seen.has(s2.source_id))
      continue;
    seen.add(s2.source_id);
    out.push(s2.source_id);
  }
  return out;
}
var MEMORY_EVENT_TEXT_MAX = 4000;
var TRUNCATION_MARKER = `
\u2026[truncated]`;
function capToMemoryEventLimit(text) {
  if (text.length <= MEMORY_EVENT_TEXT_MAX)
    return text;
  const head = text.slice(0, MEMORY_EVENT_TEXT_MAX - TRUNCATION_MARKER.length);
  return head + TRUNCATION_MARKER;
}
async function absorbRetroMemory(store, narrative, opts) {
  const eligible = narrative.items.filter((i2) => i2.memory_eligible);
  if (eligible.length === 0)
    return { appended: false };
  const text = capToMemoryEventLimit(eligible.map((i2) => `[${i2.kind}] ${i2.text}`).join(`
`));
  const eventId = retroMemoryEventId(narrative.work_item_id);
  try {
    const event = await store.append({
      schema_version: "0.1.0",
      event_id: eventId,
      event_type: "analysis",
      actor: { kind: "agent", role: opts.actorRole },
      text,
      created_at: opts.createdAt,
      status: "pending",
      sources: opts.sources ?? [],
      confidence_kind: "EXTRACTED",
      sensitivity: "internal",
      governs: []
    });
    return { appended: true, event };
  } catch (err) {
    if (err instanceof Error && err.name === "MemoryEventExistsError") {
      return { appended: false };
    }
    throw err;
  }
}

