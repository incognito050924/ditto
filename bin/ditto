// src/schemas/handoff.ts
init_zod();
init_common();
var handoff = exports_external.object({
  schema_version: schemaVersion,
  work_item_id: workItemId,
  autopilot_id: autopilotId.optional().describe("Same autopilot_id the next session resumes under (\xA76.10)"),
  from_context: exports_external.string().min(1).describe("Where this handoff is written from: session/agent and its state"),
  to_owner: exports_external.string().min(1).optional().describe("Profile or handle expected to pick up"),
  original_intent: exports_external.string().min(1).describe("Original user intent"),
  current_state: exports_external.string().min(1).describe("Where things stand now"),
  decisions_made: exports_external.array(exports_external.string()).default([]),
  critical_decisions: exports_external.array(exports_external.object({
    decision: exports_external.string().min(1),
    rationale: exports_external.string().min(1).describe("Why this decision was made (preserved inline)")
  })).default([]).describe("Decisions that cannot be re-derived from the codebase \u2014 kept inline"),
  irreversible_risks: exports_external.array(exports_external.object({
    risk: exports_external.string().min(1),
    why_irreversible: exports_external.string().min(1).describe("Why this risk cannot be undone (preserved inline)")
  })).default([]).describe("Risks whose substance is non-recoverable \u2014 kept inline, not pointer-only"),
  changed_files: exports_external.array(relativePath).default([]),
  evidence_refs: exports_external.array(evidenceRef).default([]).describe("Inline summaries/hashes/commands, not raw artifacts"),
  failed_or_unverified: exports_external.array(exports_external.string()).default([]),
  open_threads: exports_external.array(exports_external.string()).default([]),
  next_first_check: exports_external.string().min(1).describe("What the next agent checks first"),
  forbidden_scope_creep: exports_external.array(exports_external.string()).default([]),
  artifact_available: exports_external.boolean().default(true).describe("False when raw artifacts are absent from this clone/session (\xA76.10)"),
  created_at: isoDateTime
}).describe("Minimal context for resuming across session/context/agent boundaries (\xA76.10)");

// src/core/handoff-store.ts
init_ditto_paths();
init_fs();
init_work_item_store();
function buildHandoff(input) {
  return handoff.parse({
    schema_version: "0.1.0",
    work_item_id: input.workItem.id,
    ...input.autopilotId ? { autopilot_id: input.autopilotId } : {},
    from_context: input.fromContext,
    ...input.toOwner ? { to_owner: input.toOwner } : {},
    original_intent: input.workItem.source_request,
    current_state: input.currentState,
    decisions_made: input.decisionsMade ?? [],
    critical_decisions: input.criticalDecisions ?? [],
    irreversible_risks: input.irreversibleRisks ?? [],
    changed_files: input.changedFiles ?? input.workItem.changed_files,
    evidence_refs: input.evidenceRefs ?? [],
    failed_or_unverified: input.failedOrUnverified ?? [],
    open_threads: input.openThreads ?? [],
    next_first_check: input.nextFirstCheck,
    forbidden_scope_creep: input.forbiddenScopeCreep ?? [],
    artifact_available: input.artifactAvailable ?? true,
    created_at: (input.now ?? new Date).toISOString()
  });
}
function renderHandoff(h2) {
  const lines = [];
  lines.push(`# Handoff: ${h2.work_item_id}`);
  if (h2.autopilot_id)
    lines.push(`autopilot: ${h2.autopilot_id}`);
  lines.push("", `from: ${h2.from_context}`, "");
  lines.push("## \uC6D0\uB798 \uC758\uB3C4");
  lines.push(h2.original_intent, "");
  lines.push("## \uD604\uC7AC \uC0C1\uD0DC");
  lines.push(h2.current_state, "");
  if (h2.decisions_made.length > 0) {
    lines.push("## \uB0B4\uB824\uC9C4 \uACB0\uC815");
    for (const d2 of h2.decisions_made)
      lines.push(`- ${d2}`);
    lines.push("");
  }
  if (h2.critical_decisions.length > 0) {
    lines.push("## \uD575\uC2EC \uACB0\uC815 (\uC7AC\uD638\uCD9C \uBD88\uAC00)");
    for (const d2 of h2.critical_decisions)
      lines.push(`- ${d2.decision} \u2014 ${d2.rationale}`);
    lines.push("");
  }
  if (h2.irreversible_risks.length > 0) {
    lines.push("## \uBE44\uAC00\uC5ED \uC704\uD5D8");
    for (const r3 of h2.irreversible_risks)
      lines.push(`- ${r3.risk} \u2014 ${r3.why_irreversible}`);
    lines.push("");
  }
  if (h2.changed_files.length > 0) {
    lines.push("## \uBCC0\uACBD \uD30C\uC77C");
    for (const f3 of h2.changed_files)
      lines.push(`- ${f3}`);
    lines.push("");
  }
  if (h2.evidence_refs.length > 0) {
    lines.push("## \uC99D\uAC70 (inline)");
    for (const e2 of h2.evidence_refs)
      lines.push(`- ${JSON.stringify(e2)}`);
    lines.push("");
  }
  if (h2.failed_or_unverified.length > 0) {
    lines.push("## \uC2E4\uD328 / \uBBF8\uAC80\uC99D");
    for (const u3 of h2.failed_or_unverified)
      lines.push(`- ${u3}`);
    lines.push("");
  }
  if (h2.open_threads.length > 0) {
    lines.push("## \uC5F4\uB9B0 \uC2A4\uB808\uB4DC");
    for (const t2 of h2.open_threads)
      lines.push(`- ${t2}`);
    lines.push("");
  }
  lines.push("## \uB2E4\uC74C agent \uAC00 \uAC00\uC7A5 \uBA3C\uC800 \uBCFC \uAC83");
  lines.push(h2.next_first_check, "");
  if (h2.forbidden_scope_creep.length > 0) {
    lines.push("## \uAE08\uC9C0: scope creep");
    for (const s2 of h2.forbidden_scope_creep)
      lines.push(`- ${s2}`);
    lines.push("");
  }
  if (!h2.artifact_available) {
    lines.push("\u26A0 raw artifacts \uAC00 \uC774 \uD074\uB860/\uC138\uC158\uC5D0 \uC5C6\uB2E4 \u2014 \uC778\uB77C\uC778 \uC694\uC57D\uB9CC \uC2E0\uB8B0\uD560 \uAC83.", "");
  }
  return lines.join(`
`).trimEnd();
}
function serialize(h2) {
  return `---
${JSON.stringify(h2)}
---

${renderHandoff(h2)}
`;
}
function parseHandoffFile(text) {
  if (!text.startsWith(`---
`)) {
    throw new Error("handoff file: missing leading frontmatter fence");
  }
  const rest = text.slice(4);
  const end = rest.indexOf(`
---`);
  if (end === -1)
    throw new Error("handoff file: unterminated frontmatter");
  const handoff2 = handoff.parse(JSON.parse(rest.slice(0, end)));
  const body = rest.slice(end + 4).replace(/^\n+/, "");
  return { handoff: handoff2, body };
}
function stamp(now) {
  return now.toISOString().replace(/[:.]/g, "-");
}
var STALE_ACTIVE_RETENTION_DAYS = 7;
var STALE_ACTIVE_RETENTION_MS = STALE_ACTIVE_RETENTION_DAYS * 24 * 60 * 60 * 1000;

class HandoffStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  dir() {
    return localDir(this.repoRoot, "handoff");
  }
  activePath(workItemId2) {
    return join23(this.dir(), `${workItemId2}.md`);
  }
  activeRel(workItemId2) {
    return `.ditto/local/handoff/${workItemId2}.md`;
  }
  archiveRel(workItemId2, ts) {
    return `.ditto/local/handoff/archive/${workItemId2}__${ts}.md`;
  }
  archiveRelFromBasename(name, ts) {
    const stem = name.replace(/\.md$/, "");
    return `.ditto/local/handoff/archive/${stem}__${ts}.md`;
  }
  async link(workItemId2, rel) {
    const items = new WorkItemStore(this.repoRoot);
    if (await items.exists(workItemId2)) {
      await items.update(workItemId2, (current) => ({ ...current, handoff_path: rel }));
    }
  }
  async write(h2) {
    await atomicWriteText(this.activePath(h2.work_item_id), serialize(h2));
    const rel = this.activeRel(h2.work_item_id);
    await this.link(h2.work_item_id, rel);
    return rel;
  }
  async writeArchived(h2, now = new Date) {
    const rel = this.archiveRel(h2.work_item_id, stamp(now));
    await atomicWriteText(join23(this.repoRoot, rel), serialize(h2));
    await this.link(h2.work_item_id, rel);
    return rel;
  }
  async listActive() {
    let names;
    try {
      names = await readdir9(this.dir());
    } catch {
      return [];
    }
    const out = [];
    for (const name of names) {
      if (!name.endsWith(".md"))
        continue;
      const path = join23(this.dir(), name);
      try {
        const { handoff: handoff2, body } = parseHandoffFile(await Bun.file(path).text());
        out.push({ handoff: handoff2, body, path });
      } catch {}
    }
    return out.sort((a2, b2) => a2.handoff.created_at.localeCompare(b2.handoff.created_at));
  }
  async consume(now = new Date) {
    const active = await this.listActive();
    if (active.length === 0)
      return [];
    await ensureDir(join23(this.dir(), "archive"));
    for (const a2 of active) {
      const dest = join23(this.repoRoot, this.archiveRel(a2.handoff.work_item_id, stamp(now)));
      try {
        await rename3(a2.path, dest);
      } catch {}
    }
    return active;
  }
  async getActive(workItemId2) {
    const path = this.activePath(workItemId2);
    try {
      const { handoff: handoff2, body } = parseHandoffFile(await Bun.file(path).text());
      return { handoff: handoff2, body, path };
    } catch {
      return null;
    }
  }
  async consumeFor(workItemId2, now = new Date) {
    const active = await this.getActive(workItemId2);
    if (active === null)
      return null;
    await ensureDir(join23(this.dir(), "archive"));
    const dest = join23(this.repoRoot, this.archiveRel(workItemId2, stamp(now)));
    try {
      await rename3(active.path, dest);
    } catch {}
    return active;
  }
  async sweepStaleActive(now = new Date) {
    const dir = this.dir();
    let names;
    try {
      names = await readdir9(dir);
    } catch {
      return [];
    }
    const swept = [];
    let ensured = false;
    for (const name of names) {
      if (!name.endsWith(".md"))
        continue;
      const path = join23(dir, name);
      let mtimeMs;
      try {
        mtimeMs = (await stat4(path)).mtimeMs;
      } catch {
        continue;
      }
      if (now.getTime() - mtimeMs <= STALE_ACTIVE_RETENTION_MS)
        continue;
      let handoff2 = null;
      try {
        handoff2 = parseHandoffFile(await Bun.file(path).text()).handoff;
      } catch {
        handoff2 = null;
      }
      const archivePath = handoff2 ? this.archiveRel(handoff2.work_item_id, stamp(now)) : this.archiveRelFromBasename(name, stamp(now));
      if (!ensured) {
        await ensureDir(join23(dir, "archive"));
        ensured = true;
      }
      try {
        await rename3(path, join23(this.repoRoot, archivePath));
        swept.push({ path, archivePath, handoff: handoff2 });
      } catch {}
    }
    return swept;
  }
  async exists(workItemId2) {
    return Bun.file(this.activePath(workItemId2)).exists();
  }
  async get(workItemId2) {
    return parseHandoffFile(await Bun.file(this.activePath(workItemId2)).text()).handoff;
  }
}

