// src/cli/commands/prism.ts
import { randomBytes as randomBytes4 } from "crypto";
init_fs();

// src/core/prism/designdoc.ts
function title(id) {
  return SPEC_SECTIONS.find((s2) => s2.id === id)?.title ?? id;
}
var FENCE = /(^|\n)\s*(```+|~~~+)/;
function isGroundingRef(s2) {
  if (!s2 || s2.trim().length === 0)
    return false;
  return /\S+\.\w+:\d+/.test(s2) || /\[.+\]\(.+\)/.test(s2) || /\bADR-/.test(s2) || /\b(?:proj_|memevt_|src_)/.test(s2);
}
function renderFactual(claims) {
  if (!claims || claims.length === 0)
    return "\uC5C6\uC74C";
  return claims.map((c5) => c5.grounding ? `- ${c5.claim} (\uADFC\uAC70: ${c5.grounding})` : `- ${c5.claim} (\uADFC\uAC70 \uC5C6\uC74C \u2014 \uBBF8\uD574\uACB0)`).join(`
`);
}
function renderDesignDoc(input) {
  const acRows = input.acceptanceCriteria.map((a4) => `| ${a4.id} | ${a4.statement} | ${a4.evidence} |`).join(`
`);
  const riskRows = input.risks.map((r4) => `| ${r4.risk} | ${r4.handling} | ${r4.flag ?? "\u2014"} |`).join(`
`);
  const parts = [
    `# ${input.feature} \u2014 \uC124\uACC4 \uBB38\uC11C`,
    "",
    "> \uC18C\uBE44\uC790: DITTO(design \u2192 implement \u2192 verify) + \uC0AC\uB78C. \uC6D0\uBB38 \uC804\uC0AC \uAE08\uC9C0 \u2014 \uC694\uC57D+\uB9C1\uD06C.",
    "",
    `## 1. ${title("feature")}`,
    "",
    `- \uC774\uB984: ${input.feature}`,
    "",
    `## 2. ${title("summary")}`,
    "",
    input.summary,
    "",
    `## 3. ${title("background")}`,
    "",
    renderFactual(input.background),
    "",
    `## 4. ${title("goals")}`,
    "",
    input.goals.map((g4) => `- ${g4}`).join(`
`),
    "",
    `## 5. ${title("non-goals")}`,
    "",
    input.nonGoals.map((g4) => `- ${g4}`).join(`
`),
    "",
    `## 6. ${title("acceptance-criteria")}`,
    "",
    "| id | \uC644\uB8CC \uC870\uAC74 | evidence |",
    "|---|---|---|",
    acRows,
    "",
    `## 7. ${title("risks")}`,
    "",
    "| \uC704\uD5D8 | \uCC98\uB9AC | \uD50C\uB798\uADF8 |",
    "|---|---|---|",
    riskRows,
    "",
    `## 8. ${title("impact")}`,
    "",
    renderFactual(input.impact),
    "",
    `## 9. ${title("interview-log")}`,
    "",
    input.interviewSummary ?? "\uC5C6\uC74C",
    ""
  ];
  return parts.join(`
`);
}
function emitDesignDoc(input, opts) {
  const reasons = [];
  const contained = containScopePath(opts.targetPath, opts.repoRoot);
  if (!contained.ok)
    reasons.push(`\uBB38\uC11C \uACBD\uB85C\uAC00 repo \uBC16\uC785\uB2C8\uB2E4: ${contained.detail}`);
  if (input.summary.trim().length === 0)
    reasons.push("\uD544\uC218 \uC808\uC774 \uBE44\uC5B4 \uC788\uC74C: \uC694\uC57D");
  if (input.goals.filter((g4) => g4.trim().length > 0).length === 0)
    reasons.push("\uD544\uC218 \uC808\uC774 \uBE44\uC5B4 \uC788\uC74C: \uBAA9\uD45C");
  if (input.nonGoals.filter((g4) => g4.trim().length > 0).length === 0)
    reasons.push("\uD544\uC218 \uC808\uC774 \uBE44\uC5B4 \uC788\uC74C: \uBE44\uBAA9\uD45C");
  if (input.acceptanceCriteria.length === 0)
    reasons.push("\uD544\uC218 \uC808\uC774 \uBE44\uC5B4 \uC788\uC74C: \uC644\uB8CC \uC870\uAC74");
  if (input.risks.length === 0)
    reasons.push("\uD544\uC218 \uC808\uC774 \uBE44\uC5B4 \uC788\uC74C: \uC704\uD5D8");
  const factual = [
    ...(input.background ?? []).map((c5) => ({ section: "\uBC30\uACBD", claim: c5 })),
    ...(input.impact ?? []).map((c5) => ({ section: "\uC601\uD5A5\uB3C4", claim: c5 }))
  ];
  for (const { section, claim: claim2 } of factual) {
    if (FENCE.test(claim2.claim))
      reasons.push(`${section} \uC808\uC5D0 \uC6D0\uBB38 \uC804\uC0AC(\uCF54\uB4DC\uBE14\uB85D)\uAC00 \uC788\uC2B5\uB2C8\uB2E4 \u2014 \uC694\uC57D+\uB9C1\uD06C\uB9CC \uD5C8\uC6A9`);
  }
  if (input.interviewSummary && FENCE.test(input.interviewSummary))
    reasons.push("\uC778\uD130\uBDF0 \uC808\uC5D0 \uC6D0\uBB38 \uC804\uC0AC(\uCF54\uB4DC\uBE14\uB85D)\uAC00 \uC788\uC2B5\uB2C8\uB2E4 \u2014 \uC694\uC57D+\uB9C1\uD06C\uB9CC \uD5C8\uC6A9");
  const ungrounded = factual.filter(({ claim: claim2 }) => !isGroundingRef(claim2.grounding));
  const unresolved = ungrounded.map(({ section, claim: claim2 }) => `${section}: ${claim2.claim}`);
  if (ungrounded.length > 0 && !opts.allowUngrounded) {
    for (const { section, claim: claim2 } of ungrounded)
      reasons.push(`${section} \uC808\uC758 \uC0AC\uC2E4 \uC8FC\uC7A5\uC5D0 \uADFC\uAC70\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4: "${claim2.claim}"`);
  }
  if (reasons.length > 0)
    return { status: "rejected", reasons };
  const markdown = scrubTokens(renderDesignDoc(input));
  return {
    status: "emitted",
    markdown,
    digest: computeSpecDigest(markdown),
    abs: contained.ok ? contained.abs : opts.targetPath,
    unresolved
  };
}

// src/core/prism/engine.ts
function severityOf(prism, nodeId2) {
  return prism.severities.find((s2) => s2.node_id === nodeId2)?.severity ?? "noncritical";
}
function assignSeverity(prism, nodeId2, severity2, reason) {
  if (!prism.tree.nodes.some((n3) => n3.id === nodeId2)) {
    return { ok: false, reasons: [`unknown prism node id: ${nodeId2}`] };
  }
  const current = severityOf(prism, nodeId2);
  const isDemotion = current === "critical" && severity2 === "noncritical";
  if (isDemotion && (reason === undefined || reason.trim().length === 0)) {
    return {
      ok: false,
      reasons: [
        `critical\u2192noncritical demotion of ${nodeId2} requires an explicit reason (MODEL-2 \u2014 a severity demotion is decision-grade, never silent)`
      ]
    };
  }
  const others = prism.severities.filter((s2) => s2.node_id !== nodeId2);
  const assignment = {
    node_id: nodeId2,
    severity: severity2,
    ...isDemotion ? { demotion_reason: reason } : {}
  };
  return { ok: true, prism: { ...prism, severities: [...others, assignment] }, reasons: [] };
}
function evaluationOf(prism, nodeId2) {
  return (prism.evaluations ?? []).find((e2) => e2.node_id === nodeId2);
}
function upsertEvaluation(prism, nodeId2, patch) {
  const existing = prism.evaluations ?? [];
  const current = existing.find((e2) => e2.node_id === nodeId2);
  const others = existing.filter((e2) => e2.node_id !== nodeId2);
  const merged = { ...current ?? {}, ...patch, node_id: nodeId2 };
  return { ...prism, evaluations: [...others, merged] };
}
function evidenceAddedForNode(prism, nodeId2) {
  const node2 = prism.tree.nodes.find((n3) => n3.id === nodeId2);
  if (node2 !== undefined && node2.children.length > 0)
    return true;
  const evalRec = evaluationOf(prism, nodeId2);
  const critique = evalRec?.opponent_critique;
  const dissent = evalRec?.opponent_dissent;
  return critique !== undefined && critique.trim().length > 0 || dissent !== undefined && dissent.trim().length > 0;
}
function isUnknownCloseState(state) {
  return state === "out_of_scope" || state === "user_owned";
}
function closePrismNode(prism, nodeId2, state, reason, residualRisk) {
  const gate2 = coverageClosureGate(prism.tree, nodeId2, state);
  if (!gate2.pass)
    return { ok: false, reasons: gate2.reasons };
  const isCritical = severityOf(prism, nodeId2) === "critical";
  const noResidual = residualRisk === undefined || residualRisk.trim().length === 0;
  if (isCritical && isUnknownCloseState(state) && noResidual) {
    return {
      ok: false,
      reasons: [
        `unknown-close (${state}) of critical node ${nodeId2} requires a recorded residual_risk \u2014 a no-residual "\uBAA8\uB984-\uB2EB\uAE30" of critical scope is rejected and never counts as critical resolution (MODEL-1)`
      ]
    };
  }
  if (isCritical && state === "resolved") {
    const evalRec = evaluationOf(prism, nodeId2);
    const missing = [];
    const hasReason = evalRec?.justifying_reason !== undefined && evalRec.justifying_reason.trim().length > 0;
    if (!hasReason)
      missing.push("a non-empty justifying_reason");
    if (evalRec?.refutation_attempted !== true) {
      missing.push("an attempted refutation (refutation_attempted)");
    }
    if (!evidenceAddedForNode(prism, nodeId2)) {
      missing.push("added grounding this round \u2014 a child decomposition or a recorded opponent artifact, not a self-authored reason alone (OBJ-1)");
    }
    if (missing.length > 0) {
      return {
        ok: false,
        prism: upsertEvaluation(prism, nodeId2, { evaluation: "unevaluated" }),
        reasons: [
          `resolved-close of critical node ${nodeId2} requires ${missing.join(", ")} \u2014 the close is rejected and the node is stamped prism-level unevaluated (A2, ac-1; homomorphic with the MODEL-1 residual gate)`
        ]
      };
    }
  }
  const tree = closeNode(prism.tree, nodeId2, state, reason, residualRisk);
  const closed = { ...prism, tree };
  const next = isCritical && state === "resolved" ? upsertEvaluation(closed, nodeId2, { evaluation: "justified" }) : closed;
  return { ok: true, prism: next, reasons: [] };
}
function isCriticalResolved(node2, evaluation) {
  if (evaluation === "unevaluated")
    return false;
  if (node2.state === "open")
    return false;
  if (node2.state === "resolved")
    return true;
  return node2.residual_risk !== undefined && node2.residual_risk.trim().length > 0;
}
function criticalTermination(prism) {
  if (prism.tree.nodes.length === 0) {
    return {
      terminated: false,
      reason: "empty map \u2014 no scope explored yet (B1 vacuous-truth guard)"
    };
  }
  const criticalIds = new Set(prism.severities.filter((s2) => s2.severity === "critical").map((s2) => s2.node_id));
  const criticalNodes = prism.tree.nodes.filter((n3) => criticalIds.has(n3.id));
  if (criticalNodes.length === 0) {
    return {
      terminated: false,
      reason: "no critical nodes \u2014 termination/notification does NOT fire on a 0-critical map (B1 vacuous-truth guard)"
    };
  }
  const unresolved = criticalNodes.filter((n3) => !isCriticalResolved(n3, evaluationOf(prism, n3.id)?.evaluation));
  if (unresolved.length > 0) {
    return {
      terminated: false,
      reason: `${unresolved.length} critical node(s) still unresolved`
    };
  }
  return {
    terminated: true,
    reason: "every critical node resolved (non-critical scope may survive \u2014 the user decides)"
  };
}
function completenessSeedId(fragmentId) {
  return `prism_seed_${fragmentId}`;
}
var COMPLETENESS_SEED_DEPTH_WEIGHT = 0.5;
function seedUncoveredFragments(prism, fragments, mappings) {
  const nodeIds = new Set(prism.tree.nodes.map((n3) => n3.id));
  const covered = new Set(mappings.filter((m4) => nodeIds.has(m4.node_id)).map((m4) => m4.fragment_id));
  const rootExists = nodeIds.has(prism.tree.root_id);
  let tree = prism.tree;
  const seededFragmentIds = [];
  for (const frag of fragments) {
    if (covered.has(frag.id))
      continue;
    const seedId = completenessSeedId(frag.id);
    if (nodeIds.has(seedId))
      continue;
    tree = addNode(tree, {
      id: seedId,
      parent_id: rootExists ? prism.tree.root_id : null,
      label: frag.text,
      origin: "discovered",
      depth_weight: COMPLETENESS_SEED_DEPTH_WEIGHT,
      state: "open",
      children: []
    });
    nodeIds.add(seedId);
    seededFragmentIds.push(frag.id);
  }
  return {
    prism: { ...prism, tree },
    seededFragmentIds,
    reason: seededFragmentIds.length === 0 ? "every original-intent fragment is addressed by \u22651 node \u2014 no completeness gap" : `seeded ${seededFragmentIds.length} uncovered original-intent fragment(s) as noncritical surface node(s) \u2014 gap surfaced, termination not hard-blocked (ac-2)`
  };
}
function buildIntentFragments(intent) {
  const fragments = [];
  const goal = intent.goal?.trim();
  if (goal)
    fragments.push({ id: "goal", text: goal });
  (intent.in_scope ?? []).forEach((raw, i3) => {
    const text = raw.trim();
    if (text)
      fragments.push({ id: `in_scope[${i3}]`, text });
  });
  return fragments;
}
function fragmentKeywords(text) {
  return text.split(/[\s,.;:!?\u00B7\u2014\u2026()[\]{}"'`/\\]+/).map((t3) => t3.trim()).filter((t3) => t3.length >= 2);
}
function deriveFragmentMappings(fragments, prism) {
  const nodeTokens = prism.tree.nodes.map((n3) => ({
    id: n3.id,
    tokens: new Set(fragmentKeywords(`${n3.label} ${n3.close_reason ?? ""}`))
  }));
  const mappings = [];
  for (const frag of fragments) {
    const keywords = fragmentKeywords(frag.text);
    if (keywords.length === 0)
      continue;
    for (const node2 of nodeTokens) {
      if (keywords.some((kw) => node2.tokens.has(kw))) {
        mappings.push({ fragment_id: frag.id, node_id: node2.id });
      }
    }
  }
  return mappings;
}
var MINIMAL_LAUNCH_MESSAGE = "\uD575\uC2EC\uC73C\uB85C \uAF2D \uC815\uD574\uC57C \uD560 \uAC83\uC740 \uBAA8\uB450 \uC815\uB9AC\uB410\uC5B4\uC694. \uC9C0\uAE08 \uCD5C\uC18C\uD55C\uC73C\uB85C \uCC29\uC218\uD560 \uC218 \uC788\uC5B4\uC694. (\uB0A8\uC740 \uD56D\uBAA9\uC740 \uCC29\uC218\uD558\uBA74\uC11C \uC815\uD574\uB3C4 \uB429\uB2C8\uB2E4.)";
var REANCHOR_PROMPT = '\uCC29\uC218 \uC804\uC5D0 \uC6D0\uB798 \uC758\uB3C4\uB97C \uB2E4\uC2DC \uBD05\uB2C8\uB2E4 \u2014 \uC544\uB798 \uC6D0\uBB38\uC744 \uC2E4\uC81C\uB85C "\uB2EC\uC131"\uD588\uB294\uC9C0, \uC544\uB2C8\uBA74 "\uD2B9\uC9D5\uB9CC \uC11C\uC220"\uD558\uACE0 \uB118\uC5B4\uAC14\uB294\uC9C0 \uD655\uC778\uD558\uC138\uC694.';
function buildReAnchor(originalIntent2) {
  return `${REANCHOR_PROMPT}

${originalIntent2.trim()}`;
}
function resolveLaunchNotification(prism, now, originalIntent2) {
  const { terminated } = criticalTermination(prism);
  const alreadyNotified = prism.notified_at !== undefined;
  if (terminated) {
    if (alreadyNotified)
      return { prism, notify: false, retracted: false };
    const hasIntent = originalIntent2 !== undefined && originalIntent2.trim().length > 0;
    return {
      prism: { ...prism, notified_at: now.toISOString() },
      notify: true,
      retracted: false,
      message: MINIMAL_LAUNCH_MESSAGE,
      ...hasIntent ? { reAnchor: buildReAnchor(originalIntent2) } : {}
    };
  }
  if (alreadyNotified) {
    const { notified_at: _dropped, ...rest } = prism;
    return { prism: rest, notify: false, retracted: true };
  }
  return { prism, notify: false, retracted: false };
}
function renderProgressSummary(prism) {
  return prism.tree.nodes.filter((n3) => n3.state === "open" && n3.id !== prism.tree.root_id).map((n3) => n3.label);
}
function normalizeSignature(signature2) {
  return signature2.trim().toLowerCase().replace(/\s+/g, " ");
}
var TRIVIAL_STREAK_CAP = 3;
function detectDivergence(round, history) {
  if (round.challenge) {
    if (round.challenge.new_evidence) {
      return {
        diverged: false,
        action: "challenge-node",
        reason: `challenge to decided ${round.challenge.decided_id} carries NEW evidence \u2014 admit as a visible challenge node (once)`
      };
    }
    return {
      diverged: true,
      kind: "decided_conflict_no_evidence",
      action: "cap-stop",
      reason: `re-challenge to decided ${round.challenge.decided_id} with no new evidence \u2014 flagged divergence (visibly suppressed, not silent)`
    };
  }
  if (round.question) {
    const key = normalizeSignature(round.question.signature);
    if (history.some((h3) => normalizeSignature(h3.signature) === key)) {
      return {
        diverged: true,
        kind: "repeat_question",
        action: "cap-stop",
        reason: "near-duplicate of an earlier question \u2014 repeated with no new signal (\uCCC7\uBC14\uD034)"
      };
    }
    if (round.question.trivial) {
      let streak = 1;
      for (let i3 = history.length - 1;i3 >= 0; i3--) {
        if (history[i3]?.trivial)
          streak += 1;
        else
          break;
      }
      if (streak >= TRIVIAL_STREAK_CAP) {
        return {
          diverged: true,
          kind: "trivial_streak",
          action: "cap-stop",
          reason: `${streak} consecutive trivial questions \u2014 flagged divergence`
        };
      }
    }
  }
  return { diverged: false, action: "continue", reason: "no divergence signal" };
}
var PRISM_CAPS = {
  callsPerNode: 8,
  treeNodeCount: 60,
  totalRounds: 40
};
function runPrismRounds(rounds, caps = PRISM_CAPS, start = {}) {
  let usage = {
    callsThisNode: start.callsThisNode ?? 0,
    treeNodeCount: start.treeNodeCount ?? 0,
    roundsRun: start.roundsRun ?? 0
  };
  const history = [];
  const divergences = [];
  for (const round of rounds) {
    const cap = capStatus(caps, usage);
    if (cap.capped) {
      return {
        roundsRun: usage.roundsRun,
        treeNodeCount: usage.treeNodeCount,
        halted: true,
        escalation: cap.reasons,
        divergences
      };
    }
    if (round.question || round.challenge) {
      divergences.push(detectDivergence(round, history));
      if (round.question)
        history.push(round.question);
    }
    usage = {
      ...usage,
      treeNodeCount: usage.treeNodeCount + (round.addedNodeCount ?? 0),
      roundsRun: usage.roundsRun + 1
    };
  }
  return {
    roundsRun: usage.roundsRun,
    treeNodeCount: usage.treeNodeCount,
    halted: false,
    escalation: [],
    divergences
  };
}

// src/core/opponent-router.ts
var TOKEN_MAP = {
  codex: { provider: "codex", model: "codex" },
  "claude-opus": { provider: "claude-code", model: "claude-opus" },
  "claude-sonnet": { provider: "claude-code", model: "claude-sonnet" }
};
function mapToken(token, currentHost) {
  return TOKEN_MAP[token] ?? { provider: currentHost, model: token };
}
function resolveOpponentCandidates(policy, options) {
  const { currentHost } = options;
  const tokens2 = [policy.opponent_preferred, ...policy.opponent_fallback];
  const seen = new Set;
  const out = [];
  for (const token of tokens2) {
    if (seen.has(token))
      continue;
    seen.add(token);
    out.push({ token, ...mapToken(token, currentHost) });
  }
  if (currentHost === "codex")
    return out.filter((candidate) => candidate.provider === "codex");
  return out;
}

class NoOpponentAvailableError extends Error {
  constructor(message) {
    super(message);
    this.name = "NoOpponentAvailableError";
  }
}
function selectOpponent(candidates, isAvailable) {
  if (candidates.length === 0) {
    throw new NoOpponentAvailableError("no opponent candidates resolved from model_policy");
  }
  const preferred = candidates[0];
  let preferredReason = "none";
  for (let i3 = 0;i3 < candidates.length; i3++) {
    const candidate = candidates[i3];
    const availability = isAvailable(candidate);
    if (availability.available) {
      if (i3 === 0) {
        return {
          provider: candidate.provider,
          model: candidate.model,
          fallback_from: null,
          fallback_reason: "none"
        };
      }
      const sameProvider = candidate.provider === preferred.provider;
      return {
        provider: candidate.provider,
        model: candidate.model,
        fallback_from: sameProvider ? null : preferred.provider,
        fallback_reason: sameProvider ? "none" : preferredReason
      };
    }
    if (i3 === 0)
      preferredReason = availability.reason ?? "runtime";
  }
  throw new NoOpponentAvailableError(`no available opponent among ${candidates.length} candidate(s): ${candidates.map((c5) => c5.token).join(", ")}`);
}

// src/core/prism/opponent.ts
var OPPONENT_FANOUT_CAP = 3;
function resolveOpponentSelection(config) {
  const candidates = resolveOpponentCandidates(config.policy, { currentHost: config.currentHost });
  try {
    return selectOpponent(candidates, config.isAvailable);
  } catch (error) {
    if (error instanceof NoOpponentAvailableError)
      return null;
    throw error;
  }
}
function flaggedCriticalNodeIds(prism) {
  return prism.evaluations.filter((e2) => e2.evaluation === "unevaluated").map((e2) => e2.node_id).filter((id) => severityOf(prism, id) === "critical");
}
function labelOf(prism, nodeId2) {
  return prism.tree.nodes.find((n3) => n3.id === nodeId2)?.label ?? nodeId2;
}
function upsertEvaluation2(prism, nodeId2, patch) {
  const exists = prism.evaluations.some((e2) => e2.node_id === nodeId2);
  const evaluations = exists ? prism.evaluations.map((e2) => e2.node_id === nodeId2 ? { ...e2, ...patch } : e2) : [...prism.evaluations, { node_id: nodeId2, ...patch }];
  return { ...prism, evaluations };
}
function recordOpponentCritique(prism, nodeId2, outcome) {
  const patch = outcome.status === "engaged" ? { opponent_critique: outcome.text, opponent_status: "engaged" } : { opponent_status: "host_absent" };
  return upsertEvaluation2(prism, nodeId2, patch);
}
function recordOpponentDissent(prism, nodeId2, outcome) {
  const patch = outcome.status === "engaged" ? { opponent_dissent: outcome.text, opponent_status: "engaged" } : { opponent_status: "host_absent" };
  return upsertEvaluation2(prism, nodeId2, patch);
}
async function engageDialecticCritique(prism, config) {
  const flagged = flaggedCriticalNodeIds(prism);
  const selection = resolveOpponentSelection(config);
  if (selection === null) {
    let next2 = prism;
    for (const nodeId2 of flagged) {
      next2 = recordOpponentCritique(next2, nodeId2, { status: "host_absent" });
    }
    return {
      prism: next2,
      host_available: false,
      selection: null,
      engaged: [],
      degraded: [...flagged],
      skipped_by_cap: 0
    };
  }
  const cap = config.cap ?? OPPONENT_FANOUT_CAP;
  let next = prism;
  const engaged = [];
  const degraded = [];
  let invoked = 0;
  let skippedByCap = 0;
  for (const nodeId2 of flagged) {
    if (invoked >= cap) {
      skippedByCap += 1;
      continue;
    }
    invoked += 1;
    const text = await config.delegate({
      concern: "critique",
      node_id: nodeId2,
      label: labelOf(next, nodeId2),
      intent: config.intent,
      selection
    });
    if (text && text.trim().length > 0) {
      next = recordOpponentCritique(next, nodeId2, { status: "engaged", text });
      engaged.push(nodeId2);
    } else {
      next = recordOpponentCritique(next, nodeId2, { status: "host_absent" });
      degraded.push(nodeId2);
    }
  }
  return {
    prism: next,
    host_available: true,
    selection,
    engaged,
    degraded,
    skipped_by_cap: skippedByCap
  };
}
async function engageIndependentDissent(prism, config) {
  const anchor = config.anchorNodeId ?? prism.tree.root_id;
  const selection = resolveOpponentSelection(config);
  if (selection === null) {
    const next2 = recordOpponentDissent(prism, anchor, { status: "host_absent" });
    return {
      prism: next2,
      host_available: false,
      selection: null,
      engaged: [],
      degraded: [anchor],
      skipped_by_cap: 0
    };
  }
  const text = await config.delegate({
    concern: "dissent",
    node_id: anchor,
    label: labelOf(prism, anchor),
    intent: config.intent,
    selection
  });
  if (text && text.trim().length > 0) {
    const next2 = recordOpponentDissent(prism, anchor, { status: "engaged", text });
    return {
      prism: next2,
      host_available: true,
      selection,
      engaged: [anchor],
      degraded: [],
      skipped_by_cap: 0
    };
  }
  const next = recordOpponentDissent(prism, anchor, { status: "host_absent" });
  return {
    prism: next,
    host_available: true,
    selection,
    engaged: [],
    degraded: [anchor],
    skipped_by_cap: 0
  };
}

// src/core/prism/loop.ts
async function runDivergenceRound(store, input) {
  const verdict2 = detectDivergence(input.round, input.history);
  const recordedAt = (input.now ?? new Date).toISOString();
  if (verdict2.action === "challenge-node") {
    const decision = await store.appendDecision({
      schema_version: "0.1.0",
      work_item_id: input.workItemId,
      kind: "challenge_admit",
      ...input.round.challenge ? { node_id: input.round.challenge.decided_id } : {},
      reason: verdict2.reason,
      recorded_at: recordedAt
    });
    return { verdict: verdict2, decision };
  }
  if (verdict2.diverged) {
    const decision = await store.appendDecision({
      schema_version: "0.1.0",
      work_item_id: input.workItemId,
      kind: "early_exit",
      reason: verdict2.reason,
      recorded_at: recordedAt
    });
    return { verdict: verdict2, decision };
  }
  return { verdict: verdict2 };
}
async function runOpponentCritiqueRound(store, workItemId2, config) {
  const prism = await store.getMap(workItemId2);
  const outcome = await engageDialecticCritique(prism, config);
  await store.writeMap(outcome.prism);
  return outcome;
}
async function runOpponentDissentRound(store, workItemId2, config) {
  const prism = await store.getMap(workItemId2);
  const outcome = await engageIndependentDissent(prism, config);
  await store.writeMap(outcome.prism);
  return outcome;
}

// src/cli/commands/prism.ts
init_work_item_store();
function prismNodeId() {
  return `prism_${randomBytes4(6).toString("hex")}`;
}
function asArray3(value) {
  if (value === undefined)
    return [];
  return Array.isArray(value) ? value : [value];
}
function upsertPrismEvaluation(prism, nodeId2, patch) {
  const existing = prism.evaluations ?? [];
  const current = existing.find((e2) => e2.node_id === nodeId2);
  const others = existing.filter((e2) => e2.node_id !== nodeId2);
  const merged = { ...current ?? {}, ...patch, node_id: nodeId2 };
  return { ...prism, evaluations: [...others, merged] };
}
async function readOriginalIntent(repoRoot, workItemId2) {
  const intents = new IntentStore(repoRoot);
  if (!await intents.exists(workItemId2))
    return;
  return (await intents.get(workItemId2)).source_request;
}
async function readIntentFragments(repoRoot, workItemId2) {
  const intents = new IntentStore(repoRoot);
  if (!await intents.exists(workItemId2))
    return [];
  return buildIntentFragments(await intents.get(workItemId2));
}
var BARE_MODEL_POLICY = {
  producer: "current-host",
  opponent_preferred: "codex",
  opponent_fallback: [],
  synthesizer: "claude-opus"
};
async function loadOrInit(store, workItemId2) {
  if (await store.exists(workItemId2))
    return store.getMap(workItemId2);
  const rootId = prismNodeId();
  return {
    schema_version: "0.1.0",
    work_item_id: workItemId2,
    tree: {
      schema_version: "0.1.0",
      work_item_id: workItemId2,
      root_id: rootId,
      nodes: [
        {
          id: rootId,
          parent_id: null,
          label: "original intent",
          origin: "seed",
          depth_weight: 1,
          state: "open",
          children: []
        }
      ]
    },
    severities: [],
    evaluations: []
  };
}
var prismSeedCommand = defineCommand({
  meta: { name: "seed", description: "Add one issue-map node (interview round; cap-enforced)" },
  args: {
    wi: { type: "string", description: "Work item id (wi_*)" },
    label: { type: "string", description: "Plain-language label of the issue" },
    critical: { type: "boolean", description: "Mark the node critical (MODEL-2)", default: false },
    "max-nodes": { type: "string", description: "Tree-node cap override (default 60)" },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    if (!args.wi || !args.label) {
      writeError("prism seed requires --wi <wi_*> and --label <text>");
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await resolveRepoRootForCreate();
    const store = new PrismStore(repoRoot);
    try {
      const prism = await loadOrInit(store, args.wi);
      const roundsRun = (await store.readValueRounds(args.wi)).length;
      const caps = {
        ...PRISM_CAPS,
        ...args["max-nodes"] ? { treeNodeCount: Number(args["max-nodes"]) } : {}
      };
      const drive = runPrismRounds([{ addedNodeCount: 1 }], caps, {
        treeNodeCount: prism.tree.nodes.length,
        roundsRun
      });
      if (drive.halted) {
        if (format === "json") {
          writeJson2({ work_item_id: args.wi, halted: true, escalation: drive.escalation });
        } else {
          writeError("prism seed HALTED \u2014 cap reached (escalate, not success):");
          for (const r4 of drive.escalation)
            writeError(`  - ${r4}`);
        }
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      const nodeId2 = prismNodeId();
      const child = {
        id: nodeId2,
        parent_id: prism.tree.root_id,
        label: args.label,
        origin: "derived",
        depth_weight: 0.5,
        state: "open",
        children: []
      };
      let next = { ...prism, tree: addNode(prism.tree, child) };
      if (args.critical) {
        const gate2 = assignSeverity(next, nodeId2, "critical");
        if (!gate2.ok) {
          writeError(gate2.reasons.join("; "));
          process.exit(RUNTIME_ERROR_EXIT);
          return;
        }
        next = gate2.prism;
      }
      await store.writeMap(next);
      await store.appendValueRound(args.wi, {
        ts: new Date().toISOString(),
        work_item_id: args.wi,
        round: roundsRun + 1,
        section: "prism-issue-map",
        generator_count: 1,
        dry: true,
        selected: [],
        all_scored: [],
        novelty: true
      });
      if (format === "json") {
        writeJson2({
          work_item_id: args.wi,
          node_id: nodeId2,
          severity: severityOf(next, nodeId2),
          node_count: next.tree.nodes.length
        });
      } else {
        writeHuman(`seeded: ${args.label} [${severityOf(next, nodeId2)}] (${nodeId2})`);
      }
    } catch (err) {
      writeError(`prism seed failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var prismDivergeCommand = defineCommand({
  meta: {
    name: "diverge",
    description: "Evaluate one interview round for divergence and emit the verdict (ac-10)"
  },
  args: {
    wi: { type: "string", description: "Work item id (wi_*)" },
    question: { type: "string", description: "The current question signature (question round)" },
    trivial: { type: "boolean", description: "Mark the current question trivial", default: false },
    seen: {
      type: "string",
      description: "A prior question signature (repeatable) \u2014 non-trivial history"
    },
    "seen-trivial": {
      type: "string",
      description: "A prior TRIVIAL question signature (repeatable) \u2014 appended to the history tail; the trivial_streak shape counts consecutive trivial entries at the tail, so these make it CLI-reachable (wi_2607075vc)"
    },
    "challenge-of": {
      type: "string",
      description: "Decided node id being re-challenged (challenge round)"
    },
    signature: { type: "string", description: "The re-challenge signature (with --challenge-of)" },
    "new-evidence": {
      type: "boolean",
      description: "The re-challenge carries NEW grounding evidence (admissible once)",
      default: false
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    if (!args.wi) {
      writeError("prism diverge requires --wi <wi_*>");
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const hasQuestion = Boolean(args.question);
    const hasChallenge = Boolean(args["challenge-of"]);
    if (hasQuestion === hasChallenge) {
      writeError("prism diverge requires exactly one of --question <sig> or --challenge-of <node>");
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    if (hasChallenge && !args.signature) {
      writeError("prism diverge --challenge-of also requires --signature <text>");
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const round = hasChallenge ? {
      challenge: {
        decided_id: args["challenge-of"],
        signature: args.signature,
        new_evidence: args["new-evidence"]
      }
    } : { question: { signature: args.question, trivial: args.trivial } };
    const history = [
      ...asArray3(args.seen).map((signature2) => ({ signature: signature2, trivial: false })),
      ...asArray3(args["seen-trivial"]).map((signature2) => ({ signature: signature2, trivial: true }))
    ];
    const repoRoot = await resolveRepoRootForCreate();
    const store = new PrismStore(repoRoot);
    try {
      const { verdict: verdict2, decision } = await runDivergenceRound(store, {
        workItemId: args.wi,
        round,
        history
      });
      const roundsRun = (await store.readValueRounds(args.wi)).length;
      await store.appendValueRound(args.wi, {
        ts: new Date().toISOString(),
        work_item_id: args.wi,
        round: roundsRun + 1,
        section: "prism-divergence",
        generator_count: 1,
        dry: true,
        selected: [],
        all_scored: [],
        novelty: deriveNovelty(verdict2)
      });
      if (format === "json") {
        writeJson2({ work_item_id: args.wi, verdict: verdict2, ...decision ? { decision } : {} });
      } else {
        writeHuman(`\uD310\uC815: ${verdict2.action} \u2014 ${verdict2.reason}`);
        if (decision)
          writeHuman(`\uAE30\uB85D\uB428(Record tier): ${decision.kind}`);
      }
      if (verdict2.diverged)
        process.exit(RUNTIME_ERROR_EXIT);
    } catch (err) {
      writeError(`prism diverge failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var prismCloseCommand = defineCommand({
  meta: { name: "close", description: "Close an issue-map node (MODEL-1 unknown-close gate)" },
  args: {
    wi: { type: "string", description: "Work item id (wi_*)" },
    node: { type: "string", description: "Node id to close" },
    state: { type: "string", description: "resolved | out_of_scope | user_owned" },
    reason: { type: "string", description: "Why closed (justification)" },
    residual: {
      type: "string",
      description: "Surviving risk (required for a critical unknown-close)"
    },
    "justifying-reason": {
      type: "string",
      description: "The reason justifying a critical resolved-close (A2 gate input, ac-1)"
    },
    "refutation-attempted": {
      type: "boolean",
      description: "A strongest-rebuttal (Popper refutation) was attempted before closing (A2 gate input, ac-1)",
      default: false
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const state = args.state;
    if (!args.wi || !args.node || !state) {
      writeError("prism close requires --wi, --node, and --state");
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    if (state !== "resolved" && state !== "out_of_scope" && state !== "user_owned") {
      writeError(`--state must be resolved | out_of_scope | user_owned (got: ${state})`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await resolveRepoRootForCreate();
    const store = new PrismStore(repoRoot);
    try {
      const prism = await store.getMap(args.wi);
      const evalPatch = {};
      if (args["justifying-reason"])
        evalPatch.justifying_reason = args["justifying-reason"];
      if (args["refutation-attempted"])
        evalPatch.refutation_attempted = true;
      const prismForClose = Object.keys(evalPatch).length > 0 ? upsertPrismEvaluation(prism, args.node, evalPatch) : prism;
      const result2 = closePrismNode(prismForClose, args.node, state, args.reason, args.residual);
      if (!result2.ok) {
        if (result2.prism)
          await store.writeMap(result2.prism);
        if (format === "json") {
          writeJson2({ work_item_id: args.wi, ok: false, reasons: result2.reasons });
        } else {
          writeError("prism close REJECTED:");
          for (const r4 of result2.reasons)
            writeError(`  - ${r4}`);
        }
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      const next = result2.prism;
      await store.writeMap(next);
      if (state !== "resolved") {
        await store.appendDecision({
          schema_version: "0.1.0",
          work_item_id: args.wi,
          kind: state === "user_owned" ? "unknown_close" : "skip",
          node_id: args.node,
          reason: args.reason ?? `closed as ${state}`,
          ...args.residual ? { residual_risk: args.residual } : {},
          recorded_at: new Date().toISOString()
        });
      }
      if (format === "json") {
        writeJson2({ work_item_id: args.wi, ok: true, node_id: args.node, state });
      } else {
        writeHuman(`closed: ${args.node} \u2192 ${state}`);
      }
    } catch (err) {
      writeError(`prism close failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
