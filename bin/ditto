    },
    confirm: {
      type: "boolean",
      description: "Add the admitted candidates (default off: propose-only, mutates nothing, ac-7)",
      default: false
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let candidates;
    try {
      candidates = parseDiscoveryCandidates(await readDiscoveryInput(args.file));
    } catch (err) {
      writeError(`coverage discover input invalid: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await resolveRepoRootForCreate();
    try {
      const effective = await loadEffectiveTaxonomy(repoRoot);
      const verdicts = admitDiscoveredCategories(candidates, effective);
      const admitted = verdicts.filter((v2) => v2.admitted).map((v2) => ({ id: v2.id, lens: v2.lens ?? "", evidence: v2.evidence ?? "" }));
      const dropped = verdicts.filter((v2) => !v2.admitted).map((v2) => ({ id: v2.id, reason: v2.reason, detail: v2.detail }));
      const added = [];
      if (args.confirm) {
        for (const a2 of admitted) {
          const id = bareFloorId2(a2.id);
          await applyTaxonomyMutation(repoRoot, { kind: "add", id, lens: a2.lens });
          added.push(id);
        }
      }
      if (format === "json") {
        writeJson2({ admitted, dropped, confirmed: Boolean(args.confirm), added });
        return;
      }
      writeHuman(`coverage discover: ${admitted.length} admitted, ${dropped.length} dropped${args.confirm ? ` (${added.length} added)` : " (propose-only \u2014 nothing written)"}`);
      for (const a2 of admitted) {
        writeHuman(`  [admit] ${a2.id}`);
        writeHuman(`    ${a2.lens}`);
        writeHuman(`    evidence: ${a2.evidence}`);
      }
      for (const d2 of dropped)
        writeHuman(`  [drop:${d2.reason}] ${d2.id} \u2014 ${d2.detail}`);
    } catch (err) {
      writeError(`coverage discover failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var coverageCommand = defineCommand({
  meta: {
    name: "coverage",
    description: "Coverage outcome loop + far-field taxonomy management: record escapes (feedback) / residual rows (residual), surface augmentation candidates (propose), suggest feedback templates (suggest); and manage the tier-\u2461 taxonomy \u2014 list, add, disable, reroute, discover (wi_260707phi)"
  },
  subCommands: {
    feedback: coverageFeedbackCommand,
    residual: coverageResidualCommand,
    propose: coverageProposeCommand,
    suggest: coverageSuggestCommand,
    list: coverageTaxonomyListCommand,
    add: coverageTaxonomyAddCommand,
    disable: coverageTaxonomyDisableCommand,
    reroute: coverageTaxonomyRerouteCommand,
    discover: coverageTaxonomyDiscoverCommand
  }
});

// src/cli/commands/decision-conflict.ts
init_zod();
var gateInput = exports_external.object({
  mode: exports_external.enum(["interactive", "autopilot"]).default("autopilot"),
  conflicts: exports_external.array(decisionConflict).default([])
});
var decisionConflictGateCmd = defineCommand({
  meta: {
    name: "gate",
    description: "Route detected ADR conflicts by (kind, level, mode); block intent conflicts, disclose all"
  },
  args: {
    json: {
      type: "string",
      description: 'JSON: {mode:"interactive"|"autopilot", conflicts:[{adr_id,kind:forbid|require|prefer,level:intent|method,basis}]}',
      required: true
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let raw;
    try {
      raw = JSON.parse(args.json);
    } catch (err) {
      writeError(`--json is not valid JSON: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const parsed = gateInput.safeParse(raw);
    if (!parsed.success) {
      writeError("--json failed schema validation:");
      for (const issue of parsed.error.issues) {
        writeError(`  - ${issue.path.join(".") || "(root)"}: ${issue.message}`);
      }
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const result2 = decisionConflictGate(parsed.data.conflicts, parsed.data.mode);
    const status = result2.blocked ? "BLOCKED" : result2.needsApproval ? "NEEDS APPROVAL" : result2.disclose ? "DISCLOSE" : "CLEAR";
    if (format === "json") {
      writeJson2(result2);
    } else {
      writeHuman(`decision-conflict gate: ${status}`);
      for (const d2 of result2.dispositions) {
        writeHuman(`  - ${d2.conflict.adr_id} (${d2.conflict.kind}/${d2.conflict.level}) \u2192 ${d2.route}: ${d2.conflict.basis}`);
      }
    }
    if (result2.blocked || result2.needsApproval)
      process.exit(RUNTIME_ERROR_EXIT);
  }
});
var decisionConflictCommand = defineCommand({
  meta: {
    name: "decision-conflict",
    description: "ADR decision-conflict guardrail (ADR-0020): route + disclose detected ADR conflicts"
  },
  subCommands: {
    gate: decisionConflictGateCmd
  }
});

