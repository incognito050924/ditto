// src/core/provision/memory-separate.ts
import { existsSync as existsSync9, readFileSync as readFileSync5, writeFileSync } from "fs";
import { join as pathJoin } from "path";
var GITIGNORE_ENTRY = ".ditto/memory/";
function join77(...parts) {
  return parts.join("/");
}
function ensureGitignored(deps) {
  const current = deps.readGitignore();
  const lines = current.split(`
`).map((l2) => l2.trim());
  if (lines.includes(GITIGNORE_ENTRY))
    return false;
  const sep8 = current === "" || current.endsWith(`
`) ? "" : `
`;
  deps.writeGitignore(`${current}${sep8}
# ditto memory: \uBCC4\uB3C4 \uC800\uC7A5\uC18C\uB85C \uBD84\uB9AC\uB428(\uC911\uBCF5 \uAD00\uB9AC \uBC29\uC9C0)
${GITIGNORE_ENTRY}
`);
  return true;
}
var submoduleManual = (memoryDir) => [
  "# submodule\uC740 \uC6D0\uACA9\uC774 \uC120\uD589\uB3FC\uC57C \uD55C\uB2E4. memory\uB97C \uC6D0\uACA9\uC5D0 \uC62C\uB9B0 \uB4A4:",
  `cd ${memoryDir} && git init && git add -A && git commit -m "memory" && git remote add origin <URL> && git push -u origin main`,
  "# \uADF8\uB2E4\uC74C \uBD80\uBAA8\uC5D0\uC11C: git rm -r --cached .ditto/memory && git submodule add <URL> .ditto/memory"
];
async function separateMemoryRepo(deps, mode = "gitignore") {
  const memoryDir = join77(deps.repoRoot, ".ditto", "memory");
  if (!deps.pathExists(memoryDir)) {
    return {
      status: "failed",
      message: `${memoryDir}\uC774(\uAC00) \uC5C6\uB2E4 \u2014 memory\uAC00 \uCD08\uAE30\uD654\uB418\uC9C0 \uC54A\uC558\uB2E4(ditto init \uBA3C\uC800).`
    };
  }
  if (mode === "submodule") {
    return {
      status: "manual",
      message: "submodule \uBD84\uB9AC\uB294 \uC6D0\uACA9\uC774 \uC120\uD589\uB3FC\uC57C \uD574 \uC790\uB3D9\uD654\uD558\uC9C0 \uC54A\uB294\uB2E4 \u2014 \uC544\uB798 \uC808\uCC28\uB97C \uB530\uB974\uB77C.",
      manual: submoduleManual(memoryDir)
    };
  }
  const alreadyRepo = deps.pathExists(join77(memoryDir, ".git"));
  if (!alreadyRepo) {
    const r3 = await deps.run("git", ["init"], memoryDir);
    if (r3.exit_code !== 0) {
      return {
        status: "failed",
        message: `git init \uC2E4\uD328 (exit=${r3.exit_code ?? "null"})${r3.stderr ? `: ${r3.stderr.trim()}` : ""}`,
        manual: [
          `cd ${memoryDir} && git init`,
          `echo '${GITIGNORE_ENTRY}' >> ${deps.repoRoot}/.gitignore`
        ]
      };
    }
  }
  const added = ensureGitignored(deps);
  if (alreadyRepo && !added) {
    return { status: "already", message: `${memoryDir}\uC740(\uB294) \uC774\uBBF8 \uBD84\uB9AC\uB3FC \uC788\uACE0 gitignore\uB428` };
  }
  return {
    status: "separated",
    message: `memory\uB97C \uBCC4\uB3C4 \uC800\uC7A5\uC18C\uB85C \uBD84\uB9AC: ${memoryDir} (git init) + \uBD80\uBAA8 .gitignore\uC5D0 ${GITIGNORE_ENTRY} \uCD94\uAC00`
  };
}
function defaultMemorySeparateDeps(repoRoot) {
  const gitignorePath = pathJoin(repoRoot, ".gitignore");
  return {
    repoRoot,
    run: async (cmd, args, cwd) => {
      const proc = Bun.spawn([cmd, ...args], {
        cwd,
        stdout: "ignore",
        stderr: "pipe",
        stdin: "ignore"
      });
      const [exit_code, stderr2] = await Promise.all([
        proc.exited,
        new Response(proc.stderr).text().catch(() => "")
      ]);
      return { exit_code, stderr: stderr2 };
    },
    pathExists: (p) => existsSync9(p),
    readGitignore: () => existsSync9(gitignorePath) ? readFileSync5(gitignorePath, "utf8") : "",
    writeGitignore: (content) => writeFileSync(gitignorePath, content, "utf8")
  };
}

// src/core/provision/playwright.ts
import { existsSync as existsSync10, readdirSync as readdirSync2 } from "fs";
import { homedir as homedir9, platform as osPlatform } from "os";
import { join as join78 } from "path";
function playwrightCacheRoot(os = osPlatform()) {
  if (os === "win32")
    return join78(homedir9(), "AppData", "Local", "ms-playwright");
  if (os === "darwin")
    return join78(homedir9(), "Library", "Caches", "ms-playwright");
  return join78(homedir9(), ".cache", "ms-playwright");
}
function bunCacheDir() {
  return join78(process.env.BUN_INSTALL ?? join78(homedir9(), ".bun"), "install", "cache");
}
function detectPlaywright(deps) {
  const core = deps.listDir(deps.bunCache).some((e2) => /^playwright-core@\d+\.\d+\.\d+$/.test(e2));
  const chromium = deps.listDir(deps.cacheRoot).some((e2) => /^chromium-\d+$/.test(e2));
  return { core, chromium, available: core && chromium };
}
function manualInstructions2(cacheRoot) {
  return [`bunx playwright install chromium   # Chromium\uC744 ${cacheRoot}\uC5D0 \uBC1B\uB294\uB2E4 (\uC804\uC81C: bun)`];
}
async function installPlaywright(deps) {
  if (detectPlaywright(deps).available) {
    return {
      status: "already-present",
      binary: deps.cacheRoot,
      message: "playwright already installed (playwright-core + cached chromium)"
    };
  }
  const r3 = await deps.run("bun", ["x", "playwright", "install", "chromium"]);
  if (r3.exit_code !== 0) {
    return {
      status: "failed",
      message: `playwright \uC124\uCE58 \uC2E4\uD328 (bun exit=${r3.exit_code ?? "null"})${r3.stderr ? `: ${r3.stderr.trim()}` : ""}`,
      manual: manualInstructions2(deps.cacheRoot)
    };
  }
  if (!detectPlaywright(deps).available) {
    return {
      status: "failed",
      message: "\uC124\uCE58 \uBA85\uB839\uC740 \uB05D\uB0AC\uC73C\uB098 \uCE90\uC2DC probe\uAC00 \uC5EC\uC804\uD788 \uC74C\uC131\uC774\uB2E4",
      manual: manualInstructions2(deps.cacheRoot)
    };
  }
  return {
    status: "installed",
    binary: deps.cacheRoot,
    message: `Chromium \uC124\uCE58 \uC644\uB8CC \u2192 ${deps.cacheRoot}`
  };
}
var defaultPlaywrightDeps = {
  cacheRoot: playwrightCacheRoot(),
  bunCache: bunCacheDir(),
  listDir: (dir) => {
    try {
      return existsSync10(dir) ? readdirSync2(dir) : [];
    } catch {
      return [];
    }
  },
  run: async (binary, args) => {
    const proc = Bun.spawn([binary, ...args], {
      stdout: "ignore",
      stderr: "pipe",
      stdin: "ignore"
    });
    const [exit_code, stderr2] = await Promise.all([
      proc.exited,
      new Response(proc.stderr).text().catch(() => "")
    ]);
    return { exit_code, stderr: stderr2 };
  }
};
function playwrightProvisioner(deps = defaultPlaywrightDeps) {
  return {
    id: "playwright",
    label: "Playwright/Chromium",
    resolveExisting: async () => detectPlaywright(deps).available ? deps.cacheRoot : null,
    install: () => installPlaywright(deps),
    manual: () => manualInstructions2(deps.cacheRoot),
    prereqs: () => []
  };
}

// src/core/provision/provisioner.ts
function codeqlProvisioner(deps = defaultInstallDeps) {
  return {
    id: "codeql",
    label: "CodeQL CLI",
    resolveExisting: deps.resolveExisting,
    install: () => installCodeqlCli(deps),
    manual: () => manualInstructions(deps.platform()),
    prereqs: () => []
  };
}
function defaultRegistry() {
  return {
    tools: new Map([
      ["codeql", codeqlProvisioner()],
      ["playwright", playwrightProvisioner()]
    ]),
    lsp: lspProvisioners()
  };
}

// src/core/setup.ts
init_fs();
import { cp, readFile as readFile18, rm as rm3, writeFile as writeFile4 } from "fs/promises";
