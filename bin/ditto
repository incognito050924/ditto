// src/schemas/e2e-assertion-map.ts
init_zod();
init_common();
var assertionDslForm = exports_external.enum(["contains", "visible", "hidden", "present", "url-contains"]).describe("DSL \uD655\uC778 form: contains | visible | hidden | present | url-contains");
var assertionStrength = exports_external.enum(["exact", "weaker", "stronger", "unmapped"]).describe("Relation of emitted matcher to DSL assertion");
var assertionMapEntry = exports_external.object({
  journey_id: journeyDslId,
  step_id: exports_external.string().min(1).describe("DSL step id (sN) this confirm assertion belongs to"),
  dsl_assertion: exports_external.string().min(1).describe("The DSL \uD655\uC778 clause (REDACTED \u2014 secret values masked to <env:VAR>)"),
  dsl_form: assertionDslForm,
  emitted_assertion: exports_external.string().describe("The emitted expect(...) statement (REDACTED); empty when unmapped"),
  emitted_matcher: exports_external.string().describe("The Playwright matcher name (e.g. toContainText); empty when unmapped"),
  strength: assertionStrength,
  flag: exports_external.boolean().describe("True whenever strength !== exact (needs human review)"),
  note: exports_external.string().min(1).optional().describe("Why the entry is flagged (weakened/strengthened/dropped rationale)")
}).strict().describe("One DSL confirm step mapped to its emitted assertion");
var assertionMap = exports_external.object({
  schema_version: schemaVersion,
  work_item_id: exports_external.string().min(1).describe("Work item the map was built for"),
  journey_id: journeyDslId,
  generated_spec: exports_external.string().min(1).describe("Repo-relative path of the generated spec analysed"),
  entries: exports_external.array(assertionMapEntry).describe("One entry per DSL \uD655\uC778 step (recognised form)"),
  weakened_count: exports_external.number().int().nonnegative().describe("Count of strength === weaker entries"),
  unmapped_count: exports_external.number().int().nonnegative().describe("Count of strength === unmapped entries (any > 0 \u2192 hard-fail gate)")
}).strict().describe("Assertion map (.ditto/local/work-items/<wi>/e2e-assertion-map.json)");

// src/core/e2e/secret-redaction.ts
var CRED_REF = /^(env|secret):(.+)$/;
function collectTargets(rule) {
  const targets = new Map;
  for (const varName of rule.secretVars) {
    targets.set(varName, `<env:${varName}>`);
  }
  for (const ref of rule.credentialRefs) {
    const match = CRED_REF.exec(ref);
    if (!match)
      continue;
    const [, scheme = "", varName = ""] = match;
    targets.set(varName, `<${scheme}:${varName}>`);
  }
  return targets;
}
function redactForPlan(text, rule) {
  const redactions = [];
  let out = text;
  for (const [varName, placeholder] of collectTargets(rule)) {
    const value = rule.envValues[varName];
    if (!value)
      continue;
    const location2 = out.indexOf(value);
    if (location2 === -1)
      continue;
    out = out.split(value).join(placeholder);
    redactions.push({ field: varName, ref: placeholder, location: location2 });
  }
  return { text: out, redactions };
}
function assertNoPlaintextSecret(text, rule) {
  for (const [varName, value] of Object.entries(rule.envValues)) {
    if (!value)
      continue;
    if (text.includes(value)) {
      throw new Error(`Plaintext secret detected: the value bound to ${varName} appears literally in the output (fail-closed; redact via redactForPlan before writing git-tracked artifacts).`);
    }
  }
}

// src/core/e2e/assertion-mapping.ts
var EMPTY_RULE = { secretVars: [], credentialRefs: [], envValues: {} };
var confirmLine = /^\s*\d+\.\s+\[([sb]\d+)\]\s*(?:\([^)]*\)\s*)?\uD655\uC778:\s*(.+?)\s*$/;
var markerLine = /^\s*\/\/\s*@step\s+(\S+\/[sb]\d+)\b/;
var UNCLASSIFIED_FORM = "present";
function detectForm(target) {
  const t3 = target.trim();
  if (/\burl[\s-]+contains\b/.test(t3))
    return "url-contains";
  if (/\bcontains\b/.test(t3))
    return "contains";
  if (/\bvisible\b/.test(t3))
    return "visible";
  if (/\bhidden\b/.test(t3))
    return "hidden";
  if (/\bpresent\b/.test(t3))
    return "present";
  return null;
}
function extractConfirmSteps(body) {
  const steps = [];
  for (const line of body.split(`
`)) {
    const m4 = confirmLine.exec(line);
    if (!m4)
      continue;
    const [, stepId = "", target = ""] = m4;
    steps.push({ stepId, form: detectForm(target), target: target.trim() });
  }
  return steps;
}
function matchBalanced(text, openIdx) {
  let depth = 0;
  for (let i3 = openIdx;i3 < text.length; i3++) {
    const c5 = text[i3];
    if (c5 === "(")
      depth++;
    else if (c5 === ")") {
      depth--;
      if (depth === 0)
        return i3;
    }
  }
  return -1;
}
function extractExpect(region2) {
  const kw = /(?:await\s+)?expect\s*\(/.exec(region2);
  if (!kw)
    return null;
  const expectIdx = region2.indexOf("expect", kw.index);
  const argOpen = region2.indexOf("(", expectIdx);
  const argClose = matchBalanced(region2, argOpen);
  if (argClose < 0)
    return null;
  const rest = region2.slice(argClose + 1);
  const chain = /^\s*(?:\.\s*not\s*)?\.\s*([A-Za-z][A-Za-z0-9]*)\s*\(/.exec(rest);
  if (!chain)
    return null;
  const matcher = chain[1] ?? "";
  const matcherOpen = chain[0].length - 1;
  const matcherClose = matchBalanced(rest, matcherOpen);
  if (matcherClose < 0)
    return null;
  const matcherArg = rest.slice(matcherOpen + 1, matcherClose).trim();
  const statement = region2.slice(expectIdx, argClose + 1 + matcherClose + 1).trim();
  return { statement, matcher, matcherArg };
}
function classify(form, matcher, matcherArg) {
  const isRegexArg = matcherArg.startsWith("/");
  switch (form) {
    case "contains":
      if (matcher === "toContainText")
        return { strength: "exact" };
      if (matcher === "toBeVisible")
        return {
          strength: "weaker",
          note: "DSL contains asserts text; emitted only checks visibility"
        };
      if (matcher === "toHaveText")
        return {
          strength: "stronger",
          note: "DSL contains (substring); emitted asserts exact text equality"
        };
      return {
        strength: "weaker",
        note: `emitted ${matcher} does not reproduce contains semantics`
      };
    case "visible":
      if (matcher === "toBeVisible")
        return { strength: "exact" };
      return { strength: "weaker", note: `DSL visible; emitted ${matcher} is weaker` };
    case "hidden":
      if (matcher === "toBeHidden")
        return { strength: "exact" };
      return { strength: "weaker", note: `DSL hidden; emitted ${matcher} is weaker` };
    case "present":
      if (matcher === "toBeAttached" || matcher === "toHaveCount")
        return { strength: "exact" };
      return { strength: "weaker", note: `DSL present; emitted ${matcher} is weaker` };
    case "url-contains":
      if (matcher === "toHaveURL") {
        if (isRegexArg)
          return { strength: "exact" };
        return {
          strength: "stronger",
          note: "DSL url contains (substring); emitted asserts an exact URL"
        };
      }
      return { strength: "weaker", note: `DSL url contains; emitted ${matcher} is weaker` };
  }
}
function regionFor(markers, lines, ref) {
  const mi = markers.findIndex((m4) => m4.ref === ref);
  const startMarker = mi < 0 ? undefined : markers[mi];
  if (!startMarker)
    return null;
  const startLine = startMarker.idx + 1;
  const nextMarker = markers[mi + 1];
  const endLine = nextMarker ? nextMarker.idx : lines.length;
  return lines.slice(startLine, endLine).join(`
`);
}
function buildAssertionMap(input) {
  const rule = input.rule ?? EMPTY_RULE;
  const redact = (text) => redactForPlan(text, rule).text;
  const lines = input.generatedSpec.split(`
`);
  const markers = [];
  lines.forEach((l2, i3) => {
    const m4 = markerLine.exec(l2);
    if (m4)
      markers.push({ idx: i3, ref: m4[1] ?? "" });
  });
  const entries = [];
  for (const step of extractConfirmSteps(input.journeyBody)) {
    const region2 = regionFor(markers, lines, `${input.journeyId}/${step.stepId}`);
    const emitted = region2 == null ? null : extractExpect(region2);
    let strength;
    let note;
    let emittedMatcher = "";
    let emittedAssertion = "";
    if (step.form == null) {
      strength = "unmapped";
      note = "unrecognised \uD655\uC778 form \u2014 no contains/visible/hidden/present/url-contains keyword";
    } else if (!emitted) {
      strength = "unmapped";
      note = region2 == null ? "no @step marker for this confirm step in the generated spec" : "no expect(...) assertion found in the step region";
    } else {
      const c5 = classify(step.form, emitted.matcher, emitted.matcherArg);
      strength = c5.strength;
      note = c5.note;
      emittedMatcher = emitted.matcher;
      emittedAssertion = redact(emitted.statement);
    }
    entries.push({
      journey_id: input.journeyId,
      step_id: step.stepId,
      dsl_assertion: redact(step.target),
      dsl_form: step.form ?? UNCLASSIFIED_FORM,
      emitted_assertion: emittedAssertion,
      emitted_matcher: emittedMatcher,
      strength,
      flag: strength !== "exact",
      ...note ? { note } : {}
    });
  }
  return assertionMap.parse({
    schema_version: "0.1.0",
    work_item_id: input.workItemId,
    journey_id: input.journeyId,
    generated_spec: input.generatedSpecPath,
    entries,
    weakened_count: entries.filter((e2) => e2.strength === "weaker").length,
    unmapped_count: entries.filter((e2) => e2.strength === "unmapped").length
  });
}
function cell(text) {
  const t3 = text.replace(/\r?\n/g, " ").replace(/\|/g, "\\|").trim();
  return t3 === "" ? "\u2014" : t3;
}
function renderAssertionMapDoc(map) {
  const strengthLabel = {
    exact: "exact",
    weaker: "weaker",
    stronger: "stronger",
    unmapped: "unmapped"
  };
  const out = [];
  out.push(`# Assertion map \u2014 ${map.journey_id}`);
  out.push("");
  out.push(`Generated spec: \`${map.generated_spec}\``);
  out.push(`Weakened: ${map.weakened_count} \xB7 Unmapped: ${map.unmapped_count} (unmapped > 0 \u2192 \uAC8C\uC774\uD2B8 \uD558\uB4DC \uC2E4\uD328)`);
  out.push("");
  out.push("| \uC5EC\uC815\xB7\uB2E8\uACC4 | DSL\uD655\uC778 | \uD615 | \uC2E4\uC81C assertion | matcher | \uAC15\uB3C4 | \u26A0\uAC80\uD1A0 |");
  out.push("| --- | --- | --- | --- | --- | --- | --- |");
  for (const e2 of map.entries) {
    out.push(`| ${cell(`${e2.journey_id}/${e2.step_id}`)} | ${cell(e2.dsl_assertion)} | ${cell(e2.dsl_form)} | ${cell(e2.emitted_assertion)} | ${cell(e2.emitted_matcher)} | ${cell(strengthLabel[e2.strength])} | ${e2.flag ? "\u26A0" : ""} |`);
  }
  out.push("");
  out.push("## \uAC80\uD1A0 \uD544\uC694");
  const flagged = map.entries.filter((e2) => e2.flag);
  if (flagged.length === 0) {
    out.push("\uC5C6\uC74C");
  } else {
    for (const e2 of flagged) {
      out.push(`- \`${e2.journey_id}/${e2.step_id}\` (${e2.strength}) \u2014 ${e2.note ?? e2.dsl_assertion}`);
    }
  }
  out.push("");
  return out.join(`
`);
}
function assertionMapGate(map) {
  const hardFail = map.unmapped_count > 0;
  const flagged = map.entries.some((e2) => e2.flag);
  const reason = hardFail ? `${map.unmapped_count} DSL assertion(s) dropped (unmapped) \u2014 hard fail` : map.weakened_count > 0 ? `${map.weakened_count} assertion(s) weakened \u2014 review required, gate passes` : flagged ? "assertions strengthened \u2014 review required, gate passes" : "all assertions map exactly";
  return { hardFail, flagged, reason };
}

// src/core/e2e/conformance.ts
function checkStepConformance(input) {
  const errors3 = [];
  const required = [];
  const journey = parseJourneyDoc(input.journeyText);
  if (!journey.ok) {
    errors3.push(`journey: ${journey.error}`);
  } else {
    if (journey.stepIds.length === 0) {
      errors3.push(`journey "${journey.frontMatter.id}": body declares no step id ([sN]) \u2014 nothing to trace, vacuous pass refused`);
    }
    required.push(...journey.stepIds.map((id) => `${journey.frontMatter.id}/${id}`));
    for (const blockId of journey.frontMatter.uses_blocks) {
      const text = input.blockTexts[blockId];
      if (text === undefined) {
        errors3.push(`block "${blockId}" is declared in uses_blocks but no block file was found`);
        continue;
      }
      const block2 = parseBlockDoc(text);
      if (!block2.ok) {
        errors3.push(`block "${blockId}": ${block2.error}`);
        continue;
      }
      if (block2.frontMatter.id !== blockId) {
        errors3.push(`block "${blockId}": front-matter id "${block2.frontMatter.id}" does not match the uses_blocks reference/filename \u2014 block id and filename stem must be identical`);
        continue;
      }
      if (block2.stepIds.length === 0) {
        errors3.push(`block "${blockId}": body declares no step id ([bN]) \u2014 nothing to trace, vacuous pass refused`);
        continue;
      }
      required.push(...block2.stepIds.map((id) => `${block2.frontMatter.id}/${id}`));
    }
    const body = splitFrontMatter(input.journeyText)?.body ?? "";
    const declared = new Set(journey.frontMatter.uses_blocks);
    for (const called of new Set(extractBlockCalls(body))) {
      if (!declared.has(called)) {
        errors3.push(`block "${called}" is invoked by a \uBE14\uB85D: step but missing from uses_blocks \u2014 declare it (\uC601\uD5A5 \uCD94\uB9BC\uACFC \uBE14\uB85D \uAC8C\uC774\uD2B8\uAC00 \uC774 \uC120\uC5B8\uC744 \uBCF8\uB2E4)`);
      }
    }
    for (const caseName of extractCaseNames(body)) {
      if (!input.generatedText.includes(caseName)) {
        errors3.push(`case "${caseName}" is declared in ## \uCF00\uC774\uC2A4 but not found in the generated spec \u2014 every case must become a test`);
      }
    }
  }
  const found = [
    ...new Set([
      ...extractStepMarkers(input.generatedText),
      ...input.supportTexts.flatMap(extractStepMarkers)
    ])
  ];
  const missing = required.filter((ref) => !found.includes(ref));
  return { ok: errors3.length === 0 && missing.length === 0, required, found, missing, errors: errors3 };
}

