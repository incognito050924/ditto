var journeyRoles = ["ui", "user_journey"];
var acgReviewFile = exports_external.object({
  path: exports_external.string().min(1).optional().describe("Code location; required unless role is a journey"),
  journey_id: exports_external.string().optional().describe("JourneySpec.id; required when role is ui/user_journey (OBJ-52)"),
