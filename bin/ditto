// src/acg/change-map/render.ts
var RISK_BADGE = {
  low: "\uD83D\uDFE2[low]",
  medium: "\uD83D\uDFE1[medium]",
  high: "\uD83D\uDD34[high]"
};
var RISK_ORDER = { low: 0, medium: 1, high: 2 };
function resolveRisk(contract, review) {
  if (review && review.files.length > 0) {
    return review.files.reduce((worst2, f3) => RISK_ORDER[f3.risk] > RISK_ORDER[worst2] ? f3.risk : worst2, "low");
  }
  return contract.risk_default;
}
function nodeRef(node2) {
  return node2.journey_id ?? node2.path ?? "";
}
function reviewRef(file) {
  return file.journey_id ?? file.path ?? "";
}
function evidenceBadge(ref, review) {
  const file = review?.files.find((f3) => reviewRef(f3) === ref);
  if (!file)
    return "\u2610";
  if (file.unresolved)
    return "\u26A0";
  return file.evidence ? "\u2611" : "\u2610";
}
function summarize(contract, impact, review) {
  return {
    change_id: contract.work_item_id,
    risk: resolveRisk(contract, review),
    impact: impact?.affected_nodes.length ?? 0,
    unresolved: impact?.unresolved.length ?? 0,
    open_accept: contract.acceptance.length
  };
}
function render(contract, impact, review) {
  const lines = [];
  lines.push(`\u25C6 ${contract.work_item_id} ${RISK_BADGE[resolveRisk(contract, review)]} "${contract.purpose}"`);
  lines.push(`  decision: ${contract.decision_ref ?? "\u2014"}`);
  lines.push("  scope:");
  lines.push(`    allow \u2500 ${contract.allowed_scope.map((s2) => s2.ref).join(", ")}`);
  lines.push(`    forbid \u2715 ${contract.forbidden_scope.map((s2) => s2.ref).join("  \u2715 ")}`);
  if (impact && (impact.affected_nodes.length > 0 || impact.unresolved.length > 0)) {
    lines.push("  impact:");
    for (const node2 of impact.affected_nodes) {
      const ref = nodeRef(node2);
      lines.push(`    \u2192 ${node2.kind} ${ref} ${evidenceBadge(ref, review)}`);
    }
    for (const u3 of impact.unresolved) {
      lines.push(`    \u26A0 unresolved: ${u3.kind} ${u3.path} \u2014 ${u3.reason}`);
    }
  }
  lines.push("  accept:");
  for (const a2 of contract.acceptance) {
    lines.push(`    \u2610 "${a2.criterion}" (${a2.evidence_kind})`);
  }
  return `${lines.join(`
`)}
`;
}
function label(text) {
  return text.replaceAll('"', "'").replaceAll(`
`, " ");
}
function nodeId(prefix, index) {
  return `${prefix}${index}`;
}
var RISK_CLASSDEF = {
  low: "classDef low fill:#dcfce7,stroke:#16a34a;",
  medium: "classDef medium fill:#fef9c3,stroke:#ca8a04;",
  high: "classDef high fill:#fee2e2,stroke:#dc2626;"
};
function renderMermaid(contract, impact, review) {
  const risk = resolveRisk(contract, review);
  const lines = ["graph LR"];
  lines.push(`  C["\u25C6 ${label(contract.work_item_id)}<br/>${risk}"]:::${risk}`);
  contract.forbidden_scope.forEach((s2, i2) => {
    const id = nodeId("F", i2);
    lines.push(`  C -.->|\u2715 forbid| ${id}["${label(s2.ref)}"]:::forbid`);
  });
  if (impact) {
    impact.affected_nodes.forEach((node2, i2) => {
      const ref = nodeRef(node2);
      const id = nodeId("A", i2);
      lines.push(`  C -->|${node2.kind} ${evidenceBadge(ref, review)}| ${id}["${label(ref)}"]`);
    });
    impact.unresolved.forEach((u3, i2) => {
      const id = nodeId("U", i2);
      lines.push(`  C -.->|\u26A0 unresolved| ${id}["${label(`${u3.kind}: ${u3.path}`)}"]:::unresolved`);
    });
  }
  lines.push("");
  lines.push(`  ${RISK_CLASSDEF[risk]}`);
  lines.push("  classDef forbid fill:#fee2e2,stroke:#dc2626,stroke-dasharray:4;");
  lines.push("  classDef unresolved fill:#f3f4f6,stroke:#6b7280,stroke-dasharray:2;");
  return `\`\`\`mermaid
${lines.join(`
`)}
\`\`\`
`;
}
