// src/core/hosts/types.ts
var registry = new Map;
function registerHostAdapter(adapter) {
  registry.set(adapter.id, adapter);
}
function getHostAdapter(id) {
  const adapter = registry.get(id);
  if (!adapter)
    throw new Error(`unknown host adapter: ${id}`);
  return adapter;
}
function listHostAdapters() {
  return [...registry.values()];
}
class InvalidHostError extends Error {
  value;
  constructor(value) {
    super(`invalid --host value "${value}"; expected one of: codex, claude-code`);
    this.value = value;
    this.name = "InvalidHostError";
  }
}
function parseHostId(value) {
  if (value === undefined)
    return;
  if (value === "codex" || value === "claude-code")
    return value;
  throw new InvalidHostError(value);
}

