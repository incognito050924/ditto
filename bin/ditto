// src/core/autopilot-store.ts
init_ditto_paths();
init_fs();

class AutopilotStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  dir(workItemId2) {
    return localDir(this.repoRoot, "work-items", workItemId2);
  }
  graphPath(workItemId2) {
    return join12(this.dir(workItemId2), "autopilot.json");
  }
  decisionsPath(workItemId2) {
    return join12(this.dir(workItemId2), "autopilot-decisions.jsonl");
  }
  async exists(workItemId2) {
    return Bun.file(this.graphPath(workItemId2)).exists();
  }
  async get(workItemId2) {
    return readJson(this.graphPath(workItemId2), autopilot);
  }
  async write(workItemId2, graph) {
    await ensureDir(this.dir(workItemId2));
    return writeJson(this.graphPath(workItemId2), autopilot, graph);
  }
  async updateNode(workItemId2, nodeId, mutator) {
    const graph = await this.get(workItemId2);
    let found = false;
    const nodes = graph.nodes.map((node) => {
      if (node.id !== nodeId)
        return node;
      found = true;
      const next = mutator(node);
      if (next.id !== node.id) {
        throw new Error(`updateNode mutator changed node id from ${node.id} to ${next.id}`);
      }
      return next;
    });
    if (!found)
      throw new Error(`node ${nodeId} not found in autopilot graph for ${workItemId2}`);
    return writeJson(this.graphPath(workItemId2), autopilot, { ...graph, nodes });
  }
  async addNodes(workItemId2, newNodes, allowedAcceptanceIds) {
    const graph = await this.get(workItemId2);
    validateNodeAddition(graph.nodes, newNodes, allowedAcceptanceIds);
    return writeJson(this.graphPath(workItemId2), autopilot, {
      ...graph,
      nodes: [...graph.nodes, ...newNodes]
    });
  }
  async removeNodes(workItemId2, ids) {
    if (ids.length === 0)
      return this.get(workItemId2);
    const graph = await this.get(workItemId2);
    const removal = new Set(ids);
    for (const id of ids) {
      const node = graph.nodes.find((n2) => n2.id === id);
      if (!node)
        throw new Error(`cannot remove unknown node: ${id}`);
      if (node.status !== "pending")
        throw new Error(`cannot remove node not pending: ${id}`);
    }
    const survivors = graph.nodes.filter((n2) => !removal.has(n2.id));
    for (const n2 of survivors) {
      for (const dep of n2.depends_on) {
        if (removal.has(dep)) {
          throw new Error(`removal would leave dangling depends_on: ${n2.id} -> ${dep}`);
        }
      }
    }
    return writeJson(this.graphPath(workItemId2), autopilot, { ...graph, nodes: survivors });
  }
  async updateApprovalGate(workItemId2, mutator) {
    const graph = await this.get(workItemId2);
    return writeJson(this.graphPath(workItemId2), autopilot, {
      ...graph,
      approval_gate: mutator(graph.approval_gate)
    });
  }
  async appendDecision(workItemId2, decision) {
    await ensureDir(this.dir(workItemId2));
    const path = this.decisionsPath(workItemId2);
    const file = Bun.file(path);
    const existing = await file.exists() ? await file.text() : "";
    const prefix = existing.length === 0 || existing.endsWith(`
`) ? existing : `${existing}
`;
    await atomicWriteText(path, `${prefix}${JSON.stringify(decision)}
`);
  }
  async readDecisions(workItemId2) {
    const file = Bun.file(this.decisionsPath(workItemId2));
    if (!await file.exists())
      return [];
    const text = await file.text();
    return text.split(`
`).filter((line) => line.trim().length > 0).map((line) => JSON.parse(line));
  }
}

// src/core/coverage-manager.ts
var CLOSED_STATES = new Set([
  "resolved",
  "user_owned",
  "out_of_scope"
]);
var DEFAULT_DRY_K = 2;
function isClosed(node) {
  return CLOSED_STATES.has(node.state);
}
function addNode(map, child) {
  if (map.nodes.some((n2) => n2.id === child.id)) {
    throw new Error(`duplicate coverage node id: ${child.id}`);
  }
  if (child.parent_id !== null && !map.nodes.some((n2) => n2.id === child.parent_id)) {
    throw new Error(`dangling parent_id: node ${child.id} references unknown ${child.parent_id}`);
  }
  const nodes = map.nodes.map((n2) => n2.id === child.parent_id ? { ...n2, children: [...n2.children, child.id] } : n2);
  nodes.push({ ...child });
  return { ...map, nodes };
}
function closeNode(map, id, state) {
  if (!map.nodes.some((n2) => n2.id === id)) {
    throw new Error(`unknown coverage node id: ${id}`);
  }
  return {
    ...map,
    nodes: map.nodes.map((n2) => n2.id === id ? { ...n2, state } : n2)
  };
}
function selectReadyCoverageNodes(map) {
  const byId = new Map(map.nodes.map((n2) => [n2.id, n2]));
  return map.nodes.filter((n2) => {
    if (isClosed(n2))
      return false;
    return n2.children.every((childId) => {
      const c3 = byId.get(childId);
      return c3 !== undefined && isClosed(c3);
    });
  });
}
function coverageClosureGate(map, id, state) {
  const byId = new Map(map.nodes.map((n2) => [n2.id, n2]));
  const target = byId.get(id);
  if (target === undefined) {
    return { pass: false, reasons: [`unknown coverage node id: ${id}`] };
  }
  const openChildren = target.children.filter((childId) => {
    const c3 = byId.get(childId);
    return c3 !== undefined && !isClosed(c3);
  });
  if (openChildren.length > 0) {
    return {
      pass: false,
      reasons: [
        `cannot project ${state} onto ${id}: subtree not dry \u2014 open child(ren): ${openChildren.join(", ")}`
      ]
    };
  }
  return { pass: true, reasons: [] };
}
function recordDryRound(counter, round) {
  return round.admissibleBranchesAdded > 0 ? 0 : counter + 1;
}
function isCoverageTerminated(map, dryCounter, k2 = DEFAULT_DRY_K) {
  const allClosed = map.nodes.every(isClosed);
  return allClosed && dryCounter >= k2;
}
function buildJudgeInput(args) {
  return {
    node: { ...args.node },
    original_intent: args.originalIntent,
    cross_cutting_constraints: [...args.crossCuttingConstraints]
  };
}
function serializePlanDialog(input) {
  const lines = [];
  const kind = input.kind ?? "plan-dialog";
  lines.push("---");
  lines.push(`kind: ${kind}`);
  lines.push(`work_item_id: ${input.workItemId}`);
  lines.push("---");
  lines.push("");
  lines.push(`# ${kind}`);
  lines.push("");
  lines.push("## \uC0AC\uC6A9\uC790 Q&A");
  if (input.userQa.length === 0) {
    lines.push("(none)");
  } else {
    for (const qa of input.userQa) {
      lines.push(`- Q: ${qa.question}`);
      lines.push(`  - why_matters: ${qa.why_matters}`);
      lines.push(`  - A: ${qa.answer}`);
    }
  }
  lines.push("");
  lines.push("## QuestionGate self-answer (\uC548 \uBB3C\uC740 \uADFC\uAC70)");
  if (input.selfAnswers.length === 0) {
    lines.push("(none)");
  } else {
    for (const sa of input.selfAnswers) {
      lines.push(`- Q: ${sa.question}`);
      lines.push(`  - \uC548 \uBB3C\uC740 \uADFC\uAC70: ${sa.why_not_asked}`);
      for (const attempt of sa.attempts) {
        lines.push(`  - [${attempt.source}] ${attempt.result}`);
      }
    }
  }
  lines.push("");
  lines.push("## assumptions");
  if (input.assumptions.length === 0) {
    lines.push("(none)");
  } else {
    for (const a2 of input.assumptions) {
      lines.push(`- (${a2.label}) ${a2.statement} \u2014 because_no_answer_to: ${a2.because_no_answer_to}`);
    }
  }
  lines.push("");
  lines.push("## \uB2EB\uD78C \uD56D\uBAA9");
  if (input.closedItems.length === 0) {
    lines.push("(none)");
  } else {
    for (const item of input.closedItems) {
      lines.push(`- [${item.state}] ${item.id}: ${item.label}`);
    }
  }
  lines.push("");
  lines.push("## \uC5F4\uB9B0 \uD56D\uBAA9");
  if (input.openItems.length === 0) {
    lines.push("(none)");
  } else {
    for (const item of input.openItems) {
      lines.push(`- [${item.state}] ${item.id}: ${item.label}`);
    }
  }
  lines.push("");
  return lines.join(`
`);
}
var COVERAGE_AXIS_MECHANISMS = {
  completeness: {
    mechanism_id: "multi-angle-blind-sweep+breadth-termination",
    description: "Multiple blind fresh sweeps decompose scope (\xA74.2); every coverage node must close to terminate (\xA75).",
    enforce: (map, dryCounter, k2 = DEFAULT_DRY_K) => isCoverageTerminated(map, dryCounter, k2)
  },
  neutrality: {
    mechanism_id: "opponent-router-dialectic-3role+leading-question-review",
    description: "Per-scope Dialectic Producer/Opponent/Synthesizer via opponent-router reuse; passes only when the Opponent actually ran AND the Synthesizer reached a decided verdict \u2014 a missing/blocked deliberation or single-agent role-play is rejected (\xA74.3).",
    enforce: (state) => state?.opponent_ran === true && state.verdict !== "blocked"
  },
  balance: {
    mechanism_id: "per-node-depth-weight-gate+deterministic-floor",
    description: "Each scope carries depth_weight (fresh-judge estimated); the achieved depth is floor-capped (deterministicFloor, \xA710 \uCC28\uC6A9) so a high self-report cannot escape unresolved critical scope, then must meet the node weight \u2014 proportional, not uniform (\xA74.4).",
    enforce: (node, state) => {
      const floor = deterministicFloor({
        open_required_sections: state.open_required_sections,
        conflicting: state.conflicting,
        assumption_ratio: state.assumption_ratio
      });
      const cappedDepth = Math.min(state.achievedDepth, 1 - floor);
      return cappedDepth >= node.depth_weight;
    }
  },
  discovery: {
    mechanism_id: "loop-until-dry-admissible-novelty",
    description: "A dedicated completeness-critic pass runs until admissible (critical/major) novelty is exhausted (K consecutive dry rounds, \xA74.5).",
    enforce: (round) => recordDryRound(0, round)
  },
  priority: {
    mechanism_id: "user-priority-weighting-termination-block",
    description: "High user-priority nodes get a weighted depth criterion: a high-priority node must reach its depth_weight before it may close; a shallow important node blocks termination. Normal/low-priority nodes are not subjected to this extra block here (\xA72 \uC6B0\uC120\uC21C\uC704).",
    enforce: (node, state) => state.userPriority !== "high" || state.achievedDepth >= node.depth_weight
  },
  temporal: {
    mechanism_id: "plan-brief-baseline-freeze+divergence-detection",
    description: "plan_brief/coverage result is frozen as the implementation baseline; this engine compares a downstream interface surface against the frozen baseline and reports divergence. Drift ENFORCEMENT proper is the implementation stage (reviewer/verifier) \u2014 this engine only produces the baseline and detects divergence (\xA72 \uC2DC\uAC04\uC815\uD569, contract \xA72 l.62).",
    enforce: (baseline, current) => {
      if (baseline.length !== current.length)
        return false;
      const frozen = new Set(baseline);
      return current.every((item) => frozen.has(item));
    }
  }
};
var FEW_FILES = 3;
function selectCoverageTier(input) {
  if (input.large || input.risk.irreversible || input.risk.non_local) {
    return "full";
  }
  const fewFiles = input.changedFileCount <= FEW_FILES;
  if (fewFiles && !input.interfaceChanged && safeDefaultable(input.risk)) {
    return "light";
  }
  return "standard";
}
function tierBriefApproval(tier) {
  return tier === "light" ? "not_required" : "pending";
}
function producePlanGate(input) {
  const tier = selectCoverageTier(input.tierInputs);
  return {
    status: input.requireApproval ? "pending" : tierBriefApproval(tier),
    change_surface: [...input.changeSurface],
    plan_brief: {
      interface_changes: [...input.brief.interface_changes],
      dod: [...input.brief.dod],
      test_scenarios: [...input.brief.test_scenarios]
    }
  };
}

// src/core/gates.ts
function gate(reasons) {
  return { pass: reasons.length === 0, reasons };
}
function deterministicFloor(s2) {
  const raw = 0.05 * s2.open_required_sections + 0.1 * s2.conflicting + 0.05 * s2.assumption_ratio;
  return Math.min(1, Math.max(0, raw));
}
function ambiguityFromInterview(state) {
  const open = state.dimensions.filter((d2) => d2.critical && d2.state !== "resolved").length;
  const asked = state.questions.length;
  const assumption_ratio = asked === 0 ? state.assumptions.length > 0 ? 1 : 0 : state.assumptions.length / asked;
  return {
    open_required_sections: open,
    conflicting: 0,
    assumption_ratio: Math.min(1, assumption_ratio)
  };
}
function interviewReadinessGate(state) {
  const reasons = [];
  const unresolved = state.dimensions.filter((d2) => d2.critical && d2.state !== "resolved").map((d2) => d2.id);
  if (unresolved.length > 0) {
    reasons.push(`critical dimensions unresolved: ${unresolved.join(", ")}`);
  }
  const floor = deterministicFloor(ambiguityFromInterview(state));
  const capped = Math.min(state.readiness.score, 1 - floor);
  if (capped < state.readiness.threshold) {
    reasons.push(`readiness ${capped.toFixed(2)} (floor-capped) below threshold ${state.readiness.threshold}`);
  }
  return gate(reasons);
}
function deriveClosureMode(reason, gatePassed) {
  switch (reason) {
    case "readiness_met":
    case "converged":
      return "mutual_agreement";
    case "cap_reached":
    case "diminishing_returns":
      return gatePassed ? "mutual_agreement" : "ledger_only";
    case "user_deferred":
    case "user_owned_decision":
    case "blocked":
      return "safe_default";
  }
}
var VAGUE_TERMS = [
  "robust",
  "fast",
  "faster",
  "secure",
  "user-friendly",
  "user friendly",
  "better",
  "improve",
  "improved",
  "properly",
  "correctly",
  "efficient",
  "efficiently",
  "intuitive",
  "seamless",
  "optimal",
  "scalable",
  "flexible",
  "nice"
];
var OBSERVABLE = /\b(returns?|rejects?|responds?|displays?|shows?|exits?|equals?|matches?|contains?|within|less than|greater than|at most|at least|status|code)\b|\d|\uBC18\uD658|\uAC70\uBD80|\uC751\uB2F5|\uD45C\uC2DC|\uB178\uCD9C|\uC885\uB8CC|\uAC19\uC74C|\uC77C\uCE58|\uD3EC\uD568|\uD1B5\uACFC|\uC2E4\uD328|\uC0DD\uC131|\uAC31\uC2E0|\uD638\uCD9C|\uAC15\uB4F1|\uC7AC\uD604|\uBB34\uD6A8\uD654|\uD544\uD130|\uC815\uB82C|\uBCD1\uD569|\uC9D1\uACC4|\uBD84\uD560|\uB80C\uB354|\uCC28\uB2E8/i;
function escapeRegex(s2) {
  return s2.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}
function acceptanceTestable(ac) {
  const reasons = [];
  const lower = ac.statement.toLowerCase();
  const vague = VAGUE_TERMS.filter((t2) => new RegExp(`\\b${escapeRegex(t2)}\\b`).test(lower));
  if (vague.length > 0)
    reasons.push(`vague term(s): ${[...new Set(vague)].join(", ")}`);
  const hasEvidence = (ac.evidence_required?.length ?? 0) > 0;
  if (!OBSERVABLE.test(ac.statement) && !hasEvidence)
    reasons.push("no observable/measurable predicate found");
  return gate(reasons);
}
function isGrounded(u3) {
  return typeof u3.grounding === "string" && u3.grounding.trim().length > 0;
}
function referencesAcceptanceId(u3, acceptanceIds) {
  const haystack = `${u3.item} ${u3.reason}`;
  return acceptanceIds.some((id) => new RegExp(`(?<![\\w-])${escapeRegex(id)}(?![\\w-])`).test(haystack));
}
function resolvabilityBlockers(unverified, acceptanceIds) {
  const blockers = [];
  for (const u3 of unverified) {
    const grounded = isGrounded(u3);
    const acRef = referencesAcceptanceId(u3, acceptanceIds);
    if (u3.resolvability === "agent_resolvable" || acRef && u3.resolvability === undefined) {
      if (grounded && u3.resolvability !== "agent_resolvable")
        continue;
      blockers.push({
        item: u3.item,
        reason: u3.resolvability === "agent_resolvable" ? "declared agent_resolvable but parked (resolve it, do not park)" : "references an owned acceptance criterion but is unverified",
        kind: "agent_resolvable",
        userDecision: false
      });
      continue;
    }
    if (u3.resolvability === "blocked_external" || u3.resolvability === "accepted_tradeoff") {
      if (grounded)
        continue;
      blockers.push({
        item: u3.item,
        reason: `declared ${u3.resolvability} without grounding (ungrounded residual claim)`,
        kind: "blocked_external",
        userDecision: false
      });
      continue;
    }
    if (u3.resolvability === "user_decision") {
      if (grounded)
        continue;
      blockers.push({
        item: u3.item,
        reason: "declared user_decision without a recorded decision pointer (surface for user ok)",
        kind: "user_decision",
        userDecision: true
      });
    }
  }
  return blockers;
}
function completionGate(item, completion) {
  const reasons = [];
  const expected = item.acceptance_criteria.map((c3) => c3.id);
  const expectedSet = new Set(expected);
  const reported = completion.acceptance.map((a2) => a2.criterion_id);
  const reportedSet = new Set(reported);
  if (reported.length !== reportedSet.size) {
    const seen = new Set;
    const dupes = new Set;
    for (const id of reported) {
      if (seen.has(id))
        dupes.add(id);
      seen.add(id);
    }
    reasons.push(`duplicate criterion_id(s): ${[...dupes].join(", ")}`);
  }
  const missing = expected.filter((id) => !reportedSet.has(id));
  if (missing.length > 0)
    reasons.push(`missing criteria: ${missing.join(", ")}`);
  const extra = [...reportedSet].filter((id) => !expectedSet.has(id));
  if (extra.length > 0)
    reasons.push(`extra criteria not in work item: ${extra.join(", ")}`);
  if (completion.final_verdict === "pass") {
    const notPass = completion.acceptance.filter((a2) => a2.verdict !== "pass").map((a2) => a2.criterion_id);
    if (notPass.length > 0) {
      reasons.push(`final_verdict=pass but not-pass criteria: ${[...new Set(notPass)].join(", ")}`);
    }
  }
  return gate(reasons);
}
function completionEvidenceGate(completion) {
  if (completion.final_verdict !== "pass")
    return gate([]);
  const ranCommand = completion.verifications.length > 0;
  const hasRealCriterionEvidence = completion.acceptance.some((a2) => a2.evidence.some((e2) => e2.kind !== "note") || a2.evidence_records.length > 0);
  if (!ranCommand && !hasRealCriterionEvidence) {
    return gate([
      "final_verdict=pass with no runnable verification evidence (ack/approval is not verification)"
    ]);
  }
  return gate([]);
}
function convergenceGate(c3) {
  const reasons = [];
  const maxScore = Math.max(...c3.versions.map((v2) => v2.score));
  const selected = c3.versions.find((v2) => v2.version === c3.selected_version);
  if (!selected) {
    reasons.push(`selected_version ${c3.selected_version} not present in versions`);
  } else if (selected.score !== maxScore) {
    reasons.push(`selected_version is not argmax (selected ${selected.score} < max ${maxScore})`);
  }
  const openComputed = c3.decision_ledger.filter((e2) => e2.admissible && e2.status === "deferred").length;
  if (c3.open_admissible_count !== openComputed) {
    reasons.push(`open_admissible_count recorded ${c3.open_admissible_count} != computed ${openComputed}`);
  }
  const expectedConverged = c3.gate.completion_gate === "pass" && openComputed === 0;
  if (c3.gate.converged !== expectedConverged) {
    reasons.push(`gate.converged recorded ${c3.gate.converged} != expected ${expectedConverged} (completion \u2227 no-open-admissible)`);
  }
  if (!expectedConverged) {
    reasons.push("not converged: completion_gate != pass or open admissible objections remain");
  }
  return gate(reasons);
}
function highRiskAssumption(a2) {
  return a2.non_local || a2.irreversible || a2.unaudited;
}
function safeDefaultable(a2) {
  return !highRiskAssumption(a2);
}
function knowledgeTriggerFired(t2) {
  return t2.adr_worthy_decision || t2.new_agreed_term || t2.repeated_pattern;
}
function knowledgeUpdateGate(t2, d2) {
  const reasons = [];
  const recorded = d2.decisions + d2.glossary_terms + d2.patterns + d2.learnings;
  if (!knowledgeTriggerFired(t2) && recorded > 0) {
    reasons.push("durable content recorded but no trigger declared (over-recording: noise)");
  }
  if (t2.adr_worthy_decision && d2.decisions === 0) {
    reasons.push("adr_worthy_decision trigger fired but no decision/ADR recorded (under-recording)");
  }
  if (t2.new_agreed_term && d2.glossary_terms === 0) {
    reasons.push("new_agreed_term trigger fired but no glossary term added (under-recording)");
  }
  if (t2.repeated_pattern && d2.patterns + d2.learnings === 0) {
    reasons.push("repeated_pattern trigger fired but no pattern/learning recorded (under-recording)");
  }
  return gate(reasons);
}
function decisionConflictGate(conflicts, mode) {
  const dispositions = conflicts.map((conflict) => {
    if (conflict.kind === "prefer")
      return { conflict, route: "justify" };
    if (conflict.level === "method")
      return { conflict, route: "align" };
    return { conflict, route: mode === "autopilot" ? "block" : "ask_user" };
  });
  return {
    dispositions,
    blocked: dispositions.some((d2) => d2.route === "block"),
    needsApproval: dispositions.some((d2) => d2.route === "ask_user"),
    disclose: conflicts.length > 0
  };
}
function decisionConflictRequiresApproval(conflicts) {
  return conflicts.some((c3) => c3.kind !== "prefer" && c3.level === "intent");
}
function idSet(items) {
  return new Set(items.map((i2) => i2.id));
}
function missingFrom(a2, b2) {
  return [...a2].filter((x2) => !b2.has(x2));
}
function intentDriftGate(a2) {
  const reasons = [];
  const advisories = [];
  const intentGoal = a2.intent.goal.trim();
  const intentAcIds = idSet(a2.intent.acceptance_criteria);
  if (a2.workItem.goal.trim() !== intentGoal) {
    advisories.push("H1: work-item goal diverges from intent goal (re-statement or drift \u2014 review)");
  }
  if (a2.workItem.source_request.trim() !== a2.intent.source_request.trim()) {
    advisories.push("H1: work-item source_request diverges from intent (review)");
  }
  const wiAcIds = idSet(a2.workItem.acceptance_criteria);
  const wiAdded = missingFrom(wiAcIds, intentAcIds);
  if (wiAdded.length > 0) {
    reasons.push(`H1: work-item AC id(s) not in intent (scope grow): ${wiAdded.join(", ")}`);
  }
  const wiDropped = missingFrom(intentAcIds, wiAcIds);
  if (wiDropped.length > 0) {
    reasons.push(`H1: intent AC id(s) missing from work-item (scope shrink): ${wiDropped.join(", ")}`);
  }
  if (a2.graph.root_goal.trim() !== intentGoal) {
    advisories.push("H2: autopilot root_goal diverges from intent goal (re-statement or drift \u2014 review)");
  }
  const covered = new Set;
  for (const node of a2.graph.nodes) {
    for (const ref of node.acceptance_refs)
      covered.add(ref);
  }
  const uncovered = missingFrom(intentAcIds, covered);
  if (uncovered.length > 0) {
    reasons.push(`H2: intent AC id(s) addressed by no node (scope shrink): ${uncovered.join(", ")}`);
  }
  const invented = missingFrom(covered, intentAcIds);
  if (invented.length > 0) {
    reasons.push(`H2: node acceptance_refs id(s) not in intent (scope grow): ${invented.join(", ")}`);
  }
  if (a2.completion && a2.completion.final_verdict !== "pass") {
    const compIds = new Set(a2.completion.acceptance.map((c3) => c3.criterion_id));
    const compAdded = missingFrom(compIds, intentAcIds);
    if (compAdded.length > 0) {
      reasons.push(`H3: completion criterion_id(s) not in intent (scope grow): ${compAdded.join(", ")}`);
    }
    const compDropped = missingFrom(intentAcIds, compIds);
    if (compDropped.length > 0) {
      reasons.push(`H3: intent AC id(s) missing from completion (scope shrink): ${compDropped.join(", ")}`);
    }
  }
  return { ...gate(reasons), advisories };
}
function interfaceBaselineDriftGate(baseline, current) {
  if (baseline === undefined)
    return gate([]);
  const conserved = COVERAGE_AXIS_MECHANISMS.temporal.enforce(baseline, current);
  if (conserved)
    return gate([]);
  const frozen = new Set(baseline);
  const added = current.filter((c3) => !frozen.has(c3));
  const removed = baseline.filter((b2) => !current.includes(b2));
  const reasons = [];
  if (added.length > 0) {
    reasons.push(`interface/scope added vs frozen baseline (unconsented grow): ${added.join(", ")}`);
  }
  if (removed.length > 0) {
    reasons.push(`interface/scope removed vs frozen baseline (unconsented shrink): ${removed.join(", ")}`);
  }
  return gate(reasons);
}

// src/core/id.ts
import { randomBytes as randomBytes2 } from "crypto";
var SUFFIX_LENGTH = 9;
var SUFFIX_CHARSET = "abcdefghijklmnopqrstuvwxyz0123456789";
function randomSuffix(length) {
  const bytes = randomBytes2(length);
  let out = "";
  for (let i2 = 0;i2 < length; i2++) {
    const byte = bytes[i2] ?? 0;
    out += SUFFIX_CHARSET[byte % SUFFIX_CHARSET.length] ?? "a";
  }
  return out;
}
async function generateId(prefix, existsCheck, options = {}) {
  const now = options.now ?? new Date;
  const maxAttempts = options.maxAttempts ?? 8;
  const yy = String(now.getUTCFullYear() % 100).padStart(2, "0");
  const mm = String(now.getUTCMonth() + 1).padStart(2, "0");
  const dd = String(now.getUTCDate()).padStart(2, "0");
  const datePart = `${yy}${mm}${dd}`;
  const randomLen = Math.max(SUFFIX_LENGTH - datePart.length, 3);
  for (let attempt = 0;attempt < maxAttempts; attempt++) {
    const candidate = `${prefix}_${datePart}${randomSuffix(randomLen)}`;
    if (!await existsCheck(candidate))
      return candidate;
  }
  throw new Error(`failed to generate unique ${prefix}_ id after ${maxAttempts} attempts; likely a clock or RNG issue`);
}

// src/core/autopilot-bootstrap.ts
function approvalGate(input) {
  const base = { approved_at: null, approved_by: null, evidence_refs: [] };
  if (input.approvedSource) {
    return {
      ...base,
      status: "approved",
      source: input.approvedSource,
      approved_at: input.approvedSource === "user" ? (input.now ?? new Date).toISOString() : null
    };
  }
  if (highRiskAssumption(input.risk)) {
    return { ...base, status: "pending", source: null };
  }
  return { ...base, status: "not_required", source: "small_reversible_policy" };
}
async function bootstrapAutopilot(repoRoot, input) {
  if (input.intent.work_item_id !== input.workItem.id) {
    return {
      status: "work_item_mismatch",
      reasons: [
        `intent.work_item_id=${input.intent.work_item_id} does not match workItem.id=${input.workItem.id}`
      ]
    };
  }
  const reasons = [];
  if (input.intent.acceptance_criteria.length === 0) {
    reasons.push("intent has no acceptance criteria");
  }
  for (const ac of input.intent.acceptance_criteria) {
    const t2 = acceptanceTestable({
      statement: ac.statement,
      evidence_required: ac.evidence_required
    });
    if (!t2.pass)
      reasons.push(`criterion ${ac.id} not testable: ${t2.reasons.join("; ")}`);
  }
  if (reasons.length > 0)
    return { status: "intent_not_ready", reasons };
  const store = new AutopilotStore(repoRoot);
  const autopilotId2 = await generateId("orch", async () => false, {
    ...input.now ? { now: input.now } : {}
  });
  const acceptanceIds = input.intent.acceptance_criteria.map((c3) => c3.id);
  const graph = {
    schema_version: "0.1.0",
    autopilot_id: autopilotId2,
    work_item_id: input.workItem.id,
    mode: "autopilot",
    root_goal: input.intent.goal,
    completion_boundary: "entire_work_item",
    approval_gate: approvalGate(input),
    nodes: (input.generateNodes ?? defaultNodeGenerator)(acceptanceIds),
    caps: { fix_per_node: 2, switch_per_node: 1, converge_rounds: 3 },
    continue_policy: {
      continue_after_approval: true,
      continue_after_checkpoint: true,
      continue_after_fixable_failure: true,
      ask_user_only_for_user_owned_decisions: true
    },
    stop_conditions: [
      "all_acceptance_criteria_passed_or_explicitly_closed",
      "blocked_by_user_owned_decision",
      "blocked_by_external_system",
      "safety_boundary_hit"
    ],
    user_interrupt_policy: "ask_only_for_user_owned_decisions"
  };
  const written = await store.write(input.workItem.id, graph);
  return { status: "created", graph: written };
}

// src/core/worktree.ts
init_ditto_paths();
init_fs();
import { execFileSync } from "child_process";
import { realpathSync } from "fs";
import { relative as relative3 } from "path";
async function createWorktreeForRun(repoRoot, runId2) {
  const relativePath2 = `${RUN_WORKTREE_PREFIX}${runId2}`;
  const absolutePath = localDir(repoRoot, "worktrees", runId2);
  await ensureDir(localDir(repoRoot, "worktrees"));
  execFileSync("git", ["worktree", "add", "--detach", absolutePath, "HEAD"], {
    cwd: repoRoot,
    stdio: ["ignore", "ignore", "pipe"]
  });
  return { absolutePath, relativePath: relativePath2 };
}
var RUN_WORKTREE_PREFIX = ".ditto/local/worktrees/";
function listRunWorktrees(repoRoot) {
  const out = execFileSync("git", ["worktree", "list", "--porcelain"], {
    cwd: repoRoot,
    encoding: "utf8",
    stdio: ["ignore", "pipe", "pipe"]
  });
  const root = realpathSync(repoRoot);
  const paths = [];
  for (const line of out.split(`
`)) {
    if (!line.startsWith("worktree "))
      continue;
    const abs = line.slice("worktree ".length).trim();
    const rel = relative3(root, abs);
    if (rel.startsWith(RUN_WORKTREE_PREFIX))
      paths.push(rel);
  }
  return paths;
}
function removeRunWorktree(repoRoot, relativePath2) {
  execFileSync("git", ["worktree", "remove", relativePath2], {
    cwd: repoRoot,
    stdio: ["ignore", "ignore", "pipe"]
  });
}

// src/core/autopilot-cleanup.ts
function planCleanup(repoRoot) {
  return { worktrees: listRunWorktrees(repoRoot) };
}
function cleanupApprovalGate(approvalStatus2, explicitApprove) {
  if (explicitApprove)
    return { allowed: true, reason: "operator --approve" };
  if (approvalStatus2 === "approved")
    return { allowed: true, reason: "approval_gate=approved" };
  return {
    allowed: false,
    reason: `irreversible git (worktree removal) needs explicit approval; approval_gate=${approvalStatus2} (the small-reversible waiver does not cover it)`
  };
}
async function runCleanup(repoRoot, input) {
  const aps = new AutopilotStore(repoRoot);
  const graph = await aps.get(input.workItemId);
  const node = graph.nodes.find((n2) => n2.id === input.nodeId);
  if (!node) {
    throw new Error(`node ${input.nodeId} not found in autopilot graph for ${input.workItemId}`);
  }
  if (node.kind !== "cleanup") {
    throw new Error(`node ${node.id} is kind=${node.kind}, not cleanup`);
  }
  if (node.status === "passed") {
    throw new Error(`cleanup node ${node.id} already passed`);
  }
  const plan = planCleanup(repoRoot);
  const gate2 = cleanupApprovalGate(graph.approval_gate.status, input.approve ?? false);
  if (node.status !== "running") {
    await aps.updateNode(input.workItemId, node.id, (n2) => ({
      ...n2,
      status: nodeTransition(n2.status, "dispatch")
    }));
  }
  if (plan.worktrees.length > 0 && !gate2.allowed) {
    await aps.updateNode(input.workItemId, node.id, (n2) => ({
      ...n2,
      status: nodeTransition("running", "block")
    }));
    await aps.appendDecision(input.workItemId, {
      ts: (input.now ?? new Date).toISOString(),
      node_id: node.id,
      failure_class: "user_decision_needed",
      decision: "escalate",
      reason: gate2.reason,
      attempts: node.attempts
    });
    return { status: "blocked", node_id: node.id, plan: plan.worktrees, reason: gate2.reason };
  }
  const removed = [];
  const skipped = [];
  for (const wt of plan.worktrees) {
    try {
      removeRunWorktree(repoRoot, wt);
      removed.push(wt);
    } catch (err) {
      skipped.push({ path: wt, reason: err instanceof Error ? err.message : String(err) });
    }
  }
  const evidence = removed.map((wt) => ({
    kind: "command",
    command: `git worktree remove ${wt}`,
    summary: "run worktree torn down"
  }));
  const skippedNote = skipped.length > 0 ? `; ${skipped.length} skipped (dirty/locked)` : "";
  const note = plan.worktrees.length === 0 ? "no run worktrees to clean" : `removed ${removed.length}/${plan.worktrees.length} run worktree(s)${skippedNote}`;
  evidence.push({ kind: "note", summary: note });
  await aps.updateNode(input.workItemId, node.id, (n2) => ({
    ...n2,
    status: nodeTransition("running", "pass"),
    evidence_refs: evidence
  }));
  return { status: "passed", node_id: node.id, plan: plan.worktrees, removed, skipped };
}

