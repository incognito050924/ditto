// src/acg/icl/tokenizer.ts
class IclTokenizeError extends Error {
  line;
  constructor(message, line) {
    super(message);
    this.line = line;
    this.name = "IclTokenizeError";
  }
}
var PUNCT = new Set(["{", "}", "(", ")", ":"]);
function isIdentChar(ch) {
  return /[A-Za-z0-9_.\-]/.test(ch);
}
function tokenize(source) {
  const tokens = [];
  let i2 = 0;
  let line = 1;
  const n2 = source.length;
  const readString = () => {
    i2 += 1;
    const start = i2;
    while (i2 < n2 && source[i2] !== '"') {
      if (source[i2] === `
`) {
        throw new IclTokenizeError("unterminated string literal", line);
      }
      i2 += 1;
    }
    if (i2 >= n2) {
      throw new IclTokenizeError("unterminated string literal", line);
    }
    const value = source.slice(start, i2);
    i2 += 1;
    return value;
  };
  while (i2 < n2) {
    const ch = source[i2];
    if (ch === `
`) {
      line += 1;
      i2 += 1;
      continue;
    }
    if (ch === " " || ch === "\t" || ch === "\r") {
      i2 += 1;
      continue;
    }
    if (ch === "/" && source[i2 + 1] === "/") {
      while (i2 < n2 && source[i2] !== `
`)
        i2 += 1;
      continue;
    }
    if (ch === '"') {
      const startLine = line;
      const value = readString();
      tokens.push({ type: "string", value, line: startLine });
      continue;
    }
    if (ch === "#") {
      const startLine = line;
      i2 += 1;
      while (i2 < n2 && (source[i2] === " " || source[i2] === "\t"))
        i2 += 1;
      if (source[i2] !== '"') {
        throw new IclTokenizeError("# note must be followed by a quoted string", startLine);
      }
      const value = readString();
      tokens.push({ type: "note", value, line: startLine });
      continue;
    }
    if (PUNCT.has(ch)) {
      tokens.push({ type: "punct", value: ch, line });
      i2 += 1;
      continue;
    }
    if (isIdentChar(ch)) {
      const start = i2;
      while (i2 < n2 && isIdentChar(source[i2]))
        i2 += 1;
      tokens.push({ type: "ident", value: source.slice(start, i2), line });
      continue;
    }
    throw new IclTokenizeError(`unexpected character '${ch}'`, line);
  }
  return tokens;
}

// src/acg/icl/parser.ts
class IclParseError extends Error {
  line;
  constructor(message, line) {
    super(message);
    this.line = line;
    this.name = "IclParseError";
  }
}
var SCOPE_KINDS = new Set(["path", "glob", "symbol", "surface", "layer"]);
var EVIDENCE_KINDS2 = new Set([
  "test",
  "build",
  "log",
  "diff",
  "screen",
  "manual",
  "e2e"
]);
var FITNESS_KINDS = new Set([
  "architectural",
  "dependency",
  "semantic",
  "coverage",
  "consistency",
  "performance",
  "duplication",
  "complexity",
  "user_journey"
]);
var RISK_LEVELS = new Set(["low", "medium", "high"]);
var FREQUENCIES = new Set(["daily", "weekly", "on_release"]);
var VIOLATION_ACTIONS = new Set(["block", "warn", "track"]);

class Parser {
  tokens;
  pos = 0;
  constructor(tokens) {
    this.tokens = tokens;
  }
  peek() {
    return this.tokens[this.pos];
  }
  next() {
    const tok = this.tokens[this.pos];
    if (!tok) {
      throw new IclParseError("unexpected end of input");
    }
    this.pos += 1;
    return tok;
  }
  expectIdent(value) {
    const tok = this.next();
    if (tok.type !== "ident" || tok.value !== value) {
      throw new IclParseError(`expected '${value}', got '${tok.value}'`, tok.line);
    }
    return tok;
  }
  expectPunct(value) {
    const tok = this.next();
    if (tok.type !== "punct" || tok.value !== value) {
      throw new IclParseError(`expected '${value}', got '${tok.value}'`, tok.line);
    }
    return tok;
  }
  expectString(what) {
    const tok = this.next();
    if (tok.type !== "string") {
      throw new IclParseError(`expected string for ${what}, got '${tok.value}'`, tok.line);
    }
    return tok.value;
  }
  isIdent(value) {
    const tok = this.peek();
    return tok !== undefined && tok.type === "ident" && tok.value === value;
  }
  isPunct(value) {
    const tok = this.peek();
    return tok !== undefined && tok.type === "punct" && tok.value === value;
  }
  parseProgram() {
    const { title, intent } = this.parseIntentBlock();
    const fitness = [];
    while (this.isIdent("fitness")) {
      fitness.push(this.parseFitnessBlock());
    }
    const trailing = this.peek();
    if (trailing) {
      throw new IclParseError(`unexpected token '${trailing.value}' after program`, trailing.line);
    }
    return { intentTitle: title, intent, fitness };
  }
  parseIntentBlock() {
    this.expectIdent("intent");
    const title = this.expectString("intent title");
    this.expectPunct("{");
    this.expectIdent("purpose");
    this.expectPunct(":");
    const purpose = this.expectString("purpose");
    const { allow, forbid } = this.parseScopeSection();
    const invariants = this.isIdent("invariant") ? this.parseInvariantSection() : [];
    const acceptance = this.parseAcceptanceSection();
    const meta = this.isIdent("meta") ? this.parseMetaSection() : {};
    this.expectPunct("}");
    return { title, intent: { purpose, allow, forbid, invariants, acceptance, meta } };
  }
  parseScopeSection() {
    this.expectIdent("allow");
    this.expectPunct("{");
    const allow = [];
    while (!this.isPunct("}")) {
      allow.push(this.parseScopeRef());
    }
    this.expectPunct("}");
    this.expectIdent("forbid");
    this.expectPunct("{");
    const forbid = [];
    while (!this.isPunct("}")) {
      forbid.push(this.parseScopeRef());
    }
    this.expectPunct("}");
    return { allow, forbid };
  }
  parseScopeRef() {
    const kindTok = this.next();
    if (kindTok.type !== "ident" || !SCOPE_KINDS.has(kindTok.value)) {
      throw new IclParseError(`expected scope kind, got '${kindTok.value}'`, kindTok.line);
    }
    const ref = this.expectString("scope reference");
    const scope = {
      kind: kindTok.value,
      ref,
      line: kindTok.line
    };
    if (this.isIdent("as")) {
      this.next();
      scope.alias = this.expectString("scope alias");
    }
    const noteTok = this.peek();
    if (noteTok && noteTok.type === "note") {
      this.next();
      scope.note = noteTok.value;
    }
    return scope;
  }
  parseInvariantSection() {
    this.expectIdent("invariant");
    this.expectPunct("{");
    const invariants = [];
    while (!this.isPunct("}")) {
      const statement = this.expectString("invariant statement");
      let promote = false;
      if (this.isIdent("promote")) {
        this.next();
        promote = true;
      }
      invariants.push({ statement, promote });
    }
    this.expectPunct("}");
    return invariants;
  }
  parseAcceptanceSection() {
    this.expectIdent("accept");
    this.expectPunct("{");
    const acceptance = [];
    while (!this.isPunct("}")) {
      const criterion = this.expectString("acceptance criterion");
      this.expectIdent("by");
      const evTok = this.next();
      if (evTok.type !== "ident" || !EVIDENCE_KINDS2.has(evTok.value)) {
        throw new IclParseError(`expected evidence kind, got '${evTok.value}'`, evTok.line);
      }
      acceptance.push({ criterion, evidence: evTok.value });
    }
    this.expectPunct("}");
    return acceptance;
  }
  parseMetaSection() {
    this.expectIdent("meta");
    this.expectPunct("{");
    const meta = {};
    while (!this.isPunct("}")) {
      const keyTok = this.next();
      if (keyTok.type !== "ident") {
        throw new IclParseError(`expected meta key, got '${keyTok.value}'`, keyTok.line);
      }
      this.expectPunct(":");
      if (keyTok.value === "risk") {
        const valTok = this.next();
        if (valTok.type !== "ident" || !RISK_LEVELS.has(valTok.value)) {
          throw new IclParseError(`expected risk level, got '${valTok.value}'`, valTok.line);
        }
        meta.risk = valTok.value;
      } else if (keyTok.value === "decision") {
        meta.decision = this.expectString("decision");
      } else if (keyTok.value === "rationale") {
        meta.rationale = this.expectString("rationale");
      } else {
        throw new IclParseError(`unknown meta key '${keyTok.value}'`, keyTok.line);
      }
    }
    this.expectPunct("}");
    return meta;
  }
  parseFitnessBlock() {
    this.expectIdent("fitness");
    const name = this.expectString("fitness name");
    this.expectPunct("{");
    this.expectIdent("statement");
    this.expectPunct(":");
    const statement = this.expectString("fitness statement");
    this.expectIdent("kind");
    this.expectPunct(":");
    const kindTok = this.next();
    if (kindTok.type !== "ident" || !FITNESS_KINDS.has(kindTok.value)) {
      throw new IclParseError(`expected fitness kind, got '${kindTok.value}'`, kindTok.line);
    }
    const kind = kindTok.value;
    this.expectIdent("check");
    this.expectPunct(":");
    const check = this.parseCheck();
    this.expectIdent("when");
    this.expectPunct(":");
    const when = this.parseCadence();
    this.expectIdent("on_violation");
    this.expectPunct(":");
    const ovTok = this.next();
    if (ovTok.type !== "ident" || !VIOLATION_ACTIONS.has(ovTok.value)) {
      throw new IclParseError(`expected on_violation action, got '${ovTok.value}'`, ovTok.line);
    }
    const on_violation = ovTok.value;
    this.expectPunct("}");
    return { name, statement, kind, check, when, on_violation };
  }
  parseCheck() {
    const modeTok = this.next();
    if (modeTok.type !== "ident" || !["cmd", "query", "judge"].includes(modeTok.value)) {
      throw new IclParseError(`expected cmd/query/judge, got '${modeTok.value}'`, modeTok.line);
    }
    const spec = this.expectString("check spec");
    return { mode: modeTok.value, spec };
  }
  parseCadence() {
    const modeTok = this.next();
    if (modeTok.type !== "ident" || !["per_change", "periodic", "both"].includes(modeTok.value)) {
      throw new IclParseError(`expected per_change/periodic/both, got '${modeTok.value}'`, modeTok.line);
    }
    if (modeTok.value === "per_change") {
      return { mode: "per_change" };
    }
    this.expectPunct("(");
    const freqTok = this.next();
    if (freqTok.type !== "ident" || !FREQUENCIES.has(freqTok.value)) {
      throw new IclParseError(`expected frequency, got '${freqTok.value}'`, freqTok.line);
    }
    this.expectPunct(")");
    return {
      mode: modeTok.value,
      frequency: freqTok.value
    };
  }
}
function parse3(source) {
  const tokens = tokenize(source);
  return new Parser(tokens).parseProgram();
}

// src/acg/icl/static-check.ts
function staticCheck(program) {
  const errors3 = [];
  const warnings = [];
  const { intent, fitness } = program;
  if (intent.forbid.length === 0) {
    errors3.push({
      kind: "static",
      rule: 1,
      severity: "error",
      message: "forbid block is empty \u2014 an empty forbid permits unbounded change"
    });
  }
  const forbidKeys = new Set(intent.forbid.map((s2) => `${s2.kind}\x00${s2.ref}`));
  for (const a2 of intent.allow) {
    if (forbidKeys.has(`${a2.kind}\x00${a2.ref}`)) {
      errors3.push({
        kind: "static",
        rule: 2,
        severity: "error",
        message: `scope ${a2.kind} "${a2.ref}" appears in both allow and forbid`
      });
    }
  }
  if (intent.acceptance.length === 0) {
    errors3.push({
      kind: "static",
      rule: 3,
      severity: "error",
      message: "accept block is empty \u2014 a change with no completion criteria is forbidden"
    });
  }
  const hasPromote = intent.invariants.some((inv) => inv.promote);
  if (hasPromote && fitness.length === 0) {
    warnings.push({
      kind: "static",
      rule: 4,
      severity: "warning",
      message: "invariant marked promote but no fitness block declared \u2014 stage 8 must materialise it"
    });
  }
  return { errors: errors3, warnings };
}

// src/acg/icl/compile.ts
var SCOPE_KIND_MAP = {
  path: "path",
  glob: "glob",
  symbol: "symbol",
  surface: "public_surface",
  layer: "layer"
};
function mergeNote(scope) {
  const parts = [];
  if (scope.alias !== undefined)
    parts.push(scope.alias);
  if (scope.note !== undefined)
    parts.push(scope.note);
  return parts.length > 0 ? parts.join(" \u2014 ") : undefined;
}
function mapScopeRef(scope) {
  const note = mergeNote(scope);
  const out = { kind: SCOPE_KIND_MAP[scope.kind], ref: scope.ref };
  if (note !== undefined)
    out.note = note;
  return out;
}
function mapCadence(when) {
  switch (when.mode) {
    case "per_change":
      return { per_change: true, periodic: "none" };
    case "periodic":
      return { per_change: false, periodic: when.frequency };
    case "both":
      return { per_change: true, periodic: when.frequency };
  }
}
function buildEvaluator(check, judgeModelVersion) {
  if (check.mode === "judge") {
    return {
      mode: "llm_judged",
      spec: check.spec,
      reproducibility: {
        model_version: judgeModelVersion,
        votes: 3,
        tie_break: "fail_closed",
        input_fixing: "\uBCC0\uACBD diff \uC804\uCCB4"
      }
    };
  }
  return { mode: "deterministic", spec: check.spec };
}
function fitnessId(name) {
  return name;
}
function buildFitness(f3, env2) {
  return {
    schema_version: "0.1.0",
    kind: "acg.fitness-function.v1",
    produced_by: env2.produced_by,
    produced_at: env2.produced_at,
    id: fitnessId(f3.name),
    statement: f3.statement,
    fitness_kind: f3.kind,
    evaluator: buildEvaluator(f3.check, env2.judge_model_version),
    cadence: mapCadence(f3.when),
    on_violation: f3.on_violation,
    source_change: env2.work_item_id
  };
}
function buildChangeContract(program, env2) {
  const { intent } = program;
  return {
    schema_version: "0.1.0",
    kind: "acg.change-contract.v1",
    work_item_id: env2.work_item_id,
    produced_by: env2.produced_by,
    produced_at: env2.produced_at,
    purpose: intent.purpose,
    allowed_scope: intent.allow.map(mapScopeRef),
    forbidden_scope: intent.forbid.map(mapScopeRef),
    invariants: intent.invariants.map((inv) => ({
      statement: inv.statement,
      promotable: inv.promote
    })),
    acceptance: intent.acceptance.map((a2) => ({
      criterion: a2.criterion,
      evidence_kind: a2.evidence
    })),
    decision_ref: intent.meta.decision ?? null,
    risk_default: intent.meta.risk ?? "low"
  };
}
function compileIcl(source, env2) {
  let program;
  try {
    program = parse3(source);
  } catch (err) {
    if (err instanceof IclParseError || err instanceof IclTokenizeError) {
      return {
        ok: false,
        errors: [
          err.line !== undefined ? { kind: "parse", message: err.message, line: err.line } : { kind: "parse", message: err.message }
        ]
      };
    }
    throw err;
  }
  const { errors: staticErrors, warnings: staticWarnings } = staticCheck(program);
  if (staticErrors.length > 0) {
    return {
      ok: false,
      errors: staticErrors.map((e2) => ({
        kind: "static",
        rule: e2.rule,
        severity: e2.severity,
        message: e2.message
      }))
    };
  }
  const contractParsed = acgChangeContract.safeParse(buildChangeContract(program, env2));
  if (!contractParsed.success) {
    return { ok: false, errors: zodErrors(contractParsed.error) };
  }
  const fitnessFunctions = [];
  for (const f3 of program.fitness) {
    const parsed = acgFitnessFunction.safeParse(buildFitness(f3, env2));
    if (!parsed.success) {
      return { ok: false, errors: zodErrors(parsed.error) };
    }
    fitnessFunctions.push(parsed.data);
  }
  const warnings = staticWarnings.map((w2) => ({
    kind: "static",
    rule: w2.rule,
    severity: w2.severity,
    message: w2.message
  }));
  return warnings.length > 0 ? { ok: true, changeContract: contractParsed.data, fitnessFunctions, warnings } : { ok: true, changeContract: contractParsed.data, fitnessFunctions };
}
function zodErrors(error) {
  return error.issues.map((issue) => ({
    kind: "schema",
    message: issue.message,
    path: issue.path.join(".")
  }));
}
// src/acg/scope/symbol-expand.ts
import { join as join41, relative as relative9 } from "path";
async function expandForbiddenSymbols(contract, ctx) {
  if (!contract.forbidden_scope.some((r3) => r3.kind === "symbol")) {
    return { contract, resolved: 0, unresolved: [] };
  }
  const out = [];
  let resolved = 0;
  const unresolved = [];
  for (const ref of contract.forbidden_scope) {
    if (ref.kind !== "symbol") {
      out.push(ref);
      continue;
    }
    const declFiles = await resolveSymbolDeclFiles({
      symbol: ref.ref,
      repoRoot: ctx.repoRoot,
      sourceRoot: ctx.sourceRoot,
      language: ctx.language,
      dbPath: join41(ctx.cacheDir, "db"),
      workDir: join41(ctx.cacheDir, `q-symdecl-${ref.ref}`),
      ...ctx.binary ? { binary: ctx.binary } : {}
    }, ctx.deps);
    const files = declFiles.map((f3) => relative9(ctx.repoRoot, join41(ctx.sourceRoot, f3)));
    if (files.length === 0) {
      out.push(ref);
      unresolved.push(ref.ref);
      continue;
    }
    for (const f3 of files) {
      out.push({ kind: "path", ref: f3, note: `resolved from symbol ${ref.ref}` });
      resolved++;
    }
  }
  return { contract: { ...contract, forbidden_scope: out }, resolved, unresolved };
}

