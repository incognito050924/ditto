  init_work_item_store();
});

// src/core/fs.ts
import { randomBytes as randomBytes2 } from "crypto";
import { mkdir as mkdir2, rename as rename2, unlink as unlink2, writeFile as writeFile2 } from "fs/promises";
import { homedir as homedir3 } from "os";
import { dirname as dirname3, extname, isAbsolute, join as join8, parse as parse2, relative as relative2, resolve as resolve2 } from "path";
function isAtOrAboveHome(rel, isAbs = isAbsolute) {
  return rel === "" || !rel.startsWith("..") && !isAbs(rel);
}
async function findRepoRoot(start = process.cwd(), homeDir = homedir3()) {
  const resolved = resolve2(start);
  const worktree = parseWorktreePath(resolved);
  if (worktree !== null)
    return worktree.workspace;
  let current = resolved;
  let firstGitMatch = null;
  const root = parse2(current).root;
  const home = resolve2(homeDir);
  while (true) {
    if (isAtOrAboveHome(relative2(current, home)))
      break;
    if (await fileExists(join8(current, ".ditto")))
      return current;
    if (firstGitMatch === null && await fileExists(join8(current, ".git"))) {
      firstGitMatch = current;
    }
    if (current === root)
      break;
    current = dirname3(current);
  }
  if (firstGitMatch !== null)
    return firstGitMatch;
  throw new RepoRootNotFoundError(resolved);
}
async function resolveRepoRootForCreate(start = process.cwd(), homeDir = homedir3()) {
  try {
    return await findRepoRoot(start, homeDir);
  } catch {
    return resolve2(start);
  }
}
async function ensureDir(path) {
  await mkdir2(path, { recursive: true });
}
async function atomicWriteText(path, content) {
  await ensureDir(dirname3(path));
  const suffix = randomBytes2(6).toString("hex");
  const tmp = `${path}.${process.pid}.${suffix}.tmp`;
  try {
    await writeFile2(tmp, content, "utf8");
    await rename2(tmp, path);
  } catch (err) {
    if (await fileExists(tmp)) {
      try {
        await unlink2(tmp);
      } catch {}
    }
    throw err;
  }
}
async function readJson(path, schema) {
  const file = Bun.file(path);
  const text = await file.text();
  let raw;
  try {
    raw = JSON.parse(text);
  } catch (err) {
    throw new SchemaValidationError(path, err);
  }
  const result = schema.safeParse(raw);
  if (!result.success)
    throw new SchemaValidationError(path, result.error);
  return result.data;
}
function parseArchitectureSpecText(text, path) {
  const ext = extname(path).toLowerCase();
  if (ext === ".yaml" || ext === ".yml")
    return parseYaml(text);
  return JSON.parse(text);
}
async function readArchitectureSpec(path, schema) {
  const text = await Bun.file(path).text();
  return schema.parse(parseArchitectureSpecText(text, path));
}
async function writeJson(path, schema, value) {
  const result = schema.safeParse(value);
  if (!result.success)
    throw new SchemaValidationError(path, result.error);
  await atomicWriteText(path, `${JSON.stringify(result.data, null, 2)}
`);
  return result.data;
}
var RepoRootNotFoundError, SchemaValidationError;
var init_fs = __esm(() => {
  init_shared();
  init_worktree();
  RepoRootNotFoundError = class RepoRootNotFoundError extends Error {
    constructor(start) {
      super(`No .ditto or .git found from ${start} upward; cannot determine repo root`);
      this.name = "RepoRootNotFoundError";
    }
  };
  SchemaValidationError = class SchemaValidationError extends Error {
    path;
    constructor(path, cause) {
      super(`schema validation failed for ${path}: ${String(cause)}`, { cause });
      this.name = "SchemaValidationError";
      this.path = path;
    }
  };
});

