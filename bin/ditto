      const dot = str.indexOf(".");
      if (dot !== -1) {
        const f3 = str.substring(dot + 1).replace(/_/g, "");
        if (f3[f3.length - 1] === "0")
          node.minFractionDigits = f3.length;
      }
      return node;
    },
    stringify: stringifyNumber.stringifyNumber
  };
