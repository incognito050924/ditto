// src/core/codeql/doctor.ts
import { existsSync as existsSync5 } from "fs";
var LANG_BY_EXT = {
  ts: "javascript",
  tsx: "javascript",
  js: "javascript",
  jsx: "javascript",
  mjs: "javascript",
  cjs: "javascript",
  py: "python",
  rb: "ruby",
  java: "java",
  kt: "java",
  kts: "java",
  cs: "csharp",
  go: "go",
  cpp: "cpp",
  cc: "cpp",
  cxx: "cpp",
  c: "cpp",
  h: "cpp",
  hpp: "cpp",
  rs: "rust",
  swift: "swift"
};
var KNOWN_UNSUPPORTED_EXT = new Set(["php", "scala", "clj", "ex", "exs", "dart", "lua", "r"]);
function classifyExtensions(extCounts) {
  const byLang = new Map;
  const unsupported = [];
  for (const [ext, count] of Object.entries(extCounts)) {
    const lang = LANG_BY_EXT[ext];
    if (lang) {
      byLang.set(lang, (byLang.get(lang) ?? 0) + count);
    } else if (KNOWN_UNSUPPORTED_EXT.has(ext)) {
      unsupported.push({ ext, files: count });
    }
  }
  const languages = [...byLang.entries()].map(([language, files]) => ({ language, files })).sort((a2, b2) => b2.files - a2.files);
  return { languages, unsupported };
}
function classifyCodeqlTarget(input) {
  const findings = [];
  if (!input.cliAvailable) {
    findings.push({
      kind: "cli-unavailable",
      severity: "high",
      message: "CodeQL CLI\uB97C \uCC3E\uC744 \uC218 \uC5C6\uB2E4. \uBD84\uC11D \uBD88\uAC00 \u2014 `ditto doctor codeql --install`\uB85C \uC124\uCE58\uD558\uAC70\uB098 PATH\uC5D0 \uC9C1\uC811 \uC124\uCE58\uD558\uB77C."
    });
  }
  if (input.languages.length === 0) {
    const hint = input.unsupported.length > 0 ? ` (\uBBF8\uC9C0\uC6D0 \uC18C\uC2A4\uB9CC \uAC10\uC9C0: ${input.unsupported.map((u3) => u3.ext).join(", ")})` : "";
    findings.push({
      kind: input.unsupported.length > 0 ? "language-unsupported" : "no-source-detected",
      severity: "high",
      message: `CodeQL \uC9C0\uC6D0 \uC5B8\uC5B4 \uC18C\uC2A4\uB97C \uAC10\uC9C0\uD558\uC9C0 \uBABB\uD588\uB2E4${hint}.`
    });
    return findings;
  }
  if (input.unsupported.length > 0) {
    findings.push({
      kind: "language-unsupported",
      severity: "medium",
      message: `\uBBF8\uC9C0\uC6D0 \uC5B8\uC5B4 \uC18C\uC2A4\uAC00 \uC11E\uC5EC \uC788\uC5B4 \uD574\uB2F9 \uBD80\uBD84\uC740 \uBD84\uC11D\uB418\uC9C0 \uC54A\uB294\uB2E4: ${input.unsupported.map((u3) => `${u3.ext}(${u3.files})`).join(", ")}.`
    });
  }
  const compiled = input.languages.filter((l2) => selectBuildMode(l2.language) !== "none");
  if (compiled.length > 0 && input.buildVerified !== true) {
    findings.push({
      kind: "compiled-language-build-unverified",
      severity: "high",
      message: `\uCEF4\uD30C\uC77C \uC5B8\uC5B4(${compiled.map((l2) => l2.language).join(", ")})\uB294 clean build\uB85C \uCD94\uCD9C \uC644\uC804\uC131\uC744 \uC785\uC99D\uD574\uC57C \uD55C\uB2E4. build \uBBF8\uC785\uC99D \uC0C1\uD0DC\uC758 \uBD84\uC11D\uC740 \uBE48 \uCD94\uCD9C\uC744 '\uAE68\uB057\uD568'\uC73C\uB85C \uC624\uD310\uD560 \uC218 \uC788\uB2E4(\uBD80\uB85D4). --probe\uB85C \uC785\uC99D\uD558\uAC70\uB098 buildCommand\uB97C \uC81C\uACF5\uD558\uB77C.`
    });
  }
  return findings;
}
async function inspectCodeqlTarget(input, deps) {
  const extCounts = await deps.collectExtensions(input.sourceRoot);
  const { languages, unsupported } = classifyExtensions(extCounts);
  const cliAvailable = await deps.cliAvailable();
  const findings = classifyCodeqlTarget({
    languages,
    unsupported,
    cliAvailable,
    buildVerified: input.buildVerified
  });
  return {
    source_root: input.sourceRoot,
    detected_languages: languages,
    unsupported,
    cli_available: cliAvailable,
    build_verified: input.buildVerified === true,
    findings,
    finding_count: findings.length
  };
}
var defaultDoctorDeps = {
  collectExtensions: (sourceRoot) => countExtensions(sourceRoot),
  cliAvailable: async () => {
    const bin = process.env.CODEQL_BIN;
    if (bin)
      return existsSync5(bin);
    if (Bun.which("codeql"))
      return true;
    return existsSync5(`${process.env.HOME}/.local/share/gh/extensions/gh-codeql`);
  }
};

// src/core/codeql/dataflow-dod.ts
function pos(step) {
  return step.startLine != null ? `${step.file}:${step.startLine}` : step.file;
}
function toDataflowDoD(f3) {
  const first = f3.dataflow[0];
  const last = f3.dataflow[f3.dataflow.length - 1];
  if (first === undefined || last === undefined)
    return null;
  const source = pos(first);
  const sink = pos(last);
  return {
    given: `Untrusted input enters at the source ${source}.`,
    when: `The value reaches the sensitive sink ${sink} along the tracked dataflow path (${f3.ruleId}).`,
    then: "The source\u2192sink path is broken by a validated sanitizer/barrier, or the source is proven trusted.",
    oracle: `${source} \u2192 ${sink}`,
    rule_id: f3.ruleId
  };
}
function toDataflowDoDs(findings) {
  return findings.map(toDataflowDoD).filter((d2) => d2 !== null);
}

// src/core/codeql/review.ts
import { relative as relative12 } from "path";
async function runCodeqlReview(input, deps) {
  const result2 = await runCodeqlAnalysis(input, deps);
  const sarifText = await deps.readText(result2.sarifPath);
  const sha = deps.sha256(sarifText);
  const relPath = relative12(input.repoRoot, result2.sarifPath);
  const evidence = await deps.appendRecord(input.workItemId, {
    ref: {
      kind: "artifact",
      path: relPath,
      sha256: sha,
      summary: `CodeQL ${input.language} analysis: ${result2.findings.length} finding(s)${result2.fromCache ? " (cached)" : ""}`
    },
    captured_at: deps.now(),
    freshness: "fresh",
    stale_reason: null,
    portability: "local-artifact",
    artifact_available: true,
    exit_code: null,
    key_lines: result2.findings.slice(0, 10).map((f3) => `[${f3.ruleId}] ${f3.file ?? "?"}:${f3.startLine ?? "?"} (dataflow ${f3.dataflow.length})`)
  });
  return { result: result2, evidence };
}

// src/core/codeql/sarif-adapter.ts
function codeqlSeverity(level) {
  switch (level) {
    case "error":
      return "high";
    case "warning":
      return "medium";
    case "note":
    case "recommendation":
      return "low";
    default:
      return "medium";
  }
}
function dataflowSummary(f3) {
  if (f3.dataflow.length === 0)
    return "";
  const ends = [f3.dataflow[0], f3.dataflow[f3.dataflow.length - 1]];
  return ` (source ${ends[0].file}:${ends[0].startLine ?? "?"} \u2192 sink ${ends[1].file}:${ends[1].startLine ?? "?"}, ${f3.dataflow.length} steps)`;
}
function toReviewerFinding(f3) {
  return {
    severity: codeqlSeverity(f3.level),
    ...f3.file ? { file: f3.file } : {},
    ...f3.startLine != null ? { location: `${f3.startLine}` } : {},
    reason: `${f3.ruleId}: ${f3.message ?? "CodeQL finding"}${dataflowSummary(f3)}`
  };
}
function toReviewerFindings(findings) {
  return findings.map(toReviewerFinding);
}
function assembleReviewerOutput(findings, ctx) {
  const reviewerFindings = toReviewerFindings(findings);
  const hasHigh = reviewerFindings.some((f3) => f3.severity === "high" || f3.severity === "critical");
  const verdict2 = findings.length === 0 ? "pass" : hasHigh ? "fail" : "partial";
  const recommended = verdict2 === "pass" ? "No CodeQL findings; nothing to address." : hasHigh ? "Fix the high-severity dataflow finding(s), then re-run the CodeQL review." : "Triage the lower-severity findings, then re-run the CodeQL review.";
  return {
    schema_version: "0.1.0",
    id: ctx.id,
    work_item_id: ctx.workItemId,
    kind: "security-reviewer",
    reviewer: ctx.reviewer ?? "codeql",
    different_provider_than_generator: false,
    started_at: ctx.startedAt,
    verdict: verdict2,
    evidence: [],
    findings: reviewerFindings,
    unverified: [],
    recommended_next_action: recommended
  };
}

// src/core/codeql/review-to-ledger.ts
function doctorBlocks(report) {
  return report.findings.some((f3) => f3.severity === "high");
}
async function runCodeqlReviewToLedger(input, deps) {
  const doctor = await inspectCodeqlTarget({ sourceRoot: input.sourceRoot, buildVerified: input.buildVerified }, deps);
  if (doctorBlocks(doctor)) {
    return {
      gated: true,
      doctor,
      findings: 0,
      fromCache: false,
      verdict: null,
      highRiskWithoutEvidence: 0,
      ledgerWritten: false,
      dataflowDoDs: []
    };
  }
  const { result: result2 } = await runCodeqlReview(input, deps);
  const assembled = assembleReviewerOutput(result2.findings, {
    workItemId: input.workItemId,
    id: await deps.genReviewId(),
    startedAt: deps.now()
  });
  const output = reviewerOutput.parse(assembled);
  await deps.persistReviewerOutput(input.workItemId, output);
  const graph = projectReviewerOutputToAcgReview(output);
  await deps.persistLedger(input.workItemId, graph);
  const highRiskWithoutEvidence = graph.files.filter((f3) => f3.risk === "high" && f3.evidence === undefined).length;
  const dataflowDoDs = toDataflowDoDs(result2.findings);
  if (dataflowDoDs.length > 0) {
    await deps.persistDataflowDoDs(input.workItemId, dataflowDoDs);
  }
  return {
    gated: false,
    doctor,
    findings: result2.findings.length,
    fromCache: result2.fromCache,
    verdict: output.verdict,
    highRiskWithoutEvidence,
    ledgerWritten: true,
    dataflowDoDs
  };
}

