      status: "missing",
      raw: {},
      unavailable_reason: "codex user config not found"
    } : { host: "codex", source_file: userPath, status: "ok", raw: parseToml(userText) });
    return inventories;
  },
  async loadMcpServers(repoRoot) {
    const userPath = join4(homedir2(), ".codex", "config.toml");
