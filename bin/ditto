// src/cli/commands/push-gate.ts
import { mkdirSync, readFileSync as readFileSync7, writeFileSync } from "fs";
import { homedir as homedir11 } from "os";
import { dirname as dirname16, parse as parse4, relative as relative21, resolve as resolve22 } from "path";
init_fs();

// src/core/push-gate.ts
var ZERO_SHA = /^0{40}$/;
function parsePushedBranches(stdin3) {
  const out = [];
  for (const line of stdin3.split(`
`)) {
    const parts = line.trim().split(/\s+/);
    if (parts.length < 4)
      continue;
    const localSha = parts[1] ?? "";
    if (ZERO_SHA.test(localSha))
      continue;
    const branch = (parts[2] ?? "").match(/^refs\/heads\/(.+)$/)?.[1];
    if (branch)
      out.push(branch);
  }
  return out;
}
function pushGateDecision(pushedBranches, config) {
  if (!config)
    return { run: false };
  const protectedSet = new Set(config.protected_branches);
  const matched = protectedSet.has("*") ? [...pushedBranches] : pushedBranches.filter((b3) => protectedSet.has(b3));
  if (matched.length === 0)
    return { run: false };
  return { run: true, test_command: config.test_command, matched };
}
function normDir(d2) {
  return d2.replace(/^\.\//, "").replace(/\/+$/, "");
}
function isRepoDeclared(recipe2, repoRelDir) {
  const dir = normDir(repoRelDir);
  if (dir === "" || dir === ".")
    return false;
  return recipe2.repos?.some((r4) => normDir(r4.dir) === dir) ?? false;
}
function resolvePushGate(recipe2, repoRelDir) {
  const dir = normDir(repoRelDir);
  if (dir === "" || dir === ".")
    return recipe2.push_gate;
  return recipe2.repos?.find((r4) => normDir(r4.dir) === dir)?.push_gate;
}

// src/core/push-gate-cache.ts
import { join as join82 } from "path";
var MAX_GREEN_TREES = 20;
function shouldSkipGate(state, cache) {
  if (!state.clean)
    return false;
  return cache.trees.some((t3) => t3.tree === state.tree);
}
function shouldRecordGreen(commandRun, gateCommand, clean) {
  return clean && commandRun === gateCommand;
}
function addGreenTree(cache, tree, command, recordedAt) {
  const kept = cache.trees.filter((t3) => t3.tree !== tree);
  kept.push({ tree, recorded_at: recordedAt, command });
  return { trees: kept.slice(-MAX_GREEN_TREES) };
}
function greenCachePath(cwd) {
  return join82(cwd, ".ditto", "local", "push-gate-green.json");
}

// src/cli/commands/push-gate.ts
var GUIDANCE = "Push a non-protected branch, or set DITTO_SKIP_HOOKS=1 to bypass.";
async function execPushGate(inp) {
  if (inp.env[KILL_SWITCH])
    return { exitCode: 0 };
  if (inp.malformedRecipe) {
    return {
      exitCode: 1,
      message: `push-gate: recipe.yaml is malformed \u2014 cannot evaluate the push gate, blocking. ${GUIDANCE}`
    };
  }
  const decision = pushGateDecision(parsePushedBranches(inp.stdin), inp.gate);
  if (!decision.run)
    return { exitCode: 0 };
  if (inp.treeState && inp.greenCache && shouldSkipGate(inp.treeState, inp.greenCache)) {
    return {
      exitCode: 0,
      message: `push-gate: green-tree cache hit (${inp.treeState.tree.slice(0, 12)}) \u2014 \`${decision.test_command}\` already passed on this exact clean tree, skipping re-run.`
    };
  }
  const outcome = await inp.runTest(decision.test_command, inp.cwd);
  switch (outcome.kind) {
    case "passed":
      if (inp.treeState && inp.recordGreen && shouldRecordGreen(decision.test_command, decision.test_command, inp.treeState.clean)) {
        inp.recordGreen(inp.treeState.tree, decision.test_command);
      }
      return { exitCode: 0 };
    case "failed":
      return {
        exitCode: 1,
        message: `push-gate: \`${decision.test_command}\` failed \u2014 push blocked. Fix the tests, or set DITTO_SKIP_HOOKS=1 to bypass.`
      };
    case "unrunnable":
      return {
        exitCode: 1,
        message: `push-gate: cannot run \`${decision.test_command}\` (${outcome.reason}) \u2014 blocking. ${GUIDANCE}`
      };
    case "timeout":
      return {
        exitCode: 1,
        message: `push-gate: \`${decision.test_command}\` timed out after ${outcome.timeoutMs}ms \u2014 blocking. ${GUIDANCE}`
      };
  }
}
var PUSH_GATE_TIMEOUT_MS = 10 * 60 * 1000;
var defaultRunTest = (testCommand, cwd) => runTestCommand(testCommand, cwd, { timeoutMs: PUSH_GATE_TIMEOUT_MS });
async function resolvePushGateRoot(cwd, explicitRoot, homeDir = homedir11()) {
  const start = resolve22(cwd);
  if (explicitRoot !== undefined && explicitRoot !== "") {
    const recipeRoot2 = resolve22(explicitRoot);
    return { recipeRoot: recipeRoot2, repoRelDir: relative21(recipeRoot2, start) };
  }
  const home = resolve22(homeDir);
  const fsRoot = parse4(start).root;
  let current = dirname16(start);
  while (true) {
    if (isAtOrAboveHome(relative21(current, home)))
      break;
    const recipe2 = await loadResolvedRecipe(current, undefined);
    if (isRepoDeclared(recipe2, relative21(current, start))) {
      return { recipeRoot: current, repoRelDir: relative21(current, start) };
    }
    if (current === fsRoot)
      break;
    current = dirname16(current);
  }
  const recipeRoot = await resolveRepoRootForCreate(start, homeDir);
  return { recipeRoot, repoRelDir: relative21(recipeRoot, start) };
}
function gitOut(gitArgs, cwd) {
  try {
    const p2 = Bun.spawnSync(["git", ...gitArgs], {
      cwd,
      stdout: "pipe",
      stderr: "ignore",
      stdin: "ignore"
    });
    if (p2.exitCode !== 0)
      return null;
    return (p2.stdout?.toString() ?? "").trim();
  } catch {
    return null;
  }
}
function computeTreeState(cwd) {
  const tree = gitOut(["rev-parse", "HEAD^{tree}"], cwd);
  if (!tree)
    return;
  const status = gitOut(["status", "--porcelain"], cwd);
  return { tree, clean: status === "" };
}
function readGreenCache(cwd) {
  try {
    const parsed = JSON.parse(readFileSync7(greenCachePath(cwd), "utf8"));
    if (parsed && typeof parsed === "object" && Array.isArray(parsed.trees)) {
      return parsed;
    }
  } catch {}
  return { trees: [] };
}
function makeRecordGreen(cwd, cache) {
  return (tree, command) => {
    try {
      const next = addGreenTree(cache, tree, command, new Date().toISOString());
      const path = greenCachePath(cwd);
      mkdirSync(dirname16(path), { recursive: true });
      writeFileSync(path, `${JSON.stringify(next, null, 2)}
`);
    } catch {}
  };
}
async function maybeRecordGreenForGate(cwd, commandRun, exitCode) {
  try {
    if (exitCode !== 0)
      return;
    const { recipeRoot, repoRelDir } = await resolvePushGateRoot(cwd);
    const recipe2 = await loadResolvedRecipe(recipeRoot, undefined, () => {});
    const gate2 = resolvePushGate(recipe2, repoRelDir);
    if (!gate2)
      return;
    const treeState = computeTreeState(cwd);
    if (!treeState)
      return;
    if (!shouldRecordGreen(commandRun, gate2.test_command, treeState.clean))
      return;
    makeRecordGreen(recipeRoot, readGreenCache(recipeRoot))(treeState.tree, gate2.test_command);
  } catch {}
}
async function readStdin() {
  try {
    return await Bun.stdin.text();
  } catch {
    return "";
  }
}
var pushGateCommand = defineCommand({
  meta: {
    name: "push-gate",
    description: "Pre-push gate: read git pre-push stdin, resolve the recipe push_gate for this repo, and run its test_command before allowing a push to a protected branch. Blocks (non-zero) on a failing/unrunnable gate or a malformed recipe; exits 0 otherwise. Bypass with DITTO_SKIP_HOOKS=1."
  },
  args: {
    "workspace-root": {
      type: "string",
      description: "Absolute path to the TRUSTED workspace root whose recipe.yaml governs this push. The installed sub-repo pre-push hook passes this (wired by setup/workspace sync) so a cloned sub-repo NEVER resolves its own recipe (ROOT-ONLY trust). Omit for a normal single-repo push."
    }
  },
  run: async ({ args }) => {
    const stdin3 = await readStdin();
    const cwd = process.cwd();
    const { recipeRoot, repoRelDir } = await resolvePushGateRoot(cwd, args["workspace-root"]);
    let malformedRecipe = false;
    const recipe2 = await loadResolvedRecipe(recipeRoot, undefined, () => {
      malformedRecipe = true;
    });
    const gate2 = resolvePushGate(recipe2, repoRelDir);
    const treeState = computeTreeState(cwd);
    const greenCache = readGreenCache(recipeRoot);
    const result2 = await execPushGate({
      stdin: stdin3,
      gate: gate2,
      malformedRecipe,
      env: process.env,
      cwd,
      runTest: defaultRunTest,
      ...treeState ? { treeState } : {},
      greenCache,
      recordGreen: makeRecordGreen(recipeRoot, greenCache)
    });
    if (result2.message)
      process.stderr.write(`${result2.message}
`);
    process.exit(result2.exitCode);
  }
});

// src/cli/commands/refactor.ts
import { join as join83 } from "path";

// src/acg/scope/unit-resolve.ts
var API_LAYERS = ["controller", "controllers", "route", "routes"];
function parseUnitScope(raw) {
  const unit = raw.trim();
  if (unit === "all")
    return { kind: "all" };
  if (unit === "api")
    return { kind: "api" };
  if (unit.startsWith("layer:")) {
    const name = unit.slice("layer:".length).trim();
    if (name.length === 0)
      throw new Error("layer:<name> requires a non-empty layer name");
    return { kind: "layer", name };
  }
  if (unit.startsWith("component:")) {
    const name = unit.slice("component:".length).trim();
    if (name.length === 0)
      throw new Error("component:<name> requires a non-empty component name");
    return { kind: "component", name };
  }
  return { kind: "glob", glob: unit };
}
function fileInUnit(unit, path, archSpec) {
  switch (unit.kind) {
    case "all":
      return true;
    case "api":
      return API_LAYERS.some((seg) => path.split("/").includes(seg));
    case "layer":
      return archSpec !== undefined && pathToLayer(path, archSpec.layers) === unit.name;
    case "component":
      return layerOf(path) === unit.name;
    case "glob":
      return globToRegExp(unit.glob).test(path);
  }
}
function resolveUnitScope(unit, files, archSpec) {
  return files.filter((f4) => fileInUnit(unit, f4, archSpec));
}

// src/acg/tidy/unit-refactor.ts
function decideUnitTidy(input) {
  const debtDecreased = input.debt.after < input.debt.before;
  const residualQuestions = [];
  if (!input.baselineGreen) {
    residualQuestions.push(`unit ${input.unit}: baseline suite is red \u2014 tidy cannot start on a non-green baseline (G-R1)`);
    return {
      unit: input.unit,
      autoCommit: "none",
      barMet: false,
      debtDecreased,
      behaviorGreen: input.behaviorGreen,
      residualQuestions
    };
  }
  if (!input.coverageProviderPresent) {
    residualQuestions.push(`unit ${input.unit}: no coverage provider wired (provider 0\uAC74) \u2014 behavior preservation cannot be witnessed at full bar; tidy accumulates as diff-only on the isolated branch for human PR review, not auto-committed (\xA74.4)`);
    return {
      unit: input.unit,
      autoCommit: "diff-only",
      barMet: false,
      debtDecreased,
      behaviorGreen: input.behaviorGreen,
      residualQuestions
    };
  }
  if (input.unitCovered !== true) {
    residualQuestions.push(`unit ${input.unit}: not covered by characterization \u2014 generate a characterization for the uncovered portion first, then retry (auto-tidy-ineligible until covered)`);
    return {
      unit: input.unit,
      autoCommit: "none",
      barMet: false,
      debtDecreased,
      behaviorGreen: input.behaviorGreen,
      residualQuestions
    };
  }
  if (!input.behaviorGreen) {
    residualQuestions.push(`unit ${input.unit}: behavior preservation NOT green (L1/L2) \u2014 refactor is not auto-tidy-eligible (revert basis)`);
    return {
      unit: input.unit,
      autoCommit: "none",
      barMet: false,
      debtDecreased,
      behaviorGreen: input.behaviorGreen,
      residualQuestions
    };
  }
  if (!debtDecreased) {
    residualQuestions.push(`unit ${input.unit}: absolute fitness debt did not decrease (${input.debt.before}\u2192${input.debt.after}) \u2014 not a tidy improvement`);
    return {
      unit: input.unit,
      autoCommit: "none",
      barMet: false,
      debtDecreased,
      behaviorGreen: input.behaviorGreen,
      residualQuestions
    };
  }
  return {
    unit: input.unit,
    autoCommit: "full",
    barMet: true,
    debtDecreased,
    behaviorGreen: input.behaviorGreen,
    residualQuestions: []
  };
}

// src/cli/commands/refactor.ts
init_fs();
function trackedSrcFiles(repoRoot) {
  const r4 = Bun.spawnSync(["git", "ls-files", "--", "src"], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (r4.exitCode !== 0) {
    throw new Error(`git ls-files failed: ${r4.stderr?.toString().trim() ?? ""}`);
  }
  return r4.stdout.toString().split(`
`).map((s2) => s2.trim()).filter((s2) => s2.length > 0 && /\.[cm]?tsx?$/.test(s2) && !/\.(test|spec)\./.test(s2));
}
async function loadArchSpec2(repoRoot) {
  const specPath = join83(repoRoot, ".ditto", "architecture-spec.json");
  try {
    return await readArchitectureSpec(specPath, acgArchitectureSpec);
  } catch {
    return;
  }
}
var refactorCommand = defineCommand({
  meta: {
    name: "refactor",
    description: "Unit-scoped behavior-preserving tidy of standing code (baseline=HEAD) \u2014 `--scope all|component:<name>|layer:<name>|api|<glob>`"
  },
  args: {
    scope: {
      type: "string",
      description: "Architecture unit: all | component:<name> | layer:<name> | api | <glob>",
      required: true
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let unit;
    try {
      unit = parseUnitScope(args.scope);
    } catch (err) {
      writeError(`refactor: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    try {
      const repoRoot = await resolveRepoRootForCreate();
      const files = trackedSrcFiles(repoRoot);
      const archSpec = await loadArchSpec2(repoRoot);
      const resolved = resolveUnitScope(unit, files, archSpec);
      const decision = decideUnitTidy({
        unit: args.scope,
        files: resolved,
        baselineGreen: true,
        debt: { before: resolved.length, after: resolved.length },
        behaviorGreen: true,
        coverageProviderPresent: false
      });
      if (format === "json") {
        writeJson2({
          unit: args.scope,
          files: resolved,
          autoCommit: decision.autoCommit,
          barMet: decision.barMet,
          residualQuestions: decision.residualQuestions
        });
      } else {
        writeHuman(`refactor ${args.scope}: ${resolved.length} file(s), autoCommit=${decision.autoCommit}, barMet=${decision.barMet}`);
        for (const q2 of decision.residualQuestions)
          writeHuman(`  residual: ${q2}`);
      }
    } catch (err) {
      writeError(`refactor failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});

// src/cli/commands/review.ts
