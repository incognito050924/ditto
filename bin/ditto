function parseFunctions(raw) {
  const arr = Array.isArray(raw) ? raw : [raw];
  return arr.map((f4) => acgFitnessFunction.parse(f4));
}
var fitnessCommand = defineCommand({
  meta: { name: "fitness", description: "Run ACG fitness functions and emit an AssuranceSnapshot" },
  subCommands: {
    run: defineCommand({
      meta: {
        name: "run",
        description: "Evaluate fitness function(s) per the ADR-0004 cost policy \u2192 AssuranceSnapshot"
      },
      args: {
        "work-item": { type: "string", description: "Work item id", required: true },
        from: {
          type: "string",
          description: "Path to a fitness-function JSON (or array). Omit to load the work item's stored fitness-functions.json"
        },
        trigger: { type: "string", description: "per_change|periodic (default per_change)" },
        period: { type: "string", description: "daily|weekly|on_release (for trigger=periodic)" },
        risk: { type: "string", description: "low|medium|high (executed risk-tiered scheduling)" },
        "risk-known": {
          type: "boolean",
          default: false,
          description: "Risk tier is known (from ImpactGraph). Default false \u2192 fail-closed escalate"
        },
        verdicts: {
          type: "string",
          description: "Path to an agent-produced acg.fitness-verdict.v1 file. Routes llm_judged/executed functions to the injected provider; deterministic still runs commands"
        },
        execute: {
          type: "boolean",
          default: false,
          description: "Run executed-mode functions directly (spec + execution policy: timeout/retries/flake) instead of consuming injected verdicts. Costly \u2014 opt-in (ADR-0004 Q4). llm_judged still needs --verdicts"
        },
        output: { type: "string", description: "Output format: human|json", default: "human" }
      },
      run: async ({ args }) => {
        let format;
        try {
          format = parseOutputFormat(args.output);
        } catch (err) {
          writeError(err instanceof Error ? err.message : String(err));
          process.exit(USAGE_ERROR_EXIT);
          return;
        }
        try {
          const repoRoot = await resolveRepoRootForCreate();
          const fromPath = typeof args.from === "string" ? args.from : undefined;
          let functions;
          if (fromPath) {
            try {
              functions = parseFunctions(JSON.parse(await Bun.file(fromPath).text()));
            } catch (err) {
              writeError(`fitness run: cannot read valid fitness-function(s) from ${fromPath}: ${err instanceof Error ? err.message : String(err)}`);
              process.exit(USAGE_ERROR_EXIT);
              return;
            }
          } else {
            const stored = await new FitnessFunctionStore(repoRoot).read(args["work-item"]);
            if (stored === null) {
              writeError(`fitness run: no --from and no stored fitness-functions.json for ${args["work-item"]} (run \`ditto change-contract\` first, or pass --from)`);
              process.exit(USAGE_ERROR_EXIT);
              return;
            }
            functions = stored;
          }
          const ctx = {
            trigger: args.trigger === "periodic" ? "periodic" : "per_change",
            period: args.period,
            changeRef: args["work-item"],
            risk: args.risk,
            riskKnown: args["risk-known"],
            producedAt: new Date().toISOString()
          };
          const verdictsPath2 = typeof args.verdicts === "string" ? args.verdicts : undefined;
          const provider = args.execute ? executingProvider(repoRoot, verdictsPath2) : verdictsPath2 ? compositeProvider(repoRoot, verdictsPath2) : commandProvider(repoRoot);
          const snapshot = await runFitness(functions, ctx, provider);
          const path = localDir(repoRoot, "work-items", args["work-item"], "assurance-snapshot.json");
          await ensureDir(localDir(repoRoot, "work-items", args["work-item"]));
          await writeJson(path, acgAssuranceSnapshot, snapshot);
          const failed = snapshot.results.filter((r4) => r4.outcome === "fail").length;
          if (format === "json") {
            writeJson2({
              work_item_id: args["work-item"],
              results: snapshot.results.length,
              failed,
              outcomes: snapshot.results.map((r4) => ({ id: r4.function_id, outcome: r4.outcome }))
            });
          } else {
            writeHuman(`fitness: ${snapshot.results.length} function(s), ${failed} fail \u2192 assurance-snapshot.json`);
          }
          if (failed > 0)
            process.exit(RUNTIME_ERROR_EXIT);
        } catch (err) {
          writeError(`fitness run failed: ${err instanceof Error ? err.message : String(err)}`);
          process.exit(RUNTIME_ERROR_EXIT);
        }
      }
    }),
    drift: defineCommand({
      meta: {
        name: "drift",
        description: "Aggregate AssuranceSnapshots across work items into a per-function SLOP trend (\uB2E8\uACC48)"
      },
      args: {
        gate: {
          type: "boolean",
          default: false,
          description: "Exit non-zero when a function is on a rising SLOP trend (CI gate on accumulation across changes). C1 scheduler is a CI/cron concern, not in-repo"
        },
        "min-new-violations": {
          type: "string",
          description: "Gate threshold: only flag rising functions with at least N cumulative new violations across changes (default 0 = any rising)"
        },
        output: { type: "string", description: "Output format: human|json", default: "human" }
      },
      run: async ({ args }) => {
        let format;
        try {
          format = parseOutputFormat(args.output);
        } catch (err) {
          writeError(err instanceof Error ? err.message : String(err));
          process.exit(USAGE_ERROR_EXIT);
          return;
        }
        try {
          const repoRoot = await resolveRepoRootForCreate();
          const report = computeDrift(await loadAssuranceSnapshots(repoRoot));
          const minNew = Number.parseInt(args["min-new-violations"] ?? "0", 10);
          const assessment = args.gate ? assessDrift(report, Number.isNaN(minNew) ? 0 : minNew) : null;
          if (format === "json") {
            writeJson2(assessment ? {
              ...report,
              gate: {
                concerning: assessment.concerning.map((f4) => f4.function_id),
                min_new_violations: assessment.min_new_violations
              }
            } : report);
          } else if (report.snapshots === 0) {
            writeHuman("drift: no AssuranceSnapshots across work items yet (nothing to trend)");
          } else {
            writeHuman(`drift: ${report.functions.length} function(s) across ${report.snapshots} snapshot(s)`);
            for (const f4 of report.functions) {
              const v2 = f4.first_violations === null ? "\u2014" : `${f4.first_violations}\u2192${f4.last_violations}`;
              writeHuman(`  ${f4.direction.padEnd(12)} ${f4.function_id} (violations ${v2}, +${f4.cumulative_new_violations} new across changes, ${f4.fail_count} fail)`);
            }
            if (assessment && assessment.concerning.length > 0) {
              writeHuman(`
GATE: ${assessment.concerning.length} function(s) on a rising trend:`);
              for (const r4 of assessment.reasons)
                writeHuman(`  ${r4}`);
            }
          }
          if (assessment && assessment.concerning.length > 0)
            process.exit(RUNTIME_ERROR_EXIT);
        } catch (err) {
          writeError(`fitness drift failed: ${err instanceof Error ? err.message : String(err)}`);
          process.exit(RUNTIME_ERROR_EXIT);
        }
      }
    })
  }
});

// src/cli/commands/github.ts
init_fs();

// src/core/github-status-match.ts
function normalizeStatusName(name) {
  return name.toLowerCase().replace(/[\s_-]+/g, "");
}
var CLAIM_AUTODETECT_TABLE = {
  in_progress: ["inprogress"]
};
var STATUS_AUTODETECT_TABLE = {
  done: ["done"]
};
function matchStatusOptions(options, table) {
  const matched = {};
  const ambiguous = {};
  for (const [key, aliases] of Object.entries(table)) {
    const aliasSet = new Set(aliases);
    const hits = options.filter((o4) => aliasSet.has(normalizeStatusName(o4.name)));
    if (hits.length === 1) {
      const hit = hits[0];
      if (hit)
        matched[key] = hit.id;
    } else if (hits.length > 1) {
      ambiguous[key] = hits.map((o4) => o4.name);
    }
  }
  return { matched, ambiguous };
}
function autodetectStatusMaps(options) {
  const claim2 = matchStatusOptions(options, CLAIM_AUTODETECT_TABLE);
  const status = matchStatusOptions(options, STATUS_AUTODETECT_TABLE);
  const warnings = [];
  for (const [key, names] of Object.entries({ ...claim2.ambiguous, ...status.ambiguous })) {
    warnings.push(`Auto-detect ambiguous for '${key}': multiple board options normalize alike (${names.join(", ")}) \u2014 left unset, map it explicitly with \`ditto github setup --claim-status-map\`/\`--status-map\`.`);
  }
  return { statusMap: status.matched, claimStatusMap: claim2.matched, warnings };
}

// src/cli/commands/github.ts
var STATUS_MAP_KEYS = ["done", "abandoned"];
var CLAIM_STATUS_MAP_KEYS = ["in_progress", "blocked"];
function parseProjectRef(input) {
  const raw = input.trim();
  if (raw === "")
    return null;
  if (/github\.com/i.test(raw) || raw.includes("://")) {
    const m4 = /\/(?:users|orgs)\/([^/]+)\/projects\/(\d+)/i.exec(raw);
    if (!m4)
      return null;
    const number2 = Number.parseInt(m4[2] ?? "", 10);
    if (!Number.isInteger(number2) || number2 <= 0)
      return null;
    return { owner: m4[1] ?? "", number: number2 };
  }
  const parts = raw.split("/");
  if (parts.length !== 2)
    return null;
  const owner = (parts[0] ?? "").trim();
  const number = Number.parseInt((parts[1] ?? "").trim(), 10);
  if (owner === "" || !Number.isInteger(number) || number <= 0)
    return null;
  return { owner, number };
}
function parseKeyedOptionFlag(input, allowedKeys) {
  const map = {};
  const dropped = [];
  const allowed = allowedKeys;
  for (const part of input.split(",")) {
    const entry = part.trim();
    if (entry === "")
      continue;
    const eq = entry.indexOf("=");
    const key = (eq === -1 ? entry : entry.slice(0, eq)).trim();
    const value = (eq === -1 ? "" : entry.slice(eq + 1)).trim();
    if (allowed.includes(key) && value !== "") {
      map[key] = value;
    } else {
      dropped.push(entry);
    }
  }
  return { map, dropped };
}
function parseStatusMapFlag(input) {
  return parseKeyedOptionFlag(input, STATUS_MAP_KEYS);
}
function parseClaimStatusMapFlag(input) {
  return parseKeyedOptionFlag(input, CLAIM_STATUS_MAP_KEYS);
}
function extractStatusOptions(fieldList) {
  const field = selectStatusField(fieldList);
  if (!field)
    return null;
  return field.options.length === 0 ? null : field.options;
}
async function buildGithubConfig(io, gh, opts) {
  const notices = [];
  const rawRef = opts.project ?? (opts.nonInteractive ? "" : (await io.ask("\uB300\uC0C1 Project (owner/number \uB610\uB294 URL): ")).trim());
  const ref = parseProjectRef(rawRef);
  if (!ref) {
    return { ok: false, reason: "invalid_project", detail: rawRef };
  }
  const res = gh.projectFieldList(ref.owner, ref.number);
  if (!res.ok) {
    return { ok: false, reason: res.reason, detail: res.detail };
  }
  const options = extractStatusOptions(res.value);
  if (!options) {
    return {
      ok: false,
      reason: "no_status_field",
      detail: `Project ${ref.owner}/${ref.number}\uC5D0 status single-select \uD544\uB4DC\uAC00 \uC5C6\uC74C`
    };
  }
  const optionIds = new Set(options.map((o4) => o4.id));
  const detected = autodetectStatusMaps(options);
  for (const w2 of detected.warnings)
    notices.push(w2);
  const viewRes = gh.projectView(ref.owner, ref.number);
  const nodeId2 = viewRes.ok && typeof viewRes.value?.id === "string" ? viewRes.value.id : undefined;
  if (!nodeId2) {
    notices.push("Project node_id\uB97C \uC870\uD68C\uD558\uC9C0 \uBABB\uD568 \u2014 \uBCF4\uB4DC status \uBC18\uC601(ac-5)\uC740 skip\uB41C\uB2E4(\uB9C1\uD06C\xB7\uD45C\uC2DC\uB294 \uC815\uC0C1).");
  }
  const choiceOptions = [
    { label: "(\uB9E4\uD551 \uC548 \uD568 \u2014 \uBC18\uC601 \uC2DC skip)", value: "" },
    ...options.map((o4) => ({ label: o4.name, value: o4.id }))
  ];
  const statusMap = {};
  if (opts.nonInteractive || opts.statusMap !== undefined) {
    const { map, dropped } = parseStatusMapFlag(opts.statusMap ?? "");
    for (const d2 of dropped)
      notices.push(`status-map \uD56D\uBAA9 \uBB34\uC2DC(\uD0A4\uB294 done|abandoned\uB9CC): ${d2}`);
    for (const key of STATUS_MAP_KEYS) {
      const optId = map[key];
      if (optId === undefined)
        continue;
      if (!optionIds.has(optId)) {
        notices.push(`\uB9E4\uD551 \uC635\uC158 id '${optId}'(${key})\uAC00 Project status\uC5D0 \uC5C6\uC74C \u2014 skip`);
        continue;
      }
      statusMap[key] = optId;
    }
  } else {
    for (const key of STATUS_MAP_KEYS) {
      const picked = await select(io, `ditto '${key}' \u2192 Project status \uC635\uC158 \uC120\uD0DD`, choiceOptions, detected.statusMap[key] ?? "");
      if (picked !== "" && optionIds.has(picked))
        statusMap[key] = picked;
    }
  }
  const claimStatusMap = {};
  if (opts.nonInteractive || opts.claimStatusMap !== undefined) {
    const { map, dropped } = parseClaimStatusMapFlag(opts.claimStatusMap ?? "");
    for (const d2 of dropped)
      notices.push(`claim-status-map \uD56D\uBAA9 \uBB34\uC2DC(\uD0A4\uB294 in_progress|blocked\uB9CC): ${d2}`);
    for (const key of CLAIM_STATUS_MAP_KEYS) {
      const optId = map[key];
      if (optId === undefined)
        continue;
      if (!optionIds.has(optId)) {
        notices.push(`claim \uB9E4\uD551 \uC635\uC158 id '${optId}'(${key})\uAC00 Project status\uC5D0 \uC5C6\uC74C \u2014 skip`);
        continue;
      }
      claimStatusMap[key] = optId;
    }
  } else {
    for (const key of CLAIM_STATUS_MAP_KEYS) {
      const picked = await select(io, `ditto '${key}' \u2192 Project status \uC635\uC158 \uC120\uD0DD(claim \uBCF4\uB4DC \uBC18\uC601)`, choiceOptions, detected.claimStatusMap[key] ?? "");
      if (picked !== "" && optionIds.has(picked))
        claimStatusMap[key] = picked;
    }
  }
  const autoReflect = opts.autoReflect ?? (opts.nonInteractive ? false : await confirm(io, "\uC644\uB8CC \uC2DC Project status \uC790\uB3D9 \uBC18\uC601(auto-reflect)?", false));
  const candidate = {
    project: { owner: ref.owner, number: ref.number, ...nodeId2 ? { node_id: nodeId2 } : {} },
    status_map: statusMap,
    ...Object.keys(claimStatusMap).length > 0 ? { claim_status_map: claimStatusMap } : {},
    auto_reflect: autoReflect
  };
  const parsed = dittoConfigGithub.safeParse(candidate);
  if (!parsed.success) {
    return { ok: false, reason: "schema_invalid", detail: parsed.error.message.slice(0, 200) };
  }
  return { ok: true, config: parsed.data, notices };
}
function mergeDetectedMap(existing, detected, knownKeys, mode, mapLabel, notices) {
  const result2 = { ...existing };
  for (const key of knownKeys) {
    const det = detected[key];
    if (mode === "fill") {
      if (det !== undefined && result2[key] === undefined) {
        result2[key] = det;
        notices.push(`${mapLabel}: backfilled '${key}'=${det} (auto-detected from board).`);
      }
    } else if (det !== undefined) {
      if (result2[key] !== det) {
        notices.push(result2[key] === undefined ? `${mapLabel}: set '${key}'=${det} (auto-detected from board).` : `${mapLabel}: re-synced '${key}'=${det} (was ${result2[key]}; board-authoritative).`);
      }
      result2[key] = det;
    } else if (result2[key] !== undefined) {
      notices.push(`${mapLabel}: kept existing '${key}'=${result2[key]} \u2014 not re-derivable from the board this run (preserved, not deleted).`);
    }
  }
  return result2;
}
function syncStatusMaps(gh, existing, opts) {
  const notices = [];
  const ref = { owner: existing.project.owner, number: existing.project.number };
  const res = gh.projectFieldList(ref.owner, ref.number);
  if (!res.ok)
    return { ok: false, reason: res.reason, detail: res.detail };
  const options = extractStatusOptions(res.value);
  if (!options) {
    return {
      ok: false,
      reason: "no_status_field",
      detail: `Project ${ref.owner}/${ref.number}\uC5D0 status single-select \uD544\uB4DC\uAC00 \uC5C6\uC74C`
    };
  }
  const detected = autodetectStatusMaps(options);
  let nodeId2 = existing.project.node_id;
  const viewRes = gh.projectView(ref.owner, ref.number);
  if (viewRes.ok && typeof viewRes.value?.id === "string") {
    nodeId2 = viewRes.value.id;
  } else if (!nodeId2) {
    notices.push("Project node_id \uBBF8\uD574\uACB0 \u2014 \uBCF4\uB4DC \uC774\uB3D9(claim/reflect)\uC740 \uC5EC\uC804\uD788 skip\uB41C\uB2E4.");
  }
  const statusMap = mergeDetectedMap(existing.status_map, detected.statusMap, Object.keys(STATUS_AUTODETECT_TABLE), opts.mode, "status_map", notices);
  const claimMap = mergeDetectedMap(existing.claim_status_map ?? {}, detected.claimStatusMap, Object.keys(CLAIM_AUTODETECT_TABLE), opts.mode, "claim_status_map", notices);
  const candidate = {
    project: {
      owner: existing.project.owner,
      number: existing.project.number,
      ...nodeId2 ? { node_id: nodeId2 } : {}
    },
    status_map: statusMap,
    ...Object.keys(claimMap).length > 0 ? { claim_status_map: claimMap } : {},
    auto_reflect: existing.auto_reflect
  };
  const parsed = dittoConfigGithub.safeParse(candidate);
  if (!parsed.success) {
    return { ok: false, reason: "schema_invalid", detail: parsed.error.message.slice(0, 200) };
  }
  return { ok: true, config: parsed.data, notices, warnings: detected.warnings };
}
