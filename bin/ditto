var FAR_FIELD_ROUTED_OUT = [
  {
    id: "minimal-increment",
    lens: MINIMAL_INCREMENT_SELF_CHECK.question,
    route: "charter-self-check",
    reason: "minimal-increment\uB294 \uBA3C \uC704\uD5D8(far-field)\uC774 \uC544\uB2C8\uB77C \uC124\uACC4-\uBA54\uD0C0 \uD488\uC9C8 \u2014 \uB9E4 \uD134 \uC7AC\uC8FC\uC785\uB418\uB294 charter self-check(MINIMAL_INCREMENT_SELF_CHECK)\uAC00 \uC9D1\uD589\uD55C\uB2E4 (wi_260706n4w ac-2)",
    residual_risk: "charter projection\uC744 \uC18C\uBE44\uD558\uC9C0 \uC54A\uB294 \uACBD\uB85C(\uBE44 hook \uC9C4\uC785\xB7\uC9C1\uC811 \uC5D4\uC9C4 \uD638\uCD9C)\uC5D0\uC11C\uB294 \uC774 self-check\uAC00 \uC8FC\uC785\uB418\uC9C0 \uC54A\uC544 \uACFC\uC789/\uACFC\uC18C \uC99D\uBD84\uC774 \uC0AC\uC804 \uC810\uAC80 \uC5C6\uC774 \uC9C0\uB098\uAC08 \uC218 \uC788\uB2E4"
  }
];
function farFieldLenses(taxonomy = FAR_FIELD_TAXONOMY_FLOOR) {
  return taxonomy.map((c3) => c3.lens);
}
function resolveTaxonomy(floor, config) {
  const disabled = new Set(config.disabled ?? []);
  const added = config.added ?? [];
  const routes = config.dispositions ?? {};
  const floorById = new Map(floor.map((c3) => [c3.id, c3]));
  const overridden = new Set(added.map((c3) => c3.id));
  const kept = floor.filter((c3) => !disabled.has(c3.id) && !overridden.has(c3.id)).map((c3) => {
    const route = routes[c3.id];
    return route ? { ...c3, disposition: route } : c3;
  });
  const resolvedAdded = added.map((a2) => {
    const disposition = a2.disposition ?? routes[a2.id] ?? floorById.get(a2.id)?.disposition;
    return {
      id: a2.id,
      lens: a2.lens,
      ...disposition ? { disposition } : {}
    };
  });
  return [...kept, ...resolvedAdded];
}
async function loadFarFieldTaxonomy(repoRoot, onMalformed) {
  const file = Bun.file(`${dittoDir(repoRoot)}/coverage-taxonomy.json`);
  if (!await file.exists())
    return [...FAR_FIELD_TAXONOMY_FLOOR];
  try {
    const parsed = coverageTaxonomyConfig.safeParse(JSON.parse(await file.text()));
    if (!parsed.success) {
      onMalformed?.();
      return [...FAR_FIELD_TAXONOMY_FLOOR];
    }
    return resolveTaxonomy(FAR_FIELD_TAXONOMY_FLOOR, parsed.data);
  } catch {
    onMalformed?.();
    return [...FAR_FIELD_TAXONOMY_FLOOR];
  }
}
function warnMalformedTaxonomy(repoRoot) {
  console.warn(`ditto: malformed ${dittoDir(repoRoot)}/coverage-taxonomy.json \u2014 ignoring the tier-\u2461 taxonomy override and falling back to the built-in far-field floor (fix the file to re-enable it)`);
}
function isPlainRecord(v2) {
  return typeof v2 === "object" && v2 !== null && !Array.isArray(v2);
}
async function readRawTaxonomyConfig(path) {
  const file = Bun.file(path);
  if (!await file.exists())
    return {};
  let raw;
  try {
    raw = JSON.parse(await file.text());
  } catch (err) {
    throw new SchemaValidationError(path, err);
  }
  if (!isPlainRecord(raw)) {
    throw new SchemaValidationError(path, new Error("coverage-taxonomy.json must be a JSON object"));
  }
  return raw;
}
function mutateRawConfig(current, mutation) {
  const next = { ...current };
  if (mutation.kind === "add") {
    const existing = Array.isArray(next.added) ? next.added : [];
    const entry = {
      id: mutation.id,
      lens: mutation.lens,
      ...mutation.disposition ? { disposition: mutation.disposition } : {}
    };
    const idx = existing.findIndex((e2) => isPlainRecord(e2) && e2.id === mutation.id);
    next.added = idx >= 0 ? existing.map((e2, i2) => i2 === idx ? entry : e2) : [...existing, entry];
  } else if (mutation.kind === "disable") {
    const disabled = Array.isArray(next.disabled) ? next.disabled : [];
    next.disabled = disabled.includes(mutation.id) ? disabled : [...disabled, mutation.id];
    const reasons = isPlainRecord(next.disabled_reasons) ? next.disabled_reasons : {};
    next.disabled_reasons = { ...reasons, [mutation.id]: mutation.reason };
  } else {
    const dispositions = isPlainRecord(next.dispositions) ? next.dispositions : {};
    next.dispositions = { ...dispositions, [mutation.id]: mutation.disposition };
  }
  return next;
}
async function applyTaxonomyMutation(repoRoot, mutation) {
  const path = `${dittoDir(repoRoot)}/coverage-taxonomy.json`;
  const current = await readRawTaxonomyConfig(path);
  const next = mutateRawConfig(current, mutation);
  const parsed = coverageTaxonomyConfig.safeParse(next);
  if (!parsed.success)
    throw new SchemaValidationError(path, parsed.error);
  await atomicWriteText(path, `${JSON.stringify(next, null, 2)}
`);
  return { path, config: parsed.data };
}
var CATEGORY_NODE_PREFIX = "cov-cat-";
function farFieldCoverageNodes(intent, rootId = "cov-root", taxonomy = FAR_FIELD_TAXONOMY_FLOOR, verdicts = []) {
  const skips = new Map(verdicts.filter((v2) => v2.relevant === false && v2.reason && v2.residual_risk).map((v2) => [v2.id, v2]));
  const categoryIds = taxonomy.map((c3) => `${CATEGORY_NODE_PREFIX}${c3.id}`);
  const root = {
    id: rootId,
    parent_id: null,
    label: intent,
    origin: "seed",
    depth_weight: 1,
    state: "open",
    children: categoryIds
  };
  const categories = taxonomy.map((c3, i2) => {
    const base = {
      id: categoryIds[i2],
      parent_id: rootId,
      label: c3.lens,
      origin: "seed",
      depth_weight: 1,
      children: [],
      ...c3.disposition ? { disposition: c3.disposition } : {}
    };
    const skip = skips.get(c3.id);
    return skip ? {
      ...base,
      state: "out_of_scope",
      close_reason: skip.reason,
      residual_risk: skip.residual_risk
    } : { ...base, state: "open" };
  });
  return [root, ...categories];
}
function farFieldCategoriesEnabled() {
  const v2 = process.env.DITTO_FARFIELD_CATEGORIES?.trim().toLowerCase();
  return v2 !== "0" && v2 !== "off" && v2 !== "false";
}
function farFieldCoverageReport(map) {
  const cats = map.nodes.filter((n2) => n2.id.startsWith(CATEGORY_NODE_PREFIX));
  const open2 = cats.filter((n2) => n2.state === "open").length;
  const skipped = cats.filter((n2) => n2.state === "out_of_scope" || n2.state === "user_owned").map((n2) => ({
    id: n2.id,
    state: n2.state,
    reason: n2.close_reason ?? null,
    ...n2.disposition ? { disposition: n2.disposition } : {}
  }));
  return {
    seeded: cats.length,
    resolved: cats.filter((n2) => n2.state === "resolved").length,
    open: open2,
    skipped,
    routed_out: [...FAR_FIELD_ROUTED_OUT],
    complete: cats.length > 0 && map.nodes.every((n2) => n2.state !== "open")
  };
}

// src/core/coverage-feedback.ts
init_ditto_paths();
init_fs();

class CoverageFeedbackLedger {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  path() {
    return localDir(this.repoRoot, "coverage-feedback.jsonl");
  }
  async append(row, recordedAt) {
    const entry = coverageFeedbackEntry.parse({ ...row, recorded_at: recordedAt });
    const path = this.path();
    const file = Bun.file(path);
    const existing = await file.exists() ? await file.text() : "";
    const trimmed = existing.length === 0 || existing.endsWith(`
`) ? existing : `${existing}
`;
    await atomicWriteText(path, `${trimmed}${JSON.stringify(entry)}
`);
    return entry;
  }
  async readAll() {
    const path = this.path();
    const file = Bun.file(path);
    if (!await file.exists())
      return [];
    const text = await file.text();
    const lines = text.split(`
`).filter((l2) => l2.length > 0);
    return lines.map((line, idx) => {
      try {
        return coverageFeedbackEntry.parse(JSON.parse(line));
      } catch (err) {
        throw new Error(`coverage-feedback.jsonl ${path}:${idx + 1} invalid: ${String(err)}`);
      }
    });
  }
}
function suggestCoverageFeedback(map, workItemId2, floor = FAR_FIELD_TAXONOMY_FLOOR) {
  const floorIds = new Set(floor.map((c3) => c3.id));
  const suggestions = [];
  for (const node2 of map.nodes) {
    if (!node2.id.startsWith(CATEGORY_NODE_PREFIX))
      continue;
    if (node2.state !== "resolved")
      continue;
    const bare = node2.id.slice(CATEGORY_NODE_PREFIX.length);
    if (!floorIds.has(bare))
      continue;
    suggestions.push({
      category_id: bare,
      fault_kind: "depth",
      lens: node2.label,
      template: `ditto coverage feedback --wi ${workItemId2} --category ${bare} --evidence "<what slipped past the resolved sweep>"`
    });
  }
  return suggestions;
}
function recurrenceCounts(entries) {
  const counts = new Map;
  for (const e2 of entries) {
    if (!isFarFieldEscape(e2.fault_kind))
      continue;
    counts.set(e2.category_id, (counts.get(e2.category_id) ?? 0) + 1);
  }
  return counts;
}
async function recordResidual(ledger, input, recordedAt) {
  return ledger.append({
    work_item_id: input.work_item_id,
    category_id: input.category_id,
    fault_kind: "residual",
    evidence: input.evidence
  }, recordedAt);
}
function bareFloorId(categoryId) {
  return categoryId.startsWith(CATEGORY_NODE_PREFIX) ? categoryId.slice(CATEGORY_NODE_PREFIX.length) : categoryId;
}
function findCoverageNode(map, categoryId) {
  const prefixed = categoryId.startsWith(CATEGORY_NODE_PREFIX) ? categoryId : `${CATEGORY_NODE_PREFIX}${categoryId}`;
  return map.nodes.find((n2) => n2.id === categoryId || n2.id === prefixed);
}
async function attributeCoverageEscape(store, input, floor = FAR_FIELD_TAXONOMY_FLOOR) {
  const map = await store.exists(input.work_item_id) ? await store.getMap(input.work_item_id) : null;
  const bare = bareFloorId(input.category_id);
  const isFloorCategory = floor.some((c3) => c3.id === bare);
  const node2 = map ? findCoverageNode(map, input.category_id) : undefined;
  if (isFloorCategory) {
    if (node2?.state === "resolved") {
      return { accepted: true, fault_kind: "depth" };
    }
    return {
      accepted: false,
      reason: node2 ? `floor category '${bare}' is '${node2.state}', not a dry-closed (resolved) escape` : `floor category '${bare}' is not seeded in this work item's coverage map`
    };
  }
  const routedOut = FAR_FIELD_ROUTED_OUT.find((r3) => r3.id === bare);
  if (routedOut) {
    return {
      accepted: false,
      reason: `category '${bare}' was routed out of the far-field floor to '${routedOut.route}' (${routedOut.reason}) \u2014 this escape is a receiving-gate escape of '${routedOut.route}', not a missing floor lens (no breadth fault)`
    };
  }
  if (!node2) {
    return { accepted: true, fault_kind: "breadth" };
  }
  return {
    accepted: false,
    reason: `category '${input.category_id}' is a non-floor coverage node (state '${node2.state}') \u2014 a general bug, not a floor escape`
  };
}

// src/core/coverage-store.ts
init_coverage();
init_ditto_paths();
