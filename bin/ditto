var classifyStage = defineCommand({
  meta: {
    name: "stage",
    description: "Stage ONE already-decided doc into an action bucket with its basis (>=1 signal). Delegates to CleanupStore.stageDoc; inherits protected (ac-4) and empty-basis (ac-5) refusal. The skill calls this once per doc with the agent decision. With --auto, the auto-cleanup fail-closed guard refuses delete (ac-6)."
  },
  args: {
