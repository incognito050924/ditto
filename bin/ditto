// src/schemas/evidence-record.ts
init_zod();
init_common();
var freshness = exports_external.enum(["fresh", "stale"]).describe("Whether the captured evidence still reflects the current state");
var portability = exports_external.enum(["committed", "local-artifact"]).describe("Whether the raw artifact travels with the repo (committed) or only exists in the capturing clone/session (local-artifact)");
var evidenceRecord = exports_external.object({
  ref: evidenceRef,
  captured_at: isoDateTime,
  freshness,
  stale_reason: exports_external.string().min(1).nullable().default(null).describe("Why the evidence is stale; required when freshness=stale, null when fresh"),
  portability,
  artifact_available: exports_external.boolean().describe("True when the raw artifact can be opened in this clone/session"),
  exit_code: exports_external.number().int().nullable().default(null).describe("Process exit code for command evidence; null for non-command kinds"),
  key_lines: exports_external.array(exports_external.string()).default([]).describe("Excerpt lines that make the evidence judgeable without the raw artifact")
}).superRefine((value, ctx) => {
  if (value.freshness === "stale" && !value.stale_reason) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "freshness=stale requires a stale_reason",
      path: ["stale_reason"]
    });
  }
  if (value.freshness === "fresh" && value.stale_reason !== null) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "freshness=fresh must not carry a stale_reason (set it null)",
      path: ["stale_reason"]
    });
  }
  if (value.portability === "committed" && value.artifact_available !== true) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "portability=committed implies artifact_available=true",
      path: ["artifact_available"]
    });
  }
}).describe("Evidence freshness/portability sidecar wrapping an evidenceRef");
var evidenceIndex = exports_external.object({
  schema_version: schemaVersion,
  work_item_id: workItemId,
  records: exports_external.array(evidenceRecord).default([])
}).describe("Committable evidence ledger (.ditto/local/work-items/<id>/evidence-index.json)");

// src/schemas/completion-contract.ts
var resolvability = exports_external.enum([
  "agent_resolvable",
  "blocked_external",
  "user_decision",
  "accepted_tradeoff",
  "decision_or_adr_conflict",
  "multiple_comparable_solutions",
  "out_of_scope",
  "genuinely_dangerous"
]).describe("Declared class of why an item is unverified or a risk is surfaced; read by the gate");
var acceptanceVerdict = exports_external.object({
  criterion_id: exports_external.string().min(1),
  verdict,
  evidence: exports_external.array(evidenceRef).default([]),
  evidence_records: exports_external.array(evidenceRecord).default([]).describe("Optional freshness/portability-wrapped evidence; coexists with `evidence`"),
  notes: exports_external.string().optional()
}).describe("Per-criterion result included in the completion claim");
var completionContract = exports_external.object({
  schema_version: schemaVersion,
  work_item_id: workItemId,
  declared_by: declarerRole.describe("Agent role that judged this completion (who declared), not the execution profile; impersonation is rejected at the schema"),
  declared_at: isoDateTime,
  summary: exports_external.string().min(1).max(2000).describe("What changed, in user-facing terms; no implementation jargon"),
  changed_files: exports_external.array(relativePath).default([]),
  acceptance: exports_external.array(acceptanceVerdict).min(1).describe("Every acceptance criterion must appear here; absence is a contract violation"),
  verifications: exports_external.array(exports_external.object({
    command: exports_external.string().min(1),
    exit_code: exports_external.number().int(),
    run_id: runId.optional(),
    evidence: evidenceRef.optional()
  })).default([]).describe("Commands actually executed; not aspirational"),
  unverified: exports_external.array(uncertaintyItem.extend({
    out_of_scope: exports_external.boolean().default(false).describe("True when the item is intentionally outside acceptance scope; only such items are allowed when final_verdict=pass"),
    resolvability: resolvability.optional().describe("Declared class of why this is unverified; read by the gate, not computed here"),
    grounding: exports_external.string().min(1).optional().describe("Free-text oracle/ref (ADR id, dependency, decision pointer, file:line); a non-resolvable class attaches it and the gate later checks its presence")
  })).default([]).describe("Anything the implementer could not verify; explicit not-knowing is required"),
  remaining_risks: exports_external.array(exports_external.string()).default([]),
  remaining_risk_records: exports_external.array(exports_external.object({
    risk: exports_external.string().min(1).describe("The residual risk, in user-facing terms"),
    resolvability: resolvability.optional().describe("Declared class; agent_resolvable routes to auto-fix, the four surfacing classes surface in-flow"),
    grounding: exports_external.string().min(1).optional().describe("Oracle/ref (ADR id, decision pointer, file:line); a non-auto-fix class attaches it and the gate later checks its presence")
  })).optional().describe("Optional resolvability/grounding-labeled residual risks; coexists with `remaining_risks`"),
  non_pass_status: exports_external.object({
    state: exports_external.enum(["partial", "blocked"]).describe("honest partial (progress made, some AC non-pass) or blocked (cannot proceed)"),
    reason: exports_external.string().min(1).describe("Why the completion is partial/blocked"),
    grounding: exports_external.string().min(1).describe("Oracle/ref for the blocker (ADR id, dependency, decision pointer, file:line)")
  }).optional().describe("Optional honest partial/blocked declaration for a non-pass completion; read by the ac-1 gate, not enforced in superRefine (R10)"),
  acg_governance: exports_external.object({
    review_graph: relativePath.describe("Path to the acg.review-graph.v1 ledger consulted"),
    unresolved_high_risk: exports_external.array(exports_external.string()).default([]).describe("Identities (path|journey_id) still unresolved at high risk; empty = clear")
  }).optional().describe("Optional ACG review-by-exception governance state (D5)"),
  next_handoff_path: relativePath.optional().describe("Where the next session/agent should pick up; required if status is not done"),
  final_verdict: verdict.describe('Aggregate verdict; "pass" requires every acceptance verdict to be pass')
}).superRefine((value, ctx) => {
  if (value.final_verdict === "pass") {
    const failing = value.acceptance.filter((a2) => a2.verdict !== "pass");
    if (failing.length > 0) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        message: `final_verdict=pass but ${failing.length} acceptance criterion not pass`,
        path: ["final_verdict"]
      });
    }
    const inScopeUnverified = value.unverified.filter((u3) => !u3.out_of_scope);
    if (inScopeUnverified.length > 0) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        message: `final_verdict=pass but ${inScopeUnverified.length} in-scope unverified item(s) remain; mark out_of_scope=true if intentionally outside acceptance`,
        path: ["unverified"]
      });
    }
  }
  if (value.final_verdict !== "pass" && !value.next_handoff_path) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "non-pass final_verdict requires next_handoff_path",
      path: ["next_handoff_path"]
    });
  }
}).describe("Contract that gates work item completion; absence of fields is a failure");

// src/core/completion-store.ts
init_ditto_paths();
init_fs();
function deriveFinalVerdict(acceptance, unverified) {
  const hasInScopeUnverified = unverified.some((u3) => !u3.out_of_scope);
  if (acceptance.every((a2) => a2.verdict === "pass") && !hasInScopeUnverified)
    return "pass";
  if (acceptance.some((a2) => a2.verdict === "fail"))
    return "fail";
  if (acceptance.some((a2) => a2.verdict === "partial"))
    return "partial";
  return "unverified";
}
function buildCompletion(input) {
  const byId = new Map(input.verdicts.map((v2) => [v2.criterion_id, v2]));
  const acceptance = input.workItem.acceptance_criteria.map((c3) => {
    const provided = byId.get(c3.id);
    return {
      criterion_id: c3.id,
      verdict: provided?.verdict ?? "unverified",
      evidence: provided?.evidence ?? [],
      ...provided?.notes ? { notes: provided.notes } : {}
    };
  });
  const unverified = input.unverified ?? [];
  const finalVerdict = deriveFinalVerdict(acceptance, unverified);
  const candidate = {
    schema_version: "0.1.0",
    work_item_id: input.workItem.id,
    declared_by: input.declaredBy,
    declared_at: (input.now ?? new Date).toISOString(),
    summary: input.summary,
    changed_files: input.workItem.changed_files,
    acceptance,
    verifications: input.verifications ?? [],
    unverified,
    remaining_risks: input.remainingRisks ?? [],
    ...finalVerdict === "pass" ? {} : {
      next_handoff_path: input.nextHandoffPath ?? `.ditto/local/work-items/${input.workItem.id}/handoff.md`
    },
    final_verdict: finalVerdict
  };
  return completionContract.parse(candidate);
}
function assembleCompletionFromWorkItem(workItem2, opts) {
  return buildCompletion({
    workItem: workItem2,
    declaredBy: opts.declaredBy,
    summary: opts.summary,
    verdicts: workItem2.acceptance_criteria.map((c3) => ({
      criterion_id: c3.id,
      verdict: c3.verdict,
      evidence: c3.evidence
    })),
    now: opts.now
  });
}
function mirrorAcceptanceVerdicts(workItem2, completion) {
  const byId = new Map(completion.acceptance.map((a2) => [a2.criterion_id, a2]));
  return {
    ...workItem2,
    acceptance_criteria: workItem2.acceptance_criteria.map((c3) => {
      const match = byId.get(c3.id);
      return match ? { ...c3, verdict: match.verdict, evidence: match.evidence } : c3;
    })
  };
}

class CompletionStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  path(workItemId2) {
    return localDir(this.repoRoot, "work-items", workItemId2, "completion.json");
  }
  async exists(workItemId2) {
    return Bun.file(this.path(workItemId2)).exists();
  }
  async get(workItemId2) {
    return readJson(this.path(workItemId2), completionContract);
  }
  async write(completion) {
    return writeJson(this.path(completion.work_item_id), completionContract, completion);
  }
}

// src/core/autopilot-complete.ts
function hasVerifyEvidence(criterion) {
  return criterion.evidence.some((e2) => e2.kind === "command");
}
var SEVERITY = { fail: 0, partial: 1, unverified: 2, pass: 3 };
var worst = (a2, b2) => SEVERITY[a2] <= SEVERITY[b2] ? a2 : b2;
function perAcEvidence(node, acId) {
  return node.ac_verdicts.filter((v2) => v2.criterion_id === acId).flatMap((v2) => v2.evidence_refs ?? []);
}
function hasClosingEvidence(node, acId) {
  return node.evidence_refs.length > 0 || perAcEvidence(node, acId).length > 0;
}
function closingEvidence(node, acId) {
  return [...node.evidence_refs, ...perAcEvidence(node, acId)];
}
function nodeVerdictFor(node, acId, oracle) {
  let verdict2;
  let notes;
  if (node.status === "failed") {
    verdict2 = "fail";
    notes = "an addressing node failed";
  } else if (node.status === "passed" && hasClosingEvidence(node, acId)) {
    if (oracle) {
      let blocked;
      try {
        const sat = oracleSatisfaction(acId, oracle, closingEvidence(node, acId));
        if (!sat.pass)
          blocked = sat.reasons[0];
      } catch {
        blocked = `${acId}: ${oracle.verification_method} oracle evaluation errored (held non-pass, fail-closed)`;
      }
      if (blocked) {
        verdict2 = "unverified";
        notes = blocked;
      } else {
        verdict2 = "pass";
      }
    } else {
      verdict2 = "pass";
    }
  } else if (node.status === "passed") {
    verdict2 = "unverified";
    notes = "addressing node passed without evidence (claim \u2260 proof)";
  } else {
    verdict2 = "unverified";
    notes = "addressing node not terminal";
  }
  for (const e2 of node.ac_verdicts.filter((v2) => v2.criterion_id === acId)) {
    const folded = worst(verdict2, e2.verdict);
    if (SEVERITY[folded] < SEVERITY[verdict2]) {
      verdict2 = folded;
      notes = e2.notes ?? `verifier judged ${acId} ${e2.verdict} (per-AC verdict caps the node-level pass)`;
    }
  }
  return { verdict: verdict2, ...notes ? { notes } : {} };
}
function dependsOnPassedFix(node, byId) {
  const seen = new Set;
  const visit2 = (id) => {
    if (seen.has(id))
      return false;
    seen.add(id);
    const cur = byId.get(id);
    if (!cur)
      return false;
    for (const dep of cur.depends_on) {
      const depNode = byId.get(dep);
      if (depNode && depNode.kind === "fix" && depNode.status === "passed")
        return true;
      if (visit2(dep))
        return true;
    }
    return false;
  };
  return visit2(node.id);
}
function dependsOnNode2(node, targetId, byId) {
  const seen = new Set;
  const visit2 = (id) => {
    if (seen.has(id))
      return false;
    seen.add(id);
    const cur = byId.get(id);
    if (!cur)
      return false;
    for (const dep of cur.depends_on) {
      if (dep === targetId)
        return true;
      if (visit2(dep))
        return true;
    }
    return false;
  };
  return visit2(node.id);
}
function isStructuralUnverified(node, acId) {
  return node.status === "passed" && !hasClosingEvidence(node, acId) && node.ac_verdicts.every((v2) => v2.criterion_id !== acId || v2.verdict === "pass");
}
function deriveAcVerdicts(graph, acIds, oracles, criteria) {
  const byId = new Map(graph.nodes.map((n2) => [n2.id, n2]));
  return acIds.map((acId) => {
    const oracle = oracles?.get(acId);
    const addressing = graph.nodes.filter((n2) => n2.acceptance_refs.includes(acId));
    const evidence = addressing.flatMap((n2) => [...n2.evidence_refs, ...perAcEvidence(n2, acId)]);
    if (addressing.length === 0) {
      return {
        criterion_id: acId,
        verdict: "unverified",
        evidence,
        notes: "no node addressed this criterion"
      };
    }
    const supersedingFix = addressing.some((n2) => nodeVerdictFor(n2, acId, oracle).verdict === "pass" && dependsOnPassedFix(n2, byId));
    let verdict2 = "pass";
    let notes;
    let folded = false;
    let structuralSuperseded = false;
    for (const n2 of addressing) {
      const nv = nodeVerdictFor(n2, acId, oracle);
      if ((nv.verdict === "fail" || nv.verdict === "partial") && supersedingFix)
        continue;
      if (nv.verdict === "unverified" && isStructuralUnverified(n2, acId) && addressing.some((m2) => m2 !== n2 && nodeVerdictFor(m2, acId, oracle).verdict === "pass" && (n2.kind === "design" || dependsOnNode2(m2, n2.id, byId)))) {
        structuralSuperseded = true;
        continue;
      }
      const next = worst(verdict2, nv.verdict);
      if (!folded || SEVERITY[next] < SEVERITY[verdict2]) {
        verdict2 = next;
        notes = nv.notes;
        folded = true;
      }
    }
    if (supersedingFix && verdict2 === "pass") {
      notes = `earlier non-pass superseded by a re-verify behind a passed fix (${acId})`;
    } else if (structuralSuperseded && verdict2 === "pass") {
      notes = `evidence-less implementation pass covered by a downstream verified pass (${acId})`;
    }
    let finalEvidence = evidence;
    const criterion = criteria?.get(acId);
    if (verdict2 !== "pass" && criterion && criterion.verdict === "pass" && hasVerifyEvidence(criterion)) {
      verdict2 = "pass";
      notes = `stale node verdict superseded by a fresh evidence-backed \`ditto verify\` pass (${acId})`;
      finalEvidence = [...evidence, ...criterion.evidence];
    }
    return { criterion_id: acId, verdict: verdict2, evidence: finalEvidence, ...notes ? { notes } : {} };
  });
}
function unresolvedAgentResolvableRiskRecords(decisions, graph) {
  const records = [];
  const seen = new Set;
  for (const d2 of decisions) {
    if (d2.decision !== "auto_fix" || d2.resolvability !== "agent_resolvable")
      continue;
    const recheckPassed = graph.nodes.some((n2) => n2.id.startsWith(`${d2.node_id}.rev.`) && n2.status === "passed");
    if (recheckPassed)
      continue;
    const risk = d2.reason.replace(/^auto-fix residual risk: /, "");
    if (seen.has(risk))
      continue;
    seen.add(risk);
    records.push({ risk, resolvability: "agent_resolvable" });
  }
  return records;
}
function barrierRanGreen(node) {
  return node.status === "passed" && node.evidence_refs.some((e2) => e2.kind === "command");
}
function testBarrierUnverified(graph) {
  const barriers = graph.nodes.filter((n2) => n2.kind === "test");
  if (barriers.length === 0)
    return [];
  return barriers.filter((b2) => !barrierRanGreen(b2)).map((b2) => ({
    item: `settled-tree test barrier ${b2.id}`,
    reason: b2.status === "failed" ? `the settled-tree test barrier (${b2.id}) is RED \u2014 the suite failed, so acceptance-criteria closure is not proven` : `the settled-tree test barrier (${b2.id}) did not run GREEN (degraded / not executed / non-terminal) \u2014 the suite never proved green, so acceptance-criteria closure is unverified (ADR-0018: proceed but never claim pass)`,
    out_of_scope: false,
    resolvability: "blocked_external",
    grounding: b2.id
  }));
}
function assembleCompletionFromGraph(graph, workItem2, opts = {}) {
  const acIds = workItem2.acceptance_criteria.map((c3) => c3.id);
  const oracles = new Map(workItem2.acceptance_criteria.map((c3) => [c3.id, c3.oracle]));
  const criteria = new Map(workItem2.acceptance_criteria.map((c3) => [c3.id, c3]));
  const verdicts = deriveAcVerdicts(graph, acIds, oracles, criteria);
  const summary = opts.summary ?? `Completion assembled from autopilot ${graph.autopilot_id} (${graph.nodes.length} nodes) for "${workItem2.goal}".`;
  const nonTerminal = graph.nodes.filter((n2) => n2.status !== "passed" && n2.status !== "failed");
  const remainingRisks = [
    ...opts.remainingRisks ?? [],
    ...nonTerminal.length > 0 ? [`non-terminal graph nodes (work unfinished): ${nonTerminal.map((n2) => n2.id).join(", ")}`] : []
  ];
  const barrierUnverified = testBarrierUnverified(graph);
  const built = buildCompletion({
    workItem: workItem2,
    declaredBy: "verifier",
    summary,
    verdicts,
    ...remainingRisks.length > 0 ? { remainingRisks } : {},
    ...barrierUnverified.length > 0 ? { unverified: barrierUnverified } : {},
    ...opts.now ? { now: opts.now } : {}
  });
  const riskRecords = opts.decisions ? unresolvedAgentResolvableRiskRecords(opts.decisions, graph) : [];
  return riskRecords.length > 0 ? { ...built, remaining_risk_records: riskRecords } : built;
}
function attestCompletion(completion) {
  return attestAcVerdicts(completion.acceptance.map((a2) => ({
    criterion_id: a2.criterion_id,
    verdict: a2.verdict,
    ...a2.notes !== undefined ? { notes: a2.notes } : {}
  })));
}
function projectAutoHandling(decisions) {
  const ledger = { auto_fixed: [], surfaced: [], materialized: [] };
  for (const d2 of decisions) {
    if (d2.decision !== "auto_fix" && d2.decision !== "surface" && d2.decision !== "batch_escalate") {
      continue;
    }
    const entry = {
      node_id: d2.node_id,
      decision: d2.decision,
      ...d2.resolvability ? { resolvability: d2.resolvability } : {},
      reason: d2.reason
    };
    if (d2.decision === "auto_fix")
      ledger.auto_fixed.push(entry);
    else if (d2.decision === "surface")
      ledger.surfaced.push(entry);
    else
      ledger.materialized.push(entry);
  }
  return ledger;
}
function projectDirectionDecisions(decisions) {
  const entries = [];
  decisions.forEach((d2, index) => {
    if (d2.decision !== "direction")
      return;
    const record = d2.direction_record;
    if (!record)
      return;
    entries.push({
      decision_id: synthesizeDecisionId(d2, index),
      node_id: d2.node_id,
      fork_node_id: record.fork_node_id,
      trigger: record.trigger,
      options: record.options,
      choice: record.choice,
      intent_basis: record.intent_basis,
      blast_radius: record.blast_radius,
      reverse_cost: record.reverse_cost,
      reason: d2.reason
    });
  });
  return entries;
}

