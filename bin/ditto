async function loadJourneyNames(repoRoot) {
  const names = {};
  const journeysDir = join68(repoRoot, "e2e", "journeys");
  try {
    for (const name of await readdir20(journeysDir)) {
      if (!name.endsWith(".journey.md"))
        continue;
      const parsed = parseJourneyDoc(await readFile16(join68(journeysDir, name), "utf8"));
      if (parsed.ok)
        names[parsed.frontMatter.id] = parsed.frontMatter.name;
    }
  } catch {}
  return names;
}
var e2eFailureReport = defineCommand({
  meta: {
    name: "failure-report",
    description: "Report e2e failures in DSL step vocabulary with replay commands"
  },
  args: {
    runId: { type: "string", description: "Run id \u2192 .ditto/local/runs/<runId>/", required: true },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    try {
      const repoRoot = await resolveRepoRootForCreate();
      const reportPath = join68(localDir(repoRoot, "runs", args.runId), "playwright-report.json");
      const reportFile = Bun.file(reportPath);
      if (!await reportFile.exists()) {
        writeError(`no playwright-report.json for run ${args.runId} \u2014 run \`ditto e2e verify-generated --runId ${args.runId} --files <specs>\` first`);
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      const reporter = JSON.parse(await reportFile.text());
      const failures = await buildFailureReport(reporter, {
        repoRoot,
        readSpec: async (specFile) => {
          try {
            return await readFile16(resolve15(repoRoot, specFile), "utf8");
          } catch {
            return null;
          }
        }
      });
      if (format === "json") {
        writeJson2({ run_id: args.runId, failures });
        return;
      }
      writeHuman(`e2e failure-report ${args.runId}: \uC2E4\uD328 ${failures.length}\uAC74`);
      if (failures.length === 0)
        return;
      const names = await loadJourneyNames(repoRoot);
      for (const failure of failures) {
        writeHuman("");
        for (const line of renderFailureLines(failure, names[failure.journey_id])) {
          writeHuman(line);
        }
      }
      writeHuman("");
      writeHuman("\uD310\uC815(\uC0AC\uC6A9\uC790): ditto e2e failure-verdict --work-item <wi> --journey <id> --case <name> --classification <\uAE30\uB2A5|\uC2A4\uD06C\uB9BD\uD2B8|\uD658\uACBD|flaky> --basis <\uADFC\uAC70>");
    } catch (err) {
      writeError(`e2e failure-report failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
