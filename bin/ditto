      this.name = "CleanupBasisRequiredError";
    }
  };
});

// src/core/cleanup-archive.ts
import { execFileSync as execFileSync4 } from "child_process";
import { mkdir as mkdir7, rm, stat as stat7 } from "fs/promises";
import { dirname as dirname11, isAbsolute as isAbsolute7, join as join38, resolve as resolve10 } from "path";
function runDir(repoRoot, runId2) {
  return localDir(repoRoot, "cleanup", runId2);
}
function archiveZipPath(repoRoot, runId2) {
  return localDir(repoRoot, "cleanup", "archive", `${runId2}.zip`);
}
async function assertRunExists(repoRoot, runId2) {
  try {
    const s2 = await stat7(runDir(repoRoot, runId2));
    if (!s2.isDirectory())
      throw new CleanupRunMissingError(runId2);
  } catch (err) {
    if (err instanceof CleanupRunMissingError)
      throw err;
    throw new CleanupRunMissingError(runId2);
  }
}
async function archiveRun(repoRoot, runId2) {
  await assertRunExists(repoRoot, runId2);
  const zip = archiveZipPath(repoRoot, runId2);
  await mkdir7(dirname11(zip), { recursive: true });
  await rm(zip, { force: true });
  execFileSync4("zip", ["-r", "-q", "-y", zip, runId2], {
    cwd: localDir(repoRoot, "cleanup"),
    stdio: ["ignore", "ignore", "pipe"]
  });
  const folder = runDir(repoRoot, runId2);
  await rm(folder, { recursive: true, force: true });
  return { run_id: runId2, zip_path: zip, removed_run_dir: folder };
}
function deleteApprovalGate(confirm) {
  if (confirm)
    return { allowed: true, reason: "explicit operator confirm" };
  return {
    allowed: false,
    reason: "permanent delete needs an explicit confirm token; auto/autopilot refuses without one"
  };
}
async function deleteRun(repoRoot, runId2, confirm) {
  await assertRunExists(repoRoot, runId2);
  const gate2 = deleteApprovalGate(confirm);
  if (!gate2.allowed)
    throw new CleanupDeleteRefusedError(gate2.reason);
  const folder = runDir(repoRoot, runId2);
  await rm(folder, { recursive: true, force: true });
  return { run_id: runId2, removed_run_dir: folder };
}
function subRepoAbs(repoRoot, owningRepo) {
  if (owningRepo === null || owningRepo === ".")
    return resolve10(repoRoot);
  return isAbsolute7(owningRepo) ? owningRepo : join38(repoRoot, owningRepo);
}
function unrelatedDirt(cwd, allowed) {
  let status = "";
  try {
    status = execFileSync4("git", ["status", "--porcelain", "--untracked-files=all"], {
      cwd,
      encoding: "utf8"
    });
  } catch {
    return [];
  }
  const out = [];
  for (const line of status.split(`
`)) {
    if (line.length === 0)
      continue;
    const path = line.slice(3).trim();
    const parts = path.split(" -> ");
    const real = (parts.length > 1 ? parts[parts.length - 1] : path)?.trim() ?? path;
    if (!allowed.has(real))
      out.push(real);
  }
  return out.sort();
}
function commitPerSubRepo(repoRoot, pathsByRepo, message) {
  for (const [repo, paths] of pathsByRepo) {
    const abs = subRepoAbs(repoRoot, repo);
    const dirt = unrelatedDirt(abs, new Set(paths));
    if (dirt.length > 0)
      throw new CleanupDirtyRepoError(repo, dirt);
  }
  const commits = [];
  for (const [repo, paths] of pathsByRepo) {
    const abs = subRepoAbs(repoRoot, repo);
    for (const p of paths) {
      execFileSync4("git", ["add", "--all", "--", p], { cwd: abs, stdio: "pipe" });
    }
    const staged = execFileSync4("git", ["diff", "--cached", "--name-only", "--", ...paths], {
      cwd: abs,
      encoding: "utf8"
    }).trim();
    if (staged === "")
      continue;
    execFileSync4("git", ["commit", "-m", message, "--", ...paths], { cwd: abs, stdio: "pipe" });
    const sha = execFileSync4("git", ["rev-parse", "HEAD"], { cwd: abs, encoding: "utf8" }).trim();
    commits.push({ repo, sha, paths: [...paths] });
  }
  return commits;
}
function commitCleanup(repoRoot, index, message) {
  const byRepo = new Map;
  for (const e2 of index.entries) {
    const key = e2.owning_repo ?? ".";
    const abs = subRepoAbs(repoRoot, e2.owning_repo);
    const rel = relForRepo(repoRoot, abs, e2.original_path);
    const group = byRepo.get(key) ?? [];
    group.push(rel);
    byRepo.set(key, group);
  }
  return { commits: commitPerSubRepo(repoRoot, byRepo, message) };
}
function relForRepo(repoRoot, repoAbs, workspaceRelPath) {
  const abs = join38(repoRoot, workspaceRelPath);
  const rel = abs.startsWith(`${repoAbs}/`) ? abs.slice(repoAbs.length + 1) : workspaceRelPath;
  return rel.replace(/\\/g, "/");
}
async function restoreDoc(repoRoot, runId2, originalPath) {
  const store = new CleanupStore(repoRoot);
  const entry = await store.restore(runId2, originalPath);
  return { run_id: runId2, original_path: entry.original_path };
}
var CleanupRunMissingError, CleanupDeleteRefusedError, CleanupDirtyRepoError;
var init_cleanup_archive = __esm(() => {
  init_cleanup_store();
  init_ditto_paths();
  CleanupRunMissingError = class CleanupRunMissingError extends Error {
    constructor(runId2) {
      super(`no cleanup run folder for id: ${runId2}`);
      this.name = "CleanupRunMissingError";
    }
  };
  CleanupDeleteRefusedError = class CleanupDeleteRefusedError extends Error {
    constructor(reason) {
      super(`delete refused (fail-closed): ${reason}`);
      this.name = "CleanupDeleteRefusedError";
    }
  };
  CleanupDirtyRepoError = class CleanupDirtyRepoError extends Error {
    repo;
    dirty;
    constructor(repo, dirty) {
      super(`refusing to commit: sub-repo "${repo}" working tree has uncommitted changes ` + `unrelated to this cleanup (${dirty.join(", ")}); resolve them first (no auto clean/stash)`);
      this.repo = repo;
      this.dirty = dirty;
      this.name = "CleanupDirtyRepoError";
    }
  };
});

