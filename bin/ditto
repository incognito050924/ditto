class MemoryProjectionAbsentError extends Error {
  constructor() {
    super("no serving graph projected yet; run `ditto memory project` first");
    this.name = "MemoryProjectionAbsentError";
  }
}

class MemoryNodeNotFoundError extends Error {
  nodeId;
  constructor(nodeId) {
    super(`node "${nodeId}" not found in the serving graph`);
    this.nodeId = nodeId;
    this.name = "MemoryNodeNotFoundError";
  }
}
async function readFreshness(repoRoot) {
  const status = await memoryStatus(repoRoot);
  return {
    projection_id: status.projection_id ?? "",
    generated_at: status.generated_at ?? "",
    freshness: status.freshness,
    dirty_sources: status.dirty_sources,
    drifted_repos: status.drifted_repos,
    drifted_sources: status.drifted_sources
  };
}
function pullUsageLogPath(repoRoot) {
  return localDir(repoRoot, "memory", "pull-usage.jsonl");
}
async function recordPullQuery(repoRoot, record) {
  const path = pullUsageLogPath(repoRoot);
  await ensureDir(dirname7(path));
  await appendFile2(path, `${JSON.stringify(record)}
`, "utf8");
}
async function readPullUsage(repoRoot) {
  const path = pullUsageLogPath(repoRoot);
  if (!await Bun.file(path).exists())
    return [];
  const text = await Bun.file(path).text();
  return text.split(`
`).filter((line) => line.trim().length > 0).map((line) => JSON.parse(line));
}
function neighborsOf(graph, id) {
  const out = [];
  for (const e2 of graph.adjacency[id] ?? []) {
    out.push({ to: e2.to, edge_type: e2.edge_type, direction: "out" });
  }
  for (const [from, edges] of Object.entries(graph.adjacency)) {
    for (const e2 of edges) {
      if (e2.to === id)
        out.push({ to: from, edge_type: e2.edge_type, direction: "in" });
    }
  }
  return out;
}
function queryNeighbors(graph, node2, depth) {
  const present = new Set(graph.nodes.map((n2) => n2.id));
  if (!present.has(node2))
    throw new MemoryNodeNotFoundError(node2);
  const seen = new Set([node2]);
  let frontier = [node2];
  for (let hop = 0;hop < depth; hop++) {
    const next = [];
    for (const id of frontier) {
      for (const nb of neighborsOf(graph, id)) {
        if (!seen.has(nb.to)) {
          seen.add(nb.to);
          next.push(nb.to);
        }
      }
    }
    frontier = next;
    if (frontier.length === 0)
      break;
  }
  seen.delete(node2);
  return { root: node2, depth, neighbors: [...seen].sort() };
}
function bodyTokens(s2) {
  return new Set(s2.toLowerCase().split(/[^a-z0-9\uAC00-\uD7A3]+/).filter((t2) => t2.length >= 3));
}
function searchEventBodies(query, events) {
  const q2 = query.trim().toLowerCase();
  if (q2.length === 0)
    return [];
  const qTokens = bodyTokens(query);
  const out = [];
  for (const e2 of events) {
    const body = e2.text.toLowerCase();
    let hit = body.includes(q2);
    if (!hit) {
      const bTokens = bodyTokens(e2.text);
      for (const t2 of qTokens) {
        if (bTokens.has(t2)) {
          hit = true;
          break;
        }
      }
    }
    if (hit)
      out.push({ source_id: e2.sources[0] ?? "", event_id: e2.event_id });
  }
  return out;
}
async function queryBodies(repoRoot, query) {
  const events = await new MemoryEventStore(repoRoot).list();
  const visible = reduceEvents(events).approvedHeads.filter((e2) => e2.sensitivity !== "secret");
  const matches = searchEventBodies(query, visible);
  const freshness2 = await readFreshness(repoRoot);
  return { query, matches, ...freshness2 };
}
function symbolFilePath(symbolId) {
  const bare = symbolId.startsWith("symbol:") ? symbolId.slice("symbol:".length) : symbolId;
  const hashIdx = bare.indexOf("#");
  return hashIdx === -1 ? { path: bare, name: bare } : { path: bare.slice(0, hashIdx), name: bare.slice(hashIdx + 1) };
}
function stripExt(path) {
  return path.replace(/\.[cm]?[jt]sx?$/, "").replace(/\.(java|kt|py)$/, "");
}
function assembleSymbolBrief(symbolId, decisions) {
  const { path } = symbolFilePath(symbolId);
  const file = stripExt(path);
  const items = [];
  const rejected = [];
  const invariants = [];
  const adrs = [];
  for (const d2 of decisions) {
    const cited = d2.governs.some((g3) => {
      const gn = stripExt(g3);
      return gn.includes("*") ? globToRegExp(gn).test(file) : gn === file;
    });
    const mentioned = !cited && d2.body.includes(path);
    if (!cited && !mentioned)
      continue;
    adrs.push(d2.adr_id);
    items.push({
      adr_id: d2.adr_id,
      tag: cited ? "EXTRACTED" : "INFERRED",
      coverage: cited ? "cite" : "fallback"
    });
    rejected.push(...extractRejectedAlternatives(d2.body));
    invariants.push(...extractInvariants(d2.body));
  }
  const coverage = items.some((i2) => i2.coverage === "cite") ? "cite" : items.length > 0 ? "fallback" : "\uBBF8\uBC1C\uACAC";
  return {
    symbol: symbolId,
    governing_adrs: adrs,
    rejected_alternatives: rejected,
    invariants,
    items,
    coverage
  };
}
async function loadGoverningDecisions(repoRoot) {
  const events = await new MemoryEventStore(repoRoot).list();
  const approved = reduceEvents(events).approvedHeads.filter((e2) => e2.sensitivity !== "secret");
  const sources = await new MemorySourceStore(repoRoot).list();
  const pathOf = new Map(sources.map((s2) => [s2.source_id, s2.path]));
  const byNodeId = new Map;
  for (const e2 of approved) {
    if (e2.event_type !== "decision")
      continue;
    const sourceId = e2.sources[0];
    const rel = sourceId ? pathOf.get(sourceId) : undefined;
    let body = e2.text;
    if (rel) {
      try {
        body = await readFile2(isAbsolute3(rel) ? rel : join27(repoRoot, rel), "utf8");
      } catch {}
    }
    byNodeId.set(`decision:${e2.event_id}`, {
      adr_id: rel ? basename2(rel) : e2.event_id,
      body,
      governs: e2.governs
    });
  }
  return byNodeId;
}
async function querySymbolBrief(repoRoot, symbolId) {
  const decisions = [...(await loadGoverningDecisions(repoRoot)).values()];
  const brief = assembleSymbolBrief(symbolId, decisions);
  const freshness2 = await readFreshness(repoRoot);
  return { ...brief, ...freshness2 };
}
async function queryDecisionBriefs(repoRoot, decisionNodeIds) {
  const byNodeId = await loadGoverningDecisions(repoRoot);
  return decisionNodeIds.map(({ id, summary }) => {
    const decision = byNodeId.get(id);
    if (!decision) {
      return {
        id,
        summary,
        rejected_alternatives: [],
        invariants: [],
        tag: "\uBBF8\uBC1C\uACAC",
        coverage: "\uBBF8\uBC1C\uACAC"
      };
    }
    const symbolKey = `symbol:${decision.governs[0] ?? id}#${id}`;
    const brief = assembleSymbolBrief(symbolKey, [decision]);
    return {
      id,
      summary,
      rejected_alternatives: brief.rejected_alternatives,
      invariants: brief.invariants,
      tag: brief.items[0]?.tag ?? "\uBBF8\uBC1C\uACAC",
      coverage: brief.coverage
    };
  });
}
function shortestPath(graph, from, to) {
  const present = new Set(graph.nodes.map((n2) => n2.id));
  if (!present.has(from))
    throw new MemoryNodeNotFoundError(from);
  if (!present.has(to))
    throw new MemoryNodeNotFoundError(to);
  if (from === to)
    return { from, to, path: [from] };
  const prev = new Map;
  const visited = new Set([from]);
  const queue2 = [from];
  while (queue2.length > 0) {
    const cur = queue2.shift();
    for (const nb of neighborsOf(graph, cur)) {
      if (visited.has(nb.to))
        continue;
      visited.add(nb.to);
      prev.set(nb.to, cur);
      if (nb.to === to) {
        const path = [to];
        let step = to;
        while (step !== from) {
          step = prev.get(step);
          path.push(step);
        }
        return { from, to, path: path.reverse() };
      }
      queue2.push(nb.to);
    }
  }
  return { from, to, path: null };
}
function explainNode(graph, node2) {
  const found = graph.nodes.find((n2) => n2.id === node2);
  if (!found)
    throw new MemoryNodeNotFoundError(node2);
  const edges = neighborsOf(graph, node2).sort((a2, b2) => a2.to < b2.to ? -1 : a2.to > b2.to ? 1 : a2.edge_type < b2.edge_type ? -1 : 1);
  return { node: { id: found.id, node_type: found.node_type, name: found.name }, edges };
}
function auditCounts(graph, dirtySources) {
  const referenced = new Set;
  const seenEdges = new Set;
  let duplicate = 0;
  let contradiction = 0;
  for (const [from, edges] of Object.entries(graph.adjacency)) {
    for (const e2 of edges) {
      referenced.add(from);
      referenced.add(e2.to);
      const key = `${from}\x00${e2.to}\x00${e2.edge_type}`;
      if (seenEdges.has(key))
        duplicate++;
      else
        seenEdges.add(key);
      if (e2.edge_type === "CONTRADICTS")
        contradiction++;
    }
  }
  let orphan = 0;
  for (const n2 of graph.nodes) {
    if (!referenced.has(n2.id))
      orphan++;
  }
  return { orphan, stale: dirtySources.length, duplicate, contradiction };
}

class MemoryAuditLogStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  path() {
    return join27(dittoDir(this.repoRoot), "memory", "audit-log.jsonl");
  }
  async append(entry) {
    const p = this.path();
    await ensureDir(dirname7(p));
    await appendFile2(p, `${JSON.stringify(entry)}
`, "utf8");
  }
  async list() {
    const p = this.path();
    if (!await Bun.file(p).exists())
      return [];
    const text = await Bun.file(p).text();
    return text.split(`
`).filter((line) => line.trim().length > 0).map((line) => JSON.parse(line));
  }
}
async function runAudit(repoRoot, options = {}) {
  const graph = await new MemoryProjectionStore(repoRoot).readServing();
  if (!graph)
    throw new MemoryProjectionAbsentError;
  const fresh = await readFreshness(repoRoot);
  let edgeCount = 0;
  for (const edges of Object.values(graph.adjacency))
    edgeCount += edges.length;
  const entry = {
    audited_at: (options.now ?? new Date).toISOString(),
    projection_id: fresh.projection_id,
    freshness: fresh.freshness,
    node_count: graph.nodes.length,
    edge_count: edgeCount,
    counts: auditCounts(graph, fresh.dirty_sources)
  };
  const store = new MemoryAuditLogStore(repoRoot);
  await store.append(entry);
  const history = await store.list();
  return { entry, history_length: history.length };
}

// src/core/memory-warmstart.ts
init_memory_store();
function isWarmStartOwner(owner) {
  return owner === "researcher" || owner === "planner";
}
function warmStartEnabled() {
  return isMemoryEnabled() && process.env.DITTO_MEMORY_WARMSTART !== "0";
}
var RELATED_NODE_CAP = 8;
function tokensOf(text) {
  return (text.toLowerCase().match(/[a-z0-9]+/g) ?? []).filter((t2) => t2.length >= 4);
}
function coverageRoots(graph, workItem2) {
  const want = new Set([...tokensOf(workItem2.title), ...tokensOf(workItem2.goal)]);
  if (want.size === 0)
    return [];
  const roots = [];
  for (const n2 of graph.nodes) {
    const have = new Set([...tokensOf(n2.id), ...tokensOf(n2.name)]);
    if ([...have].some((t2) => want.has(t2)))
      roots.push(n2.id);
  }
  return roots.sort();
}
async function recordUsage(repoRoot, record) {
  const path = usageLogPath(repoRoot, record.work_item_id);
  await ensureDir(dirname8(path));
  await appendFile3(path, `${JSON.stringify(record)}
`, "utf8");
}
function usageLogPath(repoRoot, workItemId2) {
  return localDir(repoRoot, "work-items", workItemId2, "memory", "warmstart-usage.jsonl");
}
async function readUsageReport(repoRoot, workItemId2) {
  const path = usageLogPath(repoRoot, workItemId2);
  let records = [];
  if (await Bun.file(path).exists()) {
    const text = await Bun.file(path).text();
    records = text.split(`
`).filter((line) => line.trim().length > 0).map((line) => JSON.parse(line));
  }
  const hitNodeTypes = {};
  for (const r3 of records) {
    for (const [t2, n2] of Object.entries(r3.hit_node_types ?? {})) {
      hitNodeTypes[t2] = (hitNodeTypes[t2] ?? 0) + n2;
    }
  }
  return {
    opportunities: records.filter((r3) => r3.opportunity).length,
    attempts: records.filter((r3) => r3.attempt).length,
    hits: records.filter((r3) => r3.hit).length,
    actionable: records.filter((r3) => r3.actionable).length,
    hit_node_types: hitNodeTypes,
    records
  };
}
async function warmStartMemoryContext(repoRoot, node2, workItem2, options = {}) {
  if (!isWarmStartOwner(node2.owner) || !warmStartEnabled())
    return;
  const now = (options.now ?? new Date).toISOString();
  const base = {
    ts: now,
    work_item_id: workItem2.id,
    node_id: node2.id,
    owner: node2.owner,
    opportunity: true,
    attempt: false,
    hit: false,
    actionable: false
  };
  try {
    const status = await memoryStatus(repoRoot);
    base.freshness = status.freshness;
    if (status.freshness !== "fresh" && status.freshness !== "code_dirty") {
      await recordUsage(repoRoot, base);
      return;
    }
    const graph = await new MemoryProjectionStore(repoRoot).readServing();
    if (!graph || graph.nodes.length === 0) {
      await recordUsage(repoRoot, base);
      return;
    }
    const roots = coverageRoots(graph, workItem2);
    if (roots.length === 0) {
      await recordUsage(repoRoot, base);
      return;
    }
    base.attempt = true;
    const related = new Set;
    for (const root of roots) {
      related.add(root);
      for (const nb of queryNeighbors(graph, root, 2).neighbors)
        related.add(nb);
    }
    const typeOf = new Map(graph.nodes.map((n2) => [n2.id, n2.node_type]));
    const rootSet = new Set(roots);
    const tierOf = (id) => rootSet.has(id) ? 0 : typeOf.get(id) === "Decision" ? 1 : 2;
    const relatedNodes = [...related].sort((a2, b2) => tierOf(a2) - tierOf(b2) || (a2 < b2 ? -1 : a2 > b2 ? 1 : 0)).slice(0, RELATED_NODE_CAP);
    if (relatedNodes.length === 0) {
      await recordUsage(repoRoot, base);
      return;
    }
    base.hit = true;
    const hitTypes = {};
    for (const id of relatedNodes) {
      const t2 = typeOf.get(id) ?? "unknown";
      hitTypes[t2] = (hitTypes[t2] ?? 0) + 1;
    }
    base.hit_node_types = hitTypes;
    const decisionIds = new Set(graph.nodes.filter((n2) => n2.node_type === "Decision").map((n2) => n2.id));
    const decisions = relatedNodes.filter((id) => decisionIds.has(id));
    const nameOf = new Map(graph.nodes.map((n2) => [n2.id, n2.name]));
    const decisionBriefs = await queryDecisionBriefs(repoRoot, decisions.map((id) => ({ id, summary: nameOf.get(id) ?? id })));
    base.actionable = true;
    await recordUsage(repoRoot, base);
    return {
      related_nodes: relatedNodes,
      ...decisions.length > 0 ? { decisions } : {},
      ...decisionBriefs.length > 0 ? { decision_briefs: decisionBriefs } : {}
    };
  } catch {
    try {
      await recordUsage(repoRoot, base);
    } catch {}
    return;
  }
}

