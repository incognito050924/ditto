function renderJourneyDsl(input) {
  const front = journeyFrontMatter.parse({
    ditto_journey: "v2",
    id: input.id,
    name: input.name,
    description: input.description,
    surfaces: input.surfaces,
    implementation_intent: `${input.description} \u2014 ${input.intent}`
  });
  const body = input.steps.map((step, i3) => `${i3 + 1}. [${step.step_id}] ${step.intent}`).join(`
`);
  return `---
${$stringify(front)}---

${body}
`;
}
