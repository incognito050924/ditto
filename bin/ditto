    id: exports_external.string().min(1),
    refuted: exports_external.boolean().describe("true = refuter found the category IS relevant \u2192 skip overturned")
  }).describe("One adversarial refute outcome for a proposed skip (\xA75-3)");
  relevanceProvenance = exports_external.object({
    schema_version: schemaVersion,
    work_item_id: workItemId,
    judgments: exports_external.array(rawRelevanceJudgment).describe("Raw grounded judgments, pre-assembly"),
    refutes: exports_external.array(relevanceRefute).describe("Raw adversarial refutes, pre-assembly"),
    tally: exports_external.object({
      seeded: exports_external.number().int().nonnegative().describe("Category nodes seeded (breadth floor)"),
      skipped: exports_external.number().int().nonnegative().describe("Categories pre-closed out_of_scope"),
      relevant: exports_external.number().int().nonnegative().describe("Categories left open to be swept")
    }).describe("Structural cost tally \u2014 the only run-cost proxy the engine can see (no tokens)")
  }).describe("Relevance gate audit sidecar (relevance-provenance.json, \xA79) \u2014 wi_26062227h");
  oracleMode = exports_external.enum(["presence", "absence"]).describe("Oracle claim mode: presence = the cited anchor exists (file:line, codePointerMapsTo vocabulary); absence = the token does not occur in scope (wi_260706n4w)");
  ORACLE_PATTERN_TOKEN_RE = /^[^\s]+$/;
  oracleClaim = exports_external.discriminatedUnion("mode", [
