// src/core/git.ts
import { execFileSync } from "child_process";
function captureGitState(cwd) {
  let head = "0".repeat(40);
  let branch = "";
  let dirty = false;
  let untracked_count = 0;
  try {
    head = execFileSync("git", ["rev-parse", "HEAD"], { cwd, encoding: "utf8" }).trim();
  } catch {}
  try {
    branch = execFileSync("git", ["rev-parse", "--abbrev-ref", "HEAD"], {
      cwd,
      encoding: "utf8"
    }).trim();
  } catch {}
  try {
    const status = execFileSync("git", ["status", "--porcelain"], { cwd, encoding: "utf8" });
    const lines = status.split(`
`).filter((line) => line.length > 0);
    dirty = lines.length > 0;
    untracked_count = lines.filter((line) => line.startsWith("??")).length;
  } catch {}
  return { head, branch, dirty, untracked_count };
}
function listChangedFiles(cwd, options = {}) {
  try {
    const status = execFileSync("git", ["status", "--porcelain"], { cwd, encoding: "utf8" });
    return status.split(`
`).filter((line) => line.length > 0).map((line) => line.slice(3).trim()).filter((path) => path.length > 0).filter((path) => !options.excludeDittoRuns || !path.startsWith(".ditto/local/runs/")).sort();
  } catch {
    return [];
  }
}
function listChangedFilesVsRef(cwd, ref) {
  try {
    const out = execFileSync("git", ["diff", "--name-only", ref, "--"], { cwd, encoding: "utf8" });
    return out.split(`
`).map((l2) => l2.trim()).filter((p) => p.length > 0).sort();
  } catch {
    return [];
  }
}
function diffVsRef(cwd, ref) {
  try {
    return execFileSync("git", ["diff", ref, "--"], { cwd, encoding: "utf8" });
  } catch {
    return "";
  }
}
function gitRevParse(cwd, ref) {
  return execFileSync("git", ["rev-parse", ref], { cwd, encoding: "utf8" }).trim();
}
function isWorkingTreeClean(cwd) {
  try {
    return execFileSync("git", ["status", "--porcelain"], { cwd, encoding: "utf8" }).trim() === "";
  } catch {
    return false;
  }
}
function aheadBehind(cwd, base) {
  try {
    const out = execFileSync("git", ["rev-list", "--left-right", "--count", `${base}...HEAD`], {
      cwd,
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"]
    }).trim();
    const [behind, ahead] = out.split(/\s+/).map((n2) => Number.parseInt(n2, 10));
    return { ahead: ahead || 0, behind: behind || 0 };
  } catch {
    return { ahead: 0, behind: 0 };
  }
}
function addDetachedWorktree(cwd, path, ref) {
  execFileSync("git", ["worktree", "add", "--detach", "--force", path, ref], {
    cwd,
    stdio: ["ignore", "ignore", "pipe"]
  });
}
function removeWorktree(cwd, path) {
  try {
    execFileSync("git", ["worktree", "remove", "--force", path], {
      cwd,
      stdio: ["ignore", "ignore", "pipe"]
    });
  } catch {}
}
function gitPush(cwd, remote, ref) {
  try {
    execFileSync("git", ["push", remote, "--", ref], {
      cwd,
      stdio: ["ignore", "pipe", "pipe"]
    });
    return { ok: true, stderr: "" };
  } catch (err) {
    const stderr = err && typeof err === "object" && "stderr" in err && err.stderr ? String(err.stderr) : err instanceof Error ? err.message : String(err);
    return { ok: false, stderr };
  }
}
function captureGitDiff(cwd) {
  try {
    return execFileSync("git", ["diff", "--binary", "HEAD"], { cwd, encoding: "utf8" });
  } catch {
    try {
      return execFileSync("git", ["diff", "--binary"], { cwd, encoding: "utf8" });
    } catch {
      return "";
    }
  }
}
var init_git = () => {};

