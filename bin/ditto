var DEFAULT_TIDY_THRESHOLDS = {
  minCodeLines: 20,
  minCodeFiles: 3
};
var CODE_EXTENSIONS = new Set([
  ".ts",
  ".tsx",
  ".js",
  ".jsx",
  ".mjs",
  ".cjs",
  ".py",
  ".go",
  ".rs",
  ".java",
  ".kt",
  ".rb",
  ".c",
  ".h",
  ".cc",
  ".cpp",
  ".cs",
  ".swift"
]);
function isCodePath(path) {
  const dot = path.lastIndexOf(".");
  if (dot < 0)
    return false;
  return CODE_EXTENSIONS.has(path.slice(dot).toLowerCase());
}
function classifyTidyEntry(stat2, thresholds = DEFAULT_TIDY_THRESHOLDS) {
  const codeFilesArr = stat2.files.filter((f3) => f3.isCode);
  const codeFiles = codeFilesArr.length;
  const codeLines = codeFilesArr.reduce((n2, f3) => n2 + f3.added + f3.removed, 0);
  if (codeFiles === 0) {
    return {
      decision: "SKIP",
      reason: "no code files touched (docs/config only)",
      codeFiles,
      codeLines
    };
  }
  if (codeLines < thresholds.minCodeLines && codeFiles < thresholds.minCodeFiles) {
    return {
      decision: "SKIP",
      reason: `code diff below threshold (${codeLines} lines < ${thresholds.minCodeLines} and ${codeFiles} files < ${thresholds.minCodeFiles})`,
      codeFiles,
      codeLines
    };
  }
  return {
    decision: "ENTER",
    reason: `code touched and diff-stat over threshold (${codeLines} lines, ${codeFiles} files)`,
    codeFiles,
    codeLines
  };
}
async function writeTidyClassification(repoRoot, workItemId2, classification) {
  const dir = localDir(repoRoot, "work-items", workItemId2);
  await ensureDir(dir);
  const path = join13(dir, "tidy-classification.json");
  await writeJson(path, tidyClassification, classification);
  return path;
}
function collectTidyDiffStat(repoRoot, base, head = "HEAD") {
  const out = Bun.spawnSync(["git", "diff", "--numstat", `${base}...${head}`], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (out.exitCode !== 0)
    return { files: [] };
  const text = out.stdout?.toString() ?? "";
  const files = [];
  for (const line of text.split(`
`)) {
    const t2 = line.trim();
    if (t2.length === 0)
      continue;
    const [addedRaw, removedRaw, ...rest] = t2.split("\t");
    const path = rest.join("\t");
    if (path.length === 0)
      continue;
    const added = addedRaw === "-" ? 0 : Number.parseInt(addedRaw, 10) || 0;
    const removed = removedRaw === "-" ? 0 : Number.parseInt(removedRaw, 10) || 0;
    files.push({ path, added, removed, isCode: isCodePath(path) });
  }
  return { files };
}

