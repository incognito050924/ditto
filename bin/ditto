var sessionPointer = exports_external.object({
  schema_version: exports_external.literal("0.1.0"),
  session_id: exports_external.string().min(1),
  work_item_id: workItemId,
  updated_at: exports_external.string().min(1)
});
function safeSessionId(sessionId) {
  return sessionId.replace(/[^a-zA-Z0-9_-]/g, "_");
}

class SessionPointerStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  path(sessionId) {
    return localDir(this.repoRoot, "sessions", `${safeSessionId(sessionId)}.json`);
  }
  async get(sessionId) {
    try {
      const parsed = await readJson(this.path(sessionId), sessionPointer);
      return parsed.work_item_id;
    } catch {
      return null;
    }
  }
  async set(sessionId, id, now = new Date) {
    await ensureDir(localDir(this.repoRoot, "sessions"));
    await writeJson(this.path(sessionId), sessionPointer, {
      schema_version: "0.1.0",
      session_id: sessionId,
      work_item_id: id,
      updated_at: now.toISOString()
    });
  }
}

// src/hooks/envelope.ts
var APPLY_PATCH_HEADER = /^\s*\*\*\* (?:Add File|Update File|Delete File|Move to):\s*(.+?)\s*$/;
function parseApplyPatchPaths(command) {
  const seen = new Set;
  const out = [];
  for (const line of command.split(`
`)) {
    const m2 = line.match(APPLY_PATCH_HEADER);
    if (!m2)
      continue;
    const path = m2[1];
    if (path && path.length > 0 && !seen.has(path)) {
      seen.add(path);
      out.push(path);
    }
  }
  return out;
}
function mutatedPaths(host, raw) {
  const toolName = typeof raw.tool_name === "string" ? raw.tool_name : undefined;
  const toolInput = raw.tool_input ?? {};
  if (host === "codex" && toolName === "apply_patch") {
    const command = typeof toolInput.command === "string" ? toolInput.command : undefined;
    return command ? parseApplyPatchPaths(command) : [];
  }
  if (toolName === "Write" || toolName === "Edit" || toolName === "MultiEdit") {
    const filePath = typeof toolInput.file_path === "string" ? toolInput.file_path : undefined;
    return filePath ? [filePath] : [];
  }
  return [];
}

// src/hooks/post-tool-use.ts
var FILE_MUTATION_TOOLS = new Set(["Edit", "Write", "MultiEdit"]);
function exitCodeOf(response) {
  if (typeof response !== "object" || response === null)
    return 0;
  const r3 = response;
  if (typeof r3.exit_code === "number")
    return r3.exit_code;
  if (typeof r3.exitCode === "number")
    return r3.exitCode;
  if (r3.is_error === true || r3.error != null || r3.interrupted === true)
    return 1;
  return 0;
}
var postToolUseHandler = async (input) => {
  const raw = input.raw ?? {};
  const toolName = typeof raw.tool_name === "string" ? raw.tool_name : undefined;
  const isCodexPatch = input.host === "codex" && toolName === "apply_patch";
  if (toolName !== "Bash" && !FILE_MUTATION_TOOLS.has(toolName ?? "") && !isCodexPatch)
    return { exitCode: 0 };
  const sessionId = typeof raw.session_id === "string" ? raw.session_id : undefined;
  if (!sessionId)
    return { exitCode: 0 };
  const pointer = await new SessionPointerStore(input.repoRoot).get(sessionId);
  if (!pointer)
    return { exitCode: 0 };
  const toolInput = raw.tool_input ?? {};
  const store = new WorkItemStore(input.repoRoot);
  if (toolName === "Bash") {
    const command = typeof toolInput.command === "string" ? toolInput.command : undefined;
    if (!command)
      return { exitCode: 0 };
    const entry2 = commandLogEntry.parse({
      ts: new Date().toISOString(),
      kind: "command",
      command,
      exit_code: exitCodeOf(raw.tool_response),
      work_item_id: pointer
    });
    await store.appendCommandLogLine(pointer, JSON.stringify(entry2));
    return { exitCode: 0 };
  }
  if (isCodexPatch) {
    for (const path of mutatedPaths("codex", raw)) {
      const entry2 = editLogEntry.parse({
        ts: new Date().toISOString(),
        kind: "edit",
        tool: "Edit",
        file_path: path,
        work_item_id: pointer
      });
      await store.appendEditLogLine(pointer, JSON.stringify(entry2));
    }
    return { exitCode: 0 };
  }
  const filePath = typeof toolInput.file_path === "string" ? toolInput.file_path : undefined;
  if (!filePath)
    return { exitCode: 0 };
  const entry = editLogEntry.parse({
    ts: new Date().toISOString(),
    kind: "edit",
    tool: toolName,
    file_path: filePath,
    work_item_id: pointer
  });
  await store.appendEditLogLine(pointer, JSON.stringify(entry));
  return { exitCode: 0 };
};

// src/hooks/pre-compact.ts
var preCompactHandler = async (input) => {
  const raw = input.raw ?? {};
  const sessionId = typeof raw.session_id === "string" ? raw.session_id : undefined;
  if (!sessionId)
    return { exitCode: 0 };
  const pointer = await new SessionPointerStore(input.repoRoot).get(sessionId);
  if (!pointer)
    return { exitCode: 0 };
  const items = new WorkItemStore(input.repoRoot);
  if (!await items.exists(pointer))
    return { exitCode: 0 };
  const workItem2 = await items.get(pointer);
  let autopilotId2;
  try {
    const pilots = new AutopilotStore(input.repoRoot);
    if (await pilots.exists(pointer)) {
      autopilotId2 = (await pilots.get(pointer)).autopilot_id;
    }
  } catch {}
  const trigger = typeof raw.trigger === "string" ? raw.trigger : "auto";
  const handoff2 = buildHandoff({
    workItem: workItem2,
    ...autopilotId2 ? { autopilotId: autopilotId2 } : {},
    fromContext: `${input.host ?? "claude-code"} session ${sessionId} at PreCompact (${trigger})`,
    currentState: `work item status=${workItem2.status} at compaction`,
    nextFirstCheck: "Re-read the work item and its acceptance criteria, then resume the open node.",
    ...workItem2.re_entry?.command ? { openThreads: [workItem2.re_entry.command] } : {}
  });
  await new HandoffStore(input.repoRoot).write(handoff2);
  return { exitCode: 0 };
};

// src/hooks/pre-tool-use.ts
import { homedir as homedir8 } from "os";
import { join as join64 } from "path";
import { isAbsolute as isAbsolute12, relative as relative16, resolve as resolve16 } from "path";

// src/acg/scope/resolve.ts
function stripModuleExt2(p) {
  return p.replace(/\.[cm]?[jt]sx?$/, "");
}
function scopeRefMatches(ref, repoRelPath, archSpec) {
  switch (ref.kind) {
    case "path": {
      const base = ref.ref.replace(/\/$/, "");
      return repoRelPath === base || repoRelPath.startsWith(`${base}/`);
    }
    case "glob":
      return globToRegExp(ref.ref).test(repoRelPath);
    case "layer":
      return archSpec !== undefined && pathToLayer(repoRelPath, archSpec.layers) === ref.ref;
    case "public_surface": {
      if (archSpec === undefined || !archSpec.public_surfaces.includes(ref.ref))
        return false;
      const mod = stripModuleExt2(repoRelPath);
      return mod === ref.ref || mod.startsWith(`${ref.ref}/`);
    }
    default:
      return false;
  }
}
function matchForbiddenScope(refs, repoRelPath, archSpec) {
  return refs.find((r3) => scopeRefMatches(r3, repoRelPath, archSpec));
}

// src/hooks/pre-tool-use.ts
init_fs();
var HOME = process.env.HOME ?? process.env.USERPROFILE ?? "";
var IS_WIN = process.platform === "win32";
function block(category, reason) {
  return {
    exitCode: 2,
    stderr: `DITTO PreToolUse: blocked ${category} \u2014 ${reason}. Set DITTO_SKIP_HOOKS=1 to bypass.
`
  };
}
var ALLOW = { exitCode: 0 };
var SECRET_PATTERNS = [
  /(^|\/)\.env(\.[\w.-]+)?$/,
  /\.pem$/,
  /\.key$/,
  /(^|\/)id_(rsa|dsa|ecdsa|ed25519)$/,
  /(^|\/)\.ssh\//,
  /(^|\/)credentials?($|[._-])/
];
var TEMPLATE_SUFFIXES = [".example", ".sample", ".template", ".dist", ".tmpl"];
function isTemplatePath(p) {
  return TEMPLATE_SUFFIXES.some((s2) => p.endsWith(s2));
}
function isSecretPath(p) {
  if (isTemplatePath(p))
    return false;
  return SECRET_PATTERNS.some((re) => re.test(p));
}
var METADATA_VERBS = new Set([
  "ls",
  "find",
  "stat",
  "file",
  "basename",
  "dirname",
  "realpath",
  "test",
  "[",
  "which",
  "type"
]);
var SEARCH_VERBS = new Set(["grep", "rg", "egrep", "fgrep"]);
var SEARCH_PATTERN_FLAGS = new Set(["-e", "--regexp", "-f", "--file"]);
function commandSegments(cmd) {
  return cmd.split(/\|\||&&|[;&|]/).map((s2) => s2.trim());
}
function leadingCommand(seg) {
  const afterEnv = seg.replace(/^(?:\s*[A-Za-z_]\w*=(?:"[^"]*"|'[^']*'|\S+)\s+)*\s*/, "");
  return afterEnv.split(/\s+/)[0] ?? "";
}
function shellWords(seg) {
  return seg.match(/"[^"]*"|'[^']*'|\S+/g)?.map((w2) => w2.replace(/^(['"])(.*)\1$/, "$2")) ?? [];
}
function isShellEnvAssignment(word) {
  return /^[A-Za-z_]\w*=/.test(word);
}
function basenameCommand(word) {
  return word.replace(/^.*[\\/]/, "");
}
function operativeShellCommand(seg) {
  const words = shellWords(seg);
  let i2 = 0;
  while (i2 < words.length) {
    while (i2 < words.length && isShellEnvAssignment(words[i2] ?? ""))
      i2++;
    const word = words[i2] ?? "";
    if (word === "env") {
      i2++;
      while (i2 < words.length) {
        const current = words[i2] ?? "";
        if (current === "-u" || current === "--unset") {
          i2 += 2;
          continue;
        }
        if (current === "-i" || current === "--ignore-environment" || current.startsWith("-u")) {
          i2++;
          continue;
        }
        if (current.startsWith("-")) {
          i2++;
          continue;
        }
        if (isShellEnvAssignment(current)) {
          i2++;
          continue;
        }
        break;
      }
      continue;
    }
    if (word === "command" || word === "exec" || word === "sudo") {
      i2++;
      while (word === "sudo" && i2 < words.length && (words[i2] ?? "").startsWith("-"))
        i2++;
      continue;
    }
    return basenameCommand(word);
  }
  return "";
}
function shellRunsApplyPatch(cmd) {
  return commandSegments(cmd).some((seg) => operativeShellCommand(seg) === "apply_patch");
}
function isCommandTool(input, toolName) {
  return toolName === "Bash" || input.host === "codex" && toolName === "exec_command";
}
function commandToolInput(input, toolName, toolInput) {
  if (typeof toolInput.command === "string")
    return toolInput.command;
  if (input.host === "codex" && toolName === "exec_command" && typeof toolInput.cmd === "string") {
    return toolInput.cmd;
  }
  return;
}
function segmentTokens(seg) {
  const out = [];
  for (const raw of seg.split(/[\s'"=]+/)) {
    if (raw.length === 0)
      continue;
    const redir = raw.match(/^([0-9]*<)(.*)$/);
    if (redir) {
      out.push("<");
      if (redir[2] && redir[2].length > 0)
        out.push(redir[2]);
    } else {
      out.push(raw);
    }
  }
  return out;
}
function asPath(t2) {
  return t2.startsWith("@") ? t2.slice(1) : t2;
}
function bashSecretExposure(cmd) {
  for (const seg of commandSegments(cmd)) {
    const tokens = segmentTokens(seg);
    if (tokens.length === 0)
      continue;
    const verb = tokens[0] ?? "";
    const args = tokens.slice(1);
    for (let i2 = 0;i2 < args.length; i2++) {
      if (args[i2] === "<") {
        const src2 = args[i2 + 1] ?? "";
        if (isSecretPath(asPath(src2)))
          return asPath(src2);
      }
    }
    if (SEARCH_VERBS.has(verb)) {
      let seenPattern = false;
      for (let i2 = 0;i2 < args.length; i2++) {
        const a2 = args[i2] ?? "";
        if (a2 === "<") {
          i2++;
          continue;
        }
        if (a2.startsWith("-")) {
          if (SEARCH_PATTERN_FLAGS.has(a2))
            i2++;
          continue;
        }
        if (!seenPattern) {
          seenPattern = true;
          continue;
        }
        if (isSecretPath(asPath(a2)))
          return asPath(a2);
      }
      continue;
    }
    const secretToken = args.find((t2) => t2 !== "<" && !t2.startsWith("-") && isSecretPath(asPath(t2)));
    if (secretToken === undefined)
      continue;
    if (METADATA_VERBS.has(verb))
      continue;
    return asPath(secretToken);
  }
  return;
}
function isOutsideRepo(repoRoot, filePath) {
  const resolved = resolve16(repoRoot, filePath);
  const rel = relative16(repoRoot, resolved);
  return rel.startsWith("..") || isAbsolute12(rel);
}
function isClaudeMemoryPath(repoRoot, filePath) {
  const home = process.env.HOME ?? homedir8();
  if (!home)
    return false;
  const slug = resolve16(repoRoot).replace(/[^a-zA-Z0-9]/g, "-");
  const base = resolve16(home, ".claude", "projects", slug, "memory");
  const rel = relative16(base, resolve16(filePath));
  return rel.length > 0 && !rel.startsWith("..") && !isAbsolute12(rel);
}
var RM_LITERAL_BLOCK = ["rm -rf /", "rm -rf ~", "rm -rf /*", "rm -rf ~/"];
function isRecursiveForceRm(cmd) {
  if (!/(^|[;&|]\s*)rm\b/.test(cmd))
    return false;
  const hasRecursive = /\s-\w*r/i.test(cmd) || /--recursive\b/.test(cmd);
  const hasForce = /\s-\w*f/i.test(cmd) || /--force\b/.test(cmd);
  return hasRecursive && hasForce;
}
function rmTargets(cmd) {
  const m2 = cmd.match(/\brm\b([^;&|]*)/);
  if (!m2)
    return [];
  return (m2[1] ?? "").trim().split(/\s+/).filter((t2) => t2.length > 0 && !t2.startsWith("-"));
}
var WIN_ROOT = /(^|\s)[a-z]:\\?\*?(\s|$)|\\\\|%systemdrive%|%systemroot%|%userprofile%|%homepath%|%homedrive%|%windir%|%programfiles%/i;
var WIN_REMOVE_CMDS = new Set([
  "rd",
  "rmdir",
  "del",
  "erase",
  "remove-item",
  "ri",
  "rm"
]);
function isWinAbsolute(p) {
  return /^([a-z]:[\\/]|\\\\|[\\/])/i.test(p);
}
function winNorm(p) {
  return p.replace(/\//g, "\\").replace(/\\+$/, "").toLowerCase();
}
function winInside(child, parent) {
  if (!parent)
    return false;
  const c3 = winNorm(child);
  const par = winNorm(parent);
  return c3 === par || c3.startsWith(`${par}\\`);
}
function winDeleteTargets(seg) {
  return seg.split(/\s+/).map((t2) => t2.replace(/^["']+|["']+$/g, "")).filter((t2) => t2.length > 0 && !t2.startsWith("/") && !t2.startsWith("-") && t2.toLowerCase() !== "format" && !WIN_REMOVE_CMDS.has(t2.toLowerCase()));
}
function windowsDestructiveReason(normalized, home = "") {
  for (const seg of commandSegments(normalized)) {
    const cmd = leadingCommand(seg).toLowerCase();
    if (cmd === "format" && /(^|\s)[a-z]:/i.test(seg)) {
      return "format of a Windows drive";
    }
    if (!WIN_REMOVE_CMDS.has(cmd))
      continue;
    const recursive = /(^|\s)\/s\b/i.test(seg) || /-recurse\b/i.test(seg) && /-force\b/i.test(seg);
    if (!recursive)
      continue;
    if (WIN_ROOT.test(seg)) {
      return "recursive delete of a Windows drive root or system location";
    }
    const outside = winDeleteTargets(seg).find((t2) => isWinAbsolute(t2) && !/[*%]/.test(t2) && !winInside(t2, home));
    if (outside) {
      return "recursive delete of an absolute Windows path outside home";
    }
  }
  return null;
}
function checkDestructive(cmd) {
  const normalized = cmd.replace(/\s+/g, " ").trim();
  if (IS_WIN) {
    const winReason = windowsDestructiveReason(normalized, HOME);
    if (winReason)
      return block("destructive", winReason);
  }
  if (normalized.replace(/\s/g, "").includes(":(){:|:&};:")) {
    return block("destructive", "fork bomb");
  }
  if (/\bmkfs\.?\w*/.test(normalized))
    return block("destructive", "mkfs on a device");
  if (/\bdd\b[^;&|]*\bof=\/dev\//.test(normalized))
    return block("destructive", "dd to a device");
  if (/>\s*\/dev\/sd/.test(normalized))
    return block("destructive", "overwrite of a block device");
  if (commandSegments(normalized).filter((seg) => leadingCommand(seg) === "sudo").some((seg) => /\b(rm|dd|mkfs\.?\w*)\b/.test(seg))) {
    return block("destructive", "sudo with a destructive command");
  }
  const pushSegments = normalized.split(/[;&|]+/).map((seg) => seg.trim()).filter((seg) => /\bgit\b.*\bpush\b/.test(seg));
  if (pushSegments.some((seg) => /(--force-with-lease|--force|(^|\s)-\w*f)/.test(seg) && /\b(main|master)\b/.test(seg))) {
    return block("destructive", "force-push to a default branch");
  }
  if (RM_LITERAL_BLOCK.includes(normalized)) {
    return block("destructive", "recursive force remove of a root/home path");
  }
  if (isRecursiveForceRm(normalized)) {
    for (const target of rmTargets(normalized)) {
      if (/[$`*]/.test(target))
        continue;
      if (!isAbsolute12(target))
        continue;
      const insideHome = HOME.length > 0 && (target === HOME || target.startsWith(`${HOME}/`));
      if (!insideHome) {
        return block("destructive", `recursive force remove outside repo/home (${target})`);
      }
    }
  }
  return ALLOW;
}
async function loadArchSpec(repoRoot) {
  try {
    return await readArchitectureSpec(resolve16(repoRoot, ".ditto", "architecture-spec.json"), acgArchitectureSpec);
  } catch {
    return;
  }
}
async function checkForbiddenScope(input, filePath) {
  const raw = input.raw ?? {};
  const sessionId = typeof raw.session_id === "string" ? raw.session_id : undefined;
  if (!sessionId)
    return;
  const workItemId2 = await new SessionPointerStore(input.repoRoot).get(sessionId);
  if (!workItemId2)
    return;
  const contract = await new ChangeContractStore(input.repoRoot).read(workItemId2);
  if (!contract)
    return;
  const repoRel = relative16(input.repoRoot, resolve16(input.repoRoot, filePath));
  const archSpec = await loadArchSpec(input.repoRoot);
  if (contract.scope_mode === "whitelist" && contract.allowed_scope.length > 0) {
    const allowed = contract.allowed_scope.some((ref) => scopeRefMatches(ref, repoRel, archSpec));
    if (!allowed) {
      return block("tidy-scope", `${repoRel} is outside this tidy contract's allowed_scope (whitelist: allowed=diff, forbidden=\uADF8\uC678)`);
    }
    return;
  }
  if (contract.forbidden_scope.length === 0)
    return;
  const hit = matchForbiddenScope(contract.forbidden_scope, repoRel, archSpec);
  if (hit) {
    return block("forbidden-scope", `${repoRel} is in this work item's forbidden_scope (${hit.kind}:${hit.ref})`);
  }
  return;
}
function autopilotBypassActive(input) {
  const env2 = input.env ?? {};
  return env2.DITTO_AUTOPILOT_BYPASS === "1" || process.env.DITTO_AUTOPILOT_BYPASS === "1";
}
async function appendBypassRecord(repoRoot, entry) {
  const dir = join64(repoRoot, ".ditto");
  await ensureDir(dir);
  const path = join64(dir, "autopilot-bypass.jsonl");
  const file = Bun.file(path);
  const existing = await file.exists() ? await file.text() : "";
  const prefix = existing.length === 0 || existing.endsWith(`
`) ? existing : `${existing}
`;
  await atomicWriteText(path, `${prefix}${JSON.stringify(entry)}
`);
}
function fileScopeContains(scope, repoRelPath) {
  return scope.some((s2) => scopeRefMatches(/[*?[\]]/.test(s2) ? { kind: "glob", ref: s2 } : { kind: "path", ref: s2 }, repoRelPath));
}
async function checkAutopilotLease(input, filePath) {
  const raw = input.raw ?? {};
  const sessionId = typeof raw.session_id === "string" ? raw.session_id : undefined;
  if (!sessionId)
    return;
  const workItemId2 = await new SessionPointerStore(input.repoRoot).get(sessionId);
  if (!workItemId2)
    return;
  const aps = new AutopilotStore(input.repoRoot);
  if (!await aps.exists(workItemId2))
    return;
  let hasNonTerminal;
  try {
    const graph = await aps.get(workItemId2);
    hasNonTerminal = graph.nodes.some((n2) => n2.status === "pending" || n2.status === "running" || n2.status === "blocked");
  } catch {
    return;
  }
  if (!hasNonTerminal)
    return;
  const leases = await new ActiveNodeLeaseStore(input.repoRoot).listActive(workItemId2);
  if (leases.length === 0)
    return;
  if (leases.some((l2) => l2.scope_source === "derived"))
    return;
  const repoRel = relative16(input.repoRoot, resolve16(input.repoRoot, filePath));
  const inScope = leases.some((l2) => fileScopeContains(l2.file_scope, repoRel));
  if (inScope)
    return;
  if (autopilotBypassActive(input)) {
    await appendBypassRecord(input.repoRoot, {
      ts: new Date().toISOString(),
      session_id: sessionId,
      work_item_id: workItemId2,
      file_path: repoRel,
      active_leases: leases.map((l2) => l2.node_id)
    });
    return;
  }
  return block("autopilot-path", `${repoRel} is outside every active autopilot node's file_scope (${leases.map((l2) => l2.node_id).join(", ")}); edit inside the dispatched node's scope or set DITTO_AUTOPILOT_BYPASS=1`);
}
var preToolUseHandler = async (input) => {
  const raw = input.raw ?? {};
  const toolName = raw.tool_name;
  const toolInput = raw.tool_input ?? {};
  const repoRoot = input.repoRoot;
  if (input.host === "codex" && toolName === "write_stdin") {
    const chars = typeof toolInput.chars === "string" ? toolInput.chars : undefined;
    if (!chars)
      return ALLOW;
    for (const path of parseApplyPatchPaths(chars)) {
      const verdict2 = await checkMutatedPath(input, path);
      if (verdict2)
        return verdict2;
    }
    return ALLOW;
  }
  if (isCommandTool(input, toolName)) {
    const command = commandToolInput(input, toolName, toolInput);
    if (!command)
      return ALLOW;
    if (input.host === "codex" && shellRunsApplyPatch(command)) {
      return block("apply-patch-bypass", "shell command runs apply_patch outside the Codex apply_patch tool gate");
    }
    const destructive = checkDestructive(command);
    if (destructive.exitCode === 2)
      return destructive;
    const exposed = bashSecretExposure(command);
    if (exposed !== undefined) {
      return block("secret", `command exposes a secret file (${exposed})`);
    }
    for (const dest of bashWriteTargets(command)) {
      if (isOutsideRepo(repoRoot, dest) && !isClaudeMemoryPath(repoRoot, dest)) {
        return block("scope-out", `write outside repo (${dest})`);
      }
    }
    const jvm = parseJvmCodeqlCommand(command);
    if (jvm) {
      const spec = await loadArchSpec(repoRoot);
      const sourceRoot = jvm.sourceRoot ? resolve16(repoRoot, jvm.sourceRoot) : repoRoot;
      const guard = await runInternalPackagesGuard({
        language: "java",
        entries: spec?.internal_packages ?? [],
        sourceRoot
      });
      if (guard.decision === "block") {
        return block("internal-packages", guard.reason);
      }
    }
    return ALLOW;
  }
  if (input.host === "codex" && toolName === "apply_patch") {
    for (const path of mutatedPaths("codex", raw)) {
      const verdict2 = await checkMutatedPath(input, path);
      if (verdict2)
        return verdict2;
    }
    return ALLOW;
  }
  const filePath = typeof toolInput.file_path === "string" ? toolInput.file_path : undefined;
  if (!filePath)
    return ALLOW;
  if (isSecretPath(filePath)) {
    return block("secret", `access to a secret file (${filePath})`);
  }
  if (toolName === "Write" || toolName === "Edit" || toolName === "MultiEdit") {
    if (isOutsideRepo(repoRoot, filePath) && !isClaudeMemoryPath(repoRoot, filePath)) {
      return block("scope-out", `write outside repo (${filePath})`);
    }
    const forbidden = await checkForbiddenScope(input, filePath);
    if (forbidden)
      return forbidden;
    const offPath = await checkAutopilotLease(input, filePath);
    if (offPath)
      return offPath;
  }
  return ALLOW;
};
async function checkMutatedPath(input, filePath) {
  if (isSecretPath(filePath)) {
    return block("secret", `access to a secret file (${filePath})`);
  }
  if (isOutsideRepo(input.repoRoot, filePath) && !isClaudeMemoryPath(input.repoRoot, filePath)) {
    return block("scope-out", `write outside repo (${filePath})`);
  }
  const forbidden = await checkForbiddenScope(input, filePath);
  if (forbidden)
    return forbidden;
  const offPath = await checkAutopilotLease(input, filePath);
  if (offPath)
    return offPath;
  return;
}
function bashWriteTargets(cmd) {
  const P3 = String.fromCharCode(1);
  const spans = [];
  const skeleton = cmd.replace(/'[^']*'|"(?:[^"\\]|\\.)*"/g, (q2) => {
    spans.push(q2.slice(1, -1));
    return `${P3}${spans.length - 1}${P3}`;
  });
  const placeholderRe = new RegExp(`${P3}(\\d+)${P3}`, "g");
  const unquote = (t2) => t2.replace(placeholderRe, (_3, i2) => spans[Number(i2)] ?? "");
  const out = [];
  const push = (raw) => {
    if (!raw)
      return;
    const t2 = unquote(raw);
    if (t2.length === 0 || /[$`*]/.test(t2))
      return;
    out.push(t2);
  };
  for (const m2 of skeleton.matchAll(/>>?\s*([^\s;&|>]+)/g)) {
    const t2 = m2[1];
    if (t2 && !unquote(t2).startsWith("/dev/"))
      push(t2);
  }
  for (const m2 of skeleton.matchAll(/\btee\b\s+(?:-\S+\s+)*([^\s;&|]+)/g)) {
    push(m2[1]);
  }
  for (const m2 of skeleton.matchAll(/\b(?:cp|mv)\b([^;&|]*)/g)) {
    const args = (m2[1] ?? "").trim().split(/\s+/).filter((a2) => a2.length > 0 && !a2.startsWith("-"));
    if (args.length >= 2)
      push(args[args.length - 1]);
  }
  return out;
}

