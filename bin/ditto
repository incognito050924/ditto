var prismOpponentStatus = exports_external.enum(["engaged", "host_absent"]).describe("Opponent-seam status: engaged (host ran, critique/dissent recorded) \xB7 host_absent (opponent host missing \u2192 graceful degrade to the deterministic shell, self-describing not silent, ADR-0018 / OBJ-3)");
