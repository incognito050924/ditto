// src/cli/commands/change-contract.ts
init_fs();
var changeContractCommand = defineCommand({
  meta: {
    name: "change-contract",
    description: "Compile an ICL file into a ChangeContract and store it (\uB2E8\uACC41, forbidden_scope \uC9D1\uD589 \uC785\uB825)"
  },
  args: {
    "work-item": { type: "string", description: "Work item id", required: true },
    file: { type: "string", description: "Path to the .icl source", required: true },
    "judge-model": {
      type: "string",
      description: "judge_model_version for llm_judged fitness (default: unspecified)"
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let source;
    try {
      source = await readFile9(args.file, "utf8");
    } catch {
      writeError(`change-contract: cannot read ICL file ${args.file}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const result2 = compileIcl(source, {
      work_item_id: args["work-item"],
      produced_by: "agent",
      produced_at: new Date().toISOString(),
      judge_model_version: args["judge-model"] ?? "unspecified"
    });
    if (!result2.ok) {
      if (format === "json") {
        writeJson2({ ok: false, errors: result2.errors });
      } else {
        writeError(`change-contract: ICL \uCEF4\uD30C\uC77C \uC2E4\uD328 (${result2.errors.length} error)`);
        for (const e2 of result2.errors) {
          const where = e2.kind === "parse" && e2.line ? ` (line ${e2.line})` : "";
          writeError(`  - [${e2.kind}] ${e2.message}${where}`);
        }
      }
      process.exit(RUNTIME_ERROR_EXIT);
      return;
    }
    const repoRoot = await resolveRepoRootForCreate();
    const expanded = await expandForbiddenSymbols(result2.changeContract, {
      repoRoot,
      sourceRoot: join44(repoRoot, "src"),
      language: "javascript",
      cacheDir: codeqlCacheDir(repoRoot, "javascript"),
      deps: makeRelationDeps()
    });
    await new ChangeContractStore(repoRoot).write(args["work-item"], expanded.contract);
    await new FitnessFunctionStore(repoRoot).write(args["work-item"], result2.fitnessFunctions);
    const summary = {
      work_item_id: args["work-item"],
      forbidden_scope: expanded.contract.forbidden_scope.length,
      allowed_scope: expanded.contract.allowed_scope.length,
      fitness_functions: result2.fitnessFunctions.length,
      symbols_resolved: expanded.resolved,
      symbols_unresolved: expanded.unresolved,
      warnings: result2.warnings?.length ?? 0
    };
    if (format === "json") {
      writeJson2(summary);
    } else {
      const unresolvedNote = summary.symbols_unresolved.length > 0 ? `, unresolved symbols [${summary.symbols_unresolved.join(", ")}]` : "";
      writeHuman(`change-contract: saved \u2192 .ditto/local/work-items/${args["work-item"]}/change-contract.json ` + `(forbidden ${summary.forbidden_scope}, allowed ${summary.allowed_scope}, ` + `fitness ${summary.fitness_functions}, symbols\u2192path ${summary.symbols_resolved}${unresolvedNote}, ` + `warnings ${summary.warnings})`);
    }
  }
});

// src/acg/change-map/render.ts
var RISK_BADGE = {
  low: "\uD83D\uDFE2[low]",
  medium: "\uD83D\uDFE1[medium]",
  high: "\uD83D\uDD34[high]"
};
var RISK_ORDER = { low: 0, medium: 1, high: 2 };
function resolveRisk(contract, review) {
  if (review && review.files.length > 0) {
    return review.files.reduce((worst2, f3) => RISK_ORDER[f3.risk] > RISK_ORDER[worst2] ? f3.risk : worst2, "low");
  }
  return contract.risk_default;
}
function nodeRef(node2) {
  return node2.journey_id ?? node2.path ?? "";
}
function reviewRef(file) {
  return file.journey_id ?? file.path ?? "";
}
function evidenceBadge(ref, review) {
  const file = review?.files.find((f3) => reviewRef(f3) === ref);
  if (!file)
    return "\u2610";
  if (file.unresolved)
    return "\u26A0";
  return file.evidence ? "\u2611" : "\u2610";
}
function summarize(contract, impact, review) {
  return {
    change_id: contract.work_item_id,
    risk: resolveRisk(contract, review),
    impact: impact?.affected_nodes.length ?? 0,
    unresolved: impact?.unresolved.length ?? 0,
    open_accept: contract.acceptance.length
  };
}
function render(contract, impact, review) {
  const lines = [];
  lines.push(`\u25C6 ${contract.work_item_id} ${RISK_BADGE[resolveRisk(contract, review)]} "${contract.purpose}"`);
  lines.push(`  decision: ${contract.decision_ref ?? "\u2014"}`);
  lines.push("  scope:");
  lines.push(`    allow \u2500 ${contract.allowed_scope.map((s2) => s2.ref).join(", ")}`);
  lines.push(`    forbid \u2715 ${contract.forbidden_scope.map((s2) => s2.ref).join("  \u2715 ")}`);
  if (impact && (impact.affected_nodes.length > 0 || impact.unresolved.length > 0)) {
    lines.push("  impact:");
    for (const node2 of impact.affected_nodes) {
      const ref = nodeRef(node2);
      lines.push(`    \u2192 ${node2.kind} ${ref} ${evidenceBadge(ref, review)}`);
    }
    for (const u3 of impact.unresolved) {
      lines.push(`    \u26A0 unresolved: ${u3.kind} ${u3.path} \u2014 ${u3.reason}`);
    }
  }
  lines.push("  accept:");
  for (const a2 of contract.acceptance) {
    lines.push(`    \u2610 "${a2.criterion}" (${a2.evidence_kind})`);
  }
  return `${lines.join(`
`)}
`;
}
function label(text) {
  return text.replaceAll('"', "'").replaceAll(`
`, " ");
}
function nodeId(prefix, index) {
  return `${prefix}${index}`;
}
var RISK_CLASSDEF = {
  low: "classDef low fill:#dcfce7,stroke:#16a34a;",
  medium: "classDef medium fill:#fef9c3,stroke:#ca8a04;",
  high: "classDef high fill:#fee2e2,stroke:#dc2626;"
};
function renderMermaid(contract, impact, review) {
  const risk = resolveRisk(contract, review);
  const lines = ["graph LR"];
  lines.push(`  C["\u25C6 ${label(contract.work_item_id)}<br/>${risk}"]:::${risk}`);
  contract.forbidden_scope.forEach((s2, i2) => {
    const id = nodeId("F", i2);
    lines.push(`  C -.->|\u2715 forbid| ${id}["${label(s2.ref)}"]:::forbid`);
  });
  if (impact) {
    impact.affected_nodes.forEach((node2, i2) => {
      const ref = nodeRef(node2);
      const id = nodeId("A", i2);
      lines.push(`  C -->|${node2.kind} ${evidenceBadge(ref, review)}| ${id}["${label(ref)}"]`);
    });
    impact.unresolved.forEach((u3, i2) => {
      const id = nodeId("U", i2);
      lines.push(`  C -.->|\u26A0 unresolved| ${id}["${label(`${u3.kind}: ${u3.path}`)}"]:::unresolved`);
    });
  }
  lines.push("");
  lines.push(`  ${RISK_CLASSDEF[risk]}`);
  lines.push("  classDef forbid fill:#fee2e2,stroke:#dc2626,stroke-dasharray:4;");
  lines.push("  classDef unresolved fill:#f3f4f6,stroke:#6b7280,stroke-dasharray:2;");
  return `\`\`\`mermaid
${lines.join(`
`)}
\`\`\`
`;
}
// src/cli/commands/change-map.ts
init_ditto_paths();
init_fs();

// src/schemas/acg-impact-graph.ts
init_zod();
var journeyKinds = ["ui_surface", "user_journey"];
var acgAffectedNode = exports_external.object({
  kind: exports_external.enum([
    "direct_caller",
    "transitive_caller",
    "type_contract",
    "generated_client",
    "test",
    "doc",
    "external_surface",
    "ui_surface",
    "user_journey"
  ]),
  path: exports_external.string().min(1).optional().describe("Code location; required unless kind is a journey"),
  symbol: exports_external.string().optional(),
  journey_id: exports_external.string().optional().describe("JourneySpec.id; required when kind is ui_surface/user_journey (OBJ-31)"),
  reason: exports_external.string().optional(),
  handled: exports_external.boolean().default(false)
}).superRefine((value, ctx) => {
  const isJourney = journeyKinds.includes(value.kind);
  if (isJourney && !value.journey_id) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "ui_surface/user_journey node requires journey_id",
      path: ["journey_id"]
    });
  }
  if (!isJourney && !value.path) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "non-journey node requires path",
      path: ["path"]
    });
  }
}).describe("One affected node; journey kinds use journey_id, others use path");
var acgUnresolvedImpact = exports_external.object({
  kind: exports_external.enum([
    "dynamic_call",
    "reflection",
    "string_dispatch",
    "config_driven",
    "cross_repo",
    "journey_unknown"
  ]),
  path: exports_external.string().min(1),
  reason: exports_external.string().min(1)
}).describe("Statically unresolvable impact \u2014 left as unverified risk");
var acgImpactGraph = exports_external.object({
  ...acgChangeEnvelope("acg.impact-graph.v1"),
  change_target: exports_external.string().min(1),
  change_type: exports_external.enum(["rename", "signature", "behavior", "delete", "add", "move"]),
  affected_nodes: exports_external.array(acgAffectedNode).default([]),
  unresolved: exports_external.array(acgUnresolvedImpact).default([])
}).describe("ACG ImpactGraph \u2014 affected nodes + unresolved impact");

// src/cli/commands/change-map.ts
var changeMapCommand = defineCommand({
  meta: {
    name: "change-map",
    description: "Render the Change Map text notation for a work item (50-change-map \xA72.1)"
  },
  args: {
    "work-item": { type: "string", description: "Work item id", required: true },
    output: {
      type: "string",
      description: "Output format: human|json|mermaid",
      default: "human"
    }
  },
  run: async ({ args }) => {
    const isMermaid = args.output === "mermaid";
    let format = "human";
    if (!isMermaid) {
      try {
        format = parseOutputFormat(args.output);
      } catch (err) {
        writeError(err instanceof Error ? err.message : String(err));
        process.exit(USAGE_ERROR_EXIT);
        return;
      }
    }
    const repoRoot = await resolveRepoRootForCreate();
    const workItem2 = args["work-item"];
    const contract = await new ChangeContractStore(repoRoot).read(workItem2);
    if (!contract) {
      writeError(`change-map: change-contract.json not found for ${workItem2}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let impact;
    try {
      impact = await readJson(localDir(repoRoot, "work-items", workItem2, "impact-graph.json"), acgImpactGraph);
    } catch {
      impact = undefined;
    }
    const reviewStore = new AcgReviewStore(repoRoot);
    const review = await reviewStore.exists(workItem2) ? await reviewStore.get(workItem2) : undefined;
    if (isMermaid) {
      writeHuman(renderMermaid(contract, impact, review));
    } else if (format === "json") {
      writeJson2(summarize(contract, impact, review));
    } else {
      writeHuman(render(contract, impact, review));
    }
  }
});

// src/cli/commands/classify.ts
import { isAbsolute as isAbsolute6, join as join47 } from "path";

// src/core/cleanup-scan.ts
init_cleanup_store();
init_memory_scan();
import { readdir as readdir14, stat as stat5 } from "fs/promises";
import { isAbsolute as isAbsolute5, join as join46, relative as relative11, resolve as resolve9 } from "path";
var SKIP_DIRS3 = new Set([
  "node_modules",
  ".git",
  ".ditto",
  "target",
  "build",
  "dist",
  ".gradle",
  "out",
  "coverage"
]);
var DOC_EXTS = new Set([".md", ".mdx", ".txt", ".rst", ".adoc"]);
function isDocFile(name) {
  const dot = name.lastIndexOf(".");
  if (dot < 0)
    return false;
  return DOC_EXTS.has(name.slice(dot).toLowerCase());
}
async function walkDocs(root, maxDepth = 12) {
  const out = [];
  async function walk(dir, depth) {
    if (depth > maxDepth)
      return;
    let entries;
    try {
      entries = await readdir14(dir, { withFileTypes: true });
    } catch {
      return;
    }
    for (const e2 of entries) {
      const full = join46(dir, e2.name);
      if (e2.isDirectory()) {
        if (!SKIP_DIRS3.has(e2.name))
          await walk(full, depth + 1);
      } else if (e2.isFile() && isDocFile(e2.name)) {
        out.push(full);
      }
    }
  }
  await walk(resolve9(root), 0);
  out.sort();
  return out;
}
function trackedPaths(repoRoot) {
  const proc = Bun.spawnSync(["git", "ls-files"], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (proc.exitCode !== 0)
    return new Set;
  return new Set((proc.stdout?.toString() ?? "").split(`
`).map((l2) => l2.trim()).filter((l2) => l2.length > 0));
}
function docsTouchedByCommits(repoRoot, commits) {
  const out = new Set;
  for (const c3 of commits) {
    const proc = Bun.spawnSync(["git", "show", "--name-only", "--pretty=format:", c3], {
      cwd: repoRoot,
      stdout: "pipe",
      stderr: "pipe"
    });
    if (proc.exitCode !== 0)
      continue;
    for (const l2 of (proc.stdout?.toString() ?? "").split(`
`)) {
      const p = l2.trim();
      if (p.length > 0)
        out.add(p);
    }
  }
  return out;
}
function lastCommitTouchingMs(repoRoot, pathspec) {
  const proc = Bun.spawnSync(["git", "log", "-1", "--format=%ct", "--", pathspec], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (proc.exitCode !== 0)
    return null;
  const secs = Number((proc.stdout?.toString() ?? "").trim());
  return Number.isFinite(secs) && secs > 0 ? secs * 1000 : null;
}
function hasInboundReference(repoRoot, repoRel) {
  const base = repoRel.split("/").pop() ?? repoRel;
  const proc = Bun.spawnSync(["git", "grep", "-F", "-l", "-I", "--", base], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (proc.exitCode !== 0)
    return false;
  const hits = (proc.stdout?.toString() ?? "").split(`
`).map((l2) => l2.trim()).filter((l2) => l2.length > 0 && l2 !== repoRel);
  return hits.length > 0;
}
async function scanCandidates(repoRoot, options) {
  const root = resolve9(repoRoot);
  const absFiles = await walkDocs(root);
  const tracked = trackedPaths(root);
  const scopeCommitDocs = options.scopeCommits && options.scopeCommits.length > 0 ? docsTouchedByCommits(root, options.scopeCommits) : null;
  const candidates = [];
  const excludedProtected = [];
  for (const abs of absFiles) {
    const repoRel = relative11(root, abs).replace(/\\/g, "/");
    if (repoRel.startsWith("..") || isAbsolute5(repoRel))
      continue;
    if (isProtectedPath(repoRel)) {
      excludedProtected.push(repoRel);
      continue;
    }
    const isTracked = tracked.has(repoRel);
    if (options.trackedFilter === "tracked-only" && !isTracked)
      continue;
    if (options.trackedFilter === "untracked-only" && isTracked)
      continue;
    if (options.scopeGlob && !matchesGlob2(repoRel, options.scopeGlob))
      continue;
    if (scopeCommitDocs && !scopeCommitDocs.has(repoRel))
      continue;
    const owning = await findOwningRepo(abs, root);
    const owningRepo = owning === null ? null : relative11(root, owning).replace(/\\/g, "/") || ".";
    const signals = [];
    if (!hasInboundReference(root, repoRel)) {
      signals.push({ kind: "orphan", detail: `no inbound reference to ${repoRel}` });
    }
    const docMtimeMs = (await stat5(abs)).mtimeMs;
    const lastCommitMs = lastCommitTouchingMs(root, repoRel);
    if (lastCommitMs !== null && docMtimeMs < lastCommitMs) {
      signals.push({
        kind: "stale",
        detail: `doc mtime older than its most recent commit (${new Date(lastCommitMs).toISOString()})`
      });
    }
    candidates.push({ path: repoRel, owning_repo: owningRepo, tracked: isTracked, signals });
  }
  return { candidates, excluded_protected: excludedProtected };
}
function matchesGlob2(repoRel, glob) {
  const re = globToRegExp3(glob);
  return re.test(repoRel);
}
function globToRegExp3(glob) {
  let out = "";
  for (let i2 = 0;i2 < glob.length; i2++) {
    const c3 = glob[i2];
    if (c3 === "*") {
      if (glob[i2 + 1] === "*") {
        out += ".*";
        i2++;
      } else {
        out += "[^/]*";
      }
    } else if (c3 === "?") {
      out += "[^/]";
    } else if (".+^${}()|[]\\".includes(c3)) {
      out += `\\${c3}`;
    } else {
      out += c3;
    }
  }
  return new RegExp(`^${out}$`);
}

// src/cli/commands/classify.ts
init_cleanup_store();
init_fs();
init_cleanup_index();
var AUTO_ARCHIVE_ACTIONS = ["quarantine", "absorb-then-discard"];

class AutoCleanupDeleteRefusedError extends Error {
  constructor(action) {
    super(`auto-cleanup path refuses action "${action}": auto/autopilot runs can only archive, never delete (ac-6 fail-closed)`);
    this.name = "AutoCleanupDeleteRefusedError";
  }
}
function autoChainArchiveAction(action) {
  if (AUTO_ARCHIVE_ACTIONS.includes(action)) {
    return action;
  }
  throw new AutoCleanupDeleteRefusedError(action);
}
function parseFormatOrExit(output) {
  try {
    return parseOutputFormat(output);
  } catch (err) {
    writeError(err instanceof Error ? err.message : String(err));
    process.exit(USAGE_ERROR_EXIT);
  }
}
var DEFAULT_CATEGORIES = ["design", "report", "note", "scratch"];
function parseListArg(value) {
  return (value ?? "").split(",").map((s2) => s2.trim()).filter((s2) => s2.length > 0);
}
function parseAggressivenessOrExit(value) {
  const n2 = Number(value);
  if (!Number.isInteger(n2) || n2 < 1 || n2 > 5) {
    writeError(`--aggressiveness/\uC801\uADF9\uC131 must be an integer 1..5; got "${value}"`);
    process.exit(USAGE_ERROR_EXIT);
  }
  return n2;
}
function parseConcurrencyOrExit(value) {
  const n2 = Number(value);
  if (!Number.isInteger(n2) || n2 < 1) {
    writeError(`--concurrency/\uB3D9\uC2DC\uC131 must be a positive integer; got "${value}"`);
    process.exit(USAGE_ERROR_EXIT);
  }
  return n2;
}
function parseTrackedOrExit(value) {
  const parsed = cleanupTrackedFilter.safeParse(value);
  if (!parsed.success) {
    writeError(`--tracked must be one of ${cleanupTrackedFilter.options.join("|")}; got "${value}"`);
    process.exit(USAGE_ERROR_EXIT);
  }
  return parsed.data;
}
function scopeIsCommits(scope) {
  const tokens = scope.split(",").map((s2) => s2.trim()).filter((s2) => s2.length > 0);
  return tokens.length > 0 && tokens.every((t2) => /^[0-9a-f]{7,40}$/i.test(t2));
}
var classifyScan = defineCommand({
  meta: {
    name: "scan",
    description: "Discover candidate docs across the workspace with deterministic lost-authority signals (orphan/stale). Excludes the protected set (ac-4); resolves each doc owning sub-repo (ac-7). The contradiction signal needs judgment \u2192 per-doc agent in the skill, not here."
  },
  args: {
    scope: {
      type: "string",
      description: "\uBC94\uC704 \u2014 gitignore-form glob OR a comma-separated commit-hash list to limit scope",
      required: false
    },
    tracked: {
      type: "string",
      description: `Tracked filter: ${cleanupTrackedFilter.options.join("|")} (default tracked-only)`,
      default: "tracked-only"
    },
    categories: {
      type: "string",
      description: "\uBD84\uB958\uC720\uD615 \u2014 comma-separated doc categories (default all four)",
      required: false
    },
    aggressiveness: {
      type: "string",
      description: "\uC801\uADF9\uC131 \u2014 1 (conservative) \u2026 5 (aggressive); default 3",
      default: "3"
    },
    concurrency: {
      type: "string",
      description: "\uB3D9\uC2DC\uC131 \u2014 worker count the skill fans out at (default 4)",
      default: "4"
    },
    "auto-cleanup": {
      type: "boolean",
      description: "\uC790\uB3D9\uC815\uB9AC \u2014 chain into the archive-only cleanup path after classification (default off; delete never runs on this path, ac-6)",
      default: false
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    const format = parseFormatOrExit(args.output);
    const trackedFilter = parseTrackedOrExit(args.tracked);
    const aggressiveness = parseAggressivenessOrExit(args.aggressiveness);
    const concurrency = parseConcurrencyOrExit(args.concurrency);
    const categories = args.categories === undefined ? [...DEFAULT_CATEGORIES] : parseListArg(args.categories);
    const scope = args.scope;
    const scopeCommits = scope && scopeIsCommits(scope) ? scope.split(",").map((s2) => s2.trim()) : undefined;
    const scopeGlob = scope && !scopeCommits ? scope : undefined;
    const repoRoot = await resolveRepoRootForCreate();
    try {
      const result2 = await scanCandidates(repoRoot, {
        trackedFilter,
        aggressiveness,
        ...scopeGlob ? { scopeGlob } : {},
        ...scopeCommits ? { scopeCommits } : {},
        categories
      });
      const params = {
        tracked_filter: trackedFilter,
        categories,
        auto_cleanup: args["auto-cleanup"],
        concurrency,
        aggressiveness,
        ...scope ? { scope } : {}
      };
      if (format === "json") {
        writeJson2({ params, ...result2 });
      } else {
        writeHuman(`Scanned ${repoRoot}`);
        writeHuman(`  candidates: ${result2.candidates.length}`);
        writeHuman(`  excluded (protected): ${result2.excluded_protected.length}`);
        writeHuman(`  tracked filter: ${trackedFilter}  aggressiveness: ${aggressiveness}`);
        if (args["auto-cleanup"]) {
          writeHuman("  auto-cleanup: ON (archive-only \u2014 delete never runs, ac-6)");
        }
        for (const c3 of result2.candidates) {
          const sig = c3.signals.map((s2) => s2.kind).join(",") || "-";
          writeHuman(`  ${c3.tracked ? "T" : "U"} ${c3.path}	[${sig}]	repo=${c3.owning_repo ?? "."}`);
        }
      }
    } catch (err) {
      writeError(`classify scan failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
