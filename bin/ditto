// src/core/active-node-lease.ts
init_zod();
init_common();
init_ditto_paths();
init_fs();
import { join as join19 } from "path";
var activeNodeLease = exports_external.object({
  node_id: exports_external.string().min(1),
  work_item_id: workItemId,
  file_scope: exports_external.array(relativePath),
  scope_source: exports_external.enum(["declared", "derived"]).default("declared"),
  created_at: isoDateTime
}).describe("One in-flight autopilot node lease");
var LEAKED_LEASE_MAX_AGE_MS = 24 * 60 * 60 * 1000;
function isLeaked(lease, now) {
  const createdMs = Date.parse(lease.created_at);
  if (Number.isNaN(createdMs))
    return false;
  return now - createdMs > LEAKED_LEASE_MAX_AGE_MS;
}
var leaseFile = exports_external.object({
  schema_version: exports_external.literal("0.1.0"),
  leases: exports_external.array(activeNodeLease).default([])
}).describe("Active-node leases for one work item (node_id \u2192 lease map, as a list)");

class ActiveNodeLeaseStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  dir(workItemId2) {
    return localDir(this.repoRoot, "work-items", workItemId2);
  }
  path(workItemId2) {
    return join19(this.dir(workItemId2), "active-leases.json");
  }
  async listActive(workItemId2) {
    let leases;
    try {
      leases = (await readJson(this.path(workItemId2), leaseFile)).leases;
    } catch {
      return [];
    }
    const now = Date.now();
    const live = leases.filter((l2) => !isLeaked(l2, now));
    if (live.length !== leases.length) {
      try {
        await writeJson(this.path(workItemId2), leaseFile, {
          schema_version: "0.1.0",
          leases: live
        });
      } catch {}
    }
    return live;
  }
  async set(lease) {
    await ensureDir(this.dir(lease.work_item_id));
    const current = await this.listActive(lease.work_item_id);
    const next = [...current.filter((l2) => l2.node_id !== lease.node_id), lease];
    await writeJson(this.path(lease.work_item_id), leaseFile, {
      schema_version: "0.1.0",
      leases: next
    });
  }
  async removeByNode(workItemId2, nodeId) {
    const current = await this.listActive(workItemId2);
    const next = current.filter((l2) => l2.node_id !== nodeId);
    if (next.length === current.length)
      return;
    await ensureDir(this.dir(workItemId2));
    await writeJson(this.path(workItemId2), leaseFile, {
      schema_version: "0.1.0",
      leases: next
    });
  }
}

// src/core/agent-variants.ts
init_fs();
init_shared();
import { readdir as readdir7 } from "fs/promises";
import { basename, join as join20 } from "path";
async function loadVariantCatalog(repoRoot) {
  const dir = join20(repoRoot, ".ditto", "agents");
  let entries;
  try {
    entries = await readdir7(dir);
  } catch {
    return [];
  }
  const catalog = [];
  for (const entry of entries.sort()) {
    if (!entry.endsWith(".md"))
      continue;
    const text = await Bun.file(join20(dir, entry)).text();
    const variant = parseVariant(text);
    if (variant)
      catalog.push(variant);
  }
  return catalog;
}
function selectVariantCandidates(catalog, owner, fileScope, hint, opts = { scopeDeclared: true }) {
  const candidates = catalog.filter((v2) => v2.role === owner && (v2.match.length === 0 || opts.scopeDeclared && v2.match.some((glob) => fileScope.some((path) => globMatch(glob, path))))).map((v2) => ({ name: v2.name, description: v2.description }));
  if (hint === undefined)
    return candidates;
  const hinted = candidates.find((c3) => c3.name === hint) ?? catalog.filter((v2) => v2.role === owner && v2.name === hint).map((v2) => ({ name: v2.name, description: v2.description }))[0];
  if (!hinted)
    return candidates;
  return [hinted, ...candidates.filter((c3) => c3.name !== hint)];
}
function parseVariant(text) {
  const fm = extractFrontmatter(text);
  if (fm === null)
    return null;
  const lines = fm.split(`
`);
  let name;
  let role;
  let description = "";
  let match = [];
  for (let i2 = 0;i2 < lines.length; i2++) {
    const line = lines[i2] ?? "";
    const m2 = /^([A-Za-z_][\w-]*):(.*)$/.exec(line);
    if (!m2)
      continue;
    const key = m2[1];
    const rest = (m2[2] ?? "").trim();
    if (key === "name")
      name = stripQuotes(rest);
    else if (key === "role")
      role = stripQuotes(rest);
    else if (key === "description") {
      if (rest === "|" || rest === ">") {
        const block = [];
        const baseIndent = indentOf(lines[i2 + 1] ?? "");
        while (i2 + 1 < lines.length) {
          const next = lines[i2 + 1] ?? "";
          if (next.trim() === "") {
            block.push("");
            i2++;
            continue;
          }
          if (indentOf(next) < baseIndent)
            break;
          block.push(next.slice(baseIndent));
          i2++;
        }
        description = block.join(`
`).trim();
      } else {
        description = stripQuotes(rest);
      }
    } else if (key === "match") {
      if (rest.startsWith("[")) {
        match = parseInlineList(rest);
      } else if (rest === "") {
        const items = [];
        while (i2 + 1 < lines.length) {
          const next = lines[i2 + 1] ?? "";
          const im = /^\s*-\s+(.*)$/.exec(next);
          if (!im)
            break;
          items.push(stripQuotes((im[1] ?? "").trim()));
          i2++;
        }
        match = items;
      } else {
        match = [stripQuotes(rest)];
      }
    }
  }
  if (!name || !role)
    return null;
  return { name, role, description, match };
}
function findOrphanVariants(variantNames, hostAgentNames) {
  const host = new Set(hostAgentNames);
  return variantNames.filter((name) => !host.has(name));
}
function recommendVariantRole(name, description) {
  const text = `${name} ${description}`.toLowerCase();
  if (/security|appsec|vuln/.test(text))
    return "security-reviewer";
  if (/review|audit/.test(text))
    return "reviewer";
  if (/architect|architecture|design/.test(text))
    return "architect";
  if (/research|investigate/.test(text))
    return "researcher";
  if (/test|qa/.test(text))
    return "verifier";
  if (/refactor|tidy/.test(text))
    return "refactorer";
  return "implementer";
}
async function writeAgentVariants(repoRoot, variants) {
  const dir = join20(repoRoot, ".ditto", "agents");
  const written = [];
  const skipped = [];
  for (const variant of variants) {
    const name = variant.name;
    if (name === "" || name === "." || name === ".." || name.includes("/") || name.includes("\\") || name.includes("\x00") || basename(name) !== name) {
      throw new Error(`unsafe agent variant name (must be a single safe path segment): ${name}`);
    }
    const file = join20(dir, `${variant.name}.md`);
    if (await fileExists(file)) {
      skipped.push(variant.name);
      continue;
    }
    await ensureDir(dir);
    await Bun.write(file, renderVariant(variant));
    written.push(variant.name);
  }
  return { written, skipped };
}
function renderVariant(variant) {
  const lines = ["---", `name: ${variant.name}`, `role: ${variant.role}`];
  if (variant.match.length > 0)
    lines.push(`match: [${variant.match.join(", ")}]`);
  lines.push("description: |");
  for (const line of variant.description.split(`
`))
    lines.push(`  ${line}`);
  lines.push("---", "");
  return lines.join(`
`);
}
function extractFrontmatter(text) {
  const lines = text.split(`
`);
  if ((lines[0] ?? "").trim() !== "---")
    return null;
  for (let i2 = 1;i2 < lines.length; i2++) {
    if ((lines[i2] ?? "").trim() === "---") {
      return lines.slice(1, i2).join(`
`);
    }
  }
  return null;
}
function indentOf(line) {
  const m2 = /^(\s*)/.exec(line);
  return (m2?.[1] ?? "").length;
}
function stripQuotes(s2) {
  if (s2.length >= 2 && (s2.startsWith('"') && s2.endsWith('"') || s2.startsWith("'") && s2.endsWith("'"))) {
    return s2.slice(1, -1);
  }
  return s2;
}
function parseInlineList(s2) {
  const inner = s2.replace(/^\[/, "").replace(/\]$/, "").trim();
  if (inner === "")
    return [];
  return inner.split(",").map((part) => stripQuotes(part.trim())).filter((part) => part.length > 0);
}
function globMatch(glob, path) {
  let re = "";
  for (let i2 = 0;i2 < glob.length; i2++) {
    const c3 = glob[i2];
    if (c3 === "*") {
      if (glob[i2 + 1] === "*") {
        re += ".*";
        i2++;
      } else {
        re += "[^/]*";
      }
    } else if (".+?^${}()|[]\\/".includes(c3)) {
      re += `\\${c3}`;
    } else {
      re += c3;
    }
  }
  return new RegExp(`^${re}$`).test(path);
}

// src/core/autopilot-converge.ts
var FORWARD_FIX_MARKER = ".fix.r";
var FORWARD_REVIEW_MARKER = ".rev.r";
function forwardRound(reviewNodeId) {
  return reviewNodeId.split(FORWARD_REVIEW_MARKER).length - 1;
}
function totalForwardRounds(nodeIds) {
  return nodeIds.filter((id) => id.includes(FORWARD_REVIEW_MARKER)).length;
}
function mkNode(id, kind, purpose, depends_on, acceptance_refs) {
  return {
    id,
    kind,
    owner: kindToOwner(kind),
    purpose,
    status: "pending",
    depends_on,
    acceptance_refs,
    evidence_refs: [],
    attempts: { fix: 0, switch: 0 }
  };
}
function forwardShape(trigger, seed, round, fixId) {
  switch (trigger) {
    case "reverify":
      return {
        recheckKind: "verify",
        fixPurpose: `Collect evidence for the unverified in-scope criteria raised by ${seed.id} (round ${round})`,
        reviewPurpose: `Re-verify after ${fixId}; close only on an evidence-backed pass verdict`
      };
    case "risk_fix":
      return {
        recheckKind: "verify",
        fixPurpose: `Resolve the agent_resolvable residual risk surfaced by ${seed.id} (round ${round})`,
        reviewPurpose: `Re-verify after ${fixId}; close only when the risk is verified resolved`
      };
    case "follow_up":
      return {
        recheckKind: "verify",
        fixPurpose: `Address the in-scope follow-up surfaced by ${seed.id} (round ${round})`,
        reviewPurpose: `Re-verify after ${fixId}; close only when the follow-up is verified done`
      };
    default:
      return {
        recheckKind: seed.kind,
        fixPurpose: `Resolve findings raised by ${seed.id} (round ${round})`,
        reviewPurpose: `Re-check after ${fixId}; close the loop only on a findings=0 verdict`
      };
  }
}
function planForwardReexpansion(outcome) {
  const { reviewNode, hasFindings, round, budget } = outcome;
  const trigger = outcome.trigger ?? "review";
  if (!hasFindings)
    return { decision: "close" };
  if (outcome.blockedByOptionalTool) {
    const { tool, grounding } = outcome.blockedByOptionalTool;
    return {
      decision: "surface",
      resolvability: "blocked_external",
      grounding,
      reason: `${trigger} cannot be auto-fixed: optional tool '${tool}' is absent (ADR-0018 graceful-degrade). Surfaced blocked_external with grounding, not agent_resolvable \u2014 an agent_resolvable re-verify would loop because grounding never releases it (gates.ts:222-237).`
    };
  }
  if (round >= budget) {
    return {
      decision: "escalate",
      reason: `forward re-expansion budget reached (round ${round} \u2265 converge_rounds ${budget}) with findings still open on ${reviewNode.id}; cap-reached \u2260 converged, escalate rather than pass`
    };
  }
  const fixId = `${reviewNode.id}${FORWARD_FIX_MARKER}${round}`;
  const reviewId2 = `${reviewNode.id}${FORWARD_REVIEW_MARKER}${round}`;
  const shape = forwardShape(trigger, reviewNode, round, fixId);
  const fix = mkNode(fixId, "fix", shape.fixPurpose, [reviewNode.id], reviewNode.acceptance_refs);
  const review = mkNode(reviewId2, shape.recheckKind, shape.reviewPurpose, [fixId], reviewNode.acceptance_refs);
  return { decision: "expand", nodes: [fix, review] };
}

// src/core/autopilot-dispatch.ts
var OWNER_TOOLS = {
  researcher: ["Read", "Grep", "Glob", "Bash", "WebSearch", "WebFetch"],
  planner: ["Read", "Grep", "Glob"],
  implementer: ["Read", "Grep", "Glob", "Edit", "Write", "Bash"],
  reviewer: ["Read", "Grep", "Glob", "Bash"],
  verifier: ["Read", "Grep", "Glob", "Bash"],
  architect: ["Read", "Grep", "Glob"],
  "playwright-e2e": ["Read", "Grep", "Glob", "Bash"],
  "knowledge-curator": ["Read", "Grep", "Glob", "Write"],
  "security-reviewer": ["Read", "Grep", "Glob", "Bash"],
  refactorer: ["Read", "Grep", "Glob", "Edit", "Write", "Bash"],
  retrospective: ["Read", "Grep", "Glob", "Bash"],
  driver: [],
  "main-session": [],
  tester: ["Read", "Grep", "Glob", "Bash"]
};
function isMutatingOwner(owner) {
  return OWNER_TOOLS[owner].includes("Edit");
}
function isReviewOwner(owner) {
  return owner === "reviewer" || owner === "verifier" || owner === "security-reviewer";
}
var PLANNER_GENERATE_DIRECTIVE = "Emit a `generated_nodes` subgraph: pick the \xA72.2 lifecycle stages this task " + "actually needs (research\xB7design\xB7implement\xB7review\xB7verify\xB7\u2026), each node " + "{id, kind, purpose, depends_on, acceptance_refs, file_scope} mapped to its " + "acceptance criteria; scale to task size (small tasks stay minimal \u2014 do not " + "force a stage). For each MUTATING node declare `file_scope` (the repo-relative " + "paths it will edit) as precisely and DISJOINTLY as you can: non-overlapping " + "scopes let independent mutators run in parallel, while leaving it off forces the " + "engine to serialize that node conservatively (one scope-unknown mutator at a " + "time). Omit it ONLY when the scope is genuinely unknown \u2014 never guess a scope " + "that might overlap another node (a wrong disjoint claim risks a clobber).";
var CITE_OR_ABSTAIN_DIRECTIVE = "Consult the governing decisions in context.memory.decision_briefs: cite the " + "ones you relied on (follow them or justify any deviation), and if none apply " + "to this task, state that explicitly (cite-or-abstain).";
var RED_FIRST_DIRECTIVE = "Red-first discipline (code-behavior AC): write the failing test that asserts " + "this criterion FIRST and run it; confirm it fails on the AC assertion itself, " + "not on a compile/import error (no phantom red), then make the smallest change " + "to turn it green. Report both the red run and the green run (command + exit code).";
var SCOPE_LOCAL_UNIT_DIRECTIVE = "Scope-local unit tests (mid-wave): run ONLY the mock-unit tests for your own " + "file_scope \u2014 do NOT run the full or cross-module suite while other implementers may " + "be editing in parallel. The whole-suite GREEN is proven ONCE after the wave settles by " + "the deterministic settled-tree test barrier, not by you. Report the command + exit code " + "of your scoped unit run.";
function isRedFirstImplement(owner, acceptance) {
  return owner === "implementer" && acceptance.some((a2) => a2.oracle?.verification_method === "dynamic_test");
}
function buildDelegationPacket(node, workItem2, variantCandidates = [], fileScope = workItem2.changed_files, memoryContext, retroContext, changeSurface) {
  const isPlanner = node.owner === "planner";
  const acceptance = node.acceptance_refs.flatMap((id) => {
    const ac = workItem2.acceptance_criteria?.find((c3) => c3.id === id);
    if (!ac)
      return [];
    return [{ id: ac.id, statement: ac.statement, ...ac.oracle ? { oracle: ac.oracle } : {} }];
  });
  const doneWhen = acceptance.length > 0 ? `acceptance criteria satisfied with evidence: ${acceptance.map((a2) => {
    const how = a2.oracle ? ` [oracle: ${a2.oracle.verification_method}]` : "";
    return `${a2.id} \u2014 ${a2.statement}${how}`;
  }).join("; ")}` : node.acceptance_refs.length > 0 ? `acceptance criteria satisfied with evidence: ${node.acceptance_refs.join(", ")}` : node.purpose;
  const expectedOutcome = isPlanner ? `${doneWhen} (return the plan as a generated_nodes subgraph)` : doneWhen;
  return {
    task: node.purpose,
    expected_outcome: expectedOutcome,
    required_tools: OWNER_TOOLS[node.owner],
    must_do: [
      "Work only from this packet.",
      "Return a single result with evidence (command + exit code, file:line).",
      ...isPlanner ? [PLANNER_GENERATE_DIRECTIVE] : [],
      ...isRedFirstImplement(node.owner, acceptance) ? [RED_FIRST_DIRECTIVE] : [],
      ...node.owner === "implementer" ? [SCOPE_LOCAL_UNIT_DIRECTIVE] : [],
      ...memoryContext?.decisions?.length || memoryContext?.decision_briefs?.length ? [CITE_OR_ABSTAIN_DIRECTIVE] : [],
      `Stop when done_when is met: ${doneWhen}.`
    ],
    must_not_do: [
      "Do not assume the orchestrator's hypotheses or other nodes' internal state (Context Isolation).",
      "Do not grow or shrink the goal scope; no unrequested refactors or extra features.",
      ...isMutatingOwner(node.owner) ? [] : ["Do not mutate files (read-only role)."]
    ],
    context: {
      work_item_id: workItem2.id,
      file_scope: fileScope,
      done_when: doneWhen,
      acceptance_refs: node.acceptance_refs,
      acceptance,
      ...memoryContext ? { memory: memoryContext } : {},
      ...retroContext ? { retro: retroContext } : {},
      ...changeSurface ? { change_surface: changeSurface } : {}
    },
    variant_candidates: variantCandidates
  };
}
var ACK_ONLY = /^(done|ok|okay|complete|completed|finished|fixed|pass|passed|success|succeeded|yes|ack|acknowledged|\u2713|\u2705|\uD83D\uDC4D)[\s.!]*$/i;
function guardChildResult(text) {
  const trimmed = text.trim();
  if (trimmed.length === 0) {
    return { contentful: false, failure_class: "fixable", reason: "empty child result" };
  }
  if (ACK_ONLY.test(trimmed)) {
    return {
      contentful: false,
      failure_class: "fixable",
      reason: `ack-only child result ("${trimmed}") \u2014 acknowledgement is not evidence`
    };
  }
  return { contentful: true };
}
function guardMutatingEvidence(owner, outcome, changedFiles) {
  if (outcome === "pass" && isMutatingOwner(owner) && changedFiles.length === 0) {
    return {
      contentful: false,
      failure_class: "fixable",
      reason: `mutating node (${owner}) claimed pass with no changed_files \u2014 a mutation with zero file changes is not evidence of work (claim \u2260 proof)`
    };
  }
  return { contentful: true };
}
function guardAcClosingEvidence(args) {
  if (args.outcome !== "pass")
    return { contentful: true };
  const passVerdicts = args.ac_verdicts.filter((v2) => v2.verdict === "pass");
  if (passVerdicts.length === 0)
    return { contentful: true };
  const topLevelEvidence = args.evidence_refs.length > 0;
  const unevidenced = passVerdicts.filter((v2) => !topLevelEvidence && (v2.evidence_refs?.length ?? 0) === 0);
  if (unevidenced.length > 0) {
    const ids = unevidenced.map((v2) => v2.criterion_id).join(", ");
    const criteria = unevidenced.length === 1 ? "criterion" : "criteria";
    const head = `node judged acceptance ${criteria} \`pass\` (${ids}) but carried no evidence`;
    return {
      contentful: false,
      failure_class: "fixable",
      reason: `${head} \u2014 closing a criterion to pass on a bare claim is not proof (claim \u2260 proof). Attach the evidence (test/build/run output, artifact) at the top-level \`evidence_refs\`, or on the matching \`ac_verdict\` entry's \`evidence_refs\`, before passing`
    };
  }
  return { contentful: true };
}
function guardOwnerEnvelope(raw) {
  const parsed = ownerReturnEnvelope.safeParse(raw);
  if (!parsed.success) {
    const reason = parsed.error.issues.map((i2) => `${i2.path.join(".") || "(root)"}: ${i2.message}`).join("; ");
    return {
      contentful: false,
      failure_class: "fixable",
      reason: `owner-return envelope does not conform: ${reason}`
    };
  }
  return { contentful: true };
}
function guardEnvelopeOwnerMatch(env2, nodeOwner2) {
  if (env2.owner_kind !== nodeOwner2) {
    return {
      contentful: false,
      failure_class: "fixable",
      reason: `owner-return envelope owner_kind="${env2.owner_kind}" does not match the dispatched node owner="${nodeOwner2}" \u2014 the role (and its reachability exemption) cannot be self-relabeled`
    };
  }
  return { contentful: true };
}
async function guardEnvelopeArtifact(env2, readFile2) {
  if (env2.artifact_location === undefined)
    return { contentful: true };
  try {
    const content = await readFile2(env2.artifact_location);
    if (content.trim().length === 0) {
      return {
        contentful: false,
        failure_class: "fixable",
        reason: `envelope artifact_location (${env2.artifact_location}) resolves to an empty artifact \u2014 a pointer to nothing is not evidence`
      };
    }
    return { contentful: true };
  } catch (err) {
    return {
      contentful: false,
      failure_class: "fixable",
      reason: `envelope artifact_location (${env2.artifact_location}) is unresolvable: ${err instanceof Error ? err.message : String(err)}`
    };
  }
}
function decideOnFailure(failureClass, attempts, caps) {
  switch (failureClass) {
    case "fixable":
      return attempts.fix < caps.fix_per_node ? { decision: "retry", cap_exceeded: false } : { decision: "escalate", cap_exceeded: true };
    case "wrong_approach":
      return attempts.switch < caps.switch_per_node ? { decision: "switch_approach", cap_exceeded: false } : { decision: "escalate", cap_exceeded: true };
    case "blocked_external":
    case "user_decision_needed":
      return { decision: "escalate", cap_exceeded: false };
  }
}

// src/core/autopilot-driver.ts
function mutationGate(graph) {
  const gate2 = graph.approval_gate;
  const briefRegimeActive = gate2.change_surface !== undefined;
  const designPassed = (graph.nodes ?? []).some((n2) => n2.kind === "design" && n2.status === "passed");
  if (designPassed && !briefRegimeActive && gate2.status === "approved" && gate2.source === null) {
    return {
      allowed: false,
      action: "present_plan",
      reason: "design passed, change_surface absent, and approval has no authorizer (source=null): produce the brief before mutating"
    };
  }
  if (briefRegimeActive && gate2.status === "approved" && gate2.plan_brief === undefined) {
    return {
      allowed: false,
      action: "present_plan",
      reason: "plan approved but plan_brief is absent: produce the brief before mutating"
    };
  }
  switch (gate2.status) {
    case "approved":
    case "not_required":
      return { allowed: true, action: "proceed", reason: `approval=${gate2.status}` };
    case "pending":
      return {
        allowed: false,
        action: "present_plan",
        reason: "approval pending: present the plan and stop before mutating"
      };
    case "rejected":
      return { allowed: false, action: "blocked", reason: "plan was rejected" };
  }
}
function rollbackOnRejection(graph) {
  if (graph.approval_gate.status !== "rejected") {
    throw new Error(`rollbackOnRejection requires approval_gate.status='rejected', got '${graph.approval_gate.status}'`);
  }
  const nodes = graph.nodes.map((n2) => n2.status === "running" ? { ...n2, status: nodeTransition("running", "rollback") } : n2);
  return { nodes, stopped: true, reason: "plan rejected: rolled back in-flight nodes" };
}
function allNodesTerminal(graph) {
  return graph.nodes.every((n2) => n2.kind === "retro" || n2.status === "passed" || n2.status === "failed");
}

// src/acg/tidy/subgraph.ts
var node = (id, kind, purpose, depends_on, acceptance_refs, file_scope) => ({
  id,
  kind,
  owner: kindToOwner(kind),
  purpose,
  status: "pending",
  depends_on,
  acceptance_refs,
  evidence_refs: [],
  attempts: { fix: 0, switch: 0 },
  ...file_scope !== undefined ? { file_scope } : {}
});
function buildTidySubgraph(input) {
  const prefix = input.idPrefix ?? "T";
  const cleanup = input.fileBatches.map((batch, i2) => node(`${prefix}c${i2 + 1}`, "refactor", `Tidy (behaviour-preserving) cleanup of ${batch.join(", ")}`, [input.implementNodeId], [], batch));
  const replay = node(`${prefix}replay`, "verify", "Replay the implementation DoD + fitness delta after tidy (no edits)", cleanup.map((n2) => n2.id), input.acceptanceIds);
  return [...cleanup, replay];
}

// src/core/autopilot-tidy.ts
function planTidyOnImplementPass(input) {
  const classification = classifyTidyEntry(input.diffStat);
  if (classification.decision === "SKIP") {
    return { classification, nodes: [] };
  }
  const codeFiles = input.diffStat.files.filter((f3) => f3.isCode).map((f3) => f3.path);
  const fileBatches = codeFiles.map((path) => [path]);
  const nodes = buildTidySubgraph({
    implementNodeId: input.implementNodeId,
    fileBatches,
    acceptanceIds: input.acceptanceIds,
    idPrefix: `${input.implementNodeId}t`
  });
  return { classification, nodes };
}

// src/core/completion-coverage-doctor.ts
import { readdir as readdir8 } from "fs/promises";
import { join as join21 } from "path";
init_work_item();
init_ditto_paths();
init_fs();
init_work_item_store();
function isClosed2(ac) {
  const hasEvidence = (ac.evidence?.length ?? 0) > 0 || (ac.evidence_records?.length ?? 0) > 0;
  return ac.verdict === "pass" && hasEvidence;
}
function isUnitOnlyClosure(ac) {
  if (ac.verdict !== "pass")
    return false;
  const refs = [...ac.evidence ?? [], ...ac.evidence_records ?? []];
  if (refs.length === 0)
    return false;
  const hasCommand = refs.some((e2) => e2.kind === "command");
  const hasRuntimeOrArtifact = refs.some((e2) => e2.kind === "file" || e2.kind === "artifact");
  return hasCommand && !hasRuntimeOrArtifact;
}
function countUnitOnlyClosures(completion) {
  return (completion?.acceptance ?? []).filter(isUnitOnlyClosure).length;
}
async function listArchived(repoRoot) {
  const base = localDir(repoRoot, "archive");
  let labels;
  try {
    labels = await readdir8(base);
  } catch {
    return [];
  }
  const out = [];
  for (const label of labels) {
    let ids;
    try {
      ids = await readdir8(join21(base, label));
    } catch {
      continue;
    }
    for (const id of ids) {
      try {
        const item = await readJson(join21(base, label, id, "work-item.json"), workItem);
        out.push({ id, title: item.title, status: item.status, updated_at: item.updated_at });
      } catch {}
    }
  }
  return out;
}
async function readArchivedCompletion(repoRoot, label, id) {
  const path = localDir(repoRoot, "archive", label, id, "completion.json");
  if (!await Bun.file(path).exists())
    return null;
  try {
    return await readJson(path, completionContract);
  } catch {
    return null;
  }
}
function defaultCompletionCoverageDeps(repoRoot) {
  const workItems = new WorkItemStore(repoRoot);
  const completions = new CompletionStore(repoRoot);
  const archiveLabelOf = new Map;
  return {
    listWorkItems: async () => {
      const active = await workItems.list();
      const base = localDir(repoRoot, "archive");
      let labels = [];
      try {
        labels = await readdir8(base);
      } catch {
        labels = [];
      }
      for (const label of labels) {
        try {
          for (const id of await readdir8(join21(base, label)))
            archiveLabelOf.set(id, label);
        } catch {}
      }
      const archived = await listArchived(repoRoot);
      return [...active, ...archived];
    },
    readCompletion: async (id) => {
      const label = archiveLabelOf.get(id);
      if (label)
        return readArchivedCompletion(repoRoot, label, id);
      return await completions.exists(id) ? completions.get(id) : null;
    }
  };
}
function buildRow(summary, completion) {
  const acceptance = completion?.acceptance ?? [];
  const total = acceptance.length;
  const closed = acceptance.filter(isClosed2).length;
  return {
    work_item_id: summary.id,
    title: summary.title,
    status: summary.status,
    has_completion: completion !== null,
    total_acceptance: total,
    closed_acceptance: closed,
    coverage: total === 0 ? 0 : closed / total
  };
}
function totalsOf(rows) {
  const totalAcceptance = rows.reduce((s2, r3) => s2 + r3.total_acceptance, 0);
  const closedAcceptance = rows.reduce((s2, r3) => s2 + r3.closed_acceptance, 0);
  return {
    work_items: rows.length,
    with_completion: rows.filter((r3) => r3.has_completion).length,
    total_acceptance: totalAcceptance,
    closed_acceptance: closedAcceptance,
    coverage: totalAcceptance === 0 ? 0 : closedAcceptance / totalAcceptance
  };
}
async function collectCompletionCoverageReport(deps) {
  const summaries = await deps.listWorkItems();
  const rows = [];
  for (const summary of summaries) {
    const completion = await deps.readCompletion(summary.id);
    rows.push(buildRow(summary, completion));
  }
  return { rows, totals: totalsOf(rows) };
}

