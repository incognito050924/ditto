async function readReviewerOutput(path) {
  const raw = await Bun.file(path).text();
  return reviewerOutput.parse(JSON.parse(raw));
}
function parseIntArg(raw) {
  if (typeof raw !== "string" || raw.trim().length === 0)
    return;
  const n2 = Number.parseInt(raw, 10);
  if (!Number.isFinite(n2) || n2 <= 0)
    throw new Error(`expected a positive integer, got "${raw}"`);
  return n2;
}
var reviewCommand = defineCommand({
  meta: {
    name: "review",
    description: "Unit-scoped consistency/security audit of standing code (baseline=HEAD) \u2014 `--scope all|component:<name>|layer:<name>|api|<glob>`"
  },
  args: {
    scope: {
      type: "string",
      description: "Architecture unit: all | component:<name> | layer:<name> | api | <glob>",
      required: true
    },
    from: {
      type: "string",
      description: "Comma-separated reviewer-output JSON paths (code-reviewer, security-reviewer) to aggregate into one unit acg-review.json ledger",
      required: false
    },
    "work-item": {
      type: "string",
      description: "Work item id to write the unit ledger under (required with --from)",
      required: false
    },
    "batch-size": { type: "string", description: "Files per review batch (default 25)" },
    "file-limit": {
      type: "string",
      description: "Hard cap on reviewed files (overflow dropped + logged, never silent \u2014 PM-5)"
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    let unit;
    let batchSize;
    let fileLimit;
    try {
      format = parseOutputFormat(args.output);
      unit = parseUnitScope(args.scope);
      batchSize = parseIntArg(args["batch-size"]);
      fileLimit = parseIntArg(args["file-limit"]);
    } catch (err) {
      writeError(`review: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    try {
      const repoRoot = await resolveRepoRootForCreate();
      const files = trackedSrcFiles2(repoRoot);
      const archSpec = await loadArchSpec3(repoRoot);
      const resolved = resolveUnitScope(unit, files, archSpec);
      const plan = planUnitReview(resolved, { batchSize, fileLimit });
      let ledgerWritten = false;
      let highRiskUnevidenced = 0;
      if (typeof args.from === "string" && args.from.trim().length > 0) {
        const workItemId2 = args["work-item"];
        if (workItemId2 === undefined || workItemId2.trim().length === 0) {
          writeError("review: --from requires --work-item to locate the unit ledger");
          process.exit(USAGE_ERROR_EXIT);
          return;
        }
        const paths = args.from.split(",").map((p) => p.trim()).filter((p) => p.length > 0);
        const outputs = [];
        for (const p of paths)
          outputs.push(await readReviewerOutput(p));
        const graph = aggregateUnitReview(outputs);
        await new AcgReviewStore(repoRoot).write(workItemId2, graph);
        ledgerWritten = true;
        highRiskUnevidenced = graph.files.filter((f3) => f3.risk === "high" && f3.evidence === undefined).length;
      }
      if (format === "json") {
        writeJson2({
          unit: args.scope,
          files: resolved,
          roles: plan.roles,
          batches: plan.batches,
          progress: plan.progress,
          resolvedCount: plan.resolvedCount,
          reviewedCount: plan.reviewedCount,
          dropped: plan.dropped,
          ledgerWritten,
          highRiskWithoutEvidence: highRiskUnevidenced
        });
      } else {
        writeHuman(`review ${args.scope}: ${plan.resolvedCount} file(s), ${plan.batches.length} batch(es) [${plan.progress}], roles=${plan.roles.join("+")}`);
        for (const d2 of plan.dropped)
          writeHuman(`  dropped (over --file-limit, logged): ${d2}`);
        if (ledgerWritten) {
          writeHuman(`  wrote acg-review.json: ${highRiskUnevidenced} high-risk without evidence`);
        }
      }
    } catch (err) {
      writeError(`review failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});

