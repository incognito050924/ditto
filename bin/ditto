      const rows = args["work-item"] ? report.rows.filter((r4) => r4.work_item_id === args["work-item"]) : report.rows;
      if (format === "json") {
        writeJson2(args["work-item"] ? { rows } : report);
      } else if (rows.length === 0) {
        writeHuman("intent-quality: no work items");
      } else {
        writeHuman("work_item\tquestions\tclosure\treadiness\tfix\trework\tretry/switch\thandoff\tdrift\tpost_cost\ttspec_rounds\ttspec_q");
        for (const r4 of rows) {
