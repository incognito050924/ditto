// src/acg/scope/unit-resolve.ts
var API_LAYERS = ["controller", "controllers", "route", "routes"];
function parseUnitScope(raw) {
  const unit = raw.trim();
  if (unit === "all")
    return { kind: "all" };
  if (unit === "api")
    return { kind: "api" };
  if (unit.startsWith("layer:")) {
    const name = unit.slice("layer:".length).trim();
    if (name.length === 0)
      throw new Error("layer:<name> requires a non-empty layer name");
    return { kind: "layer", name };
  }
  if (unit.startsWith("component:")) {
    const name = unit.slice("component:".length).trim();
    if (name.length === 0)
      throw new Error("component:<name> requires a non-empty component name");
    return { kind: "component", name };
  }
  return { kind: "glob", glob: unit };
}
function fileInUnit(unit, path, archSpec) {
  switch (unit.kind) {
    case "all":
      return true;
    case "api":
      return API_LAYERS.some((seg) => path.split("/").includes(seg));
    case "layer":
      return archSpec !== undefined && pathToLayer(path, archSpec.layers) === unit.name;
    case "component":
      return layerOf(path) === unit.name;
    case "glob":
      return globToRegExp(unit.glob).test(path);
  }
}
function resolveUnitScope(unit, files, archSpec) {
  return files.filter((f3) => fileInUnit(unit, f3, archSpec));
}

// src/acg/tidy/unit-refactor.ts
function decideUnitTidy(input) {
  const debtDecreased = input.debt.after < input.debt.before;
  const residualQuestions = [];
  if (!input.baselineGreen) {
    residualQuestions.push(`unit ${input.unit}: baseline suite is red \u2014 tidy cannot start on a non-green baseline (G-R1)`);
    return {
      unit: input.unit,
      autoCommit: "none",
      barMet: false,
      debtDecreased,
      behaviorGreen: input.behaviorGreen,
      residualQuestions
    };
  }
  if (!input.coverageProviderPresent) {
    residualQuestions.push(`unit ${input.unit}: no coverage provider wired (provider 0\uAC74) \u2014 behavior preservation cannot be witnessed at full bar; tidy accumulates as diff-only on the isolated branch for human PR review, not auto-committed (\xA74.4)`);
    return {
      unit: input.unit,
      autoCommit: "diff-only",
      barMet: false,
      debtDecreased,
      behaviorGreen: input.behaviorGreen,
      residualQuestions
    };
  }
  if (input.unitCovered !== true) {
    residualQuestions.push(`unit ${input.unit}: not covered by characterization \u2014 generate a characterization for the uncovered portion first, then retry (auto-tidy-ineligible until covered)`);
    return {
      unit: input.unit,
      autoCommit: "none",
      barMet: false,
      debtDecreased,
      behaviorGreen: input.behaviorGreen,
      residualQuestions
    };
  }
  if (!input.behaviorGreen) {
    residualQuestions.push(`unit ${input.unit}: behavior preservation NOT green (L1/L2) \u2014 refactor is not auto-tidy-eligible (revert basis)`);
    return {
      unit: input.unit,
      autoCommit: "none",
      barMet: false,
      debtDecreased,
      behaviorGreen: input.behaviorGreen,
      residualQuestions
    };
  }
  if (!debtDecreased) {
    residualQuestions.push(`unit ${input.unit}: absolute fitness debt did not decrease (${input.debt.before}\u2192${input.debt.after}) \u2014 not a tidy improvement`);
    return {
      unit: input.unit,
      autoCommit: "none",
      barMet: false,
      debtDecreased,
      behaviorGreen: input.behaviorGreen,
      residualQuestions
    };
  }
  return {
    unit: input.unit,
    autoCommit: "full",
    barMet: true,
    debtDecreased,
    behaviorGreen: input.behaviorGreen,
    residualQuestions: []
  };
}

// src/cli/commands/refactor.ts
init_fs();
function trackedSrcFiles(repoRoot) {
  const r3 = Bun.spawnSync(["git", "ls-files", "--", "src"], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (r3.exitCode !== 0) {
    throw new Error(`git ls-files failed: ${r3.stderr?.toString().trim() ?? ""}`);
  }
  return r3.stdout.toString().split(`
`).map((s2) => s2.trim()).filter((s2) => s2.length > 0 && /\.[cm]?tsx?$/.test(s2) && !/\.(test|spec)\./.test(s2));
}
async function loadArchSpec2(repoRoot) {
  const specPath = join73(repoRoot, ".ditto", "architecture-spec.json");
  try {
    return await readArchitectureSpec(specPath, acgArchitectureSpec);
  } catch {
    return;
  }
}
var refactorCommand = defineCommand({
  meta: {
    name: "refactor",
    description: "Unit-scoped behavior-preserving tidy of standing code (baseline=HEAD) \u2014 `--scope all|component:<name>|layer:<name>|api|<glob>`"
  },
  args: {
    scope: {
      type: "string",
      description: "Architecture unit: all | component:<name> | layer:<name> | api | <glob>",
      required: true
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let unit;
    try {
      unit = parseUnitScope(args.scope);
    } catch (err) {
      writeError(`refactor: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    try {
      const repoRoot = await resolveRepoRootForCreate();
      const files = trackedSrcFiles(repoRoot);
      const archSpec = await loadArchSpec2(repoRoot);
      const resolved = resolveUnitScope(unit, files, archSpec);
      const decision = decideUnitTidy({
        unit: args.scope,
        files: resolved,
        baselineGreen: true,
        debt: { before: resolved.length, after: resolved.length },
        behaviorGreen: true,
        coverageProviderPresent: false
      });
      if (format === "json") {
        writeJson2({
          unit: args.scope,
          files: resolved,
          autoCommit: decision.autoCommit,
          barMet: decision.barMet,
          residualQuestions: decision.residualQuestions
        });
      } else {
        writeHuman(`refactor ${args.scope}: ${resolved.length} file(s), autoCommit=${decision.autoCommit}, barMet=${decision.barMet}`);
        for (const q2 of decision.residualQuestions)
          writeHuman(`  residual: ${q2}`);
      }
    } catch (err) {
      writeError(`refactor failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});

