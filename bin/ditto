    close_reason: exports_external.string().optional().describe("Recorded justification when the node is closed in a non-resolved state \u2014 a skip/deferral must be justified, never silent (\xA78-2, ac-2)"),
    residual_risk: exports_external.string().optional().describe("The surviving risk a non-resolved close leaves behind (out_of_scope/user_owned) \u2014 distinct from close_reason (WHY skipped); this names WHAT RISK survives the skip. Required for a non-resolved close, recorded on the node (surviving-risk self-description gap)"),
