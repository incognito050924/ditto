var e2eResult = exports_external.enum(["pass", "fail", "unverified", "blocked"]).describe("Journey outcome: pass (every assertion checkable and held), fail (a checkable " + "assertion was contradicted), unverified (ran, but \u22651 assertion was not a " + 'mechanically-checkable predicate \u2014 honest "could not evaluate", not a fail), ' + "or blocked (could not run at all)");
var e2eStep = exports_external.object({
  action: exports_external.string().min(1).describe('User action performed, e.g. "click Login"'),
  target: exports_external.string().optional().describe("Selector/URL/element the action targets"),
  expectation: exports_external.string().optional().describe("What should be observable after the action")
}).describe("One step in the user journey");
var e2eAssertion = exports_external.object({
  description: exports_external.string().min(1).describe("What is being asserted about the journey"),
  satisfied: exports_external.boolean().describe("Whether the assertion held when the journey ran"),
  checkable: exports_external.boolean().default(true).describe("Whether the runner could mechanically evaluate this assertion (false \u21D2 unverified)")
}).describe("A checked assertion about the journey outcome");
var artifactRef = exports_external.object({
  path: relativePath.describe("Repo-relative path under .ditto/local/runs/<id>/"),
  sha256: sha256.optional()
}).describe("Pointer to a captured artifact (path + optional hash; raw stays under .ditto/local/runs)");
var e2eArtifacts = exports_external.object({
  screenshots: exports_external.array(artifactRef).default([]),
  trace: artifactRef.nullable().default(null),
  console: artifactRef.nullable().default(null),
  network: artifactRef.nullable().default(null)
}).describe("Captured browser artifacts (\xA710)");
var e2eJourney = exports_external.object({
  schema_version: schemaVersion,
  journey: exports_external.string().min(1).describe("User journey name"),
  journey_id: exports_external.string().min(1).optional().describe("ACG JourneySpec.id this run realizes (D4; distinct from `journey` name)"),
  work_item_id: workItemId.optional().describe("Work item this journey run belongs to (D4)"),
  url: exports_external.string().min(1).describe("Target URL or dev-server entry under test"),
  steps: exports_external.array(e2eStep).default([]),
  assertions: exports_external.array(e2eAssertion).default([]),
  result: e2eResult,
  artifacts: e2eArtifacts.default({}),
  reproduction: exports_external.string().min(1).nullable().default(null).describe('Reproduction steps; required when result=fail (\uC124\uACC4\uC11C \xA710 "\uC2E4\uD328 \uC2DC \uC7AC\uD604 \uC808\uCC28")')
}).superRefine((value, ctx) => {
  if (value.result === "fail" && value.reproduction === null) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "result=fail requires reproduction steps",
      path: ["reproduction"]
    });
  }
  if (value.result === "pass" && value.assertions.some((a2) => !a2.checkable || !a2.satisfied)) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "result=pass but an assertion is unchecked or not satisfied",
      path: ["result"]
    });
  }
  const claimedUnchecked = value.assertions.find((a2) => !a2.checkable && a2.satisfied);
  if (claimedUnchecked) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "an unchecked assertion (checkable=false) cannot be satisfied=true",
      path: ["assertions"]
    });
  }
  if (value.result === "unverified") {
    if (value.assertions.some((a2) => a2.checkable && !a2.satisfied)) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        message: "result=unverified but a checkable assertion was not satisfied (that is a fail)",
        path: ["result"]
      });
    }
    if (!value.assertions.some((a2) => !a2.checkable)) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        message: "result=unverified requires at least one unchecked (checkable=false) assertion",
        path: ["result"]
      });
    }
  }
}).describe("A browser user-journey verification result (\xA710)");

// src/core/e2e/browser.ts
init_ditto_paths();
init_shared();
function runnerScriptPath() {
  return join30(dirname9(fileURLToPath(import.meta.url)), "playwright-runner.mjs");
}
async function resolvePlaywrightCore() {
  const bunInstall = process.env.BUN_INSTALL ?? join30(homedir5(), ".bun");
  const cacheDir = join30(bunInstall, "install", "cache");
  let entries;
  try {
    entries = await readdir10(cacheDir);
  } catch {
    return null;
  }
  const versions = entries.filter((e2) => /^playwright-core@\d+\.\d+\.\d+$/.test(e2)).sort((a2, b2) => compareSemver(b2.split("@")[1], a2.split("@")[1]));
  for (const v2 of versions) {
    const mjs = join30(cacheDir, v2, "index.mjs");
    if (await fileExists(mjs))
      return mjs;
  }
  return null;
}
function compareSemver(a2, b2) {
  const pa = a2.split(".").map(Number);
  const pb = b2.split(".").map(Number);
  for (let i2 = 0;i2 < 3; i2++) {
    if ((pa[i2] ?? 0) !== (pb[i2] ?? 0))
      return (pa[i2] ?? 0) - (pb[i2] ?? 0);
  }
  return 0;
}
async function findCachedChromium() {
  const cacheRoot = join30(homedir5(), "Library", "Caches", "ms-playwright");
  let entries;
  try {
    entries = await readdir10(cacheRoot);
  } catch {
    return null;
  }
  const chromiumDirs = entries.filter((e2) => /^chromium-\d+$/.test(e2)).sort((a2, b2) => Number(b2.split("-")[1]) - Number(a2.split("-")[1]));
  const candidates = [
    "chrome-mac-arm64/Google Chrome for Testing.app/Contents/MacOS/Google Chrome for Testing",
    "chrome-mac/Chromium.app/Contents/MacOS/Chromium"
  ];
  for (const dir of chromiumDirs) {
    for (const rel of candidates) {
      const abs = join30(cacheRoot, dir, rel);
      if (await fileExists(abs))
        return abs;
    }
  }
  return null;
}
function repoRelative(repoRoot, path) {
  return relative7(repoRoot, path).split(sep3).join("/");
}
async function sha256OfFile(path) {
  const bytes = await readFile5(path);
  return createHash4("sha256").update(bytes).digest("hex");
}
async function probePlaywright(repoRoot) {
  let proc;
  try {
    proc = spawnProviderProcess({
      binary: "bunx",
      args: ["--no-install", "playwright", "--version"],
      repoRoot,
      cwd: ".",
      env: { set: {}, unset: [] }
    });
  } catch (err) {
    return {
      available: false,
      reason: `Playwright probe could not spawn: ${err instanceof Error ? err.message : String(err)}`
    };
  }
  const completion = await proc.completion;
  if (completion.exit_code !== 0) {
    return {
      available: false,
      reason: `Playwright/Chromium not available (bunx --no-install playwright --version exit=${completion.exit_code ?? "null"}); not auto-installing per orchestrator hard constraint`
    };
  }
  const playwrightCore = await resolvePlaywrightCore();
  const executablePath = await findCachedChromium();
  if (!playwrightCore || !executablePath) {
    return {
      available: false,
      reason: `Playwright CLI present but no real-launch inputs (playwright-core=${playwrightCore ? "ok" : "unresolved"}, cachedChromium=${executablePath ? "ok" : "absent"}); not auto-installing per orchestrator hard constraint`
    };
  }
  return {
    available: true,
    reason: "playwright --version succeeded; cached Chromium + playwright-core resolved",
    playwrightCore,
    executablePath
  };
}
function buildJourney(input) {
  return e2eJourney.parse({
    schema_version: "0.1.0",
    journey: input.journey,
    url: input.url,
    steps: input.steps,
    assertions: input.assertions,
    result: input.result,
    ...input.artifacts ? { artifacts: input.artifacts } : {},
    ...input.reproduction !== undefined ? { reproduction: input.reproduction } : {}
  });
}
function blockedJourney(spec, reason) {
  return buildJourney({
    journey: spec.journey,
    url: spec.url,
    steps: spec.steps,
    assertions: spec.assertions.map((a2) => ({ description: a2.description, satisfied: false })),
    result: "blocked",
    reproduction: reason
  });
}
async function runJourney(repoRoot, runId2, spec) {
  const probe = await probePlaywright(repoRoot);
  if (!probe.available || !probe.playwrightCore || !probe.executablePath) {
    return { journey: blockedJourney(spec, probe.reason), run_id: runId2, probe };
  }
  const runDir = localDir(repoRoot, "runs", runId2);
  await mkdir2(runDir, { recursive: true });
  const configAbs = join30(runDir, "runner-config.json");
  await writeFile2(configAbs, JSON.stringify({
    playwrightCore: probe.playwrightCore,
    executablePath: probe.executablePath,
    url: spec.url,
    steps: spec.steps,
    assertions: spec.assertions.map((a2) => ({ description: a2.description })),
    runDir
  }));
  let runnerExit;
  try {
    const runner = spawnProviderProcess({
      binary: "node",
      args: [runnerScriptPath(), configAbs],
      repoRoot,
      cwd: ".",
      env: { set: {}, unset: [] }
    });
    runnerExit = (await runner.completion).exit_code;
  } catch (err) {
    return {
      journey: blockedJourney(spec, `capture runner could not spawn: ${err instanceof Error ? err.message : String(err)}`),
      run_id: runId2,
      probe
    };
  }
  if (runnerExit !== 0) {
    return {
      journey: blockedJourney(spec, `capture runner exited non-zero (exit=${runnerExit ?? "null"}); treating as blocked rather than asserting an unobserved pass`),
      run_id: runId2,
      probe
    };
  }
  const screenshotAbs = join30(runDir, "journey.png");
  const traceAbs = join30(runDir, "trace.zip");
  const consoleAbs = join30(runDir, "console.log");
  const networkAbs = join30(runDir, "network.log");
  const screenshots = [];
  if (await fileExists(screenshotAbs)) {
    screenshots.push({
      path: repoRelative(repoRoot, screenshotAbs),
      sha256: await sha256OfFile(screenshotAbs)
    });
  }
  const trace = await fileExists(traceAbs) ? { path: repoRelative(repoRoot, traceAbs) } : null;
  const consoleArtifact = await fileExists(consoleAbs) ? { path: repoRelative(repoRoot, consoleAbs) } : null;
  const network = await fileExists(networkAbs) ? { path: repoRelative(repoRoot, networkAbs) } : null;
  const outcomeAbs = join30(runDir, "outcome.json");
  if (!await fileExists(outcomeAbs)) {
    return {
      journey: blockedJourney(spec, "Playwright present but no capture outcome was produced; treating as blocked rather than asserting an unobserved pass"),
      run_id: runId2,
      probe
    };
  }
  let outcome;
  try {
    outcome = JSON.parse(await readFile5(outcomeAbs, "utf8"));
  } catch (err) {
    return {
      journey: blockedJourney(spec, `capture outcome unreadable: ${err instanceof Error ? err.message : String(err)}`),
      run_id: runId2,
      probe
    };
  }
  const assertions = spec.assertions.map((a2, i2) => ({
    description: a2.description,
    satisfied: outcome.satisfied[i2] ?? false,
    checkable: outcome.checkable?.[i2] ?? true
  }));
  const journey = buildJourney({
    journey: spec.journey,
    url: spec.url,
    steps: spec.steps,
    assertions,
    result: outcome.result,
    artifacts: { screenshots, trace, console: consoleArtifact, network },
    reproduction: outcome.result === "fail" ? outcome.reproduction ?? "see captured artifacts" : null
  });
  return { journey, run_id: runId2, probe };
}

// src/core/e2e/authoring-guard.ts
async function withBrowserGuard(repoRoot, action, options = {}) {
  const probe = await (options.probe ?? probePlaywright)(repoRoot);
  if (!probe.available) {
    return { result: "blocked", reason: probe.reason, probe };
  }
  return { result: "ran", value: await action(probe), probe };
}

// src/core/e2e/generated-verify.ts
async function runPlaywrightTests(repoRoot, files, jsonReportPath) {
  const proc = spawnProviderProcess({
    binary: "npx",
    args: [
      "playwright",
      "test",
      ...files,
      ...jsonReportPath !== undefined ? ["--reporter=line,json"] : []
    ],
    repoRoot,
    cwd: ".",
    env: {
      set: jsonReportPath !== undefined ? { PLAYWRIGHT_JSON_OUTPUT_NAME: jsonReportPath } : {},
      unset: []
    }
  });
  const [stdoutText, stderrText] = await Promise.all([
    new Response(proc.stdout).text(),
    new Response(proc.stderr).text()
  ]);
  const completion = await proc.completion;
  return { exit_code: completion.exit_code, output: `${stdoutText}${stderrText}` };
}
var OUTPUT_TAIL_LINES = 40;
function outputTail(output) {
  const lines = output.split(`
`).filter((l2) => l2.trim() !== "");
  return lines.slice(-OUTPUT_TAIL_LINES);
}
async function verifyGenerated(repoRoot, runId2, files, options = {}) {
  const runner = options.runner ?? runPlaywrightTests;
  const runDir = localDir(repoRoot, "runs", runId2);
  await mkdir3(runDir, { recursive: true });
  const outcome = await withBrowserGuard(repoRoot, () => runner(repoRoot, files, join31(runDir, "playwright-report.json")), options.probe ? { probe: options.probe } : {});
  const verified_at = new Date().toISOString();
  let record;
  if (outcome.result === "blocked") {
    record = {
      run_id: runId2,
      files,
      result: "blocked",
      reason: outcome.reason,
      exit_code: null,
      output_tail: [],
      verified_at
    };
  } else {
    const pass = outcome.value.exit_code === 0;
    record = {
      run_id: runId2,
      files,
      result: pass ? "pass" : "fail",
      reason: `npx playwright test exited ${outcome.value.exit_code ?? "null"}`,
      exit_code: outcome.value.exit_code,
      output_tail: outputTail(outcome.value.output),
      verified_at
    };
  }
  await atomicWriteText(join31(runDir, "generated-verify.json"), `${JSON.stringify(record, null, 2)}
`);
  return record;
}

// src/core/e2e/regression-select.ts
import { readFile as readFile6, readdir as readdir11, stat as stat3 } from "fs/promises";
import { join as join32, relative as relative8, resolve as resolve6, sep as sep4 } from "path";

// src/core/e2e/journey-dsl.ts
init_shared();
var stepLine = /^\s*\d+\.\s+\[([sb]\d+)\]/;
var blockCallLine = /^\s*\d+\.\s+\[[sb]\d+\]\s*(?:\([^)]*\)\s*)?\uBE14\uB85D:\s*([^\s(]+)/;
var stepMarker = /^\s*\/\/\s*@step\s+(\S+\/[sb]\d+)\b/;
function splitFrontMatter(text) {
  const lines = text.split(`
`);
  if ((lines[0] ?? "").trim() !== "---")
    return null;
  for (let i2 = 1;i2 < lines.length; i2++) {
    if ((lines[i2] ?? "").trim() === "---") {
      return { frontMatter: lines.slice(1, i2).join(`
`), body: lines.slice(i2 + 1).join(`
`) };
    }
  }
  return null;
}
function extractStepIds(body) {
  const ids = [];
  for (const line of body.split(`
`)) {
    const m2 = stepLine.exec(line);
    if (m2?.[1])
      ids.push(m2[1]);
  }
  return ids;
}
function extractBlockCalls(body) {
  const ids = [];
  for (const line of body.split(`
`)) {
    const m2 = blockCallLine.exec(line);
    if (m2?.[1])
      ids.push(m2[1]);
  }
  return ids;
}
function extractCaseNames(body) {
  const lines = body.split(`
`);
  const start = lines.findIndex((l2) => /^##\s*\uCF00\uC774\uC2A4\s*$/.test(l2.trim()));
  if (start < 0)
    return [];
  const names = [];
  let sawHeader = false;
  for (let i2 = start + 1;i2 < lines.length; i2++) {
    const line = (lines[i2] ?? "").trim();
    if (line.startsWith("#"))
      break;
    if (!line.startsWith("|")) {
      if (names.length > 0 || sawHeader)
        break;
      if (line === "")
        continue;
      break;
    }
    if (/^\|[\s\-:|]+\|?$/.test(line))
      continue;
    if (!sawHeader) {
      sawHeader = true;
      continue;
    }
    const first = line.split("|")[1]?.trim();
    if (first !== undefined && first !== "")
      names.push(first);
  }
  return names;
}
function extractStepMarkers(generated) {
  const refs = [];
  for (const line of generated.split(`
`)) {
    const m2 = stepMarker.exec(line);
    if (m2?.[1])
      refs.push(m2[1]);
  }
  return refs;
}
function parseDoc(text, schema) {
  const split = splitFrontMatter(text);
  if (!split)
    return { ok: false, error: "no leading ---\u2026--- front-matter block" };
  let raw;
  try {
    raw = parseYaml(split.frontMatter);
  } catch (err) {
    return {
      ok: false,
      error: `front-matter YAML parse failed: ${err instanceof Error ? err.message : String(err)}`
    };
  }
  const parsed = schema.safeParse(raw);
  if (!parsed.success)
    return { ok: false, error: parsed.error.message };
  const stepIds = extractStepIds(split.body);
  const seen = new Set;
  for (const id of stepIds) {
    if (seen.has(id)) {
      return { ok: false, error: `duplicate step id [${id}] \u2014 step ids must be unique` };
    }
    seen.add(id);
  }
  return { ok: true, frontMatter: parsed.data, stepIds };
}
function parseJourneyDoc(text) {
  return parseDoc(text, journeyFrontMatter);
}
function parseBlockDoc(text) {
  return parseDoc(text, blockFrontMatter);
}

// src/core/e2e/regression-select.ts
var COMPONENT_PREFIX = "component:";
function matchesComponentPattern(pattern, path) {
  if (!pattern.includes("*")) {
    return path === pattern || path.startsWith(pattern.endsWith("/") ? pattern : `${pattern}/`);
  }
  return globToRegExp2(pattern).test(path);
}
function globToRegExp2(pattern) {
  let out = "^";
  let i2 = 0;
  while (i2 < pattern.length) {
    if (pattern.startsWith("**/", i2)) {
      out += "(?:.*/)?";
      i2 += 3;
      continue;
    }
    if (pattern.startsWith("**", i2)) {
      out += ".*";
      i2 += 2;
      continue;
    }
    const ch = pattern[i2];
    out += ch === "*" ? "[^/]*" : ch.replace(/[.+?^${}()|[\]\\]/, "\\$&");
    i2 += 1;
  }
  return new RegExp(`${out}$`);
}
var toPosix = (p) => p.split(sep4).join("/");
async function fileExists2(path) {
  try {
    return (await stat3(path)).isFile();
  } catch {
    return false;
  }
}
async function loadJourneyEntries(journeysDir) {
  const journeysAbs = resolve6(journeysDir);
  const repoRoot = resolve6(journeysAbs, "..", "..");
  const generatedDir = resolve6(journeysAbs, "..", "generated");
  let names;
  try {
    names = (await readdir11(journeysAbs)).filter((n2) => n2.endsWith(".journey.md")).sort();
  } catch {
    return { entries: [], invalid: [] };
  }
  const entries = [];
  const invalid = [];
  for (const name of names) {
    const fileAbs = join32(journeysAbs, name);
    const fileRel = toPosix(relative8(repoRoot, fileAbs));
    const parsed = parseJourneyDoc(await readFile6(fileAbs, "utf8"));
    if (!parsed.ok) {
      invalid.push({ file: fileRel, error: parsed.error });
      continue;
    }
    const slug = name.slice(0, -".journey.md".length);
    const specAbs = join32(generatedDir, `${slug}.spec.ts`);
    entries.push({
      id: parsed.frontMatter.id,
      name: parsed.frontMatter.name,
      description: parsed.frontMatter.description,
      surfaces: parsed.frontMatter.surfaces,
      uses_blocks: parsed.frontMatter.uses_blocks,
      journey_file: fileRel,
      generated_spec: toPosix(relative8(repoRoot, specAbs)),
      missing_generated: !await fileExists2(specAbs)
    });
  }
  return { entries, invalid };
}
var normalizePath2 = (p) => toPosix(p).replace(/^\.\//, "");
async function selectImpactedJourneys(journeysDir, changedPaths) {
  const { entries, invalid } = await loadJourneyEntries(journeysDir);
  const normalized = changedPaths.map(normalizePath2);
  const matchedPaths = new Set;
  const journeys = [];
  for (const entry of entries) {
    const matched = [];
    for (const surface of entry.surfaces) {
      if (!surface.startsWith(COMPONENT_PREFIX))
        continue;
      const pattern = normalizePath2(surface.slice(COMPONENT_PREFIX.length));
      const hits = normalized.filter((p) => matchesComponentPattern(pattern, p));
      if (hits.length === 0)
        continue;
      matched.push(surface);
      for (const hit of hits)
        matchedPaths.add(hit);
    }
    if (matched.length > 0)
      journeys.push({ ...entry, matched_surfaces: matched });
  }
  return {
    journeys,
    unmatched_changed_paths: normalized.filter((p) => !matchedPaths.has(p)),
    invalid_journeys: invalid
  };
}

// src/core/e2e/regression-gate.ts
function regressionGatePath(repoRoot, workItemId2) {
  return join33(localDir(repoRoot, "work-items", workItemId2), "regression-gate.json");
}
async function mapRunFailures(repoRoot, runId2, selected) {
  const reportFile = Bun.file(join33(localDir(repoRoot, "runs", runId2), "playwright-report.json"));
  if (!await reportFile.exists())
    return [];
  let reporter;
  try {
    reporter = JSON.parse(await reportFile.text());
  } catch {
    return [];
  }
  const failures = await buildFailureReport(reporter, {
    repoRoot,
    readSpec: async (specFile) => {
      try {
        return await readFile7(resolve7(repoRoot, specFile), "utf8");
      } catch {
        return null;
      }
    }
  });
  const knownIds = new Set(selected.map((j) => j.id));
  const bySpecFile = new Map(selected.map((j) => [j.generated_spec, j.id]));
  return failures.map((f3) => ({
    journey_id: knownIds.has(f3.journey_id) ? f3.journey_id : bySpecFile.get(f3.spec_file) ?? "(unmapped)",
    case: f3.case_name === "" ? "(unmapped)" : f3.case_name
  }));
}
async function runRegressionGate(repoRoot, input, options = {}) {
  const journeysDir = join33(repoRoot, "e2e", "journeys");
  const selection = await selectImpactedJourneys(journeysDir, input.changedPaths);
  let selected;
  if (input.journeyIds !== undefined) {
    const { entries } = await loadJourneyEntries(journeysDir);
    selected = input.journeyIds.map((id) => {
      const auto = selection.journeys.find((j) => j.id === id);
      if (auto)
        return auto;
      const entry = entries.find((e2) => e2.id === id);
      if (!entry)
        throw new Error(`unknown journey id: ${id} \u2014 e2e/journeys\uC5D0 \uD574\uB2F9 \uC5EC\uC815\uC774 \uC5C6\uB2E4`);
      return { ...entry, matched_surfaces: [] };
    });
  } else {
    selected = selection.journeys;
  }
  const missing = selected.filter((j) => j.missing_generated);
  const runnable = selected.filter((j) => !j.missing_generated);
  const journeyResults = missing.map((j) => ({ journey_id: j.id, result: "not_run" }));
  let result2;
  let reason;
  let failures = [];
  if (selected.length === 0) {
    result2 = "pass";
    reason = "\uC601\uD5A5\uBC1B\uB294 \uC5EC\uC815 \uC5C6\uC74C \u2014 \uBCC0\uACBD \uACBD\uB85C\uC640 \uAD50\uCC28\uD558\uB294 component: \uD45C\uBA74\uC774 \uC5C6\uB2E4";
  } else if (runnable.length === 0) {
    result2 = "fail";
    reason = "\uCD94\uB824\uC9C4 \uC5EC\uC815 \uC804\uBD80 generated spec \uBD80\uC7AC \u2014 \uBAA9\uB85D\uC5D0 \uC788\uC5C8\uB294\uB370 \uC2E4\uD589 \uC548 \uB428\uC740 pass\uAC00 \uC544\uB2C8\uB2E4";
  } else {
    const verify = await verifyGenerated(repoRoot, input.runId, runnable.map((j) => j.generated_spec), options);
    if (verify.result === "blocked") {
      result2 = "blocked";
      reason = verify.reason;
      for (const j of runnable)
        journeyResults.push({ journey_id: j.id, result: "blocked" });
    } else if (verify.result === "pass") {
      for (const j of runnable)
        journeyResults.push({ journey_id: j.id, result: "pass" });
      if (missing.length > 0) {
        result2 = "fail";
        reason = `\uC2E4\uD589\uB41C \uC5EC\uC815\uC740 \uD1B5\uACFC\uD588\uC9C0\uB9CC ${missing.length}\uAC1C \uC5EC\uC815\uC758 generated spec\uC774 \uC5C6\uB2E4 \u2014 \uCD94\uB824\uC9C4 \uBAA9\uB85D \uC548\uC5D0\uC11C \uBBF8\uC2E4\uD589\uC740 \uC2E4\uD328\uB2E4`;
      } else {
        result2 = "pass";
        reason = verify.reason;
      }
    } else {
      result2 = "fail";
      reason = verify.reason;
      failures = await mapRunFailures(repoRoot, input.runId, runnable);
      const failing = new Set(failures.map((f3) => f3.journey_id));
      const unlocalized = failures.length === 0 || failing.has("(unmapped)");
      for (const j of runnable) {
        const failed = unlocalized || failing.has(j.id);
        journeyResults.push({ journey_id: j.id, result: failed ? "fail" : "pass" });
      }
    }
  }
  if (selection.invalid_journeys.length > 0 && result2 === "pass") {
    result2 = "fail";
    reason = `${selection.invalid_journeys.length}\uAC1C journey\uAC00 front-matter \uD30C\uC2F1 \uBD88\uAC00 \u2014 \uC601\uD5A5 \uCD94\uB9BC\uC5D0\uC11C \uBE60\uC84C\uC744 \uC218 \uC788\uC5B4 pass\uB85C \uB2EB\uC744 \uC218 \uC5C6\uB2E4 (${selection.invalid_journeys.map((i2) => i2.file).join(", ")})`;
  }
  const record = await writeJson(regressionGatePath(repoRoot, input.workItemId), regressionGateRecord, {
    work_item: input.workItemId,
    run_id: input.runId,
    changed_paths: input.changedPaths,
    selected: selected.map((j) => ({
      id: j.id,
      name: j.name,
      description: j.description,
      journey_file: j.journey_file,
      generated_spec: j.generated_spec,
      matched_surfaces: j.matched_surfaces,
      missing_generated: j.missing_generated
    })),
    auto_selected: selection.journeys.map((j) => j.id),
    journey_results: journeyResults,
    invalid_journeys: selection.invalid_journeys,
    result: result2,
    failures,
    reason,
    recorded_at: new Date().toISOString()
  });
  return { record, selection };
}

// src/core/e2e/applicability.ts
import { existsSync as existsSync4, readFileSync } from "fs";
import { join as join34 } from "path";
var WEB_FRAMEWORKS = [
  "react",
  "react-dom",
  "vue",
  "svelte",
  "@sveltejs/kit",
  "@angular/core",
  "preact",
  "solid-js",
  "next",
  "nuxt",
  "remix",
  "@remix-run/react",
  "astro",
  "gatsby"
];
function evaluateAxis3Applicability(signals) {
  const hasWeb = signals.web_framework !== null || signals.ui_file_count > 0;
  if (hasWeb) {
    const parts = [];
    if (signals.web_framework)
      parts.push(`framework: ${signals.web_framework}`);
    if (signals.ui_file_count > 0)
      parts.push(`${signals.ui_file_count} UI/markup file(s)`);
    return {
      applicable: true,
      reason: `web UI present (${parts.join(", ")})`,
      covered_by: [],
      signals
    };
  }
  return {
    applicable: false,
    reason: "no web UI detected (no browser-framework dependency, no UI/markup files)",
    covered_by: ["axis-2 (reviewer / code-level verification)", "axis-1 (intent alignment)"],
    signals
  };
}
function dependencyNames(pkg) {
  if (!pkg)
    return new Set;
  const names = new Set;
  for (const key of ["dependencies", "devDependencies", "peerDependencies"]) {
    const section = pkg[key];
    if (section && typeof section === "object") {
      for (const name of Object.keys(section))
        names.add(name);
    }
  }
  return names;
}
var UI_EXTENSIONS = [".tsx", ".jsx", ".vue", ".svelte", ".html"];
function defaultReadPackageJson(repoRoot) {
  return () => {
    const path = join34(repoRoot, "package.json");
    if (!existsSync4(path))
      return null;
    try {
      const parsed = JSON.parse(readFileSync(path, "utf8"));
      return parsed && typeof parsed === "object" ? parsed : null;
    } catch {
      return null;
    }
  };
}
function defaultCountUiFiles(repoRoot) {
  return () => {
    const srcDir = join34(repoRoot, "src");
    if (!existsSync4(srcDir))
      return 0;
    const glob = new Bun.Glob(`**/*{${UI_EXTENSIONS.join(",")}}`);
    let count = 0;
    for (const _3 of glob.scanSync({ cwd: srcDir, onlyFiles: true })) {
      count++;
      if (count >= 50)
        break;
    }
    return count;
  };
}
function defaultApplicabilityDeps(repoRoot) {
  return {
    repoRoot,
    readPackageJson: defaultReadPackageJson(repoRoot),
    countUiFiles: defaultCountUiFiles(repoRoot)
  };
}
function detectWebUiSignals(deps) {
  const names = dependencyNames(deps.readPackageJson());
  const web_framework = WEB_FRAMEWORKS.find((f3) => names.has(f3)) ?? null;
  return { web_framework, ui_file_count: deps.countUiFiles() };
}
function evaluateAxis3FromRepo(deps) {
  return evaluateAxis3Applicability(detectWebUiSignals(deps));
}

// src/core/e2e/web-surface.ts
var CODE_EXTENSIONS2 = [
  ".ts",
  ".js",
  ".mts",
  ".cts",
  ".mjs",
  ".cjs",
  ".py",
  ".go",
  ".rb",
  ".java",
  ".kt",
  ".rs",
  ".php",
  ".cs"
];
var API_SEGMENTS = new Set(["api", "apis", "routes", "controllers", "endpoints"]);
var API_BASENAME = /(^|[-._])(server|handler|controller)$/;
function extensionOf(path) {
  const base = path.slice(path.lastIndexOf("/") + 1);
  const dot = base.lastIndexOf(".");
  return dot <= 0 ? "" : base.slice(dot).toLowerCase();
}
function isFrontendPath(path) {
  return UI_EXTENSIONS.includes(extensionOf(path));
}
function isApiPath(path) {
  if (!CODE_EXTENSIONS2.includes(extensionOf(path)))
    return false;
  const segments = path.toLowerCase().split("/");
  const dirs = segments.slice(0, -1);
  if (dirs.some((s2) => API_SEGMENTS.has(s2)))
    return true;
  const base = segments.at(-1) ?? "";
  const stem = base.slice(0, base.indexOf(".") === -1 ? base.length : base.lastIndexOf("."));
  return API_BASENAME.test(stem);
}
function detectWebSurfaceChange(changedPaths) {
  const surfaces = [];
  for (const path of changedPaths) {
    if (isFrontendPath(path)) {
      surfaces.push({ kind: "frontend", path });
    } else if (isApiPath(path)) {
      surfaces.push({ kind: "api", path });
    }
  }
  return { web: surfaces.length > 0, surfaces };
}

// src/core/e2e/completion-gate.ts
async function checkE2eCompletionGate(repoRoot, input) {
  const violations = [];
  const detection = detectWebSurfaceChange(input.changedFiles);
  if (detection.web) {
    const decided = input.decisions.some((d2) => d2.decision === "e2e_accept" || d2.decision === "e2e_decline");
    if (!decided) {
      violations.push({
        code: "proposal_missing",
        message: `\uC6F9 \uD45C\uBA74 \uBCC0\uACBD(${detection.surfaces.length} surface)\uC774 \uC788\uB294\uB370 E2E \uC81C\uC548 \uACB0\uC815 \uB808\uCF54\uB4DC(e2e_accept|e2e_decline)\uAC00 \uC5C6\uB2E4 \u2014 ` + `\`ditto autopilot propose-e2e --workItem ${input.workItemId} --changedFiles <csv>\`\uB85C \uC0AC\uC6A9\uC790\uC5D0\uAC8C \uC81C\uC548\uD558\uACE0 \uACB0\uC815\uC744 \uAE30\uB85D\uD558\uB77C (ac-6)`
      });
    }
  }
  const selection = await selectImpactedJourneys(join35(repoRoot, "e2e", "journeys"), input.changedFiles);
  const impacted = selection.journeys.length > 0 || selection.invalid_journeys.length > 0;
  if (!impacted)
    return violations;
  const recordFile = Bun.file(regressionGatePath(repoRoot, input.workItemId));
  const demand = `\`ditto e2e regression --work-item ${input.workItemId} --changed-files <csv>\`\uB97C \uC2E4\uD589\uD574 \uAE30\uB85D\uC744 \uB0A8\uACA8\uB77C (ac-7)`;
  if (!await recordFile.exists()) {
    violations.push({
      code: "regression_missing",
      message: `\uBCC0\uACBD\uACFC \uAD50\uCC28\uD558\uB294 \uC5EC\uC815\uC774 \uC788\uB294\uB370 regression-gate \uAE30\uB85D\uC774 \uC5C6\uB2E4 \u2014 ${demand}`
    });
    return violations;
  }
  let parsed;
  try {
    parsed = regressionGateRecord.safeParse(JSON.parse(await recordFile.text()));
  } catch {
    parsed = { success: false };
  }
  if (!parsed.success) {
    violations.push({
      code: "regression_missing",
      message: `regression-gate \uAE30\uB85D\uC774 \uC190\uC0C1\uB418\uC5B4 \uD310\uB3C5 \uBD88\uAC00 \u2014 ${demand}`
    });
    return violations;
  }
  const covered = new Set(parsed.data.changed_paths);
  const missing = input.changedFiles.filter((p) => !covered.has(p));
  if (missing.length > 0) {
    violations.push({
      code: "regression_missing",
      message: `regression-gate \uAE30\uB85D\uC774 \uD604\uC7AC changed_files\uB97C \uCEE4\uBC84\uD558\uC9C0 \uC54A\uB294\uB2E4(\uBBF8\uCEE4\uBC84 ${missing.length}\uAC74: ${missing.slice(0, 3).join(", ")}\u2026) \u2014 \uCD5C\uC2E0 diff\uB85C ${demand}`
    });
    return violations;
  }
  if (parsed.data.result !== "pass") {
    violations.push({
      code: "regression_non_pass",
      message: `regression-gate \uAE30\uB85D\uC774 ${parsed.data.result} \u2014 \uC2E4\uD328\uC758 \uCC98\uB9AC(\uAE30\uB2A5/\uC2A4\uD06C\uB9BD\uD2B8/\uD658\uACBD/flaky \uD310\uC815)\uB97C \uB2EB\uAE30 \uC804\uC5D0\uB294 \uC644\uB8CC\uD560 \uC218 \uC5C6\uB2E4: ${parsed.data.reason}`
    });
  }
  return violations;
}

// src/cli/commands/autopilot.ts
init_fs();
var autopilotBootstrap = defineCommand({
  meta: {
    name: "bootstrap",
    description: "Build the autopilot graph for a work item from its intent.json"
  },
  args: {
    workItem: {
      type: "string",
      description: "Work item id (wi_*) whose intent.json drives the graph",
      required: true
    },
    riskNonLocal: {
      type: "boolean",
      description: "Set when the change touches code outside the obvious local site",
      default: false
    },
    riskIrreversible: {
      type: "boolean",
      description: "Set when the change cannot be undone by a follow-up commit",
      default: false
    },
    riskUnaudited: {
      type: "boolean",
      description: "Set when the change introduces dependencies / surfaces nobody has reviewed",
      default: false
    },
    approvedSource: {
      type: "string",
      description: "Pre-approval source: approved_spec|issue|prd|user (omit for auto risk gate)",
      required: false
    },
    output: {
      type: "string",
      description: "Output format: human|json",
      default: "human"
    }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const approvedSource = args.approvedSource;
    if (approvedSource !== undefined && !["approved_spec", "issue", "prd", "user"].includes(approvedSource)) {
      writeError(`invalid --approved-source "${approvedSource}"; expected one of: approved_spec, issue, prd, user`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await resolveRepoRootForCreate();
    const items = new WorkItemStore(repoRoot);
    if (!await items.exists(args.workItem)) {
      writeError(`work item ${args.workItem} not found`);
      process.exit(RUNTIME_ERROR_EXIT);
      return;
    }
    const intentStore = new IntentStore(repoRoot);
    if (!await intentStore.exists(args.workItem)) {
      writeError(`intent.json missing for ${args.workItem}. Run /ditto:deep-interview (ditto deep-interview finalize) first.`);
      process.exit(RUNTIME_ERROR_EXIT);
      return;
    }
    const workItem2 = await items.get(args.workItem);
    const intent = await intentStore.get(args.workItem);
    const result2 = await bootstrapAutopilot(repoRoot, {
      workItem: workItem2,
      intent,
      risk: {
        non_local: args.riskNonLocal,
        irreversible: args.riskIrreversible,
        unaudited: args.riskUnaudited
      },
      ...approvedSource ? { approvedSource } : {}
    });
    if (result2.status !== "created") {
      writeError(`autopilot bootstrap failed (${result2.status}):`);
      for (const reason of result2.reasons)
        writeError(`  - ${reason}`);
      process.exit(RUNTIME_ERROR_EXIT);
      return;
    }
    if (format === "json") {
      writeJson2({
        work_item_id: args.workItem,
        autopilot_id: result2.graph.autopilot_id,
        approval_gate: result2.graph.approval_gate.status,
        node_ids: result2.graph.nodes.map((n2) => n2.id),
        path: `.ditto/local/work-items/${args.workItem}/autopilot.json`
      });
    } else {
      writeHuman(`Bootstrapped autopilot ${result2.graph.autopilot_id}`);
      writeHuman(`  work_item:     ${args.workItem}`);
      writeHuman(`  approval_gate: ${result2.graph.approval_gate.status}`);
      writeHuman(`  nodes:         ${result2.graph.nodes.map((n2) => n2.id).join(" -> ")}`);
      writeHuman(`  path:          .ditto/local/work-items/${args.workItem}/autopilot.json`);
    }
  }
});
async function requireGraph(workItem2) {
  const repoRoot = await resolveRepoRootForCreate();
  if (!await new AutopilotStore(repoRoot).exists(workItem2)) {
    writeError(`autopilot.json missing for ${workItem2}. Run ditto autopilot bootstrap (or deep-interview finalize) first.`);
    process.exit(RUNTIME_ERROR_EXIT);
  }
  return repoRoot;
}
var autopilotNextNode = defineCommand({
  meta: {
    name: "next-node",
    description: "Compute the next loop action (select ready node, consume approval gate, dispatch)"
  },
  args: {
    workItem: { type: "string", description: "Work item id (wi_*)", required: true },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await requireGraph(args.workItem);
    try {
      const res = await nextNode(repoRoot, args.workItem);
      if (format === "json") {
        writeJson2(res);
      } else if (res.action === "spawn") {
        writeHuman(`Next: spawn ${res.owner} on ${res.node_id}`);
        writeHuman(`  task:       ${res.packet.task}`);
        writeHuman(`  done_when:  ${res.packet.context.done_when}`);
        writeHuman(`  file_scope: ${res.packet.context.file_scope.join(", ") || "(none)"}`);
      } else if (res.action === "spawn_wave") {
        writeHuman(`Next: spawn wave (${res.spawns.length} parallel nodes)`);
        for (const s2 of res.spawns) {
          writeHuman(`  - ${s2.owner} on ${s2.node_id}: ${s2.packet.task}`);
        }
      } else {
        writeHuman(`Next: ${res.action} \u2014 ${res.reason}`);
        if (res.action === "rollback") {
          writeHuman(`  rolled_back: ${res.rolled_back_node_ids.join(", ") || "(none)"}`);
        } else if (res.action === "blocked") {
          writeHuman(`  blocked:     ${res.blocked_node_ids.join(", ") || "(none)"}`);
        } else if (res.action === "done") {
          writeHuman(`  \u2192 run completion (${res.all_passed ? "expect pass" : "expect partial/fail"})`);
        } else if (res.action === "cleanup") {
          writeHuman(`  node:        ${res.node_id}`);
          writeHuman(`  \u2192 run: ditto autopilot cleanup --workItem <wi> --node ${res.node_id}`);
        } else if (res.action === "main_session") {
          writeHuman(`  node:        ${res.node_id}`);
          writeHuman("  \u2192 run the ditto:e2e-author skill inline, then record-result");
        }
      }
    } catch (err) {
      writeError(`next-node failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var autopilotRecordResult = defineCommand({
  meta: {
    name: "record-result",
    description: "Record an owner subagent's result: G7 guard, classify, decide, persist"
  },
  args: {
    workItem: { type: "string", description: "Work item id (wi_*)", required: true },
    json: {
      type: "string",
      description: "JSON payload matching recordResultPayload schema",
      required: true
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let raw;
    try {
      raw = JSON.parse(args.json);
    } catch (err) {
      writeError(`--json is not valid JSON: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const parsed = recordResultPayload.safeParse(raw);
    if (!parsed.success) {
      writeError("--json failed schema validation:");
      for (const issue of parsed.error.issues) {
        writeError(`  - ${issue.path.join(".") || "(root)"}: ${issue.message}`);
      }
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await requireGraph(args.workItem);
    try {
      const res = await recordResult(repoRoot, { workItemId: args.workItem, payload: parsed.data });
      if (format === "json") {
        writeJson2(res);
      } else {
        writeHuman(`Recorded ${res.node_id}: ${res.outcome} \u2192 status=${res.status}`);
        if (!res.guard_contentful) {
          writeHuman("  (G7: non-contentful result \u2014 claimed outcome overridden to fixable)");
        }
        if (res.decision) {
          writeHuman(`  decision: ${res.decision}${res.cap_exceeded ? " (cap exceeded)" : ""}`);
        }
      }
    } catch (err) {
      writeError(`record-result failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
async function measureReproposalForCompletion(repoRoot) {
  const adrDir = join36(dittoDir(repoRoot), "knowledge", "adr");
  let names;
  try {
    names = (await readdir12(adrDir)).filter((n2) => n2.endsWith(".md")).sort();
  } catch {
    names = [];
  }
  const adrs = await Promise.all(names.map(async (n2) => ({ id: n2, body: await readFile8(join36(adrDir, n2), "utf8") })));
  return measureHallucination(adrs, []);
}
var autopilotComplete = defineCommand({
  meta: {
    name: "complete",
    description: "Assemble a completion contract from the finished autopilot graph (evidence-gated)"
  },
  args: {
    workItem: { type: "string", description: "Work item id (wi_*)", required: true },
    summary: {
      type: "string",
      description: "Completion narrative; a terse default is derived when omitted",
      required: false
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await requireGraph(args.workItem);
    try {
      const aps = new AutopilotStore(repoRoot);
      const graph = await aps.get(args.workItem);
      const workItem2 = await new WorkItemStore(repoRoot).get(args.workItem);
      const e2eViolations = await checkE2eCompletionGate(repoRoot, {
        workItemId: args.workItem,
        changedFiles: workItem2.changed_files,
        decisions: await aps.readDecisions(args.workItem)
      });
      if (e2eViolations.length > 0) {
        if (format === "json") {
          writeJson2({ work_item_id: args.workItem, e2e_gate: e2eViolations });
        } else {
          writeError(`complete blocked by the e2e completion gate (${e2eViolations.length}):`);
          for (const v2 of e2eViolations)
            writeError(`  [${v2.code}] ${v2.message}`);
        }
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      const completion = assembleCompletionFromGraph(graph, workItem2, {
        ...args.summary ? { summary: args.summary } : {}
      });
      await new CompletionStore(repoRoot).write(completion);
      const cite = await checkCiteGate(repoRoot, { workItemId: args.workItem, graph });
      const measurement = await measureReproposalForCompletion(repoRoot);
      const citeCrossCheck = crossValidateCite(cite, measurement);
      const conflicts = await detectActiveConflicts(repoRoot, {
        workItemId: args.workItem,
        graph
      });
      if (format === "json") {
        writeJson2({
          work_item_id: args.workItem,
          final_verdict: completion.final_verdict,
          acceptance: completion.acceptance.map((a2) => ({
            criterion_id: a2.criterion_id,
            verdict: a2.verdict,
            evidence_count: a2.evidence.length
          })),
          cite_gate: {
            verdict: cite.verdict,
            pushed_node_ids: cite.pushed_node_ids,
            warnings: cite.warnings
          },
          cite_cross_check: citeCrossCheck,
          conflict_warnings: conflicts,
          path: `.ditto/local/work-items/${args.workItem}/completion.json`
        });
      } else {
        writeHuman(`Assembled completion for ${args.workItem}: final_verdict=${completion.final_verdict}`);
        for (const a2 of completion.acceptance) {
          writeHuman(`  ${a2.criterion_id}: ${a2.verdict} (${a2.evidence.length} evidence)`);
        }
        if (completion.final_verdict !== "pass") {
          writeHuman("  (non-pass: criteria without evidence stay unverified \u2014 close them, then re-run)");
        }
        if (cite.verdict === "warning") {
          writeHuman(`  cite-or-abstain (ac-2, advisory \u2014 non-blocking): ${cite.warnings.length} warning(s)`);
          for (const w2 of cite.warnings)
            writeHuman(`    [${w2.node_id}] ${w2.message}`);
        }
        writeHuman(`  cite cross-check (ac-4, advisory \u2014 non-blocking): ${citeCrossCheck.combined} (re-proposal rate ${citeCrossCheck.reproposal_rate.toFixed(3)})`);
        if (conflicts.length > 0) {
          writeHuman(`  \uB2A5\uB3D9 \uBAA8\uC21C\uACBD\uACE0 (\uB2E8\uACC42, advisory \u2014 non-blocking): ${conflicts.length}\uAC74 \u2014 \uAE30\uAC01\uB41C \uB300\uC548 \uC7AC\uC81C\uC548 \uAC00\uB2A5\uC131`);
          for (const c3 of conflicts)
            writeHuman(`    [${c3.node_id}] ${c3.message}`);
        }
      }
    } catch (err) {
      writeError(`complete failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var autopilotCleanup = defineCommand({
  meta: {
    name: "cleanup",
    description: "Run the deterministic cleanup step for a driver-owned node (gated worktree teardown)"
  },
  args: {
    workItem: { type: "string", description: "Work item id (wi_*)", required: true },
    node: { type: "string", description: "Cleanup node id", required: true },
    approve: {
      type: "boolean",
      description: "Explicit approval for the irreversible git (worktree removal) step",
      default: false
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await requireGraph(args.workItem);
    try {
      const res = await runCleanup(repoRoot, {
        workItemId: args.workItem,
        nodeId: args.node,
        approve: args.approve
      });
      if (format === "json") {
        writeJson2(res);
      } else if (res.status === "blocked") {
        writeHuman(`Cleanup ${res.node_id}: blocked \u2014 ${res.reason}`);
        writeHuman(`  plan (${res.plan.length}): ${res.plan.join(", ") || "(none)"}`);
        writeHuman("  \u2192 re-run with --approve to authorize the irreversible git step");
      } else {
        writeHuman(`Cleanup ${res.node_id}: passed \u2014 removed ${res.removed.length}/${res.plan.length} worktree(s)`);
        if (res.skipped.length > 0) {
          for (const s2 of res.skipped)
            writeHuman(`  skipped: ${s2.path} (${s2.reason})`);
        }
      }
    } catch (err) {
      writeError(`cleanup failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var autopilotProposeE2e = defineCommand({
  meta: {
    name: "propose-e2e",
    description: "Detect web-surface changes and record the user decision on E2E authoring (accept adds an e2e-author node)"
  },
  args: {
    workItem: { type: "string", description: "Work item id (wi_*)", required: true },
    changedFiles: {
      type: "string",
      description: "Comma-separated repo-relative changed paths to scan",
      required: true
    },
    decision: {
      type: "string",
      description: "accept|decline \u2014 record the user decision (omit to only detect)",
      required: false
    },
    journeys: {
      type: "string",
      description: "Optional user journey hint carried onto the e2e-author node on accept",
      required: false
    },
    after: {
      type: "string",
      description: "Comma-separated existing node ids the e2e-author node must run AFTER (depends_on)",
      required: false
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const decision = args.decision;
    if (decision !== undefined && decision !== "accept" && decision !== "decline") {
      writeError(`invalid --decision "${decision}"; expected accept or decline`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const after = (args.after ?? "").split(",").map((id) => id.trim()).filter((id) => id.length > 0);
    const repoRoot = await requireGraph(args.workItem);
    const changed = args.changedFiles.split(",").map((p) => p.trim()).filter((p) => p.length > 0);
    const detection = detectWebSurfaceChange(changed);
    try {
      if (!detection.web) {
        if (format === "json") {
          writeJson2({ web: false, surfaces: [], proposal_needed: false });
        } else {
          writeHuman("No web-surface change detected \u2014 E2E authoring proposal not needed.");
        }
        return;
      }
      if (decision === undefined) {
        if (format === "json") {
          writeJson2({ web: true, surfaces: detection.surfaces, proposal_needed: true });
        } else {
          writeHuman(`Web-surface change detected (${detection.surfaces.length} surface(s)):`);
          for (const s2 of detection.surfaces)
            writeHuman(`  - [${s2.kind}] ${s2.path}`);
          writeHuman("  \u2192 ask the user, then re-run with --decision accept|decline");
        }
        return;
      }
      const aps = new AutopilotStore(repoRoot);
      const ts = new Date().toISOString();
      const surfaceSummary = detection.surfaces.map((s2) => `${s2.kind}:${s2.path}`).join(", ");
      if (decision === "decline") {
        await aps.appendDecision(args.workItem, {
          ts,
          node_id: "e2e-proposal",
          decision: "e2e_decline",
          reason: `user declined E2E authoring for web-surface change (${surfaceSummary})`
        });
        if (format === "json") {
          writeJson2({ web: true, decision: "decline", node_id: null });
        } else {
          writeHuman("Recorded decline \u2014 no e2e-author node added; regular verification proceeds.");
        }
        return;
      }
      const graph = await aps.get(args.workItem);
      const taken = new Set(graph.nodes.map((n2) => n2.id));
      const unknownAfter = after.filter((id) => !taken.has(id));
      if (unknownAfter.length > 0) {
        writeError(`--after references unknown node id(s): ${unknownAfter.join(", ")}`);
        process.exit(USAGE_ERROR_EXIT);
        return;
      }
      let seq = 1;
      while (taken.has(`e2e-author-${seq}`))
        seq += 1;
      const nodeId = `e2e-author-${seq}`;
      await aps.addNodes(args.workItem, [
        {
          id: nodeId,
          kind: "e2e-author",
          owner: kindToOwner("e2e-author"),
          purpose: `Author E2E journey scenarios with the user for the changed web surfaces (${surfaceSummary})${args.journeys ? ` \u2014 journey hint: ${args.journeys}` : ""}`,
          status: "pending",
          depends_on: after,
          acceptance_refs: [],
          evidence_refs: [],
          ac_verdicts: [],
          attempts: { fix: 0, switch: 0 }
        }
      ]);
      await aps.appendDecision(args.workItem, {
        ts,
        node_id: nodeId,
        decision: "e2e_accept",
        reason: `user accepted E2E authoring for web-surface change (${surfaceSummary})`
      });
      if (format === "json") {
        writeJson2({ web: true, decision: "accept", node_id: nodeId });
      } else {
        writeHuman(`Recorded accept \u2014 added e2e-author node ${nodeId} (main-session owned).`);
      }
    } catch (err) {
      writeError(`propose-e2e failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var autopilotIntentDrift = defineCommand({
  meta: {
    name: "intent-drift",
    description: "Check intent conservation across the contract chain (goal + AC id set, hop by hop vs frozen intent)"
  },
  args: {
    workItem: { type: "string", description: "Work item id (wi_*)", required: true },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await resolveRepoRootForCreate();
    const intents = new IntentStore(repoRoot);
    const items = new WorkItemStore(repoRoot);
    const graphs = new AutopilotStore(repoRoot);
    const completions = new CompletionStore(repoRoot);
    try {
      for (const [label, exists] of [
        ["intent.json", await intents.exists(args.workItem)],
        ["work-item.json", await items.exists(args.workItem)],
        ["autopilot.json", await graphs.exists(args.workItem)]
      ]) {
        if (!exists) {
          writeError(`${label} missing for ${args.workItem}; cannot check intent drift`);
          process.exit(RUNTIME_ERROR_EXIT);
          return;
        }
      }
      const intent = await intents.get(args.workItem);
      const workItem2 = await items.get(args.workItem);
      const graph = await graphs.get(args.workItem);
      const completion = await completions.exists(args.workItem) ? await completions.get(args.workItem) : undefined;
      const result2 = intentDriftGate({
        intent,
        workItem: workItem2,
        graph,
        ...completion ? { completion } : {}
      });
      const currentSurface = workItem2.changed_files;
      const surfaceDrift = interfaceBaselineDriftGate(graph.approval_gate.change_surface, currentSurface);
      const pass = result2.pass && surfaceDrift.pass;
      if (format === "json") {
        writeJson2({
          pass,
          reasons: [...result2.reasons, ...surfaceDrift.reasons],
          advisories: result2.advisories
        });
      } else {
        writeHuman(`intent drift: ${pass ? "PASS (conserved)" : "FAIL (drift detected)"}`);
        for (const r3 of result2.reasons)
          writeHuman(`  - ${r3}`);
        for (const r3 of surfaceDrift.reasons)
          writeHuman(`  - ${r3}`);
        for (const a2 of result2.advisories)
          writeHuman(`  ~ (advisory) ${a2}`);
      }
      if (!pass)
        process.exit(RUNTIME_ERROR_EXIT);
    } catch (err) {
      writeError(`intent-drift failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var autopilotCoverageNext = defineCommand({
  meta: {
    name: "coverage-next",
    description: "Compute the next plan-stage coverage step (seed root, schedule node, or dry)"
  },
  args: {
    workItem: { type: "string", description: "Work item id (wi_*)", required: true },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await requireGraph(args.workItem);
    try {
      const res = await nextCoverageNode({ repoRoot, workItemId: args.workItem });
      if (format === "json") {
        writeJson2(res);
      } else if (res.action === "dry") {
        writeHuman("Coverage: dry \u2014 sweep terminated (breadth + depth). Record the design result.");
      } else {
        writeHuman(`Coverage: interrogate ${res.node.id} (tier=${res.tier})`);
        writeHuman(`  label:       ${res.node.label}`);
        writeHuman(`  dry_counter: ${res.dryCounter}`);
        writeHuman("  \u2192 run fresh sweep + 3-role dialectic + judges with ONLY judgeInput, then coverage-round");
      }
    } catch (err) {
      writeError(`coverage-next failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var autopilotCoverageRound = defineCommand({
  meta: {
    name: "coverage-round",
    description: "Record a coverage interrogation round: append, step dry counter, gate close"
  },
  args: {
    workItem: { type: "string", description: "Work item id (wi_*)", required: true },
    json: {
      type: "string",
      description: "JSON payload matching coverageRoundPayload schema",
      required: true
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let raw;
    try {
      raw = JSON.parse(args.json);
    } catch (err) {
      writeError(`--json is not valid JSON: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const parsed = coverageRoundPayload.safeParse(raw);
    if (!parsed.success) {
      writeError("--json failed schema validation:");
      for (const issue of parsed.error.issues) {
        writeError(`  - ${issue.path.join(".") || "(root)"}: ${issue.message}`);
      }
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await requireGraph(args.workItem);
    const extra = raw;
    try {
      const res = await recordCoverageRound({
        repoRoot,
        workItemId: args.workItem,
        payload: parsed.data,
        ...extra.brief ? {
          brief: extra.brief
        } : {},
        ...extra.tier_inputs ? {
          tierInputs: extra.tier_inputs
        } : {}
      });
      if (format === "json") {
        writeJson2(res);
      } else if (res.terminated) {
        writeHuman(`Coverage round: TERMINATED \u2014 plan-dialog written (${res.planDialogPath})`);
        writeHuman("  \u2192 record the design result WITH plan_brief");
      } else {
        writeHuman(`Coverage round: ${res.closed ? "closed" : "open"} \u2014 dry_counter=${res.dryCounter}`);
        if (res.reasons.length > 0) {
          writeHuman("  close rejected (node stays open):");
          for (const r3 of res.reasons)
            writeHuman(`    - ${r3}`);
        }
      }
    } catch (err) {
      writeError(`coverage-round failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var autopilotStatus = defineCommand({
  meta: {
    name: "status",
    description: "Show the approval gate, plan brief, and node progress for a work item"
  },
  args: {
    workItem: { type: "string", description: "Work item id (wi_*)", required: true },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await requireGraph(args.workItem);
    const graph = await new AutopilotStore(repoRoot).get(args.workItem);
    const gate2 = graph.approval_gate;
    const byStatus = graph.nodes.reduce((acc, n2) => {
      acc[n2.status] = (acc[n2.status] ?? 0) + 1;
      return acc;
    }, {});
    if (format === "json") {
      writeJson2({
        work_item_id: args.workItem,
        autopilot_id: graph.autopilot_id,
        approval_gate: gate2,
        nodes: { total: graph.nodes.length, by_status: byStatus }
      });
      return;
    }
    writeHuman(`Autopilot ${graph.autopilot_id} (${args.workItem})`);
    writeHuman(`  approval_gate: ${gate2.status}${gate2.source ? ` (source: ${gate2.source})` : ""}`);
    if (gate2.approved_by)
      writeHuman(`  approved_by:   ${gate2.approved_by}`);
    if (gate2.change_surface?.length) {
      writeHuman(`  change_surface: ${gate2.change_surface.join(", ")}`);
    }
    if (gate2.plan_brief) {
      writeHuman("  plan_brief:");
      for (const c3 of gate2.plan_brief.interface_changes)
        writeHuman(`    interface: ${c3}`);
      for (const d2 of gate2.plan_brief.dod)
        writeHuman(`    dod:       ${d2}`);
      for (const s2 of gate2.plan_brief.test_scenarios)
        writeHuman(`    test:      ${s2}`);
    }
    const counts = Object.entries(byStatus).map(([s2, n2]) => `${s2}=${n2}`).join(" ");
    writeHuman(`  nodes:         ${graph.nodes.length} (${counts})`);
    if (gate2.status === "pending") {
      writeHuman("  \u2192 review the brief, then: ditto autopilot approve|reject --workItem <wi>");
    }
  }
});
