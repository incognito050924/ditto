      }));
      const gate2 = updated.approval_gate;
      if (format === "json") {
        writeJson2({ work_item_id: args.workItem, approval_gate: gate2 });
      } else {
        writeHuman(`Approved ${args.workItem}: gate=${gate2.status} source=${gate2.source}`);
        writeHuman(`  approved_by: ${gate2.approved_by} at ${gate2.approved_at}`);
      }
    } catch (err) {
      writeError(`approve failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
