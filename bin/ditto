var require_src = __commonJS((exports, module) => {
  var ESC2 = "\x1B";
  var CSI2 = `${ESC2}[`;
  var beep = "\x07";
  var cursor = {
    to(x2, y3) {
      if (!y3)
        return `${CSI2}${x2 + 1}G`;
      return `${CSI2}${y3 + 1};${x2 + 1}H`;
    },
    move(x2, y3) {
      let ret = "";
      if (x2 < 0)
        ret += `${CSI2}${-x2}D`;
      else if (x2 > 0)
        ret += `${CSI2}${x2}C`;
      if (y3 < 0)
        ret += `${CSI2}${-y3}A`;
      else if (y3 > 0)
        ret += `${CSI2}${y3}B`;
      return ret;
    },
    up: (count = 1) => `${CSI2}${count}A`,
    down: (count = 1) => `${CSI2}${count}B`,
    forward: (count = 1) => `${CSI2}${count}C`,
    backward: (count = 1) => `${CSI2}${count}D`,
