import { join as join22, relative as relative5 } from "path";

class CoverageStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  dir(workItemId2) {
    return localDir(this.repoRoot, "runs", workItemId2);
  }
  mapPath(workItemId2) {
    return join22(this.dir(workItemId2), "coverage.json");
  }
  dialogPath(workItemId2) {
    return join22(this.dir(workItemId2), "plan-dialog.md");
  }
  intentDialogPath(workItemId2) {
    return join22(this.dir(workItemId2), "intent-dialog.md");
  }
  provenancePath(workItemId2) {
    return join22(this.dir(workItemId2), "relevance-provenance.json");
  }
  async exists(workItemId2) {
    return Bun.file(this.mapPath(workItemId2)).exists();
  }
  relMapPath(workItemId2) {
    return relative5(this.repoRoot, this.mapPath(workItemId2));
  }
  async getMap(workItemId2) {
    return readJson(this.mapPath(workItemId2), coverageMap);
  }
  async writeMap(workItemId2, map) {
    await ensureDir(this.dir(workItemId2));
    return writeJson(this.mapPath(workItemId2), coverageMap, map);
  }
  async writePlanDialog(workItemId2, markdown) {
    await ensureDir(this.dir(workItemId2));
    await atomicWriteText(this.dialogPath(workItemId2), markdown);
  }
  async writeIntentDialog(workItemId2, markdown) {
    await ensureDir(this.dir(workItemId2));
    await atomicWriteText(this.intentDialogPath(workItemId2), markdown);
  }
  async hasRelevanceProvenance(workItemId2) {
    return Bun.file(this.provenancePath(workItemId2)).exists();
  }
  async getRelevanceProvenance(workItemId2) {
    return readJson(this.provenancePath(workItemId2), relevanceProvenance);
  }
  async writeRelevanceProvenance(workItemId2, provenance) {
    await ensureDir(this.dir(workItemId2));
    return writeJson(this.provenancePath(workItemId2), relevanceProvenance, provenance);
  }
}

