  finalized: exports_external.object({ at: isoDateTime }).nullable().default(null),
  updated_at: isoDateTime
}).describe("Journey-authoring working state (pre-finalize draft buffer)");

// src/core/journey-authoring/store.ts
class JourneyAuthoringStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  journeysDir() {
    return localDir(this.repoRoot, "journeys");
  }
  storiesDir() {
    return localDir(this.repoRoot, "stories");
  }
  journeyPath(id) {
    return join77(this.journeysDir(), `${id}.json`);
  }
  storyPath(id) {
    return join77(this.storiesDir(), `${id}.json`);
  }
  async getJourney(id) {
    if (!await Bun.file(this.journeyPath(id)).exists())
      return null;
    return readJson(this.journeyPath(id), acgJourneySpec);
  }
  async writeJourney(spec) {
    await ensureDir(this.journeysDir());
    return writeJson(this.journeyPath(spec.id), acgJourneySpec, spec);
  }
  async loadAllJourneys() {
    return this.loadAll(this.journeysDir(), acgJourneySpec);
  }
  async activeJourneys() {
    return (await this.loadAllJourneys()).filter((j) => j.status !== "superseded" && j.status !== "spec_first");
  }
  async getStory(id) {
    if (!await Bun.file(this.storyPath(id)).exists())
      return null;
    return readJson(this.storyPath(id), acgStorySpec);
  }
  async writeStory(spec) {
    await ensureDir(this.storiesDir());
    return writeJson(this.storyPath(spec.id), acgStorySpec, spec);
  }
  async loadAllStories() {
    return this.loadAll(this.storiesDir(), acgStorySpec);
  }
  async loadAll(dir, schema) {
    let names;
    try {
      names = (await readdir23(dir)).filter((n3) => n3.endsWith(".json")).sort();
    } catch {
      return [];
    }
    const out = [];
    for (const name of names) {
      out.push(await readJson(join77(dir, name), schema));
    }
    return out;
  }
  sessionPath(workItemId2) {
    return join77(localDir(this.repoRoot, "work-items", workItemId2), "journey-authoring-state.json");
  }
  async sessionExists(workItemId2) {
    return Bun.file(this.sessionPath(workItemId2)).exists();
  }
  async getSession(workItemId2) {
    return readJson(this.sessionPath(workItemId2), journeyAuthoringState);
  }
  async writeSession(state) {
    await ensureDir(localDir(this.repoRoot, "work-items", state.work_item_id));
    return writeJson(this.sessionPath(state.work_item_id), journeyAuthoringState, state);
  }
}
// src/core/journey-authoring/session.ts
import { join as join78 } from "path";
init_fs();
init_shared();
class IdConflictError extends Error {
  conflicts;
  constructor(conflicts) {
    super(`journey id conflict (fail-closed): ${conflicts.map((c5) => `${c5.id} \u2014 ${c5.reason}`).join("; ")}`);
    this.conflicts = conflicts;
    this.name = "IdConflictError";
  }
}

class JourneyReferenceNotFoundError extends Error {
  missing;
  constructor(missing) {
    super(`referenced journeys not found in catalog (fail-closed): ${missing.join(", ")}`);
    this.missing = missing;
    this.name = "JourneyReferenceNotFoundError";
  }
}
async function startAuthoring(repoRoot, input) {
  const nowIso = (input.now ?? new Date).toISOString();
  await new JourneyAuthoringStore(repoRoot).writeSession({
    schema_version: "0.1.0",
    work_item_id: input.workItemId,
    kind: input.kind,
    story: null,
    journeys: [],
    finalized: null,
    updated_at: nowIso
  });
}
async function recordJourney(repoRoot, input) {
  const store = new JourneyAuthoringStore(repoRoot);
  const state = await store.getSession(input.workItemId);
  const nowIso = (input.now ?? new Date).toISOString();
  const journey = journeyDraft.parse(input.journey);
  const idx = state.journeys.findIndex((j) => j.slug === journey.slug);
  const journeys = idx === -1 ? [...state.journeys, journey] : state.journeys.map((j, i3) => i3 === idx ? journey : j);
  await store.writeSession({ ...state, journeys, updated_at: nowIso });
}
async function recordStory(repoRoot, input) {
  const store = new JourneyAuthoringStore(repoRoot);
  const state = await store.getSession(input.workItemId);
  const nowIso = (input.now ?? new Date).toISOString();
  await store.writeSession({ ...state, story: storyDraft.parse(input.story), updated_at: nowIso });
}
async function finalizeAuthoring(repoRoot, input) {
  const store = new JourneyAuthoringStore(repoRoot);
  if (!await store.sessionExists(input.workItemId))
    return { status: "not_started" };
  const state = await store.getSession(input.workItemId);
  const producedAt = (input.now ?? new Date).toISOString();
  const ownerStoryId = state.story ? storyId(state.story.slug) : undefined;
  const built = state.journeys.map((d2) => {
    const id = journeyId(d2.slug);
    const spec = {
      schema_version: "0.1.0",
      kind: "acg.journey-spec.v1",
      produced_by: "agent",
      produced_at: producedAt,
      id,
      status: d2.implemented ? "awaiting_validation" : "spec_first",
      ...ownerStoryId ? { story_id: ownerStoryId } : {},
      title: d2.name,
      owner: d2.owner,
      steps: d2.steps,
      surfaces: d2.surfaces,
      fixtures: [],
      evidence_requirement: { kind: "e2e", must_pass_steps: d2.steps.map((s2) => s2.step_id) }
    };
    const dsl = renderJourneyDsl({
      id: spec.id,
      name: d2.name,
      description: d2.description,
      intent: d2.intent,
      surfaces: d2.surfaces,
      steps: d2.steps
    });
    return { draft: d2, spec, dsl };
  });
  const newIds = new Set(built.map((b3) => b3.spec.id));
  if (state.story) {
    const missing = [];
    for (const ref of state.story.reference_journey_ids) {
      if (newIds.has(ref))
        continue;
      if (!await store.getJourney(ref))
        missing.push(ref);
    }
    if (missing.length > 0)
      throw new JourneyReferenceNotFoundError(missing);
  }
  const conflicts = [];
  for (const { spec, dsl } of built) {
    const existing = await store.getJourney(spec.id);
    if (existing && (existing.story_id ?? undefined) !== ownerStoryId) {
      conflicts.push({
        id: spec.id,
        reason: `already owned by ${existing.story_id ?? "(journey-only)"}`
      });
    }
    const dslPath = join78(repoRoot, "e2e", "journeys", `${dslSlug(spec.id)}.journey.md`);
    if (await fileExists(dslPath)) {
      const existingText = await Bun.file(dslPath).text();
      const parsed = parseJourneyDoc(existingText);
      if (parsed.ok && parsed.frontMatter.id !== spec.id) {
        conflicts.push({ id: spec.id, reason: `DSL slug taken by ${parsed.frontMatter.id}` });
      } else if (existingText !== dsl) {
        conflicts.push({
          id: spec.id,
          reason: "existing DSL diverges from generated output (hand-authored / not owned)"
        });
      }
    }
  }
  if (conflicts.length > 0)
    throw new IdConflictError(conflicts);
  const writtenJourneys = [];
  const dslPaths = [];
  for (const { spec, dsl } of built) {
    writtenJourneys.push(await store.writeJourney(spec));
    const rel = join78("e2e", "journeys", `${dslSlug(spec.id)}.journey.md`);
    await atomicWriteText(join78(repoRoot, rel), dsl);
    dslPaths.push(rel);
  }
  const superseded = [];
  if (ownerStoryId) {
    for (const existing of await store.loadAllJourneys()) {
      if (existing.story_id !== ownerStoryId)
        continue;
      if (newIds.has(existing.id))
        continue;
      if (existing.status === "superseded")
        continue;
      await store.writeJourney({ ...existing, status: "superseded" });
      superseded.push(existing.id);
    }
  }
  let writtenStory = null;
  if (state.story) {
    const journeyIds = [
      ...newIds,
      ...state.story.reference_journey_ids.filter((r4) => !newIds.has(r4))
    ];
    const story = {
      schema_version: "0.1.0",
      kind: "acg.story-spec.v1",
      produced_by: "agent",
      produced_at: producedAt,
      id: ownerStoryId,
      ...state.story.title ? { title: state.story.title } : {},
      owner: state.story.owner,
      actor: state.story.actor,
      want: state.story.want,
      value: state.story.value,
      journey_ids: journeyIds
    };
    writtenStory = await store.writeStory(story);
  }
  await store.writeSession({ ...state, finalized: { at: producedAt }, updated_at: producedAt });
  return {
    status: "finalized",
    journeys: writtenJourneys,
    story: writtenStory,
    dsl_paths: dslPaths,
    superseded
  };
}
