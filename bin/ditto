// src/schemas/e2e-journey.ts
init_zod();
init_common();
var e2eResult = exports_external.enum(["pass", "fail", "unverified", "blocked"]).describe("Journey outcome: pass (every assertion checkable and held), fail (a checkable " + "assertion was contradicted), unverified (ran, but \u22651 assertion was not a " + 'mechanically-checkable predicate \u2014 honest "could not evaluate", not a fail), ' + "or blocked (could not run at all)");
var e2eStep = exports_external.object({
  action: exports_external.string().min(1).describe('User action performed, e.g. "click Login"'),
  target: exports_external.string().optional().describe("Selector/URL/element the action targets"),
  expectation: exports_external.string().optional().describe("What should be observable after the action")
}).describe("One step in the user journey");
var e2eAssertion = exports_external.object({
  description: exports_external.string().min(1).describe("What is being asserted about the journey"),
  satisfied: exports_external.boolean().describe("Whether the assertion held when the journey ran"),
  checkable: exports_external.boolean().default(true).describe("Whether the runner could mechanically evaluate this assertion (false \u21D2 unverified)")
}).describe("A checked assertion about the journey outcome");
var artifactRef = exports_external.object({
  path: relativePath.describe("Repo-relative path under .ditto/local/runs/<id>/"),
  sha256: sha256.optional()
}).describe("Pointer to a captured artifact (path + optional hash; raw stays under .ditto/local/runs)");
var e2eArtifacts = exports_external.object({
  screenshots: exports_external.array(artifactRef).default([]),
  trace: artifactRef.nullable().default(null),
  console: artifactRef.nullable().default(null),
  network: artifactRef.nullable().default(null)
}).describe("Captured browser artifacts (\xA710)");
var e2eJourney = exports_external.object({
  schema_version: schemaVersion,
  journey: exports_external.string().min(1).describe("User journey name"),
  journey_id: exports_external.string().min(1).optional().describe("ACG JourneySpec.id this run realizes (D4; distinct from `journey` name)"),
  work_item_id: workItemId.optional().describe("Work item this journey run belongs to (D4)"),
  url: exports_external.string().min(1).describe("Target URL or dev-server entry under test"),
  steps: exports_external.array(e2eStep).default([]),
  assertions: exports_external.array(e2eAssertion).default([]),
  result: e2eResult,
  artifacts: e2eArtifacts.default({}),
  reproduction: exports_external.string().min(1).nullable().default(null).describe('Reproduction steps; required when result=fail (\uC124\uACC4\uC11C \xA710 "\uC2E4\uD328 \uC2DC \uC7AC\uD604 \uC808\uCC28")')
}).superRefine((value, ctx) => {
  if (value.result === "fail" && value.reproduction === null) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "result=fail requires reproduction steps",
      path: ["reproduction"]
    });
  }
  if (value.result === "pass" && value.assertions.some((a2) => !a2.checkable || !a2.satisfied)) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "result=pass but an assertion is unchecked or not satisfied",
      path: ["result"]
    });
  }
  const claimedUnchecked = value.assertions.find((a2) => !a2.checkable && a2.satisfied);
  if (claimedUnchecked) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "an unchecked assertion (checkable=false) cannot be satisfied=true",
      path: ["assertions"]
    });
  }
  if (value.result === "unverified") {
    if (value.assertions.some((a2) => a2.checkable && !a2.satisfied)) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        message: "result=unverified but a checkable assertion was not satisfied (that is a fail)",
        path: ["result"]
      });
    }
    if (!value.assertions.some((a2) => !a2.checkable)) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        message: "result=unverified requires at least one unchecked (checkable=false) assertion",
        path: ["result"]
      });
    }
  }
}).describe("A browser user-journey verification result (\xA710)");

// src/core/e2e/browser.ts
init_ditto_paths();
init_shared();
function runnerScriptPath() {
  return join31(dirname10(fileURLToPath(import.meta.url)), "playwright-runner.mjs");
}
async function resolvePlaywrightCore() {
  const bunInstall = process.env.BUN_INSTALL ?? join31(homedir6(), ".bun");
  const cacheDir = join31(bunInstall, "install", "cache");
  let entries;
  try {
    entries = await readdir13(cacheDir);
  } catch {
    return null;
  }
  const versions = entries.filter((e2) => /^playwright-core@\d+\.\d+\.\d+$/.test(e2)).sort((a2, b2) => compareSemver(b2.split("@")[1], a2.split("@")[1]));
  for (const v2 of versions) {
    const mjs = join31(cacheDir, v2, "index.mjs");
    if (await fileExists(mjs))
      return mjs;
  }
  return null;
}
function compareSemver(a2, b2) {
  const pa = a2.split(".").map(Number);
  const pb = b2.split(".").map(Number);
  for (let i2 = 0;i2 < 3; i2++) {
    if ((pa[i2] ?? 0) !== (pb[i2] ?? 0))
      return (pa[i2] ?? 0) - (pb[i2] ?? 0);
  }
  return 0;
}
async function findCachedChromium() {
  const cacheRoot = join31(homedir6(), "Library", "Caches", "ms-playwright");
  let entries;
  try {
    entries = await readdir13(cacheRoot);
  } catch {
    return null;
  }
  const chromiumDirs = entries.filter((e2) => /^chromium-\d+$/.test(e2)).sort((a2, b2) => Number(b2.split("-")[1]) - Number(a2.split("-")[1]));
  const candidates = [
    "chrome-mac-arm64/Google Chrome for Testing.app/Contents/MacOS/Google Chrome for Testing",
    "chrome-mac/Chromium.app/Contents/MacOS/Chromium"
  ];
  for (const dir of chromiumDirs) {
    for (const rel of candidates) {
      const abs = join31(cacheRoot, dir, rel);
      if (await fileExists(abs))
        return abs;
    }
  }
  return null;
}
function repoRelative(repoRoot, path) {
  return relative9(repoRoot, path).split(sep5).join("/");
}
async function sha256OfFile(path) {
  const bytes = await readFile5(path);
  return createHash7("sha256").update(bytes).digest("hex");
}
async function probePlaywright(repoRoot) {
  let proc;
  try {
    proc = spawnProviderProcess({
      binary: "bunx",
      args: ["--no-install", "playwright", "--version"],
      repoRoot,
      cwd: ".",
      env: { set: {}, unset: [] }
    });
  } catch (err) {
    return {
      available: false,
      reason: `Playwright probe could not spawn: ${err instanceof Error ? err.message : String(err)}`
    };
  }
  const completion = await proc.completion;
  if (completion.exit_code !== 0) {
    return {
      available: false,
      reason: `Playwright/Chromium not available (bunx --no-install playwright --version exit=${completion.exit_code ?? "null"}); not auto-installing per orchestrator hard constraint`
    };
  }
  const playwrightCore = await resolvePlaywrightCore();
  const executablePath = await findCachedChromium();
  if (!playwrightCore || !executablePath) {
    return {
      available: false,
      reason: `Playwright CLI present but no real-launch inputs (playwright-core=${playwrightCore ? "ok" : "unresolved"}, cachedChromium=${executablePath ? "ok" : "absent"}); not auto-installing per orchestrator hard constraint`
    };
  }
  return {
    available: true,
    reason: "playwright --version succeeded; cached Chromium + playwright-core resolved",
    playwrightCore,
    executablePath
  };
}
function buildJourney(input) {
  return e2eJourney.parse({
    schema_version: "0.1.0",
    journey: input.journey,
    url: input.url,
    steps: input.steps,
    assertions: input.assertions,
    result: input.result,
    ...input.artifacts ? { artifacts: input.artifacts } : {},
    ...input.reproduction !== undefined ? { reproduction: input.reproduction } : {}
  });
}
function blockedJourney(spec, reason) {
  return buildJourney({
    journey: spec.journey,
    url: spec.url,
    steps: spec.steps,
    assertions: spec.assertions.map((a2) => ({ description: a2.description, satisfied: false })),
    result: "blocked",
    reproduction: reason
  });
}
async function runJourney(repoRoot, runId2, spec) {
  const probe = await probePlaywright(repoRoot);
  if (!probe.available || !probe.playwrightCore || !probe.executablePath) {
    return { journey: blockedJourney(spec, probe.reason), run_id: runId2, probe };
  }
  const runDir = localDir(repoRoot, "runs", runId2);
  await mkdir4(runDir, { recursive: true });
  const configAbs = join31(runDir, "runner-config.json");
  await writeFile3(configAbs, JSON.stringify({
    playwrightCore: probe.playwrightCore,
    executablePath: probe.executablePath,
    url: spec.url,
    steps: spec.steps,
    assertions: spec.assertions.map((a2) => ({ description: a2.description })),
    runDir
  }));
  let runnerExit;
  try {
    const runner = spawnProviderProcess({
      binary: "node",
      args: [runnerScriptPath(), configAbs],
      repoRoot,
      cwd: ".",
      env: { set: {}, unset: [] }
    });
    runnerExit = (await runner.completion).exit_code;
  } catch (err) {
    return {
      journey: blockedJourney(spec, `capture runner could not spawn: ${err instanceof Error ? err.message : String(err)}`),
      run_id: runId2,
      probe
    };
  }
  if (runnerExit !== 0) {
    return {
      journey: blockedJourney(spec, `capture runner exited non-zero (exit=${runnerExit ?? "null"}); treating as blocked rather than asserting an unobserved pass`),
      run_id: runId2,
      probe
    };
  }
  const screenshotAbs = join31(runDir, "journey.png");
  const traceAbs = join31(runDir, "trace.zip");
  const consoleAbs = join31(runDir, "console.log");
  const networkAbs = join31(runDir, "network.log");
  const screenshots = [];
  if (await fileExists(screenshotAbs)) {
    screenshots.push({
      path: repoRelative(repoRoot, screenshotAbs),
      sha256: await sha256OfFile(screenshotAbs)
    });
  }
  const trace = await fileExists(traceAbs) ? { path: repoRelative(repoRoot, traceAbs) } : null;
  const consoleArtifact = await fileExists(consoleAbs) ? { path: repoRelative(repoRoot, consoleAbs) } : null;
  const network = await fileExists(networkAbs) ? { path: repoRelative(repoRoot, networkAbs) } : null;
  const outcomeAbs = join31(runDir, "outcome.json");
  if (!await fileExists(outcomeAbs)) {
    return {
      journey: blockedJourney(spec, "Playwright present but no capture outcome was produced; treating as blocked rather than asserting an unobserved pass"),
      run_id: runId2,
      probe
    };
  }
  let outcome;
  try {
    outcome = JSON.parse(await readFile5(outcomeAbs, "utf8"));
  } catch (err) {
    return {
      journey: blockedJourney(spec, `capture outcome unreadable: ${err instanceof Error ? err.message : String(err)}`),
      run_id: runId2,
      probe
    };
  }
  const assertions = spec.assertions.map((a2, i2) => ({
    description: a2.description,
    satisfied: outcome.satisfied[i2] ?? false,
    checkable: outcome.checkable?.[i2] ?? true
  }));
  const journey = buildJourney({
    journey: spec.journey,
    url: spec.url,
    steps: spec.steps,
    assertions,
    result: outcome.result,
    artifacts: { screenshots, trace, console: consoleArtifact, network },
    reproduction: outcome.result === "fail" ? outcome.reproduction ?? "see captured artifacts" : null
  });
  return { journey, run_id: runId2, probe };
}

// src/core/e2e/authoring-guard.ts
async function withBrowserGuard(repoRoot, action, options = {}) {
  const probe = await (options.probe ?? probePlaywright)(repoRoot);
  if (!probe.available) {
    return { result: "blocked", reason: probe.reason, probe };
  }
  return { result: "ran", value: await action(probe), probe };
}

// src/core/e2e/journey-digest.ts
import { createHash as createHash8 } from "crypto";
import { readFile as readFile6, readdir as readdir14 } from "fs/promises";
init_dist2();
init_shared();

// src/core/e2e/journey-dsl.ts
init_shared();
var stepLine = /^\s*\d+\.\s+\[([sb]\d+)\]/;
var blockCallLine = /^\s*\d+\.\s+\[[sb]\d+\]\s*(?:\([^)]*\)\s*)?\uBE14\uB85D:\s*([^\s(]+)/;
var stepMarker = /^\s*\/\/\s*@step\s+(\S+\/[sb]\d+)\b/;
function splitFrontMatter(text) {
  const lines = text.split(`
`);
  if ((lines[0] ?? "").trim() !== "---")
    return null;
  for (let i2 = 1;i2 < lines.length; i2++) {
    if ((lines[i2] ?? "").trim() === "---") {
      return { frontMatter: lines.slice(1, i2).join(`
`), body: lines.slice(i2 + 1).join(`
`) };
    }
  }
  return null;
}
function extractStepIds(body) {
  const ids = [];
  for (const line of body.split(`
`)) {
    const m2 = stepLine.exec(line);
    if (m2?.[1])
      ids.push(m2[1]);
  }
  return ids;
}
function extractBlockCalls(body) {
  const ids = [];
  for (const line of body.split(`
`)) {
    const m2 = blockCallLine.exec(line);
    if (m2?.[1])
      ids.push(m2[1]);
  }
  return ids;
}
function extractCaseNames(body) {
  const lines = body.split(`
`);
  const start = lines.findIndex((l2) => /^##\s*\uCF00\uC774\uC2A4\s*$/.test(l2.trim()));
  if (start < 0)
    return [];
  const names = [];
  let sawHeader = false;
  for (let i2 = start + 1;i2 < lines.length; i2++) {
    const line = (lines[i2] ?? "").trim();
    if (line.startsWith("#"))
      break;
    if (!line.startsWith("|")) {
      if (names.length > 0 || sawHeader)
        break;
      if (line === "")
        continue;
      break;
    }
    if (/^\|[\s\-:|]+\|?$/.test(line))
      continue;
    if (!sawHeader) {
      sawHeader = true;
      continue;
    }
    const first = line.split("|")[1]?.trim();
    if (first !== undefined && first !== "")
      names.push(first);
  }
  return names;
}
function extractStepMarkers(generated) {
  const refs = [];
  for (const line of generated.split(`
`)) {
    const m2 = stepMarker.exec(line);
    if (m2?.[1])
      refs.push(m2[1]);
  }
  return refs;
}
function parseDoc(text, schema) {
  const split = splitFrontMatter(text);
  if (!split)
    return { ok: false, error: "no leading ---\u2026--- front-matter block" };
  let raw;
  try {
    raw = parseYaml(split.frontMatter);
  } catch (err) {
    return {
      ok: false,
      error: `front-matter YAML parse failed: ${err instanceof Error ? err.message : String(err)}`
    };
  }
  const parsed = schema.safeParse(raw);
  if (!parsed.success)
    return { ok: false, error: parsed.error.message };
  const stepIds = extractStepIds(split.body);
  const seen = new Set;
  for (const id of stepIds) {
    if (seen.has(id)) {
      return { ok: false, error: `duplicate step id [${id}] \u2014 step ids must be unique` };
    }
    seen.add(id);
  }
  return { ok: true, frontMatter: parsed.data, stepIds };
}
function parseJourneyDoc(text) {
  return parseDoc(text, journeyFrontMatter);
}
function parseBlockDoc(text) {
  return parseDoc(text, blockFrontMatter);
}

// src/core/e2e/journey-digest.ts
function sha256Hex2(bytes) {
  return createHash8("sha256").update(bytes).digest("hex");
}
function canonicalDigestText(text) {
  const split = splitFrontMatter(text);
  if (!split)
    return text;
  let raw;
  try {
    raw = parseYaml(split.frontMatter);
  } catch {
    return text;
  }
  if (raw === null || typeof raw !== "object" || Array.isArray(raw))
    return text;
  const { flaky_history: _omitted, ...record } = raw;
  return `---
${$stringify(record)}---
${split.body}`;
}
function computeSourceDigest(text) {
  return sha256Hex2(canonicalDigestText(text));
}
function renderGeneratedHeader(input) {
  const idTag = input.kind === "journey" ? "@ditto-journey" : "@ditto-block";
  return [
    "/**",
    " * @ditto-generated",
    ` * @ditto-source ${input.sourcePath}`,
    ` * @ditto-digest sha256:${input.digest}`,
    ` * ${idTag} ${input.id}`,
    " */"
  ].join(`
`);
}
var headerLine = (tag) => new RegExp(`^\\s*\\*\\s*${tag}\\s+(\\S+)\\s*$`, "m");
var generatedMarker = /^\s*(?:\/\/|\/?\*+)?\s*@ditto-generated\s*$/m;
function isDittoGenerated(content) {
  return generatedMarker.test(content);
}
function parseGeneratedHeader(content) {
  if (!isDittoGenerated(content))
    return null;
  const source = headerLine("@ditto-source").exec(content)?.[1];
  const digest = /^\s*\*\s*@ditto-digest\s+sha256:([a-f0-9]{64})\s*$/m.exec(content)?.[1];
  if (!source || !digest)
    return null;
  const journey = headerLine("@ditto-journey").exec(content)?.[1];
  const block = headerLine("@ditto-block").exec(content)?.[1];
  return {
    source,
    digest,
    ...journey ? { journey } : {},
    ...block ? { block } : {}
  };
}
async function detectStale(sourceAbs, generatedAbs, expectedSource) {
  let sourceText;
  try {
    sourceText = await readFile6(sourceAbs, "utf8");
  } catch {
    return { stale: true, reason: `source DSL not readable: ${sourceAbs}` };
  }
  let generated;
  try {
    generated = await readFile6(generatedAbs, "utf8");
  } catch {
    return {
      stale: true,
      reason: `generated file not readable (never generated?): ${generatedAbs}`
    };
  }
  const header = parseGeneratedHeader(generated);
  if (!header) {
    return {
      stale: true,
      reason: "generated file has no @ditto-digest header; freshness unprovable"
    };
  }
  if (expectedSource !== undefined && header.source !== expectedSource) {
    return {
      stale: true,
      reason: `@ditto-source mismatch: header points at ${header.source}, expected ${expectedSource} \u2014 provenance unprovable`
    };
  }
  const canonical = computeSourceDigest(sourceText);
  const raw = sha256Hex2(sourceText);
  if (header.digest !== canonical && header.digest !== raw) {
    return {
      stale: true,
      reason: `digest mismatch: header sha256:${header.digest} \u2260 current source sha256:${canonical} (DSL changed after last generation)`
    };
  }
  return { stale: false, reason: "header digest matches current source" };
}

// src/core/e2e/generator-fallback.ts
var FALLBACK_UNVERIFIED_MARKER = "@ditto-unverified fallback:e2e-scripter (no live browser at generation)";
var BROWSER_EVIDENCE_ACS = ["ac-3", "ac-5"];
function stampUnverified(baseHeader) {
  const marker = ` * ${FALLBACK_UNVERIFIED_MARKER}`;
  const lines = baseHeader.split(`
`);
  const closeIdx = lines.lastIndexOf(" */");
  if (closeIdx >= 0)
    lines.splice(closeIdx, 0, marker);
  else
    lines.push(marker);
  return lines.join(`
`);
}
function planAsComment(plan) {
  return plan.split(`
`).map((l2) => l2.length > 0 ? `// ${l2}` : "//").join(`
`);
}
function renderFallbackSpec(input) {
  const header = stampUnverified(renderGeneratedHeader(input.header));
  const title = `${input.header.id} \u2014 awaiting live e2e-scripter conversion (no browser at generation)`;
  return [
    header,
    "import { test } from '@playwright/test';",
    "",
    "// FALLBACK SCAFFOLD (ADR-0018 graceful degrade): produced WITHOUT a live",
    "// browser because the official Playwright generator was unusable. The single",
    "// conversion authority is the plan embedded below \u2014 a live e2e-scripter run",
    "// over this SAME plan must replace this scaffold. Until then ac-3 + ac-5",
    "// (browser evidence) are UNVERIFIED; nothing here asserts an observed pass.",
    `// Plan source: ${input.planPath}`,
    "//",
    "// ---- BEGIN PLAN ----",
    planAsComment(input.plan),
    "// ---- END PLAN ----",
    "",
    `test.fixme(${JSON.stringify(title)}, async () => {`,
    "  // Intentionally unimplemented: synthesising assertions here would fabricate",
    "  // a pass the fallback never observed. Skipped until a live run generates it.",
    "});",
    ""
  ].join(`
`);
}
function generateFallbackSpec(input) {
  if (input.probe.available) {
    return {
      used_fallback: false,
      reason: "browser available \u2014 route to the primary official generator, not the fallback",
      unverified_acs: []
    };
  }
  return {
    used_fallback: true,
    reason: `official generator unusable (${input.probe.reason}) \u2014 degraded to the e2e-scripter fallback over the plan; no live browser at generation`,
    unverified_acs: [...BROWSER_EVIDENCE_ACS],
    spec: renderFallbackSpec(input),
    specPath: input.specPath,
    warn: `UNVERIFIED FALLBACK SPEC: ${input.specPath} was scaffolded from ${input.planPath} without a live browser (ADR-0018 degrade). It is stamped @ditto-unverified; ac-3 + ac-5 (browser evidence) remain UNVERIFIED and MUST NOT be reported as passing until a live e2e-scripter run replaces it.`
  };
}
var fallbackMarker = /^\s*(?:\/\/|\/?\*+)?\s*@ditto-unverified\s+fallback:e2e-scripter\b/m;
function isFallbackUnverified(content) {
  return fallbackMarker.test(content);
}

// src/core/e2e/generated-verify.ts
async function runPlaywrightTests(repoRoot, files, jsonReportPath) {
  const proc = spawnProviderProcess({
    binary: "npx",
    args: [
      "playwright",
      "test",
      ...files,
      ...jsonReportPath !== undefined ? ["--reporter=line,json"] : []
    ],
    repoRoot,
    cwd: ".",
    env: {
      set: jsonReportPath !== undefined ? { PLAYWRIGHT_JSON_OUTPUT_NAME: jsonReportPath } : {},
      unset: []
    }
  });
  const [stdoutText, stderrText] = await Promise.all([
    new Response(proc.stdout).text(),
    new Response(proc.stderr).text()
  ]);
  const completion = await proc.completion;
  return { exit_code: completion.exit_code, output: `${stdoutText}${stderrText}` };
}
var OUTPUT_TAIL_LINES = 40;
function outputTail(output) {
  const lines = output.split(`
`).filter((l2) => l2.trim() !== "");
  return lines.slice(-OUTPUT_TAIL_LINES);
}
function passedCount(output) {
  const m2 = output.match(/(\d+)\s+passed/);
  return m2 ? Number(m2[1]) : 0;
}
async function anyFallbackUnverified(repoRoot, files) {
  for (const file of files) {
    try {
      if (isFallbackUnverified(await readFile7(join32(repoRoot, file), "utf8")))
        return true;
    } catch {}
  }
  return false;
}
async function verifyGenerated(repoRoot, runId2, files, options = {}) {
  const runner = options.runner ?? runPlaywrightTests;
  const runDir = localDir(repoRoot, "runs", runId2);
  await mkdir5(runDir, { recursive: true });
  const outcome = await withBrowserGuard(repoRoot, () => runner(repoRoot, files, join32(runDir, "playwright-report.json")), options.probe ? { probe: options.probe } : {});
  const verified_at = new Date().toISOString();
  let record;
  if (outcome.result === "blocked") {
    record = {
      run_id: runId2,
      files,
      result: "blocked",
      reason: outcome.reason,
      exit_code: null,
      output_tail: [],
      verified_at
    };
  } else {
    const exitCode = outcome.value.exit_code;
    const output = outcome.value.output;
    let result2;
    let reason;
    if (exitCode !== 0) {
      result2 = "fail";
      reason = `npx playwright test exited ${exitCode ?? "null"}`;
    } else if (await anyFallbackUnverified(repoRoot, files)) {
      result2 = "blocked";
      reason = "spec is an @ditto-unverified fallback (scaffolded without a live browser) \u2014 inherently unverified, not a pass";
    } else if (passedCount(output) === 0) {
      result2 = "blocked";
      reason = `runner exited 0 but all tests skipped \u2014 no behavior verified (${outputTail(output).slice(-1)[0] ?? "no summary"})`;
    } else {
      result2 = "pass";
      reason = `npx playwright test exited ${exitCode ?? "null"}`;
    }
    record = {
      run_id: runId2,
      files,
      result: result2,
      reason,
      exit_code: exitCode,
      output_tail: outputTail(output),
      verified_at
    };
  }
  await atomicWriteText(join32(runDir, "generated-verify.json"), `${JSON.stringify(record, null, 2)}
`);
  return record;
}

// src/core/e2e/regression-select.ts
init_shared();
import { readFile as readFile8, readdir as readdir15, stat as stat5 } from "fs/promises";
import { join as join33, relative as relative10, resolve as resolve7, sep as sep6 } from "path";
var COMPONENT_PREFIX = "component:";
function matchesComponentPattern(pattern, path) {
  if (!pattern.includes("*")) {
    return path === pattern || path.startsWith(pattern.endsWith("/") ? pattern : `${pattern}/`);
  }
  return globToRegExp2(pattern).test(path);
}
function globToRegExp2(pattern) {
  let out = "^";
  let i2 = 0;
  while (i2 < pattern.length) {
    if (pattern.startsWith("**/", i2)) {
      out += "(?:.*/)?";
      i2 += 3;
      continue;
    }
    if (pattern.startsWith("**", i2)) {
      out += ".*";
      i2 += 2;
      continue;
    }
    const ch = pattern[i2];
    out += ch === "*" ? "[^/]*" : ch.replace(/[.+?^${}()|[\]\\]/, "\\$&");
    i2 += 1;
  }
  return new RegExp(`${out}$`);
}
var toPosix = (p) => p.split(sep6).join("/");
var V1_VERSION_MISMATCH_REASON = "DSL v1 no longer supported \u2014 re-author as v2 (clean break, no auto-migration)";
function invalidJourneyReason(text, parseError) {
  const split = splitFrontMatter(text);
  if (split) {
    try {
      const raw = parseYaml(split.frontMatter);
      if (raw !== null && typeof raw === "object" && "ditto_journey" in raw && raw.ditto_journey !== "v2") {
        return V1_VERSION_MISMATCH_REASON;
      }
    } catch {}
  }
  return parseError;
}
async function fileExists2(path) {
  try {
    return (await stat5(path)).isFile();
  } catch {
    return false;
  }
}
async function loadJourneyEntries(journeysDir) {
  const journeysAbs = resolve7(journeysDir);
  const repoRoot = resolve7(journeysAbs, "..", "..");
  const generatedDir = resolve7(journeysAbs, "..", "generated");
  let names;
  try {
    names = (await readdir15(journeysAbs)).filter((n2) => n2.endsWith(".journey.md")).sort();
  } catch {
    return { entries: [], invalid: [] };
  }
  const entries = [];
  const invalid = [];
  for (const name of names) {
    const fileAbs = join33(journeysAbs, name);
    const fileRel = toPosix(relative10(repoRoot, fileAbs));
    const text = await readFile8(fileAbs, "utf8");
    const parsed = parseJourneyDoc(text);
    if (!parsed.ok) {
      invalid.push({ file: fileRel, error: invalidJourneyReason(text, parsed.error) });
      continue;
    }
    const slug = name.slice(0, -".journey.md".length);
    const specAbs = join33(generatedDir, `${slug}.spec.ts`);
    entries.push({
      id: parsed.frontMatter.id,
      name: parsed.frontMatter.name,
      description: parsed.frontMatter.description,
      surfaces: parsed.frontMatter.surfaces,
      uses_blocks: parsed.frontMatter.uses_blocks,
      journey_file: fileRel,
      generated_spec: toPosix(relative10(repoRoot, specAbs)),
      missing_generated: !await fileExists2(specAbs)
    });
  }
  return { entries, invalid };
}
var normalizePath2 = (p) => toPosix(p).replace(/^\.\//, "");
async function selectImpactedJourneys(journeysDir, changedPaths) {
  const { entries, invalid } = await loadJourneyEntries(journeysDir);
  const normalized = changedPaths.map(normalizePath2);
  const matchedPaths = new Set;
  const journeys = [];
  for (const entry of entries) {
    const matched = [];
    for (const surface of entry.surfaces) {
      if (!surface.startsWith(COMPONENT_PREFIX))
        continue;
      const pattern = normalizePath2(surface.slice(COMPONENT_PREFIX.length));
      const hits = normalized.filter((p) => matchesComponentPattern(pattern, p));
      if (hits.length === 0)
        continue;
      matched.push(surface);
      for (const hit of hits)
        matchedPaths.add(hit);
    }
    if (matched.length > 0)
      journeys.push({ ...entry, matched_surfaces: matched });
  }
  return {
    journeys,
    unmatched_changed_paths: normalized.filter((p) => !matchedPaths.has(p)),
    invalid_journeys: invalid
  };
}

// src/core/e2e/regression-gate.ts
function regressionGatePath(repoRoot, workItemId2) {
  return join34(localDir(repoRoot, "work-items", workItemId2), "regression-gate.json");
}
async function mapRunFailures(repoRoot, runId2, selected) {
  const reportFile = Bun.file(join34(localDir(repoRoot, "runs", runId2), "playwright-report.json"));
  if (!await reportFile.exists())
    return [];
  let reporter;
  try {
    reporter = JSON.parse(await reportFile.text());
  } catch {
    return [];
  }
  const failures = await buildFailureReport(reporter, {
    repoRoot,
    readSpec: async (specFile) => {
      try {
        return await readFile9(resolve8(repoRoot, specFile), "utf8");
      } catch {
        return null;
      }
    }
  });
  const knownIds = new Set(selected.map((j) => j.id));
  const bySpecFile = new Map(selected.map((j) => [j.generated_spec, j.id]));
  return failures.map((f3) => ({
    journey_id: knownIds.has(f3.journey_id) ? f3.journey_id : bySpecFile.get(f3.spec_file) ?? "(unmapped)",
    case: f3.case_name === "" ? "(unmapped)" : f3.case_name
  }));
}
async function runRegressionGate(repoRoot, input, options = {}) {
  const journeysDir = join34(repoRoot, "e2e", "journeys");
  const selection = await selectImpactedJourneys(journeysDir, input.changedPaths);
  let selected;
  if (input.journeyIds !== undefined) {
    const { entries } = await loadJourneyEntries(journeysDir);
    selected = input.journeyIds.map((id) => {
      const auto = selection.journeys.find((j) => j.id === id);
      if (auto)
        return auto;
      const entry = entries.find((e2) => e2.id === id);
      if (!entry)
        throw new Error(`unknown journey id: ${id} \u2014 e2e/journeys\uC5D0 \uD574\uB2F9 \uC5EC\uC815\uC774 \uC5C6\uB2E4`);
      return { ...entry, matched_surfaces: [] };
    });
  } else {
    selected = selection.journeys;
  }
  const missing = selected.filter((j) => j.missing_generated);
  const runnable = selected.filter((j) => !j.missing_generated);
  const journeyResults = missing.map((j) => ({ journey_id: j.id, result: "not_run" }));
  let result2;
  let reason;
  let failures = [];
  if (selected.length === 0) {
    result2 = "pass";
    reason = "\uC601\uD5A5\uBC1B\uB294 \uC5EC\uC815 \uC5C6\uC74C \u2014 \uBCC0\uACBD \uACBD\uB85C\uC640 \uAD50\uCC28\uD558\uB294 component: \uD45C\uBA74\uC774 \uC5C6\uB2E4";
  } else if (runnable.length === 0) {
    result2 = "fail";
    reason = "\uCD94\uB824\uC9C4 \uC5EC\uC815 \uC804\uBD80 generated spec \uBD80\uC7AC \u2014 \uBAA9\uB85D\uC5D0 \uC788\uC5C8\uB294\uB370 \uC2E4\uD589 \uC548 \uB428\uC740 pass\uAC00 \uC544\uB2C8\uB2E4";
  } else {
    const verify = await verifyGenerated(repoRoot, input.runId, runnable.map((j) => j.generated_spec), options);
    if (verify.result === "blocked") {
      result2 = "blocked";
      reason = verify.reason;
      for (const j of runnable)
        journeyResults.push({ journey_id: j.id, result: "blocked" });
    } else if (verify.result === "pass") {
      for (const j of runnable)
        journeyResults.push({ journey_id: j.id, result: "pass" });
      if (missing.length > 0) {
        result2 = "fail";
        reason = `\uC2E4\uD589\uB41C \uC5EC\uC815\uC740 \uD1B5\uACFC\uD588\uC9C0\uB9CC ${missing.length}\uAC1C \uC5EC\uC815\uC758 generated spec\uC774 \uC5C6\uB2E4 \u2014 \uCD94\uB824\uC9C4 \uBAA9\uB85D \uC548\uC5D0\uC11C \uBBF8\uC2E4\uD589\uC740 \uC2E4\uD328\uB2E4`;
      } else {
        result2 = "pass";
        reason = verify.reason;
      }
    } else {
      result2 = "fail";
      reason = verify.reason;
      failures = await mapRunFailures(repoRoot, input.runId, runnable);
      const failing = new Set(failures.map((f3) => f3.journey_id));
      const unlocalized = failures.length === 0 || failing.has("(unmapped)");
      for (const j of runnable) {
        const failed = unlocalized || failing.has(j.id);
        journeyResults.push({ journey_id: j.id, result: failed ? "fail" : "pass" });
      }
    }
  }
  if (selection.invalid_journeys.length > 0 && result2 === "pass") {
    result2 = "fail";
    reason = `${selection.invalid_journeys.length}\uAC1C journey\uAC00 front-matter \uD30C\uC2F1 \uBD88\uAC00 \u2014 \uC601\uD5A5 \uCD94\uB9BC\uC5D0\uC11C \uBE60\uC84C\uC744 \uC218 \uC788\uC5B4 pass\uB85C \uB2EB\uC744 \uC218 \uC5C6\uB2E4 (${selection.invalid_journeys.map((i2) => i2.file).join(", ")})`;
  }
  const record = await writeJson(regressionGatePath(repoRoot, input.workItemId), regressionGateRecord, {
    work_item: input.workItemId,
    run_id: input.runId,
    changed_paths: input.changedPaths,
    selected: selected.map((j) => ({
      id: j.id,
      name: j.name,
      description: j.description,
      journey_file: j.journey_file,
      generated_spec: j.generated_spec,
      matched_surfaces: j.matched_surfaces,
      missing_generated: j.missing_generated
    })),
    auto_selected: selection.journeys.map((j) => j.id),
    journey_results: journeyResults,
    invalid_journeys: selection.invalid_journeys,
    result: result2,
    failures,
    reason,
    recorded_at: new Date().toISOString()
  });
  return { record, selection };
}

// src/core/e2e/applicability.ts
import { existsSync as existsSync5, readFileSync as readFileSync2 } from "fs";
import { join as join35 } from "path";
var WEB_FRAMEWORKS = [
  "react",
  "react-dom",
  "vue",
  "svelte",
  "@sveltejs/kit",
  "@angular/core",
  "preact",
  "solid-js",
  "next",
  "nuxt",
  "remix",
  "@remix-run/react",
  "astro",
  "gatsby"
];
function evaluateAxis3Applicability(signals) {
  const hasWeb = signals.web_framework !== null || signals.ui_file_count > 0;
  if (hasWeb) {
    const parts = [];
    if (signals.web_framework)
      parts.push(`framework: ${signals.web_framework}`);
    if (signals.ui_file_count > 0)
      parts.push(`${signals.ui_file_count} UI/markup file(s)`);
    return {
      applicable: true,
      reason: `web UI present (${parts.join(", ")})`,
      covered_by: [],
      signals
    };
  }
  return {
    applicable: false,
    reason: "no web UI detected (no browser-framework dependency, no UI/markup files)",
    covered_by: ["axis-2 (reviewer / code-level verification)", "axis-1 (intent alignment)"],
    signals
  };
}
function dependencyNames(pkg) {
  if (!pkg)
    return new Set;
  const names = new Set;
  for (const key of ["dependencies", "devDependencies", "peerDependencies"]) {
    const section = pkg[key];
    if (section && typeof section === "object") {
      for (const name of Object.keys(section))
        names.add(name);
    }
  }
  return names;
}
var UI_EXTENSIONS = [".tsx", ".jsx", ".vue", ".svelte", ".html"];
function defaultReadPackageJson(repoRoot) {
  return () => {
    const path = join35(repoRoot, "package.json");
    if (!existsSync5(path))
      return null;
    try {
      const parsed = JSON.parse(readFileSync2(path, "utf8"));
      return parsed && typeof parsed === "object" ? parsed : null;
    } catch {
      return null;
    }
  };
}
function defaultCountUiFiles(repoRoot) {
  return () => {
    const srcDir = join35(repoRoot, "src");
    if (!existsSync5(srcDir))
      return 0;
    const glob = new Bun.Glob(`**/*{${UI_EXTENSIONS.join(",")}}`);
    let count = 0;
    for (const _3 of glob.scanSync({ cwd: srcDir, onlyFiles: true })) {
      count++;
      if (count >= 50)
        break;
    }
    return count;
  };
}
function defaultApplicabilityDeps(repoRoot) {
  return {
    repoRoot,
    readPackageJson: defaultReadPackageJson(repoRoot),
    countUiFiles: defaultCountUiFiles(repoRoot)
  };
}
function detectWebUiSignals(deps) {
  const names = dependencyNames(deps.readPackageJson());
  const web_framework = WEB_FRAMEWORKS.find((f3) => names.has(f3)) ?? null;
  return { web_framework, ui_file_count: deps.countUiFiles() };
}
function evaluateAxis3FromRepo(deps) {
  return evaluateAxis3Applicability(detectWebUiSignals(deps));
}

// src/core/e2e/web-surface.ts
var CODE_EXTENSIONS2 = [
  ".ts",
  ".js",
  ".mts",
  ".cts",
  ".mjs",
  ".cjs",
  ".py",
  ".go",
  ".rb",
  ".java",
  ".kt",
  ".rs",
  ".php",
  ".cs"
];
var API_SEGMENTS = new Set(["api", "apis", "routes", "controllers", "endpoints"]);
var API_BASENAME = /(^|[-._])(server|handler|controller)$/;
function extensionOf(path) {
  const base = path.slice(path.lastIndexOf("/") + 1);
  const dot = base.lastIndexOf(".");
  return dot <= 0 ? "" : base.slice(dot).toLowerCase();
}
function isFrontendPath(path) {
  return UI_EXTENSIONS.includes(extensionOf(path));
}
function isApiPath(path) {
  if (!CODE_EXTENSIONS2.includes(extensionOf(path)))
    return false;
  const segments = path.toLowerCase().split("/");
  const dirs = segments.slice(0, -1);
  if (dirs.some((s2) => API_SEGMENTS.has(s2)))
    return true;
  const base = segments.at(-1) ?? "";
  const stem = base.slice(0, base.indexOf(".") === -1 ? base.length : base.lastIndexOf("."));
  return API_BASENAME.test(stem);
}
function detectWebSurfaceChange(changedPaths) {
  const surfaces = [];
  for (const path of changedPaths) {
    if (isFrontendPath(path)) {
      surfaces.push({ kind: "frontend", path });
    } else if (isApiPath(path)) {
      surfaces.push({ kind: "api", path });
    }
  }
  return { web: surfaces.length > 0, surfaces };
}

// src/core/e2e/completion-gate.ts
async function checkE2eCompletionGate(repoRoot, input) {
  const violations = [];
  const detection = detectWebSurfaceChange(input.changedFiles);
  if (detection.web) {
    const decided = input.decisions.some((d2) => d2.decision === "e2e_accept" || d2.decision === "e2e_decline");
    if (!decided) {
      violations.push({
        code: "proposal_missing",
        message: `\uC6F9 \uD45C\uBA74 \uBCC0\uACBD(${detection.surfaces.length} surface)\uC774 \uC788\uB294\uB370 E2E \uC81C\uC548 \uACB0\uC815 \uB808\uCF54\uB4DC(e2e_accept|e2e_decline)\uAC00 \uC5C6\uB2E4 \u2014 ` + `\`ditto autopilot propose-e2e --workItem ${input.workItemId} --changedFiles <csv>\`\uB85C \uC0AC\uC6A9\uC790\uC5D0\uAC8C \uC81C\uC548\uD558\uACE0 \uACB0\uC815\uC744 \uAE30\uB85D\uD558\uB77C (ac-6)`
      });
    }
  }
  const selection = await selectImpactedJourneys(join36(repoRoot, "e2e", "journeys"), input.changedFiles);
  const impacted = selection.journeys.length > 0 || selection.invalid_journeys.length > 0;
  if (!impacted)
    return violations;
  const recordFile = Bun.file(regressionGatePath(repoRoot, input.workItemId));
  const demand = `\`ditto e2e regression --work-item ${input.workItemId} --changed-files <csv>\`\uB97C \uC2E4\uD589\uD574 \uAE30\uB85D\uC744 \uB0A8\uACA8\uB77C (ac-7)`;
  if (!await recordFile.exists()) {
    violations.push({
      code: "regression_missing",
      message: `\uBCC0\uACBD\uACFC \uAD50\uCC28\uD558\uB294 \uC5EC\uC815\uC774 \uC788\uB294\uB370 regression-gate \uAE30\uB85D\uC774 \uC5C6\uB2E4 \u2014 ${demand}`
    });
    return violations;
  }
  let parsed;
  try {
    parsed = regressionGateRecord.safeParse(JSON.parse(await recordFile.text()));
  } catch {
    parsed = { success: false };
  }
  if (!parsed.success) {
    violations.push({
      code: "regression_missing",
      message: `regression-gate \uAE30\uB85D\uC774 \uC190\uC0C1\uB418\uC5B4 \uD310\uB3C5 \uBD88\uAC00 \u2014 ${demand}`
    });
    return violations;
  }
  const covered = new Set(parsed.data.changed_paths);
  const missing = input.changedFiles.filter((p) => !covered.has(p));
  if (missing.length > 0) {
    violations.push({
      code: "regression_missing",
      message: `regression-gate \uAE30\uB85D\uC774 \uD604\uC7AC changed_files\uB97C \uCEE4\uBC84\uD558\uC9C0 \uC54A\uB294\uB2E4(\uBBF8\uCEE4\uBC84 ${missing.length}\uAC74: ${missing.slice(0, 3).join(", ")}\u2026) \u2014 \uCD5C\uC2E0 diff\uB85C ${demand}`
    });
    return violations;
  }
  if (parsed.data.result !== "pass") {
    violations.push({
      code: "regression_non_pass",
      message: `regression-gate \uAE30\uB85D\uC774 ${parsed.data.result} \u2014 \uC2E4\uD328\uC758 \uCC98\uB9AC(\uAE30\uB2A5/\uC2A4\uD06C\uB9BD\uD2B8/\uD658\uACBD/flaky \uD310\uC815)\uB97C \uB2EB\uAE30 \uC804\uC5D0\uB294 \uC644\uB8CC\uD560 \uC218 \uC5C6\uB2E4: ${parsed.data.reason}`
    });
  }
  return violations;
}

