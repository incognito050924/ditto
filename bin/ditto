// src/core/handoff-store.ts
init_ditto_paths();
init_fs();
function buildHandoff(input) {
  return handoff.parse({
    schema_version: "0.1.0",
    work_item_id: input.workItem.id,
    ...input.autopilotId ? { autopilot_id: input.autopilotId } : {},
    from_context: input.fromContext,
    ...input.toOwner ? { to_owner: input.toOwner } : {},
    original_intent: input.workItem.source_request,
    current_state: input.currentState,
    decisions_made: input.decisionsMade ?? [],
    changed_files: input.changedFiles ?? input.workItem.changed_files,
    evidence_refs: input.evidenceRefs ?? [],
    failed_or_unverified: input.failedOrUnverified ?? [],
    open_threads: input.openThreads ?? [],
    next_first_check: input.nextFirstCheck,
    forbidden_scope_creep: input.forbiddenScopeCreep ?? [],
    artifact_available: input.artifactAvailable ?? true,
    created_at: (input.now ?? new Date).toISOString()
  });
}
function renderHandoff(h2) {
  const lines = [];
  lines.push(`# Handoff: ${h2.work_item_id}`);
  if (h2.autopilot_id)
    lines.push(`autopilot: ${h2.autopilot_id}`);
  lines.push("", `from: ${h2.from_context}`, "");
  lines.push("## \uC6D0\uB798 \uC758\uB3C4");
  lines.push(h2.original_intent, "");
  lines.push("## \uD604\uC7AC \uC0C1\uD0DC");
  lines.push(h2.current_state, "");
  if (h2.decisions_made.length > 0) {
    lines.push("## \uB0B4\uB824\uC9C4 \uACB0\uC815");
    for (const d2 of h2.decisions_made)
      lines.push(`- ${d2}`);
    lines.push("");
  }
  if (h2.changed_files.length > 0) {
    lines.push("## \uBCC0\uACBD \uD30C\uC77C");
    for (const f3 of h2.changed_files)
      lines.push(`- ${f3}`);
    lines.push("");
  }
  if (h2.evidence_refs.length > 0) {
    lines.push("## \uC99D\uAC70 (inline)");
    for (const e2 of h2.evidence_refs)
      lines.push(`- ${JSON.stringify(e2)}`);
    lines.push("");
  }
  if (h2.failed_or_unverified.length > 0) {
    lines.push("## \uC2E4\uD328 / \uBBF8\uAC80\uC99D");
    for (const u3 of h2.failed_or_unverified)
      lines.push(`- ${u3}`);
    lines.push("");
  }
  if (h2.open_threads.length > 0) {
    lines.push("## \uC5F4\uB9B0 \uC2A4\uB808\uB4DC");
    for (const t2 of h2.open_threads)
      lines.push(`- ${t2}`);
    lines.push("");
  }
  lines.push("## \uB2E4\uC74C agent \uAC00 \uAC00\uC7A5 \uBA3C\uC800 \uBCFC \uAC83");
  lines.push(h2.next_first_check, "");
  if (h2.forbidden_scope_creep.length > 0) {
    lines.push("## \uAE08\uC9C0: scope creep");
    for (const s2 of h2.forbidden_scope_creep)
      lines.push(`- ${s2}`);
    lines.push("");
  }
  if (!h2.artifact_available) {
    lines.push("\u26A0 raw artifacts \uAC00 \uC774 \uD074\uB860/\uC138\uC158\uC5D0 \uC5C6\uB2E4 \u2014 \uC778\uB77C\uC778 \uC694\uC57D\uB9CC \uC2E0\uB8B0\uD560 \uAC83.", "");
  }
  return lines.join(`
`).trimEnd();
}
function serialize(h2) {
  return `---
${JSON.stringify(h2)}
---

${renderHandoff(h2)}
`;
}
function parseHandoffFile(text) {
  if (!text.startsWith(`---
`)) {
    throw new Error("handoff file: missing leading frontmatter fence");
  }
  const rest = text.slice(4);
  const end = rest.indexOf(`
---`);
  if (end === -1)
    throw new Error("handoff file: unterminated frontmatter");
  const handoff2 = handoff.parse(JSON.parse(rest.slice(0, end)));
  const body = rest.slice(end + 4).replace(/^\n+/, "");
  return { handoff: handoff2, body };
}
function stamp(now) {
  return now.toISOString().replace(/[:.]/g, "-");
}

class HandoffStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  dir() {
    return localDir(this.repoRoot, "handoff");
  }
  activePath(workItemId2) {
    return join59(this.dir(), `${workItemId2}.md`);
  }
  activeRel(workItemId2) {
    return `.ditto/local/handoff/${workItemId2}.md`;
  }
  archiveRel(workItemId2, ts) {
    return `.ditto/local/handoff/archive/${workItemId2}__${ts}.md`;
  }
  async link(workItemId2, rel) {
    const items = new WorkItemStore(this.repoRoot);
    if (await items.exists(workItemId2)) {
      await items.update(workItemId2, (current) => ({ ...current, handoff_path: rel }));
    }
  }
  async write(h2) {
    await atomicWriteText(this.activePath(h2.work_item_id), serialize(h2));
    const rel = this.activeRel(h2.work_item_id);
    await this.link(h2.work_item_id, rel);
    return rel;
  }
  async writeArchived(h2, now = new Date) {
    const rel = this.archiveRel(h2.work_item_id, stamp(now));
    await atomicWriteText(join59(this.repoRoot, rel), serialize(h2));
    await this.link(h2.work_item_id, rel);
    return rel;
  }
  async listActive() {
    let names;
    try {
      names = await readdir16(this.dir());
    } catch {
      return [];
    }
    const out = [];
    for (const name of names) {
      if (!name.endsWith(".md"))
        continue;
      const path = join59(this.dir(), name);
      try {
        const { handoff: handoff2, body } = parseHandoffFile(await Bun.file(path).text());
        out.push({ handoff: handoff2, body, path });
      } catch {}
    }
    return out.sort((a2, b2) => a2.handoff.created_at.localeCompare(b2.handoff.created_at));
  }
  async consume(now = new Date) {
    const active = await this.listActive();
    if (active.length === 0)
      return [];
    await ensureDir(join59(this.dir(), "archive"));
    for (const a2 of active) {
      const dest = join59(this.repoRoot, this.archiveRel(a2.handoff.work_item_id, stamp(now)));
      try {
        await rename4(a2.path, dest);
      } catch {}
    }
    return active;
  }
  async exists(workItemId2) {
    return Bun.file(this.activePath(workItemId2)).exists();
  }
  async get(workItemId2) {
    return parseHandoffFile(await Bun.file(this.activePath(workItemId2)).text()).handoff;
  }
}

// src/core/intent-quality-doctor.ts
function defaultIntentQualityDeps(repoRoot) {
  const workItems = new WorkItemStore(repoRoot);
  const interviews = new InterviewStore(repoRoot);
  const autopilots = new AutopilotStore(repoRoot);
  const handoffs = new HandoffStore(repoRoot);
  return {
    listWorkItems: () => workItems.list(),
    readInterview: async (id) => await interviews.exists(id) ? interviews.get(id) : null,
    readAutopilot: async (id) => await autopilots.exists(id) ? autopilots.get(id) : null,
    readDecisions: (id) => autopilots.readDecisions(id),
    countHandoffRounds: async (id) => (await handoffs.listActive()).filter((h2) => h2.handoff.work_item_id === id).length,
    readMetrics: (id) => workItems.readMetrics(id),
    readTechSpecRounds: (id) => workItems.readTechSpecRounds(id)
  };
}
function buildRow2(summary, interview, graph, decisions, handoffRounds, driftEvents, rounds) {
  const fixNodes = graph ? graph.nodes.filter((n2) => n2.kind === "fix") : [];
  const reworkAttempts = graph ? graph.nodes.reduce((sum, n2) => sum + (n2.attempts?.fix ?? 0), 0) : 0;
  const retrySwitch = decisions.filter((d2) => d2.decision === "retry" || d2.decision === "switch_approach").length;
  const selectedScores = rounds.flatMap((r3) => r3.selected.map((q2) => q2.scores.answer_value));
  return {
    work_item_id: summary.id,
    title: summary.title,
    status: summary.status,
    questions_asked: interview ? interview.exit.questions_asked : null,
    closure_mode: interview ? interview.exit.closure_mode : null,
    readiness_score: interview ? interview.readiness.score : null,
    readiness_gate: interview ? interview.readiness.gate : null,
    assumptions: interview ? interview.assumptions.length : 0,
    fix_nodes: fixNodes.length,
    rework_attempts: reworkAttempts,
    retry_switch_decisions: retrySwitch,
    handoff_rounds: handoffRounds,
    drift_events: driftEvents,
    post_cost: driftEvents + reworkAttempts + retrySwitch + handoffRounds,
    tech_spec_rounds: rounds.length,
    tech_spec_selected: selectedScores.length,
    tech_spec_dry_rounds: rounds.filter((r3) => r3.dry).length,
    tech_spec_mean_answer_value: selectedScores.length === 0 ? null : mean(selectedScores)
  };
}
function totalsOf2(rows) {
  return {
    work_items: rows.length,
    with_interview: rows.filter((r3) => r3.questions_asked !== null).length,
    total_questions: rows.reduce((s2, r3) => s2 + (r3.questions_asked ?? 0), 0),
    total_fix_nodes: rows.reduce((s2, r3) => s2 + r3.fix_nodes, 0),
    total_rework_attempts: rows.reduce((s2, r3) => s2 + r3.rework_attempts, 0),
    total_retry_switch_decisions: rows.reduce((s2, r3) => s2 + r3.retry_switch_decisions, 0),
    total_handoff_rounds: rows.reduce((s2, r3) => s2 + r3.handoff_rounds, 0),
    total_drift_events: rows.reduce((s2, r3) => s2 + r3.drift_events, 0),
    total_tech_spec_rounds: rows.reduce((s2, r3) => s2 + r3.tech_spec_rounds, 0)
  };
}
var QUANTILES = ["low", "mid", "high"];
function mean(xs) {
  return xs.length === 0 ? 0 : xs.reduce((s2, x2) => s2 + x2, 0) / xs.length;
}
function correlationOf(rows) {
  const interviewed = rows.filter((r3) => r3.questions_asked !== null).sort((a2, b2) => a2.questions_asked - b2.questions_asked);
  const n2 = interviewed.length;
  return QUANTILES.map((quantile, b2) => {
    const slice = n2 === 0 ? [] : interviewed.filter((_3, idx) => Math.min(2, Math.floor(idx * 3 / n2)) === b2);
    const questions = slice.map((r3) => r3.questions_asked);
    return {
      quantile,
      work_items: slice.length,
      questions_range: questions.length === 0 ? null : [Math.min(...questions), Math.max(...questions)],
      avg_questions: mean(questions),
      avg_post_cost: mean(slice.map((r3) => r3.post_cost))
    };
  });
}
async function collectIntentQualityReport(deps) {
  const summaries = await deps.listWorkItems();
  const rows = [];
  for (const summary of summaries) {
    const [interview, graph, decisions, handoffRounds, metrics, rounds] = await Promise.all([
      deps.readInterview(summary.id),
      deps.readAutopilot(summary.id),
      deps.readDecisions(summary.id),
      deps.countHandoffRounds(summary.id),
      deps.readMetrics(summary.id),
      deps.readTechSpecRounds(summary.id)
    ]);
    rows.push(buildRow2(summary, interview, graph, decisions, handoffRounds, metrics.length, rounds));
  }
  return { rows, totals: totalsOf2(rows), correlation: correlationOf(rows) };
}

// src/core/mcp-inventory.ts
async function collectMcpInventory(adapters, repoRoot) {
  const inventories = await Promise.all(adapters.map((adapter) => adapter.loadMcpServers(repoRoot)));
  const servers = inventories.flatMap((inv) => inv.servers);
  const unavailable = inventories.flatMap((inv) => inv.unavailable);
  const status = servers.length > 0 ? "ok" : "unverified";
  return {
    status,
    servers,
    unavailable,
    ...status === "unverified" ? {
      unavailable_reason: unavailable.map((item) => `${item.source_file}: ${item.reason}`).join("; ")
    } : {}
  };
}

// src/core/permission-inventory.ts
init_shared();
var WILDCARD_ALLOW = new Set(["*", "Bash", "Bash(*)", "WebFetch(*)"]);
var DESTRUCTIVE_ALLOW_PATTERNS = [
  /^Write\(/,
  /^Bash\(rm\b/,
  /^Bash\(sudo\b/
];
function classifyAllowEntry(entry) {
  if (WILDCARD_ALLOW.has(entry))
    return ["dangerous_mode", "approval_bypass"];
  if (DESTRUCTIVE_ALLOW_PATTERNS.some((re) => re.test(entry)))
    return ["write_outside_workspace"];
  return [];
}
function findingsFromPermissionInventory(inv) {
  if (inv.status === "missing") {
    return [
      {
        host: inv.host,
        source_file: inv.source_file,
        label: "missing",
        message: inv.unavailable_reason ?? "permission config not found"
      }
    ];
  }
  if (inv.status === "unverified") {
    return [
      {
        host: inv.host,
        source_file: inv.source_file,
        label: "unverified",
        message: inv.unavailable_reason ?? "permission config could not be verified"
      }
    ];
  }
  const findings = [];
  if (inv.host === "codex") {
    if (inv.raw.sandbox_mode === "danger-full-access") {
      findings.push({
        host: inv.host,
        source_file: inv.source_file,
        label: "dangerous_mode",
        message: "codex sandbox_mode=danger-full-access"
      });
      findings.push({
        host: inv.host,
        source_file: inv.source_file,
        label: "write_outside_workspace",
        message: "codex danger-full-access can write outside the workspace"
      });
    }
    if (inv.raw.network_access === true) {
      findings.push({
        host: inv.host,
        source_file: inv.source_file,
        label: "network_on",
        message: "codex network_access=true"
      });
    }
    const sandboxWorkspaceWrite = asRecord(inv.raw.sandbox_workspace_write);
    if (sandboxWorkspaceWrite?.network_access === true) {
      findings.push({
        host: inv.host,
        source_file: inv.source_file,
        label: "network_on",
        message: "codex [sandbox_workspace_write].network_access=true"
      });
    }
    if (inv.raw.approval_policy === "never") {
      findings.push({
        host: inv.host,
        source_file: inv.source_file,
        label: "approval_bypass",
        message: "codex approval_policy=never"
      });
    }
  } else {
    if (inv.raw.defaultMode === "bypassPermissions") {
      findings.push({
        host: inv.host,
        source_file: inv.source_file,
        label: "dangerous_mode",
        message: "claude-code defaultMode=bypassPermissions"
      });
      findings.push({
        host: inv.host,
        source_file: inv.source_file,
        label: "approval_bypass",
        message: "claude-code bypasses permission prompts"
      });
    }
    const permissions = asRecord(inv.raw.permissions);
    const allowList = asStringArray(permissions?.allow);
    if (allowList) {
      const seen = new Set;
      for (const entry of allowList) {
        for (const label2 of classifyAllowEntry(entry)) {
          if (seen.has(label2))
            continue;
          seen.add(label2);
          findings.push({
            host: inv.host,
            source_file: inv.source_file,
            label: label2,
            message: label2 === "write_outside_workspace" ? `claude-code permissions.allow contains destructive pattern: ${entry}` : `claude-code permissions.allow contains wildcard entry: ${entry}`
          });
        }
      }
    }
  }
  return findings;
}
async function collectPermissionFindings(adapters, repoRoot) {
  const inventoryArrays = await Promise.all(adapters.map((adapter) => adapter.loadPermissions(repoRoot)));
  return inventoryArrays.flat().flatMap(findingsFromPermissionInventory);
}

// src/core/surface-inventory.ts
import { relative as relative13, resolve as resolve11 } from "path";

// src/schemas/surface-catalog.ts
init_zod();
init_common();
var surfaceCatalogEntry = exports_external.object({
  host: exports_external.enum(["codex", "claude-code"]),
  kind: exports_external.enum(["skill", "agent", "command", "plugin", "hook"]),
  id: exports_external.string().min(1),
  path: relativePath
});
var surfaceCatalog = exports_external.object({
  schema_version: schemaVersion,
  surfaces: exports_external.array(surfaceCatalogEntry)
});

// src/core/surface-inventory.ts
init_ditto_paths();
init_shared();
function catalogFileFor(host) {
  return host === "codex" ? "surfaces.codex.json" : "surfaces.json";
}
async function loadExpected(repoRoot, catalogFile = "surfaces.json") {
  const path = localDir(repoRoot, catalogFile);
  let raw;
  try {
    raw = await readJsonIfExists(path);
  } catch {
    throw new Error(`surface catalog is malformed JSON: ${path}`);
  }
  if (raw === null) {
    throw new Error(`surface catalog is missing: ${path}`);
  }
  const parsed = surfaceCatalog.safeParse(raw);
  if (!parsed.success) {
    throw new Error(`surface catalog failed schema validation: ${path}`);
  }
  if (parsed.data.surfaces.length === 0) {
    throw new Error(`surface catalog is present but declares no surfaces: ${path}`);
  }
  return parsed.data.surfaces;
}
function keyOf(surface) {
  return `${surface.host}:${surface.kind}:${surface.id}`;
}
async function generateSurfaceCatalog(adapters, repoRoot, catalogFile = "surfaces.json") {
  const inventories = await Promise.all(adapters.map((adapter) => adapter.loadSurfaceInventory(repoRoot)));
  const surfaces = inventories.flatMap((inv) => inv.localSurfaces).filter((s2) => catalogFileFor(s2.host) === catalogFile).map((s2) => ({
    host: s2.host,
    kind: s2.kind,
    id: s2.id,
    path: relative13(repoRoot, s2.path)
  })).sort((a2, b2) => keyOf(a2).localeCompare(keyOf(b2)) || a2.path.localeCompare(b2.path));
  return surfaceCatalog.parse({ schema_version: "0.1.0", surfaces });
}
async function collectSurfaceInventory(adapters, repoRoot) {
  const inventories = await Promise.all(adapters.map((adapter) => adapter.loadSurfaceInventory(repoRoot)));
  const localActual = inventories.flatMap((inv) => inv.localSurfaces);
  const homeActual = inventories.flatMap((inv) => inv.homeSurfaces);
  const allInventory = [...localActual, ...homeActual];
  const catalogFiles = [...new Set(adapters.map((a2) => catalogFileFor(a2.id)))];
  const expectedByFile = new Map;
  for (const file of catalogFiles) {
    expectedByFile.set(file, await loadExpected(repoRoot, file));
  }
  const expected = catalogFiles.flatMap((file) => expectedByFile.get(file) ?? []);
  if (expected.length === 0) {
    return { surfaces: allInventory, mismatch_count: 0, findings: [] };
  }
  const localByKey = new Map(localActual.map((surface) => [keyOf(surface), surface]));
  const expectedByKey = new Map(expected.map((surface) => [keyOf(surface), surface]));
  const findings = [];
  for (const exp of expected) {
    const actualSurface = localByKey.get(keyOf(exp));
    if (!actualSurface) {
      findings.push({
        host: exp.host,
        kind: exp.kind,
        id: exp.id,
        path: resolve11(repoRoot, exp.path),
        mismatch: "missing_file"
      });
      continue;
    }
    if (resolve11(actualSurface.path) !== resolve11(repoRoot, exp.path)) {
      findings.push({ ...actualSurface, mismatch: "renamed" });
    }
  }
  for (const surface of localActual) {
    if (!expectedByKey.has(keyOf(surface)))
      findings.push({ ...surface, mismatch: "extra_file" });
  }
  return {
    surfaces: allInventory,
    mismatch_count: findings.length,
    findings
  };
}

// src/cli/wizard/prompt.ts
async function confirm(io, message, defaultYes) {
  if (!io.isTTY)
    return defaultYes;
  const hint = defaultYes ? "[Y/n]" : "[y/N]";
  const ans = (await io.ask(`${message} ${hint} `)).trim().toLowerCase();
  if (ans === "")
    return defaultYes;
  return ans === "y" || ans === "yes";
}
async function select(io, message, options, defaultValue) {
  if (!io.isTTY || options.length === 0)
    return defaultValue;
  const defaultIdx = options.findIndex((o3) => o3.value === defaultValue);
  io.write(`${message}
`);
  options.forEach((o3, i2) => {
    const mark = o3.value === defaultValue ? "(\uAE30\uBCF8)" : "";
    io.write(`  ${i2 + 1}. ${o3.label} ${mark}
`);
  });
  const ans = (await io.ask(`\uBC88\uD638 (Enter=${defaultIdx + 1}): `)).trim();
  if (ans === "")
    return defaultValue;
  const n2 = Number.parseInt(ans, 10);
  if (Number.isInteger(n2) && n2 >= 1 && n2 <= options.length)
    return options[n2 - 1].value;
  return defaultValue;
}
async function multiSelect(io, message, choices) {
  const defaults = choices.filter((c3) => c3.checked).map((c3) => c3.value);
  if (!io.isTTY || choices.length === 0)
    return defaults;
  io.write(`${message}
`);
  choices.forEach((c3, i2) => io.write(`  ${i2 + 1}. [${c3.checked ? "x" : " "}] ${c3.label}
`));
  const ans = (await io.ask("\uC124\uCE58\uD560 \uBC88\uD638 (\uC27C\uD45C \uAD6C\uBD84, Enter=\uAE30\uBCF8\uAC12 \uC720\uC9C0): ")).trim();
  if (ans === "")
    return defaults;
  const picked = new Set(ans.split(",").map((s2) => Number.parseInt(s2.trim(), 10)).filter((n2) => Number.isInteger(n2) && n2 >= 1 && n2 <= choices.length));
  return choices.filter((_3, i2) => picked.has(i2 + 1)).map((c3) => c3.value);
}

// src/cli/wizard/prompt-io.ts
import { createInterface } from "readline/promises";
function createStdioPromptIO() {
  const rl = createInterface({ input: process.stdin, output: process.stdout });
  return {
    isTTY: Boolean(process.stdin.isTTY),
    ask: (query) => rl.question(query),
    write: (text) => {
      process.stdout.write(text);
    },
    close: () => {
      rl.close();
    }
  };
}

// src/cli/commands/doctor.ts
var DRIFT_EXIT2 = 1;
var DOCTOR_RUNTIME_ERROR_EXIT = 70;
function exitCodeForError(err) {
  return err instanceof InvalidHostError || err instanceof InvalidOutputFormatError ? USAGE_ERROR_EXIT : DOCTOR_RUNTIME_ERROR_EXIT;
}
function selectedAdapters(host) {
  const parsed = parseHostId(host);
  return parsed ? [getHostAdapter(parsed)] : listHostAdapters();
}
function selectedHostIds(host) {
  return selectedAdapters(host).map((adapter) => adapter.id).filter((id) => id === "codex" || id === "claude-code");
}
function exitForFindings(count, advisory) {
  if (count > 0 && advisory !== true)
    process.exit(DRIFT_EXIT2);
}
async function runFix(repoRoot, items) {
  const deps = defaultDoctorFixDeps(repoRoot, homedir7());
  const io = createStdioPromptIO();
  try {
    const result2 = await applyDoctorFixes({
      ...deps,
      confirmNonReversible: (item) => confirm(io, `Apply non-reversible repair? ${item.describe}`, false)
    }, items);
    if (result2.nothingToFix) {
      writeHuman("fix: nothing to fix");
      return;
    }
    for (const item of result2.applied)
      writeHuman(`fixed	${item.describe}`);
    for (const item of result2.skipped)
      writeHuman(`skipped (non-reversible, not confirmed)	${item.describe}`);
  } finally {
    io.close();
  }
}
function planAllowlistFixes(allowlisted2, repoRoot) {
  if (allowlisted2)
    return [];
  return [
    {
      kind: "allowlist",
      reversible: true,
      targetPath: join60(repoRoot, ".claude", "settings.json"),
      describe: "add Bash(ditto:*) to project .claude/settings.json allow"
    }
  ];
}
function parseCommon(args) {
  const format = parseOutputFormat(args.output);
  const adapters = selectedAdapters(args.host);
  return { format, adapters };
}
var instructionsCommand = defineCommand({
  meta: {
    name: "instructions",
    description: "Check AGENTS.md and host instruction projections for drift"
  },
  args: {
    host: { type: "string", required: false, description: "Host: codex|claude-code" },
    output: { type: "string", default: "human", description: "Output format: human|json" },
    advisory: { type: "boolean", default: false, description: "Report drift but exit 0" },
    fix: {
      type: "boolean",
      default: false,
      description: "Repair detected instruction drift by re-projecting the managed block"
    }
  },
  run: async ({ args }) => {
    try {
      const format = parseOutputFormat(args.output);
      const hosts = selectedHostIds(args.host);
      const repoRoot = await resolveRepoRootForCreate();
      const report = await checkInstructionsForHosts(hosts, repoRoot);
      if (args.fix === true) {
        await runFix(repoRoot, planInstructionFixes(report.findings, homedir7()));
        return;
      }
      if (format === "json") {
        writeJson2({
          status: report.findings.length === 0 ? "ok" : "drift",
          sourceSha256: report.sourceSha256,
          results: report.results,
          findings: report.findings
        });
      } else if (report.findings.length === 0) {
        writeHuman("instructions: ok");
      } else {
        for (const finding2 of report.findings) {
          writeHuman(`${finding2.host}	${finding2.kind}	${finding2.path}	${finding2.message}`);
        }
      }
      exitForFindings(report.findings.length, args.advisory);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(exitCodeForError(err));
    }
  }
});
var permissionsCommand = defineCommand({
  meta: {
    name: "permissions",
    description: "Check host permission settings for risky surfaces"
  },
  args: {
    host: { type: "string", required: false, description: "Host: codex|claude-code" },
    output: { type: "string", default: "human", description: "Output format: human|json" },
    advisory: { type: "boolean", default: false, description: "Report drift but exit 0" }
  },
  run: async ({ args }) => {
    try {
      const { format, adapters } = parseCommon(args);
      const repoRoot = await resolveRepoRootForCreate();
      const findings = await collectPermissionFindings(adapters, repoRoot);
      const dangerousCount = findings.filter((finding2) => finding2.label !== "missing" && finding2.label !== "unverified").length;
      if (format === "json") {
        writeJson2({
          status: dangerousCount === 0 ? "ok" : "drift",
          dangerous_count: dangerousCount,
          findings
        });
      } else if (findings.length === 0) {
        writeHuman("permissions: ok");
      } else {
        for (const finding2 of findings) {
