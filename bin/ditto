        }
        if (!args["work-item"]) {
          writeHuman(`
questions-quantile \xD7 avg post-cost (interviewed items):`);
          for (const b3 of report.correlation) {
            const range = b3.questions_range ? `${b3.questions_range[0]}\u2013${b3.questions_range[1]}q` : "-";
            writeHuman(`  ${b3.quantile}	${b3.work_items} items	${range}	avg_q=${b3.avg_questions.toFixed(1)}	avg_post_cost=${b3.avg_post_cost.toFixed(1)}`);
          }
        }
      }
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(exitCodeForError(err));
    }
  }
});
var completionCoverageCommand = defineCommand({
  meta: {
    name: "completion-coverage",
    description: "Aggregate completion-evidence coverage (evidence-closed acceptance / total acceptance) across work items + archive, from persisted completion.json (no new instrumentation)"
  },
  args: {
    "work-item": {
      type: "string",
      required: false,
      description: "Restrict to a single work item id"
    },
    output: { type: "string", default: "human", description: "Output format: human|json" }
  },
  run: async ({ args }) => {
    try {
      const format = parseOutputFormat(args.output);
      const repoRoot = await resolveRepoRootForCreate();
      const report = await collectCompletionCoverageReport(defaultCompletionCoverageDeps(repoRoot));
      const rows = args["work-item"] ? report.rows.filter((r4) => r4.work_item_id === args["work-item"]) : report.rows;
      if (format === "json") {
        writeJson2(args["work-item"] ? { rows } : report);
      } else if (rows.length === 0) {
        writeHuman("completion-coverage: no work items");
      } else {
        writeHuman("work_item\tstatus\tcompletion\tclosed/total\tcoverage");
        for (const r4 of rows) {
          writeHuman(`${r4.work_item_id}	${r4.status}	${r4.has_completion ? "yes" : "no"}	${r4.closed_acceptance}/${r4.total_acceptance}	${r4.coverage.toFixed(2)}`);
        }
        if (!args["work-item"]) {
          const t3 = report.totals;
          writeHuman(`
total	${t3.with_completion}/${t3.work_items} with completion	${t3.closed_acceptance}/${t3.total_acceptance} acceptance closed	coverage=${t3.coverage.toFixed(2)}`);
        }
      }
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(exitCodeForError(err));
    }
  }
});
var TERMINAL_STATUSES3 = new Set(["done", "abandoned"]);
var backlogCommand = defineCommand({
  meta: {
    name: "backlog",
    description: "Read-only backlog hygiene: stale drafts, completed-but-unclosed work items, and the open count. Definitions are structural (no wall-clock age \u2014 cross-PC clock skew would flap boundaries); reports only, never closes/archives anything."
  },
  args: {
    output: { type: "string", default: "human", description: "Output format: human|json" }
  },
  run: async ({ args }) => {
    try {
      const format = parseOutputFormat(args.output);
      const repoRoot = await resolveRepoRootForCreate();
      const deps = defaultCompletionCoverageDeps(repoRoot);
      const report = await collectCompletionCoverageReport(deps);
      const staleDrafts = report.rows.filter((r4) => r4.status === "draft" && !r4.has_completion).map((r4) => ({ work_item_id: r4.work_item_id, title: r4.title }));
      const openCount = report.rows.filter((r4) => !TERMINAL_STATUSES3.has(r4.status)).length;
      const completedUnclosed = [];
      for (const r4 of report.rows) {
        if (!r4.has_completion || TERMINAL_STATUSES3.has(r4.status))
          continue;
        const completion = await deps.readCompletion(r4.work_item_id);
        if (completion?.final_verdict === "pass") {
          completedUnclosed.push({
            work_item_id: r4.work_item_id,
            title: r4.title,
            status: r4.status
          });
        }
      }
      const findingCount = staleDrafts.length + completedUnclosed.length;
      const staleAction = (id) => `resume (ditto work set-criteria/deep-interview ${id}) or abandon (ditto work abandon ${id} --reason "<why>")`;
      const closedAction = (id) => `ditto work done ${id}`;
      if (format === "json") {
        writeJson2({
          status: findingCount === 0 ? "ok" : "hygiene",
          open_count: openCount,
          stale_drafts: staleDrafts.map((s2) => ({
            ...s2,
            suggested_action: staleAction(s2.work_item_id)
          })),
          completed_unclosed: completedUnclosed.map((c5) => ({
            ...c5,
            suggested_action: closedAction(c5.work_item_id)
          }))
        });
      } else {
        writeHuman(`open	${openCount} non-terminal work items`);
        if (findingCount === 0) {
          writeHuman("backlog: ok (no stale drafts, no completed-but-unclosed)");
        } else {
          for (const s2 of staleDrafts) {
            writeHuman(`stale_draft	${s2.work_item_id}	${s2.title}`);
            writeHuman(`  \u2192 ${staleAction(s2.work_item_id)}`);
          }
          for (const c5 of completedUnclosed) {
            writeHuman(`completed_unclosed	${c5.work_item_id}	${c5.status}	${c5.title}`);
            writeHuman(`  \u2192 ${closedAction(c5.work_item_id)}`);
          }
        }
      }
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(exitCodeForError(err));
    }
  }
});
