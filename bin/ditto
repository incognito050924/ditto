// src/core/worktree.ts
import { execFileSync as execFileSync2 } from "child_process";
import { realpathSync } from "fs";
import { mkdir, readFile, readdir as readdir3, rmdir, stat as stat3, unlink, writeFile } from "fs/promises";
import { join as join7, relative, sep as sep2 } from "path";
async function createWorktreeForRun(repoRoot, runId2) {
  const relativePath2 = `${RUN_WORKTREE_PREFIX}${runId2}`;
  const absolutePath = localDir(repoRoot, "worktrees", runId2);
  await ensureDir(localDir(repoRoot, "worktrees"));
  execFileSync2("git", ["worktree", "add", "--detach", absolutePath, "HEAD"], {
    cwd: repoRoot,
    stdio: ["ignore", "ignore", "pipe"]
  });
  return { absolutePath, relativePath: relativePath2 };
}
function toPosixSeparators(p, fromSep = sep2) {
  return p.split(fromSep).join("/");
}
function parseWorktreePath(start, pathSep = sep2) {
  const posixPath = toPosixSeparators(start, pathSep);
  const marker = `/${RUN_WORKTREE_PREFIX}`;
  const idx = posixPath.indexOf(marker);
  if (idx <= 0)
    return null;
  const workspacePosix = posixPath.slice(0, idx);
  const workItemId2 = posixPath.slice(idx + marker.length).split("/")[0];
  if (!workItemId2)
    return null;
  return { workspace: workspacePosix.split("/").join(pathSep), workItemId: workItemId2 };
}
function listRunWorktrees(repoRoot) {
  const out = execFileSync2("git", ["worktree", "list", "--porcelain"], {
    cwd: repoRoot,
    encoding: "utf8",
    stdio: ["ignore", "pipe", "pipe"]
  });
  const root = realpathSync(repoRoot);
  const paths = [];
  for (const line of out.split(`
`)) {
    if (!line.startsWith("worktree "))
      continue;
    const abs = line.slice("worktree ".length).trim();
    const rel = toPosixSeparators(relative(root, abs));
    if (rel.startsWith(RUN_WORKTREE_PREFIX))
      paths.push(rel);
  }
  return paths;
}
function removeRunWorktree(repoRoot, relativePath2) {
  execFileSync2("git", ["worktree", "remove", relativePath2], {
    cwd: repoRoot,
    stdio: ["ignore", "ignore", "pipe"]
  });
}
function assertSafeArg(value, label) {
  if (value.startsWith("-")) {
    throw new Error(`${label} must not start with '-' (git option injection): ${value}`);
  }
}
function detectBaseBranch(cwd) {
  try {
    const ref = execFileSync2("git", ["symbolic-ref", "--short", "refs/remotes/origin/HEAD"], {
      cwd,
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"]
    }).trim();
    if (ref.length > 0)
      return ref;
  } catch {}
  return execFileSync2("git", ["rev-parse", "--abbrev-ref", "HEAD"], {
    cwd,
    encoding: "utf8"
  }).trim();
}
async function detectSubRepos(repoRoot) {
  let entries;
  try {
    entries = await readdir3(repoRoot, { withFileTypes: true });
  } catch {
    return [];
  }
  const subs = [];
  for (const e2 of entries) {
    if (!e2.isDirectory() || e2.name.startsWith("."))
      continue;
    if (await fileExists(join7(repoRoot, e2.name, ".git")))
      subs.push(e2.name);
  }
  return subs.sort();
}
async function classifyLockHolder(lockPath) {
  let raw;
  try {
    raw = await readFile(join7(lockPath, "pid"), "utf8");
  } catch {
    try {
      const age = Date.now() - (await stat3(lockPath)).mtimeMs;
      return age < PID_WRITE_GRACE_MS ? "alive" : "empty-stale";
    } catch {
      return "alive";
    }
  }
  const pid = Number.parseInt(raw.trim(), 10);
  if (!Number.isInteger(pid) || pid <= 0)
    return "alive";
  try {
    process.kill(pid, 0);
    return "alive";
  } catch (err) {
    return err.code === "EPERM" ? "alive" : "dead-pid";
  }
}
async function withWorktreeLock(repoRoot, fn) {
  const dir = localDir(repoRoot, "worktrees");
  await ensureDir(dir);
  const lockPath = join7(dir, ".lock");
  const pidPath = join7(lockPath, "pid");
  const deadlineMs = 30000;
  const start = Date.now();
  while (true) {
    try {
      await mkdir(lockPath);
      await writeFile(pidPath, String(process.pid), "utf8");
      break;
    } catch (err) {
      if (err.code !== "EEXIST")
        throw err;
      const state = await classifyLockHolder(lockPath);
      if (state === "dead-pid") {
        await unlink(pidPath).catch(() => {});
        await rmdir(lockPath).catch(() => {});
        continue;
      }
      if (state === "empty-stale") {
        await rmdir(lockPath).catch(() => {});
        continue;
      }
      if (Date.now() - start > deadlineMs) {
        throw new Error(`worktree lock held >${deadlineMs}ms (${lockPath}); another worktree op in flight`);
      }
      await new Promise((resolve2) => setTimeout(resolve2, 15));
    }
  }
  try {
    return await fn();
  } finally {
    await unlink(pidPath).catch(() => {});
    await rmdir(lockPath).catch(() => {});
  }
}
function addWorktree(cwd, branch, absPath, base) {
  execFileSync2("git", ["worktree", "add", "-b", branch, "--", absPath, base], {
    cwd,
    stdio: ["ignore", "ignore", "pipe"]
  });
}
async function createWorktreeForWorkItem(repoRoot, workItemId2) {
  assertSafeArg(workItemId2, "work item id");
  const branch = `${WORK_ITEM_BRANCH_PREFIX}${workItemId2}`;
  return withWorktreeLock(repoRoot, async () => {
    const workspaceRel = `${RUN_WORKTREE_PREFIX}${workItemId2}`;
    const workspaceAbs = localDir(repoRoot, "worktrees", workItemId2);
    await ensureDir(localDir(repoRoot, "worktrees"));
    const created = [];
    const meta = [];
    try {
      addWorktree(repoRoot, branch, workspaceAbs, detectBaseBranch(repoRoot));
      created.push({ cwd: repoRoot, abs: workspaceAbs, branch });
      meta.push({ owning_repo: ".", worktree_path: workspaceRel, branch });
      for (const sub of await detectSubRepos(repoRoot)) {
        assertSafeArg(sub, "sub-repo name");
        const subMainCheckout = join7(repoRoot, sub);
        const subAbs = join7(workspaceAbs, sub);
        addWorktree(subMainCheckout, branch, subAbs, detectBaseBranch(subMainCheckout));
        created.push({ cwd: subMainCheckout, abs: subAbs, branch });
        meta.push({ owning_repo: sub, worktree_path: `${workspaceRel}/${sub}`, branch });
      }
    } catch (err) {
      for (const c3 of [...created].reverse()) {
        try {
          execFileSync2("git", ["worktree", "remove", "--force", "--", c3.abs], {
            cwd: c3.cwd,
            stdio: ["ignore", "ignore", "ignore"]
          });
        } catch {}
        try {
          execFileSync2("git", ["branch", "-D", "--", c3.branch], {
            cwd: c3.cwd,
            stdio: ["ignore", "ignore", "ignore"]
          });
        } catch {}
      }
      throw err;
    }
    const store = new WorkItemStore(repoRoot);
    await store.update(workItemId2, (cur) => ({ ...cur, worktrees: meta }));
    return meta;
  });
}
async function listWorktreesForWorkspace(repoRoot) {
  const store = new WorkItemStore(repoRoot);
  const summaries = await store.list();
  const rows = [];
  for (const s2 of summaries) {
    let item;
    try {
      item = await store.get(s2.id);
    } catch {
      continue;
    }
    for (const wt of item.worktrees) {
      const wtAbs = join7(repoRoot, wt.worktree_path);
      if (!await fileExists(wtAbs)) {
        rows.push({
          work_item_id: item.id,
          owning_repo: wt.owning_repo,
          branch: wt.branch,
          worktree_path: wt.worktree_path,
          exists: false,
          orphan: false,
          dirty: false,
          base: "",
          ahead: 0,
          behind: 0
        });
        continue;
      }
      const ownerCwd = wt.owning_repo === "." ? repoRoot : join7(repoRoot, wt.owning_repo);
      const base = detectBaseBranch(ownerCwd);
      const { ahead, behind } = aheadBehind(wtAbs, base);
      rows.push({
        work_item_id: item.id,
        owning_repo: wt.owning_repo,
        branch: wt.branch,
        worktree_path: wt.worktree_path,
        exists: true,
        orphan: false,
        dirty: !isWorkingTreeClean(wtAbs),
        base,
        ahead,
        behind
      });
    }
  }
  const metaPaths = new Set(rows.map((r3) => toPosixSeparators(r3.worktree_path)));
  let onDisk;
  try {
    onDisk = listRunWorktrees(repoRoot);
  } catch {
    onDisk = [];
  }
  for (const rel of onDisk) {
    if (metaPaths.has(rel))
      continue;
    const wtAbs = join7(repoRoot, rel);
    rows.push({
      work_item_id: "",
      owning_repo: "",
      branch: readWorktreeBranch(wtAbs),
      worktree_path: rel,
      exists: true,
      orphan: true,
      dirty: !isWorkingTreeClean(wtAbs),
      base: "",
      ahead: 0,
      behind: 0
    });
  }
  return rows;
}
function readWorktreeBranch(cwd) {
  try {
    return execFileSync2("git", ["rev-parse", "--abbrev-ref", "HEAD"], {
      cwd,
      encoding: "utf8"
    }).trim();
  } catch {
    return "";
  }
}
function worktreeBindingHint(repoRoot, worktrees, workItemId2) {
  const ws = worktrees.find((w2) => w2.owning_repo === ".") ?? worktrees[0];
  if (!ws)
    return null;
  return `\u2192 cd ${join7(repoRoot, ws.worktree_path)} \uD6C4 \uAC70\uAE30\uC11C \uC138\uC158\uC744 \uC5F4\uBA74 \uC790\uB3D9\uC73C\uB85C \uC774 work item(${workItemId2})\uC5D0 \uBC14\uC778\uB529\uB429\uB2C8\uB2E4`;
}
function branchHasUnmergedCommits(cwd, branch) {
  try {
    const head = execFileSync2("git", ["rev-parse", "HEAD"], { cwd, encoding: "utf8" }).trim();
    const tip = execFileSync2("git", ["rev-parse", branch], { cwd, encoding: "utf8" }).trim();
    try {
      execFileSync2("git", ["merge-base", "--is-ancestor", tip, head], {
        cwd,
        stdio: ["ignore", "ignore", "ignore"]
      });
      return false;
    } catch {
      return true;
    }
  } catch {
    return true;
  }
}
async function removeWorktreesForWorkItem(repoRoot, workItemId2, opts = {}) {
  assertSafeArg(workItemId2, "work item id");
  const force = opts.force ?? false;
  return withWorktreeLock(repoRoot, async () => {
    const store = new WorkItemStore(repoRoot);
    const item = await store.get(workItemId2);
    const ordered = [...item.worktrees].sort((a2, b2) => (a2.owning_repo === "." ? 1 : 0) - (b2.owning_repo === "." ? 1 : 0));
    const removed = [];
    const blocked = [];
    for (const wt of ordered) {
      const ownerCwd = wt.owning_repo === "." ? repoRoot : join7(repoRoot, wt.owning_repo);
      const wtAbs = join7(repoRoot, wt.worktree_path);
      const dirty = !isWorkingTreeClean(wtAbs);
      const unmerged = branchHasUnmergedCommits(ownerCwd, wt.branch);
      if ((dirty || unmerged) && !force) {
        const why = [dirty ? "uncommitted changes" : null, unmerged ? "unmerged commits" : null].filter(Boolean).join(" + ");
        blocked.push({ worktree: wt, reason: `${why}; refusing to delete without --force` });
        continue;
      }
      try {
        const removeArgs = ["worktree", "remove"];
        if (force)
          removeArgs.push("--force");
        removeArgs.push("--", wtAbs);
        execFileSync2("git", removeArgs, { cwd: ownerCwd, stdio: ["ignore", "ignore", "pipe"] });
        execFileSync2("git", ["branch", force ? "-D" : "-d", "--", wt.branch], {
          cwd: ownerCwd,
          stdio: ["ignore", "ignore", "pipe"]
        });
        removed.push(wt);
      } catch (err) {
        blocked.push({
          worktree: wt,
          reason: err instanceof Error ? err.message : String(err)
        });
      }
    }
    if (removed.length > 0) {
      await store.update(workItemId2, (cur) => ({
        ...cur,
        worktrees: cur.worktrees.filter((w2) => !removed.some((r3) => r3.worktree_path === w2.worktree_path))
      }));
    }
    return { removed, blocked };
  });
}
function mergeBranchIntoBase(ownerCwd, branch) {
  assertSafeArg(branch, "branch");
  const current = execFileSync2("git", ["rev-parse", "--abbrev-ref", "HEAD"], {
    cwd: ownerCwd,
    encoding: "utf8"
  }).trim();
  if (current === branch) {
    return { status: "skipped", reason: "base checkout is on the work-item branch itself" };
  }
  if (!branchHasUnmergedCommits(ownerCwd, branch)) {
    return { status: "merged" };
  }
  try {
    execFileSync2("git", ["merge", "--no-edit", "--", branch], {
      cwd: ownerCwd,
      stdio: ["ignore", "ignore", "pipe"]
    });
    return { status: "merged" };
  } catch (err) {
    try {
      execFileSync2("git", ["merge", "--abort"], { cwd: ownerCwd });
    } catch {}
    const stderr = err.stderr?.toString() ?? (err instanceof Error ? err.message : String(err));
    return { status: "conflicted", reason: stderr.trim() };
  }
}
async function mergeWorktreesForWorkItem(repoRoot, workItemId2) {
  assertSafeArg(workItemId2, "work item id");
  return withWorktreeLock(repoRoot, async () => {
    const store = new WorkItemStore(repoRoot);
    const item = await store.get(workItemId2);
    const ordered = [...item.worktrees].sort((a2, b2) => (a2.owning_repo === "." ? 1 : 0) - (b2.owning_repo === "." ? 1 : 0));
    const outcomes = [];
    for (const wt of ordered) {
      const ownerCwd = wt.owning_repo === "." ? repoRoot : join7(repoRoot, wt.owning_repo);
      const r3 = mergeBranchIntoBase(ownerCwd, wt.branch);
      outcomes.push({
        worktree: wt,
        status: r3.status,
        ...r3.reason !== undefined ? { reason: r3.reason } : {}
      });
    }
    return { outcomes, allMerged: outcomes.every((o3) => o3.status === "merged") };
  });
}
