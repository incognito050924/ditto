// src/core/autopilot-approval.ts
function requirePending(gate, action) {
  if (gate.status !== "pending") {
    throw new Error(`approval gate is not pending (current: ${gate.status}); nothing to ${action}`);
  }
}
function applyApproval(gate, input = {}) {
  requirePending(gate, "approve");
  return {
    ...gate,
    status: "approved",
    source: input.source ?? "user",
    approved_at: (input.now ?? new Date).toISOString(),
    approved_by: input.by ?? "user"
  };
}
function applyRejection(gate, reason) {
  requirePending(gate, "reject");
  const evidence_refs = reason ? [...gate.evidence_refs, { kind: "note", summary: reason }] : gate.evidence_refs;
  return { ...gate, status: "rejected", evidence_refs };
}

// src/core/autopilot-graph.ts
var KIND_TO_OWNER = {
  research: "researcher",
  design: "planner",
  implement: "implementer",
  review: "reviewer",
  verify: "verifier",
  fix: "implementer",
  e2e: "playwright-e2e",
  docs: "implementer",
  knowledge: "knowledge-curator",
  security: "security-reviewer",
  refactor: "refactorer",
  retro: "retrospective",
  cleanup: "driver",
  "e2e-author": "main-session"
};
function kindToOwner(kind) {
  return KIND_TO_OWNER[kind];
}
var NODE_TRANSITIONS = {
  pending: { dispatch: "running", block: "blocked" },
  running: {
    pass: "passed",
    fail: "failed",
    block: "blocked",
    rollback: "pending",
    retry: "pending"
  },
  failed: { dispatch: "running", rollback: "pending" },
  blocked: { dispatch: "running" },
  passed: { reopen: "pending" }
};
function nodeTransition(from, event) {
  const to = NODE_TRANSITIONS[from][event];
  if (!to)
    throw new Error(`illegal node transition: ${from} --${event}-->`);
  return to;
}
function isNodeReady(node, byId) {
  if (node.status !== "pending")
    return false;
  return node.depends_on.every((dep) => byId.get(dep)?.status === "passed");
}
function selectReadyNodes(nodes) {
  const byId = new Map(nodes.map((n2) => [n2.id, n2]));
  const nonTerminalImplements = nodes.filter((n2) => n2.kind === "implement" && n2.status !== "passed" && n2.status !== "failed");
  const implementPending = nonTerminalImplements.length > 0;
  const isImplementPrecondition = (verifyId) => nonTerminalImplements.some((impl) => dependsOnNode(impl, verifyId, byId));
  return nodes.filter((n2) => {
    if (!isNodeReady(n2, byId))
      return false;
    if (n2.kind === "verify" && implementPending && !isImplementPrecondition(n2.id))
      return false;
    return true;
  });
}
function dependsOnNode(node, targetId, byId) {
  const seen = new Set;
  const visit2 = (id) => {
    if (seen.has(id))
      return false;
    seen.add(id);
    const cur = byId.get(id);
    if (!cur)
      return false;
    for (const dep of cur.depends_on) {
      if (dep === targetId)
        return true;
      if (visit2(dep))
        return true;
    }
    return false;
  };
  return visit2(node.id);
}
function fileOverlapGate(wave) {
  const claimed = new Set;
  const dispatch = [];
  const serialized = [];
  for (const node of wave) {
    const overlaps = node.file_scope.some((f3) => claimed.has(f3));
    if (overlaps) {
      serialized.push(node);
    } else {
      dispatch.push(node);
      for (const f3 of node.file_scope)
        claimed.add(f3);
    }
  }
  return { dispatch, serialized };
}
function buildInitialNodes(acceptanceIds) {
  const mk = (id, kind, purpose, depends_on, acceptance_refs) => ({
    id,
    kind,
    owner: kindToOwner(kind),
    purpose,
    status: "pending",
    depends_on,
    acceptance_refs,
    evidence_refs: [],
    attempts: { fix: 0, switch: 0 }
  });
  return [
    mk("N1", "design", "Plan the change against the acceptance criteria", [], acceptanceIds),
    mk("N2", "implement", "Implement the planned change", ["N1"], acceptanceIds),
    mk("N3", "verify", "Verify every acceptance criterion with evidence", ["N2"], acceptanceIds)
  ];
}
function proposalsToNodes(proposals) {
  return proposals.map((p) => ({
    id: p.id,
    kind: p.kind,
    owner: kindToOwner(p.kind),
    purpose: p.purpose,
    status: "pending",
    depends_on: p.depends_on,
    acceptance_refs: p.acceptance_refs,
    evidence_refs: [],
    attempts: { fix: 0, switch: 0 },
    ...p.agent_hint !== undefined ? { agent_hint: p.agent_hint } : {},
    ...p.file_scope !== undefined ? { file_scope: p.file_scope } : {}
  }));
}
var defaultNodeGenerator = buildInitialNodes;
function supersededByPromotion(nodes, generatorId, promoted) {
  const byId = new Map(nodes.map((n2) => [n2.id, n2]));
  const promotedIds = new Set(promoted.map((n2) => n2.id));
  const covered = new Set(promoted.flatMap((n2) => n2.acceptance_refs));
  const dependsOnGenerator = (start) => {
    const seen = new Set;
    const visit2 = (id) => {
      if (seen.has(id))
        return false;
      seen.add(id);
      const cur = byId.get(id);
      if (!cur)
        return false;
      for (const dep of cur.depends_on) {
        if (dep === generatorId || visit2(dep))
          return true;
      }
      return false;
    };
    return visit2(start.id);
  };
  const removal = new Set(nodes.filter((n2) => n2.status === "pending" && !promotedIds.has(n2.id) && n2.acceptance_refs.length > 0 && n2.acceptance_refs.every((ac) => covered.has(ac)) && dependsOnGenerator(n2)).map((n2) => n2.id));
  let changed = true;
  while (changed) {
    changed = false;
    for (const id of [...removal]) {
      const candidate = byId.get(id);
      if (!candidate)
        continue;
      const survivorDependsOnIt = nodes.some((n2) => !removal.has(n2.id) && n2.depends_on.includes(id));
      const ancestorSurvives = candidate.depends_on.some((dep) => dep !== generatorId && !removal.has(dep));
      if (survivorDependsOnIt || ancestorSurvives) {
        removal.delete(id);
        changed = true;
      }
    }
  }
  return [...removal];
}
function validateNodeAddition(existing, newNodes, allowedAcceptanceIds) {
  const seen = new Set;
  for (const node of existing)
    seen.add(node.id);
  for (const node of newNodes) {
    if (seen.has(node.id))
      throw new Error(`duplicate node id: ${node.id}`);
    seen.add(node.id);
  }
  if (allowedAcceptanceIds) {
    for (const node of newNodes) {
      for (const ref of node.acceptance_refs) {
        if (!allowedAcceptanceIds.has(ref)) {
          throw new Error(`acceptance_ref not in intent: node ${node.id} references unknown criterion ${ref} (scope grow)`);
        }
      }
    }
  }
  const merged = [...existing, ...newNodes];
  const byId = new Map(merged.map((n2) => [n2.id, n2]));
  for (const node of newNodes) {
    for (const dep of node.depends_on) {
      if (!byId.has(dep)) {
        throw new Error(`dangling depends_on: node ${node.id} references unknown ${dep}`);
      }
    }
  }
  const state = new Map;
  const visit2 = (id) => {
    const status = state.get(id);
    if (status === "done")
      return;
    if (status === "visiting")
      throw new Error(`cycle introduced over depends_on at node ${id}`);
    state.set(id, "visiting");
    for (const dep of byId.get(id)?.depends_on ?? [])
      visit2(dep);
    state.set(id, "done");
  };
  for (const node of merged)
    visit2(node.id);
}

