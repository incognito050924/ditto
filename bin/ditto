          }
        } catch (err) {
          writeError(`internal-packages failed: ${err instanceof Error ? err.message : String(err)}`);
          process.exit(RUNTIME_ERROR_EXIT);
        }
      }
    })
  }
});

// src/cli/commands/autopilot.ts
import { readFile as readFile10, readdir as readdir16 } from "fs/promises";
