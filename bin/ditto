// src/core/interview-store.ts
import { join as join56 } from "path";
init_ditto_paths();
init_fs();

class InterviewStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  dir(workItemId2) {
    return localDir(this.repoRoot, "work-items", workItemId2);
  }
  path(workItemId2) {
    return join56(this.dir(workItemId2), "interview-state.json");
  }
  async exists(workItemId2) {
    return Bun.file(this.path(workItemId2)).exists();
  }
  async get(workItemId2) {
    return readJson(this.path(workItemId2), interviewState);
  }
  async write(state) {
    await ensureDir(this.dir(state.work_item_id));
    return writeJson(this.path(state.work_item_id), interviewState, state);
  }
}

// src/core/interview-driver.ts
init_work_item_store();
var DEFAULT_THRESHOLD = 0.7;
var DEFAULT_QUESTION_CAP = 8;
var DEFAULT_GENERATORS = 1;
var DRY_FLOOR = 0.12;
async function startInterview(repoRoot, input) {
  const now = (input.now ?? new Date).toISOString();
  const generators = input.generators ?? DEFAULT_GENERATORS;
  const seededDimensions = input.seedUserIntentDimensions ? (await loadFarFieldTaxonomy(repoRoot, () => warnMalformedTaxonomy(repoRoot))).filter((c3) => c3.disposition === "user-intent").map((c3) => ({
    id: c3.id,
    critical: false,
    state: "unknown",
    ambiguity: 1,
    resolved_by: [],
    notes: c3.lens
  })) : [];
  const initial = {
    schema_version: "0.1.0",
    work_item_id: input.workItemId,
    status: "active",
    started_at: now,
    updated_at: now,
    dimensions: seededDimensions,
    readiness: {
      score: 0,
      threshold: input.threshold ?? DEFAULT_THRESHOLD,
      critical_unresolved: [],
      gate: "blocked"
    },
    questions: [],
    assumptions: [],
    premortem: [],
    exit: {
      reason: "readiness_met",
      closure_mode: deriveClosureMode("readiness_met", false),
      question_cap: input.questionCap ?? DEFAULT_QUESTION_CAP,
      questions_asked: 0
    }
  };
  const written = await new InterviewStore(repoRoot).write(initial);
  return { ...written, generators };
}
var recordTurnPayload = exports_external.object({
  dimension: exports_external.object({
    id: exports_external.string().min(1),
    critical: exports_external.boolean().default(false),
    state: dimensionState.default("partial"),
    ambiguity: exports_external.number().min(0).max(1).default(0.5),
    notes: exports_external.string().default("")
  }).describe("Dimension to upsert (created if absent, fields merged if present)"),
  question: exports_external.object({
    text: exports_external.string().min(1),
    why_matters: exports_external.string().min(1),
    info_gain_estimate: infoGain,
    user_explanation: exports_external.string().min(1).optional(),
    background: exports_external.string().min(1).optional(),
    grounding: exports_external.string().min(1).optional(),
    self_answer_attempts: exports_external.array(selfAnswerAttempt).optional(),
    marginal_gain: exports_external.number().min(0).max(1).optional().describe("Score-gated marginal information gain of this round; low value across a round is the dry signal")
  }).describe("The asked question and why it matters"),
  answer: exports_external.object({
    text: exports_external.string().min(1),
    kind: exports_external.enum(["user", "assumption"]),
    delegated: exports_external.boolean().optional(),
    ambiguity_delta: exports_external.number().optional(),
    self_report: answerSelfReport.optional()
  }).optional(),
  readiness_score: exports_external.number().min(0).max(1).optional().describe("LLM self-reported readiness after this turn (floor-capped by the gate)")
}).describe("One interview turn \u2014 dimension upsert + question append + optional answer");
async function recordTurn(repoRoot, input) {
  const store = new InterviewStore(repoRoot);
  const current = await store.get(input.workItemId);
  const nowIso = (input.now ?? new Date).toISOString();
  const { dimension: rawDimension, question, answer, readiness_score } = input.payload;
  const existingDim = current.dimensions.find((d2) => d2.id === rawDimension.id);
  const isCritical = rawDimension.critical || existingDim?.critical || false;
  const isAgentGuess = answer?.kind === "assumption" && answer.delegated !== true;
  const dimension = isAgentGuess && isCritical && rawDimension.state === "resolved" ? { ...rawDimension, state: "partial" } : rawDimension;
  const nextDimensions = existingDim ? current.dimensions.map((d2) => d2.id === dimension.id ? {
    ...d2,
    critical: dimension.critical || d2.critical,
    state: dimension.state,
    ambiguity: dimension.ambiguity,
    notes: dimension.notes || d2.notes,
    resolved_by: dimension.state === "resolved" ? [...d2.resolved_by] : d2.resolved_by
  } : d2) : [
    ...current.dimensions,
    {
      id: dimension.id,
      critical: dimension.critical,
      state: dimension.state,
      ambiguity: dimension.ambiguity,
      resolved_by: [],
      notes: dimension.notes
    }
  ];
  const qId = `q${(current.questions.length + 1).toString().padStart(3, "0")}`;
  const appendedQuestion = interviewQuestion.parse({
    id: qId,
    asked_at: nowIso,
    dimension: dimension.id,
    question: question.text,
    why_matters: question.why_matters,
    info_gain_estimate: question.info_gain_estimate,
    self_answer_attempts: question.self_answer_attempts ?? [],
    ...question.user_explanation !== undefined ? { user_explanation: question.user_explanation } : {},
    ...question.background !== undefined ? { background: question.background } : {},
    ...question.grounding !== undefined ? { grounding: question.grounding } : {},
    ...question.marginal_gain !== undefined ? { marginal_gain: question.marginal_gain } : {},
    ...answer ? {
      answer: answer.text,
      answer_kind: answer.kind,
      ...answer.ambiguity_delta !== undefined ? { ambiguity_delta: answer.ambiguity_delta } : {},
      ...answer.self_report !== undefined ? { answer_self_report: answer.self_report } : {}
    } : {}
  });
  const dimensionsWithResolution = answer && dimension.state === "resolved" ? nextDimensions.map((d2) => d2.id === dimension.id ? { ...d2, resolved_by: [...d2.resolved_by, qId] } : d2) : nextDimensions;
  const nextAssumptions = answer?.kind === "assumption" ? [
    ...current.assumptions,
    {
      statement: answer.text,
      label: "hypothesis",
      confidence: "medium",
      because_no_answer_to: qId
    }
  ] : current.assumptions;
  const updated = {
    ...current,
    updated_at: nowIso,
    dimensions: dimensionsWithResolution,
    questions: [...current.questions, appendedQuestion],
    assumptions: nextAssumptions,
    readiness: {
      ...current.readiness,
      ...readiness_score !== undefined ? { score: readiness_score } : {},
      critical_unresolved: dimensionsWithResolution.filter((d2) => d2.critical && d2.state !== "resolved").map((d2) => d2.id)
    },
    exit: {
      ...current.exit,
      questions_asked: current.questions.length + 1
    }
  };
  const gateResult = interviewReadinessGate(updated);
  const capReached = updated.exit.questions_asked >= updated.exit.question_cap;
  updated.readiness.gate = gateResult.pass ? "ready" : "blocked";
  if (capReached && updated.status === "active") {
    updated.exit.reason = "cap_reached";
  } else if (question.marginal_gain !== undefined && question.marginal_gain < DRY_FLOOR && !gateResult.pass && updated.status === "active") {
    updated.exit.reason = "diminishing_returns";
  }
  updated.exit.closure_mode = deriveClosureMode(updated.exit.reason, gateResult.pass);
  return store.write(updated);
}
async function checkReadiness(repoRoot, workItemId2) {
  const state = await new InterviewStore(repoRoot).get(workItemId2);
  const gate2 = interviewReadinessGate(state);
  return {
    state,
    gate: gate2,
    critical_unresolved: state.dimensions.filter((d2) => d2.critical && d2.state !== "resolved").map((d2) => d2.id),
    cap_reached: state.exit.questions_asked >= state.exit.question_cap
  };
}
var finalizePayload = exports_external.object({
  goal: exports_external.string().min(1).describe("Verifiable goal in project terms"),
  in_scope: exports_external.array(exports_external.string()).default([]),
  out_of_scope: exports_external.array(exports_external.string()).default([]),
  acceptance_criteria: exports_external.array(intentAcceptanceCriterion).min(1),
  unknowns: exports_external.array(exports_external.string()).default([]),
  follow_up_candidates: exports_external.array(exports_external.string()).default([]),
  question_policy: exports_external.enum(["ask_only_if_user_only_can_answer", "ask_freely", "never_ask"]).default("ask_only_if_user_only_can_answer"),
  risk: exports_external.object({
    non_local: exports_external.boolean().default(false),
    irreversible: exports_external.boolean().default(false),
    unaudited: exports_external.boolean().default(false)
  }).default({ non_local: false, irreversible: false, unaudited: false }),
  approved_source: exports_external.enum(["approved_spec", "issue", "prd", "user"]).optional(),
  user_confirmation: userConfirmation
}).describe("Intent fields synthesized after the interview is ready");
async function finalizeInterview(repoRoot, input) {
  const interviewStoreInstance = new InterviewStore(repoRoot);
  const intentStore = new IntentStore(repoRoot);
  const items = new WorkItemStore(repoRoot);
  const state = await interviewStoreInstance.get(input.workItemId);
  const gate2 = interviewReadinessGate(state);
  if (!gate2.pass) {
    return { status: "not_ready", gate: gate2 };
  }
  if (!input.payload.user_confirmation.confirmed) {
    return { status: "not_confirmed", gate: gate2 };
  }
  const workItem2 = await items.get(input.workItemId);
  const intent = {
    schema_version: "0.1.0",
    work_item_id: input.workItemId,
    source_request: workItem2.source_request,
    goal: input.payload.goal,
    in_scope: input.payload.in_scope,
    out_of_scope: input.payload.out_of_scope,
    acceptance_criteria: input.payload.acceptance_criteria,
    unknowns: input.payload.unknowns,
    follow_up_candidates: input.payload.follow_up_candidates,
    question_policy: input.payload.question_policy,
    ...input.sourceDigest ? { source_digest: input.sourceDigest } : {}
  };
  const writtenIntent = await intentStore.write(intent);
  await items.update(input.workItemId, (current) => ({
    ...current,
    acceptance_criteria: input.payload.acceptance_criteria.map((ac) => ({
      id: ac.id,
      statement: ac.statement,
      verdict: ac.verdict,
      evidence: ac.evidence
    })),
    goal: input.payload.goal
  }));
  const nowIso = (input.now ?? new Date).toISOString();
  await interviewStoreInstance.write({
    ...state,
    status: "converged",
    updated_at: nowIso,
    readiness: { ...state.readiness, gate: "ready" },
    user_confirmation: {
      confirmed: true,
      statement: input.payload.user_confirmation.statement,
      confirmed_at: input.payload.user_confirmation.confirmed_at ?? nowIso
    },
    exit: {
      ...state.exit,
      reason: "readiness_met",
      closure_mode: deriveClosureMode("readiness_met", true)
    }
  });
  const refreshedItem = await items.get(input.workItemId);
  const risk = input.payload.risk;
  const boot = await bootstrapAutopilot(repoRoot, {
    workItem: refreshedItem,
    intent: writtenIntent,
    risk,
    ...input.payload.approved_source ? { approvedSource: input.payload.approved_source } : {},
    ...input.now ? { now: input.now } : {}
  });
  if (boot.status !== "created") {
    throw new Error(`interview finalized but bootstrapAutopilot failed (${boot.status}): ${boot.reasons.join("; ")}`);
  }
  return { status: "finalized", intent: writtenIntent, autopilot: boot.graph };
}
async function projectInterviewDimensions(repoRoot, workItemId2) {
  const state = await new InterviewStore(repoRoot).get(workItemId2);
  const store = new CoverageStore(repoRoot);
  await nextCoverageNode({ repoRoot, workItemId: workItemId2 });
  let map = await store.getMap(workItemId2);
  const existingIds = new Set(map.nodes.map((n2) => n2.id));
  const newDims = state.dimensions.filter((d2) => !existingIds.has(`cov-dim-${d2.id}`));
  if (newDims.length > 0) {
    await recordCoverageRound({
      repoRoot,
      workItemId: workItemId2,
      payload: {
        node_id: map.root_id,
        derived_nodes: newDims.map((d2) => ({
          id: `cov-dim-${d2.id}`,
          parent_id: map.root_id,
          label: d2.notes || d2.id,
          origin: "derived",
          depth_weight: d2.critical ? 1 : 0
        })),
        admissibleBranchesAdded: newDims.length
      },
      stage: "intent"
    });
  }
  for (const d2 of state.dimensions) {
    if (d2.state !== "resolved")
      continue;
    const nodeId2 = `cov-dim-${d2.id}`;
    const node2 = (await store.getMap(workItemId2)).nodes.find((n2) => n2.id === nodeId2);
    if (node2 === undefined || node2.state !== "open")
      continue;
    await recordCoverageRound({
      repoRoot,
      workItemId: workItemId2,
      payload: {
        node_id: nodeId2,
        admissibleBranchesAdded: 0,
        close_as: "resolved",
        axis_signals: { neutrality: { opponent_ran: true, verdict: "accept" } }
      },
      stage: "intent"
    });
  }
  map = await store.getMap(workItemId2);
  const closedItems = map.nodes.filter((n2) => n2.state !== "open").map((n2) => ({ id: n2.id, label: n2.label, state: n2.state }));
  const openItems = map.nodes.filter((n2) => n2.state === "open").map((n2) => ({ id: n2.id, label: n2.label, state: n2.state }));
  const userQa = state.questions.filter((q2) => q2.answer !== undefined && q2.answer_kind === "user").map((q2) => ({
    question: q2.question,
    why_matters: q2.why_matters,
    answer: q2.answer ?? ""
  }));
  const assumptions = state.assumptions.map((a2) => ({
    statement: a2.statement,
    label: a2.label,
    because_no_answer_to: a2.because_no_answer_to
  }));
  const markdown = serializePlanDialog({
    workItemId: workItemId2,
    userQa,
    selfAnswers: [],
    assumptions,
    closedItems,
    openItems,
    kind: "intent-dialog"
  });
  await store.writeIntentDialog(workItemId2, markdown);
  return { map, intentDialogPath: `.ditto/local/runs/${workItemId2}/intent-dialog.md` };
}
var promotePremortemPayload = exports_external.object({
  items: exports_external.array(premortemItem).min(1)
}).describe("Pre-mortem items to record + promote into the interview state (\xA75)");
function requiresPromotion(item) {
  return item.reversibility === "irreversible" || item.blast_radius === "high" || item.blast_radius === "critical";
}
async function promotePremortem(repoRoot, workItemId2, payload, now) {
  const store = new InterviewStore(repoRoot);
  const state = await store.get(workItemId2);
  const unpromoted = payload.items.filter((item) => requiresPromotion(item) && item.promoted_to === "none");
  const nowIso = (now ?? new Date).toISOString();
  const written = await store.write({
    ...state,
    updated_at: nowIso,
    premortem: [...state.premortem, ...payload.items]
  });
  return { state: written, unpromoted };
}

