// src/acg/fitness/injected-provider.ts
function injectedProvider(verdictsPath2, repoRoot) {
  const resolved = isAbsolute11(verdictsPath2) ? verdictsPath2 : resolve15(repoRoot, verdictsPath2);
  let loaded;
  async function load() {
    if (loaded !== undefined)
      return loaded;
    const file = Bun.file(resolved);
    if (!await file.exists()) {
      loaded = null;
      return loaded;
    }
    let parsed;
    try {
      parsed = acgFitnessVerdictFile.safeParse(JSON.parse(await file.text()));
    } catch {
      loaded = null;
      return loaded;
    }
    if (!parsed.success) {
      loaded = null;
      return loaded;
    }
    loaded = new Map(parsed.data.verdicts.map((v2) => [v2.function_id, v2]));
    return loaded;
  }
  return {
    evaluate: async (fn) => {
      const map = await load();
      if (map === null) {
        return {
          skipped: {
            reason: `fitness-verdict source missing/invalid: ${resolved} (agent must produce a valid acg.fitness-verdict.v1 first)`
          },
          violationIds: []
        };
      }
      const entry = map.get(fn.id);
      if (!entry) {
        return {
          skipped: {
            reason: `no injected verdict for ${fn.id} (fail-closed: not a fabricated pass)`
          },
          violationIds: []
        };
      }
      if (entry.mode === "executed" && !entry.evidence_ref) {
        return {
          skipped: { reason: `executed verdict for ${fn.id} lacks evidence_ref (fail-closed)` },
          violationIds: []
        };
      }
      if (entry.verdict === "pass")
        return { violationIds: [] };
      const violationIds = entry.violation_ids && entry.violation_ids.length > 0 ? entry.violation_ids : [fn.id];
      return { violationIds };
    }
  };
}
function compositeProvider(repoRoot, verdictsPath2) {
  const deterministic = commandProvider(repoRoot);
  const injected = injectedProvider(verdictsPath2, repoRoot);
  return {
    evaluate: async (fn, ctx) => fn.evaluator.mode === "deterministic" ? deterministic.evaluate(fn, ctx) : injected.evaluate(fn, ctx)
  };
}

// src/acg/fitness/executed-provider.ts
function signature(run) {
  return JSON.stringify([...run.violationIds].sort());
}
function decideExecutedOutcome(attempts, flakePolicy) {
  const ok = attempts.filter((a2) => !a2.errored);
  if (ok.length === 0) {
    const reason = attempts[0]?.reason ?? "unknown";
    return {
      skipped: { reason: `all ${attempts.length} executed attempt(s) errored: ${reason}` },
      violationIds: []
    };
  }
  const signatures = new Set(ok.map(signature));
  if (signatures.size === 1)
    return { violationIds: ok[0].violationIds };
  if (flakePolicy === "quarantine") {
    return {
      skipped: {
        reason: `flaky executed result: ${ok.length} attempts disagreed \u2192 quarantined (not blocking)`
      },
      violationIds: []
    };
  }
  if (flakePolicy === "retry") {
    const best = ok.reduce((m2, a2) => a2.violationIds.length < m2.violationIds.length ? a2 : m2);
    return { violationIds: best.violationIds };
  }
  return { violationIds: [...new Set(ok.flatMap((a2) => a2.violationIds))] };
}
async function defaultRunOnce(spec, opts) {
  let proc;
  try {
    proc = Bun.spawn(["sh", "-c", spec], {
      cwd: opts.repoRoot,
      stdout: "pipe",
      stderr: "ignore",
      stdin: "ignore"
    });
  } catch (err) {
    return { errored: true, reason: `spawn failed: ${String(err)}`, violationIds: [] };
  }
  let timedOut = false;
  const timer = opts.timeoutMs ? setTimeout(() => {
    timedOut = true;
    proc.kill();
  }, opts.timeoutMs) : undefined;
  try {
    const out = await new Response(proc.stdout).text();
    const exitCode = await proc.exited;
    if (timedOut) {
      return { errored: true, reason: `timeout after ${opts.timeoutMs}ms`, violationIds: [] };
    }
    if (opts.requiresCleanBuild && exitCode !== 0) {
      return {
        errored: true,
        reason: `clean build not proven: spec exited non-zero (${exitCode})`,
        violationIds: []
      };
    }
    const violationIds = out.split(`
`).map((s2) => s2.trim()).filter((s2) => s2.length > 0);
    return { errored: false, violationIds };
  } finally {
    if (timer)
      clearTimeout(timer);
  }
}
var realDeps = { runOnce: defaultRunOnce };
function executedProvider(repoRoot, deps = realDeps) {
  return {
    evaluate: async (fn) => {
      if (fn.evaluator.mode !== "executed") {
        return {
          skipped: {
            reason: `executedProvider only runs mode=executed (got ${fn.evaluator.mode})`
          },
          violationIds: []
        };
      }
      const exec = fn.evaluator.execution ?? {};
      const timeoutMs = exec.timeout_s ? exec.timeout_s * 1000 : undefined;
      const attemptsN = 1 + (exec.retries ?? 0);
      const flake = exec.flake_policy ?? "fail";
      const requiresCleanBuild = exec.requires_clean_build;
      const runs = [];
      for (let i2 = 0;i2 < attemptsN; i2++) {
        runs.push(await deps.runOnce(fn.evaluator.spec, { timeoutMs, repoRoot, requiresCleanBuild }));
      }
      return decideExecutedOutcome(runs, flake);
    }
  };
}
function executingProvider(repoRoot, verdictsPath2) {
  const deterministic = commandProvider(repoRoot);
  const executed = executedProvider(repoRoot);
  const injected = verdictsPath2 ? injectedProvider(verdictsPath2, repoRoot) : null;
  return {
    evaluate: async (fn, ctx) => {
      if (fn.evaluator.mode === "deterministic")
        return deterministic.evaluate(fn, ctx);
      if (fn.evaluator.mode === "executed")
        return executed.evaluate(fn, ctx);
      if (injected)
        return injected.evaluate(fn, ctx);
      return {
        skipped: {
          reason: "llm_judged needs --verdicts (ditto does not run LLM judgment directly)"
        },
        violationIds: []
      };
    }
  };
}

