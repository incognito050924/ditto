// src/core/lsp/client.ts
function defaultLspDeps() {
  return {
    which: (b2) => Bun.which(b2),
    env: (n2) => process.env[n2],
    managedDir: join17(homedir5(), ".local", "share", "ditto", "lsp"),
    fileExists: existsSync3,
    run: async () => ({ exit_code: null, stderr: "" })
  };
}
function severityFromLsp(n2) {
  switch (n2) {
    case 2:
      return "warning";
    case 3:
      return "information";
    case 4:
      return "hint";
    default:
      return "error";
  }
}
function resolveServer(language) {
  const spec = LSP_SPECS.find((s2) => s2.language === language);
  if (!spec)
    return null;
  return resolveServerPath(spec, defaultLspDeps());
}
var DEFAULT_TIMEOUT_MS = 8000;
function frame(msg, enc) {
  const body = JSON.stringify(msg);
  return enc.encode(`Content-Length: ${Buffer.byteLength(body, "utf8")}\r
\r
${body}`);
}
function fileUri(path) {
  return `file://${path}`;
}
async function getDiagnostics(filePath, opts = {}) {
  const language = opts.language ?? "typescript";
  const spec = LSP_SPECS.find((s2) => s2.language === language);
  if (!spec)
    return [];
  const binary = resolveServer(language);
  if (!binary)
    return [];
  let text;
  try {
    text = await Bun.file(filePath).text();
  } catch {
    return [];
  }
  let proc;
  try {
    proc = Bun.spawn([binary, "--stdio"], {
      cwd: dirname5(filePath),
      stdin: "pipe",
      stdout: "pipe",
      stderr: "pipe"
    });
  } catch {
    return [];
  }
  const enc = new TextEncoder;
  const uri = fileUri(filePath);
  const stdin2 = proc.stdin;
  const send = (msg) => {
    stdin2.write(frame(msg, enc));
    stdin2.flush();
  };
  (async () => {
    try {
      for await (const _3 of proc.stderr) {}
    } catch {}
  })();
  const cleanup = () => {
    try {
      send({ jsonrpc: "2.0", id: 999, method: "shutdown" });
      send({ jsonrpc: "2.0", method: "exit" });
    } catch {}
    try {
      proc.kill();
    } catch {}
  };
  let buf = Buffer.alloc(0);
  let timer;
  const result2 = await new Promise((resolve3) => {
    let settled = false;
    const finish = (diags) => {
      if (settled)
        return;
      settled = true;
      resolve3(diags);
    };
    timer = setTimeout(() => finish([]), opts.timeoutMs ?? DEFAULT_TIMEOUT_MS);
    const onMessage = (msg) => {
      if (msg.id !== undefined && msg.method) {
        if (msg.method === "workspace/configuration") {
          const items = Array.isArray(msg.params?.items) ? msg.params?.items : [];
          send({ jsonrpc: "2.0", id: msg.id, result: items.map(() => ({})) });
        } else {
          send({ jsonrpc: "2.0", id: msg.id, result: null });
        }
        return;
      }
      if (msg.id === 1 && msg.result) {
        send({ jsonrpc: "2.0", method: "initialized", params: {} });
        send({
          jsonrpc: "2.0",
          method: "textDocument/didOpen",
          params: {
            textDocument: { uri, languageId: spec.language, version: 1, text }
          }
        });
        return;
      }
      if (msg.method === "textDocument/publishDiagnostics" && msg.params?.uri === uri) {
        const diags = (msg.params?.diagnostics ?? []).map((d2) => ({
          range: d2.range,
          severity: severityFromLsp(d2.severity),
          message: d2.message,
          ...d2.source ? { source: d2.source } : {}
        }));
        finish(diags);
      }
    };
    (async () => {
      try {
        for await (const chunk of proc.stdout) {
          buf = Buffer.concat([buf, Buffer.from(chunk)]);
          while (true) {
            const headerEnd = buf.indexOf(`\r
\r
`);
            if (headerEnd === -1)
              break;
            const header = buf.subarray(0, headerEnd).toString("utf8");
            const match = header.match(/Content-Length:\s*(\d+)/i);
            const len = match ? Number.parseInt(match[1], 10) : 0;
            const bodyStart = headerEnd + 4;
            if (buf.length < bodyStart + len)
              break;
            const body = buf.subarray(bodyStart, bodyStart + len).toString("utf8");
            buf = buf.subarray(bodyStart + len);
            try {
              onMessage(JSON.parse(body));
            } catch {}
          }
        }
      } catch {}
      finish([]);
    })();
    send({
      jsonrpc: "2.0",
      id: 1,
      method: "initialize",
      params: {
        processId: process.pid,
        rootUri: fileUri(dirname5(filePath)),
        capabilities: {
          textDocument: { publishDiagnostics: {} },
          workspace: { configuration: true }
        }
      }
    });
  });
  if (timer)
    clearTimeout(timer);
  cleanup();
  return result2;
}

// src/core/source-extensions.ts
import { readdir as readdir6 } from "fs/promises";
import { join as join18 } from "path";
var EXCLUDED_DIR = new Set([
  "node_modules",
  ".git",
  "dist",
  "build",
  "out",
  ".ditto",
  "coverage",
  ".gradle",
  "target"
]);
async function walkExtensions(dir, counts) {
  let entries;
  try {
    entries = await readdir6(dir, { withFileTypes: true });
  } catch {
    return;
  }
  for (const entry of entries) {
    if (entry.isDirectory()) {
      if (EXCLUDED_DIR.has(entry.name))
        continue;
      await walkExtensions(join18(dir, entry.name), counts);
    } else if (entry.isFile()) {
      const dot = entry.name.lastIndexOf(".");
      if (dot < 0)
        continue;
      const ext = entry.name.slice(dot + 1).toLowerCase();
      counts[ext] = (counts[ext] ?? 0) + 1;
    }
  }
}
async function countExtensions(sourceRoot) {
  const counts = {};
  await walkExtensions(sourceRoot, counts);
  return counts;
}

// src/core/provision/lsp-detect.ts
var LSP_LANG_BY_EXT = {
  ts: "typescript",
  tsx: "typescript",
  mts: "typescript",
  cts: "typescript",
  js: "javascript",
  jsx: "javascript",
  mjs: "javascript",
  cjs: "javascript",
  py: "python",
  pyi: "python",
  go: "go",
  rs: "rust",
  rb: "ruby",
  java: "java",
  kt: "kotlin",
  kts: "kotlin",
  cs: "csharp",
  swift: "swift",
  c: "c",
  h: "c",
  cpp: "cpp",
  cc: "cpp",
  cxx: "cpp",
  hpp: "cpp",
  hh: "cpp",
  hxx: "cpp",
  php: "php",
  scala: "scala",
  sc: "scala",
  dart: "dart",
  lua: "lua",
  r: "r"
};
var LSP_LANGUAGES = new Set(Object.values(LSP_LANG_BY_EXT));
function classifyLspExtensions(extCounts) {
  const byLang = new Map;
  for (const [ext, count] of Object.entries(extCounts)) {
    const lang = LSP_LANG_BY_EXT[ext];
    if (lang)
      byLang.set(lang, (byLang.get(lang) ?? 0) + count);
  }
  return [...byLang.entries()].map(([language, files]) => ({ language, files })).sort((a2, b2) => b2.files - a2.files);
}
async function detectLspLanguages(sourceRoot) {
  return classifyLspExtensions(await countExtensions(sourceRoot));
}
function lspLanguageForPath(filePath) {
  const base = filePath.slice(filePath.lastIndexOf("/") + 1);
  const dot = base.lastIndexOf(".");
  if (dot <= 0)
    return null;
  return LSP_LANG_BY_EXT[base.slice(dot + 1).toLowerCase()] ?? null;
}

