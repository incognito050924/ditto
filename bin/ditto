  memorySourceType = exports_external.enum(["code", "markdown", "spec", "note", "log", "chat", "image", "other"]).describe("Kind of raw source");
  memorySensitivity = exports_external.enum(["public", "internal", "secret"]).describe("Disclosure class of a source or memory event");
  gitCommit = exports_external.string().regex(/^[a-f0-9]{40}$/, "git commit must be 40 lowercase hex characters").describe("Full git commit sha, when the source is git-managed");
  memorySource = exports_external.object({
    schema_version: schemaVersion,
    source_id: memorySourceId,
    source_type: memorySourceType,
    path: relativePath.optional().describe("Repo-relative path for file-backed sources"),
    url: exports_external.string().url().optional().describe("Location for url-backed sources"),
    content_hash: sha256.describe("Hash of the captured content; drives stale detection"),
