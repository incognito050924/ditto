// src/core/cleanup-store.ts
import { mkdir as mkdir6, rename as rename4, stat as stat6 } from "fs/promises";
import { isAbsolute as isAbsolute6, join as join37, relative as relative11, resolve as resolve9 } from "path";
function isProtectedBasename(base) {
  if (base === "CLAUDE.md" || base === "AGENTS.md")
    return true;
  if (/^README(\..+)?$/i.test(base))
    return true;
  return false;
}
function isProtectedPath(repoRelPath) {
  const norm = repoRelPath.replace(/\\/g, "/").replace(/^\.\//, "");
  const base = norm.split("/").pop() ?? norm;
  if (isProtectedBasename(base))
    return true;
  for (const prefix of PROTECTED_DIR_PREFIXES) {
    if (norm === prefix || norm.startsWith(`${prefix}/`))
      return true;
  }
  return false;
}
function runStamp(now) {
  const p = (n2) => String(n2).padStart(2, "0");
  return `${now.getFullYear()}${p(now.getMonth() + 1)}${p(now.getDate())}` + `-${p(now.getHours())}${p(now.getMinutes())}${p(now.getSeconds())}`;
}
function toRepoRel(repoRoot, absPath) {
  return relative11(repoRoot, absPath).replace(/\\/g, "/");
}

class CleanupStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  runDir(runId2) {
    return localDir(this.repoRoot, "cleanup", runId2);
  }
  indexPath(runId2) {
    return join37(this.runDir(runId2), "index.json");
  }
  async createRun(params, now = new Date) {
    const stamp2 = runStamp(now);
    let runId2 = `cleanup-${stamp2}`;
    let suffix = 0;
    await ensureDir(localDir(this.repoRoot, "cleanup"));
    while (true) {
      try {
        await mkdir6(this.runDir(runId2), { recursive: false });
        break;
      } catch (err) {
        if (err.code !== "EEXIST")
          throw err;
        suffix += 1;
        runId2 = `cleanup-${stamp2}-${suffix}`;
      }
    }
    for (const action of CLEANUP_ACTIONS) {
      await ensureDir(join37(this.runDir(runId2), action));
    }
    const index = {
      schema_version: "0.1.0",
      run_id: runId2,
      created_at: now.toISOString(),
      workspace_root: resolve9(this.repoRoot),
      params,
      entries: []
    };
    await writeJson(this.indexPath(runId2), cleanupIndex, index);
    return runId2;
  }
  async readIndex(runId2) {
    return readJson(this.indexPath(runId2), cleanupIndex);
  }
  async stageDoc(runId2, input) {
    const abs = resolve9(input.absPath);
    const repoRel = toRepoRel(this.repoRoot, abs);
    if (repoRel.startsWith("..") || isAbsolute6(repoRel)) {
      throw new Error(`doc must live under repoRoot: ${input.absPath}`);
    }
    if (isProtectedPath(repoRel))
      throw new CleanupProtectedPathError(repoRel);
    if (input.basis.length === 0)
      throw new CleanupBasisRequiredError(repoRel);
    const name = input.name ?? repoRel.split("/").pop() ?? repoRel;
    const owning = await findOwningRepo(abs, this.repoRoot);
    const owningRepo = owning === null ? null : toRepoRel(this.repoRoot, owning) || ".";
    const destAbs = join37(this.runDir(runId2), input.action, name);
    await ensureDir(join37(this.runDir(runId2), input.action));
    await rename4(abs, destAbs);
    const entry = {
      name,
      original_path: repoRel,
      owning_repo: owningRepo,
      action: input.action,
      staged_path: toRepoRel(this.repoRoot, destAbs),
      summary: input.summary,
      basis: input.basis,
      audit: {
        classified_at: new Date().toISOString(),
        aggressiveness: input.aggressiveness,
        ...input.agent !== undefined ? { agent: input.agent } : {}
      }
    };
    const index = await this.readIndex(runId2);
    index.entries.push(entry);
    await writeJson(this.indexPath(runId2), cleanupIndex, index);
    return entry;
  }
  async restore(runId2, originalPath) {
    const index = await this.readIndex(runId2);
    const entry = index.entries.find((e2) => e2.original_path === originalPath);
    if (entry === undefined) {
      throw new Error(`no staged entry for original_path: ${originalPath}`);
    }
    const stagedAbs = join37(this.repoRoot, entry.staged_path);
    const originalAbs = join37(this.repoRoot, entry.original_path);
    await ensureDir(join37(originalAbs, ".."));
    await rename4(stagedAbs, originalAbs);
    return entry;
  }
  async exists(runId2) {
    try {
      await stat6(this.runDir(runId2));
      return true;
    } catch {
      return false;
    }
  }
}
var CLEANUP_ACTIONS, PROTECTED_DIR_PREFIXES, CleanupProtectedPathError, CleanupBasisRequiredError;
var init_cleanup_store = __esm(() => {
  init_cleanup_index();
  init_ditto_paths();
  init_fs();
  init_memory_scan();
  CLEANUP_ACTIONS = cleanupAction.options;
  PROTECTED_DIR_PREFIXES = [".ditto/knowledge", "reports/design", "reports/contracts"];
  CleanupProtectedPathError = class CleanupProtectedPathError extends Error {
    constructor(repoRelPath) {
      super(`refusing to stage protected path: ${repoRelPath}`);
      this.name = "CleanupProtectedPathError";
    }
  };
  CleanupBasisRequiredError = class CleanupBasisRequiredError extends Error {
