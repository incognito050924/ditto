// src/schemas/acg-semantic-compatibility.ts
init_zod();
var SEMANTIC_UNVERIFIED_SENTINEL = "__unverified__";
var acgSemanticCompatibilityChange = exports_external.object({
  before: exports_external.string().min(1),
  after: exports_external.string().min(1),
  old_meaning: exports_external.string().min(1).describe("Domain meaning the old signature expressed"),
  business_assumptions: exports_external.array(exports_external.string().min(1)).default([]).describe("Implicit assumptions callers depended on"),
  compatibility: exports_external.enum(["compatible", "additive", "breaking"]),
  characterization: exports_external.object({
    exists: exports_external.boolean(),
    test_ref: exports_external.string().nullable().default(null),
    candidate: exports_external.string().nullable().default(null).describe("Generated candidate when no behavior test exists"),
    adequacy: exports_external.enum(["l1_met", "l2_passed", "none"]).default("none").describe("Adequacy of the cited characterization (OBJ-11): l1_met = the changed region is executed by the test (L1), l2_passed = the old\u2194new differential passed (L2). none = mere existence, which is INSUFFICIENT for an agent semantic_safe=yes.")
  }).optional(),
  verdict: exports_external.object({
    type_safe: exports_external.boolean(),
    semantic_safe: exports_external.enum(["yes", "no", "unverified"]),
    intended_breaking: exports_external.boolean().optional(),
    reproducibility: acgFitnessVerdictReproducibility.optional().describe("Pinned judge model for an LLM meaning judgment; required for an agent-produced semantic_safe=yes (a user yes is a human attestation, exempt)")
  })
});
var acgSemanticCompatibility = exports_external.object({
  ...acgChangeEnvelope("acg.semantic-compatibility.v1"),
  changes: exports_external.array(acgSemanticCompatibilityChange).min(1)
}).superRefine((value, ctx) => {
  value.changes.forEach((change, i2) => {
    if (value.produced_by === "agent" && change.verdict.semantic_safe === "yes") {
      if (!change.verdict.reproducibility) {
        ctx.addIssue({
          code: exports_external.ZodIssueCode.custom,
          message: "agent-produced semantic_safe='yes' requires verdict.reproducibility (model_version)",
          path: ["changes", i2, "verdict", "reproducibility"]
        });
      }
      const ref = change.characterization?.test_ref;
      const witnessed = change.characterization?.exists === true && typeof ref === "string" && ref.length > 0;
      if (!witnessed) {
        ctx.addIssue({
          code: exports_external.ZodIssueCode.custom,
          message: "agent-produced semantic_safe='yes' requires characterization.exists=true with a non-empty test_ref (a passing behavior test must witness the preserved meaning)",
          path: ["changes", i2, "characterization", "test_ref"]
        });
      }
      const adequacy = change.characterization?.adequacy;
      if (adequacy !== "l1_met" && adequacy !== "l2_passed") {
        ctx.addIssue({
          code: exports_external.ZodIssueCode.custom,
          message: "agent-produced semantic_safe='yes' requires characterization.adequacy of 'l1_met' or 'l2_passed' (the cited test must execute the changed region or pass an old\u2194new differential \u2014 ref existence alone is insufficient, OBJ-11)",
          path: ["changes", i2, "characterization", "adequacy"]
        });
      }
    }
    if (change.verdict.semantic_safe !== "unverified" && change.old_meaning === SEMANTIC_UNVERIFIED_SENTINEL) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        message: `old_meaning '${SEMANTIC_UNVERIFIED_SENTINEL}' is a seed placeholder; provide the real domain meaning before declaring yes/no`,
        path: ["changes", i2, "old_meaning"]
      });
    }
  });
}).describe("ACG SemanticCompatibility \u2014 type vs meaning split verdict (multi-change)");

// src/schemas/dialectic.ts
init_zod();
init_common();
var dialecticMode = exports_external.enum(["create", "review", "decision", "proposal", "document", "final-answer"]).describe("What the three roles work on and produce");
var reviewBudget = exports_external.enum(["small", "standard", "thorough"]);
