        resolveVar: (v2) => process.env[v2]
      });
      const slug = slugFromJourney(journeyAbs);
      const outAbs = resolve15(repoRoot, args.out ?? `specs/${slug}.plan.md`);
      const sidecarAbs = outAbs.replace(/\.md$/, ".map.json");
      await atomicWriteText(outAbs, result2.plan);
      await atomicWriteText(sidecarAbs, `${JSON.stringify({ map: result2.map, assertions: result2.assertions }, null, 2)}
`);
      if (format === "json") {
        writeJson2({
          plan: repoRel(repoRoot, outAbs),
          sidecar: repoRel(repoRoot, sidecarAbs),
          redactions: result2.redactions.length
        });
      } else {
        writeHuman(`e2e plan ${slug}: ${repoRel(repoRoot, outAbs)}`);
        writeHuman(`  sidecar: ${repoRel(repoRoot, sidecarAbs)}`);
        writeHuman(`  redactions: ${result2.redactions.length}`);
      }
    } catch (err) {
      writeError(`e2e plan failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var e2eGenerate = defineCommand({
  meta: {
    name: "generate",
    description: "Route a v2 journey to the official Playwright generator (or degrade), post-pass + map"
  },
  args: {
    journey: { type: "string", description: "Path to <slug>.journey.md", required: true },
    host: { type: "string", description: "claude|codex", default: "claude" },
    "from-raw": {
      type: "string",
      description: "Raw generator spec from the e2e-author skill live drive (post-passed on the usable path)"
    },
    "work-item": { type: "string", description: "Also write the machine assertion map here" },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    if (args.host !== "claude" && args.host !== "codex") {
      writeError(`--host must be claude|codex (got: ${args.host})`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const host = args.host;
    try {
      const repoRoot = await resolveRepoRootForCreate();
      const journeyAbs = resolve15(args.journey);
      const journey = await readJourney(journeyAbs);
      if (!journey.ok) {
        writeError(`journey parse failed (DSL v2 required): ${journey.error}`);
        process.exit(USAGE_ERROR_EXIT);
        return;
      }
      const digest = computeSourceDigest(journey.text);
      const blocks = await loadBlockBodies(journeyAbs, journey.frontMatter.uses_blocks);
      const projection = projectJourneyToPlan({
        journey: journey.frontMatter,
        body: journey.body,
        blocks,
        sourcePath: repoRel(repoRoot, journeyAbs),
        digest,
        resolveVar: (v2) => process.env[v2]
      });
      const slug = slugFromJourney(journeyAbs);
      const rawSpec = args["from-raw"] !== undefined ? await readFile16(resolve15(repoRoot, args["from-raw"]), "utf8") : undefined;
      const result2 = await runGenerator(buildGenerateInput({
        repoRoot,
        host,
        journey: journey.frontMatter,
        journeyText: journey.text,
        journeyAbs,
        slug,
        digest,
        projection
      }), {
        driveOfficialGenerator: async () => {
          if (rawSpec !== undefined)
            return rawSpec;
          throw new Error("official generator is usable but the live browser drive is not available in-process \u2014 run the e2e-author skill and pass its raw spec via --from-raw");
        }
      });
      if (!result2.used_fallback && result2.unmatched && result2.unmatched.length > 0) {
        writeError(`post-pass left ${result2.unmatched.length} journey step(s) without a marker; not writing: ${result2.unmatched.join(", ")}`);
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      const rule = buildRedactionRule(journey.frontMatter);
      assertNoPlaintextSecret(result2.spec, rule);
      const specAbs = resolve15(repoRoot, result2.specPath);
      await atomicWriteText(specAbs, result2.spec.endsWith(`
`) ? result2.spec : `${result2.spec}
`);
      const wi = args["work-item"] ?? "ad-hoc";
      const amap = buildAssertionMap({
        journeyId: journey.frontMatter.id,
        journeyBody: journey.body,
        generatedSpec: result2.spec,
        workItemId: wi,
        generatedSpecPath: result2.specPath,
        rule
      });
      const mapDocRel = `specs/${slug}.assertion-map.md`;
      await atomicWriteText(resolve15(repoRoot, mapDocRel), renderAssertionMapDoc(amap));
      if (args["work-item"] !== undefined) {
        await atomicWriteText(join68(localDir(repoRoot, "work-items", wi), "e2e-assertion-map.json"), `${JSON.stringify(amap, null, 2)}
`);
      }
      const gate2 = assertionMapGate(amap);
      if (format === "json") {
        writeJson2({
          route: result2.used_fallback ? "fallback" : "primary",
          spec: result2.specPath,
          used_fallback: result2.used_fallback,
          reason: result2.reason,
          unverified_acs: result2.unverified_acs,
          injected: result2.injected,
          unmatched: result2.unmatched,
          assertion_map: {
            doc: mapDocRel,
            weakened: amap.weakened_count,
            unmapped: amap.unmapped_count,
            gate: gate2.reason
          }
        });
      } else {
        writeHuman(`e2e generate ${slug}: ${result2.used_fallback ? "DEGRADED (fallback)" : "generated"} \u2192 ${result2.specPath}`);
        writeHuman(`  ${result2.reason}`);
        if (result2.injected !== undefined)
          writeHuman(`  markers injected: ${result2.injected}`);
        writeHuman(`  assertion-map: weakened ${amap.weakened_count}, unmapped ${amap.unmapped_count} \u2014 ${gate2.reason}`);
        writeHuman(`  map doc: ${mapDocRel}`);
        if (result2.used_fallback) {
          writeHuman(`  UNVERIFIED ACs: ${result2.unverified_acs.join(", ")}`);
        }
      }
      if (result2.used_fallback) {
        if (result2.warn)
          writeError(result2.warn);
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      if (gate2.hardFail)
        process.exit(RUNTIME_ERROR_EXIT);
    } catch (err) {
      writeError(`e2e generate failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
