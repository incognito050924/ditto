// src/hooks/semantic-nudge.ts
var SEMANTIC_SOURCE_EXTENSIONS = [".ts", ".tsx", ".js", ".jsx", ".java", ".kt", ".py"];
function filterSourceFiles(files) {
  return files.filter((f4) => !f4.endsWith(".d.ts") && SEMANTIC_SOURCE_EXTENSIONS.some((ext) => f4.endsWith(ext)));
}
function semanticScanNudge(input) {
  if (!input.isNonTerminal)
    return null;
  if (input.semanticPresent)
    return null;
  if (input.base === null)
    return null;
  if (input.changedSourceFiles.length === 0)
    return null;
  if (input.observationChangeCount === null) {
    return `DITTO semantic check: ${input.changedSourceFiles.length} changed source file(s) vs ${input.base} but no current semantic-scan-observation.json. Run \`ditto semantic observe --work-item ${input.workItemId} --base ${input.base}\` to check exported-signature changes.
`;
  }
  if (input.observationChangeCount === 0)
    return null;
  return `DITTO semantic check: ${input.observationChangeCount} observed exported-signature change(s) (semantic-scan-observation.json) not yet resolved. Promote any meaning-breaking change with \`ditto semantic detect\` + \`ditto semantic verdict\`, or declare it intended.
`;
}
function computeSemanticNudge(repoRoot, workItem2, opts) {
  const base = pickBaseRef(repoRoot, workItemBaseCandidates(workItem2));
  const changedSourceFiles = base ? filterSourceFiles(listChangedFilesVsRef(repoRoot, base)) : [];
  return semanticScanNudge({
    workItemId: workItem2.id,
    isNonTerminal: opts.isNonTerminal,
    semanticPresent: opts.semanticPresent,
    base,
    changedSourceFiles,
    observationChangeCount: base ? freshObservationChangeCount(repoRoot, workItem2.id, base) : null
  });
}
function freshObservationChangeCount(repoRoot, workItemId2, base) {
  try {
    const path = localDir(repoRoot, "work-items", workItemId2, "semantic-scan-observation.json");
    const parsed = acgSemanticScanObservation.safeParse(JSON.parse(readFileSync6(path, "utf8")));
    if (!parsed.success)
      return null;
    const fingerprintNow = computeScanFingerprint(gitRevParse(repoRoot, base), diffVsRef(repoRoot, base));
    return parsed.data.fingerprint === fingerprintNow ? parsed.data.change_count : null;
  } catch {
    return null;
  }
}

// src/hooks/stop.ts
var ADMISSIBLE_SEVERITIES = new Set(["critical", "high"]);
function fileAnchorPath(mapsTo) {
  const anchor = mapsTo.trim();
  if (/^(ac-|intent:|doc:)/.test(anchor))
    return;
  const path = anchor.replace(/:\d+$/, "");
  if (!/^[\w./-]+\.[A-Za-z0-9]+$/.test(path))
    return;
  return path;
}
function dialecticForcesContinuation(d2, repoRoot) {
  const reasons = [];
  const verdict2 = d2.synthesizer.verdict;
  if (verdict2 === "reject" || verdict2 === "blocked") {
    reasons.push(`dialectic ${d2.review_id} verdict=${verdict2}; deliberation not resolved`);
  }
  if (verdict2 === "revise" && d2.round < d2.input.constraints.max_rounds && d2.synthesizer.required_edits.length > 0) {
    reasons.push(`dialectic ${d2.review_id}: verdict=revise at round ${d2.round}/${d2.input.constraints.max_rounds} with ${d2.synthesizer.required_edits.length} required_edits open \u2014 re-deliberate next round`);
  }
  const resolved = new Set([
    ...d2.synthesizer.accepted_objections,
    ...d2.synthesizer.rejected_objections.map((r4) => r4.objection)
  ]);
  for (const obj of d2.opponent.objections) {
    const admissible = obj.maps_to.trim().length > 0 && ADMISSIBLE_SEVERITIES.has(obj.severity);
    const idResolved = obj.id !== undefined && resolved.has(obj.id);
    if (admissible && !resolved.has(obj.claim) && !idResolved) {
      reasons.push(`dialectic ${d2.review_id}: admissible objection unresolved \u2014 ${obj.claim}`);
    }
    if (admissible && repoRoot !== undefined) {
      const anchor = fileAnchorPath(obj.maps_to);
      if (anchor !== undefined && !existsSync10(join72(repoRoot, anchor))) {
        reasons.push(`dialectic ${d2.review_id}: objection maps_to '${obj.maps_to}' does not resolve to an existing file \u2014 backward-finding oracle unverifiable/stale`);
      }
    }
  }
  return reasons;
}
var NON_TERMINAL_STATUSES = [
  "draft",
  "in_progress",
  "blocked",
  "partial",
  "unverified"
];
async function readArtifact(path, schema, name) {
  let text;
  try {
    text = await readFile17(path, "utf8");
  } catch {
    return { status: "absent" };
  }
  try {
    const parsed = schema.safeParse(JSON.parse(text));
    if (!parsed.success)
      return { status: "malformed", name };
    return { status: "ok", data: parsed.data };
  } catch {
    return { status: "malformed", name };
  }
}
async function readDialecticLedgers(dir) {
  const reviewsDir = join72(dir, "reviews");
  let names;
  try {
    names = await readdir22(reviewsDir);
  } catch {
    return { status: "ok", items: [] };
  }
  const files = names.filter((n3) => /^dialectic-.*\.json$/.test(n3)).sort();
  const items = [];
  for (const name of files) {
    const read = await readArtifact(join72(reviewsDir, name), dialectic, `reviews/${name}`);
    if (read.status === "malformed")
      return { status: "malformed", name: read.name };
    if (read.status === "ok")
      items.push(read.data);
  }
  return { status: "ok", items };
}
function hasPendingMutatingNode(a4) {
  return a4.nodes.some((n3) => n3.owner === "implementer" && n3.status === "pending");
}
function isDegeneratePendingAutopilot(a4) {
  return a4.approval_gate.status === "pending" && !hasPendingMutatingNode(a4);
}
function hasRunnableNode(a4) {
  const byId = new Map(a4.nodes.map((n3) => [n3.id, n3]));
  const depsPassed = (n3) => n3.depends_on.every((d2) => byId.get(d2)?.status === "passed");
  return a4.nodes.some((n3) => n3.status === "running" || n3.status === "pending" && depsPassed(n3));
}
function autopilotForcesContinuation(a4) {
  if (a4.approval_gate.status === "pending")
    return false;
  return hasRunnableNode(a4);
}
function autopilotHasNoPlan(pilot) {
  if (pilot.status === "absent")
    return true;
  if (pilot.status === "ok")
    return !pilot.data.nodes.some((n3) => n3.owner === "implementer");
  return false;
}
function autopilotBypassForcesContinuation(workItem2, completion, pilot, completionWouldClose) {
  if (completion.status !== "ok" || !completionWouldClose)
    return [];
  if (!autopilotHasNoPlan(pilot))
    return [];
  if (!NON_TERMINAL_STATUSES.includes(workItem2.status))
    return [];
  if (workItem2.autopilot_exempt === true)
    return [];
  const changedCode = completion.data.changed_files.length > 0 || workItem2.changed_files.length > 0;
  if (!changedCode)
    return [];
  return [
    `work item ${workItem2.id} changed code but is closing on completion.json alone, without going through autopilot (no real plan was ever run). Non-trivial work should run finalize \u2192 bootstrap \u2192 autopilot drive (ditto autopilot bootstrap ${workItem2.id}, then the autopilot skill). To close without autopilot, run "ditto autopilot exempt ${workItem2.id}" or transition the work item to done/abandoned.`
  ];
}
function acgReviewForcesContinuation(graph) {
  const reasons = [];
  for (const file of graph.files) {
    if (file.risk === "high" && file.evidence === undefined) {
      const id = file.path ?? file.journey_id ?? "(unidentified)";
      reasons.push(`acg review: high-risk change without evidence \u2014 ${id} (${file.risk_reason})`);
    }
  }
  return reasons;
}
function assuranceSnapshotForcesContinuation(snapshot) {
  const reasons = [];
  for (const r4 of snapshot.results) {
    if (r4.outcome === "fail") {
      const n3 = r4.new_violations ?? r4.violations ?? 0;
      reasons.push(`fitness: ${r4.function_id} failed \u2014 ${n3} blocking violation(s)`);
    }
  }
  return reasons;
}
function impactForcesContinuation(graph) {
  return graph.unresolved.map((u6) => `impact: unresolved ${u6.kind} \u2014 ${u6.path} (${u6.reason})`);
}
function semanticForcesContinuation(sem) {
  return sem.changes.flatMap((change) => {
    const v2 = change.verdict;
    const where = `${change.before} \u2192 ${change.after}`;
    if (v2.semantic_safe === "unverified") {
      return [
        `semantic: meaning compatibility unverified for ${where} \u2014 verify or declare intended`
      ];
    }
    if (v2.semantic_safe === "no" && v2.intended_breaking !== true) {
      return [`semantic: unintended meaning break ${where} (was: ${change.old_meaning})`];
    }
    return [];
  });
}
function isKnowledgeNode(n3) {
  return n3.kind === "knowledge" || n3.owner === "knowledge-curator";
}
var TERMINAL_NODE_STATUSES = new Set(["passed", "failed", "blocked"]);
function knowledgeForcesContinuation(graph, carrier) {
  const hasTerminalKnowledgeNode = graph.nodes.some((n3) => isKnowledgeNode(n3) && TERMINAL_NODE_STATUSES.has(n3.status));
  if (!hasTerminalKnowledgeNode || carrier === undefined)
    return [];
  const g4 = knowledgeUpdateGate(carrier.triggers, carrier.delta);
  return g4.pass ? [] : g4.reasons.map((r4) => `knowledge update \u2014 ${r4}`);
}
function residualResolvabilityForcesContinuation(completion, workItem2) {
  const acceptanceIds = workItem2.acceptance_criteria.map((c5) => c5.id);
  return resolvabilityBlockers(completion.unverified, acceptanceIds).map((b3) => b3.userDecision ? `residual deferred_needs_user_ok \u2014 ${b3.item}: ${b3.reason}` : `residual blocks pass-close \u2014 ${b3.item}: ${b3.reason}`);
}
function riskRecordForcesContinuation(completion, workItem2) {
  const acceptanceIds = workItem2.acceptance_criteria.map((c5) => c5.id);
  return riskRecordBlockers(completion.remaining_risk_records, acceptanceIds).map((b3) => b3.userDecision ? `residual-risk record deferred_needs_user_ok \u2014 ${b3.item}: ${b3.reason}` : `residual-risk record blocks pass-close \u2014 ${b3.item}: ${b3.reason}`);
}
function decisionConflictForcesContinuation(carrier) {
  if (carrier === undefined)
    return { reasons: [], advisories: [] };
  const { dispositions } = decisionConflictGate(carrier.conflicts, carrier.mode);
  const line = (d2) => `${d2.conflict.adr_id} (${d2.conflict.kind}/${d2.conflict.level}) \u2192 ${d2.route}: ${d2.conflict.basis}`;
  const blocks = (d2) => d2.route === "block" || d2.route === "ask_user";
  return {
    reasons: dispositions.filter(blocks).map((d2) => `decision conflict \u2014 ${line(d2)}`),
    advisories: dispositions.filter((d2) => !blocks(d2)).map((d2) => `decision conflict (disclosed, agent followed ADR) \u2014 ${line(d2)}`)
  };
}
function fitnessInputFingerprint(repoRoot) {
  try {
    const head = gitRevParse(repoRoot, "HEAD");
    const diff = captureGitDiff(repoRoot);
    const files = listChangedFiles(repoRoot).filter((p2) => !p2.startsWith(".ditto/")).join(`
`);
    return createHash13("sha256").update(`${head}
${files}
${diff}`).digest("hex");
  } catch {
    return null;
  }
}
async function maybeRunFitness(repoRoot, workItemId2, dir) {
  try {
    const fns = await new FitnessFunctionStore(repoRoot).read(workItemId2);
    if (!fns || fns.length === 0)
      return;
    const snapshotPath = join72(dir, "assurance-snapshot.json");
    const fingerprintPath = join72(dir, "fitness-input-fingerprint");
    const fingerprint = fitnessInputFingerprint(repoRoot);
    if (fingerprint !== null && await Bun.file(snapshotPath).exists() && await Bun.file(fingerprintPath).exists() && (await Bun.file(fingerprintPath).text()).trim() === fingerprint) {
      return;
    }
    const ctx = {
      trigger: "per_change",
      changeRef: workItemId2,
      riskKnown: false,
      producedAt: new Date().toISOString()
    };
    const verdictsPath2 = join72(dir, "fitness-verdicts.json");
    const provider = await Bun.file(verdictsPath2).exists() ? compositeProvider(repoRoot, verdictsPath2) : commandProvider(repoRoot);
    const snapshot = await runFitness(fns, ctx, provider);
    await ensureDir(dir);
    await writeJson(snapshotPath, acgAssuranceSnapshot, snapshot);
    if (fingerprint !== null)
      await atomicWriteText(fingerprintPath, fingerprint);
  } catch {}
}
var DRIFT_HOPS = ["H1", "H2", "H3"];
function driftHops(lines) {
  return DRIFT_HOPS.filter((h3) => lines.some((l2) => l2.includes(`${h3}:`)));
}
async function recordIntentDriftMetric(repoRoot, workItemId2, drift) {
  if (drift.reasons.length === 0 && drift.advisories.length === 0)
    return;
  try {
    const store = new WorkItemStore(repoRoot);
    const last = (await store.readMetrics(workItemId2)).at(-1);
    if (last && JSON.stringify(last.blocking_reasons) === JSON.stringify(drift.reasons) && JSON.stringify(last.advisories) === JSON.stringify(drift.advisories)) {
      return;
    }
    const record = intentMetric.parse({
      ts: new Date().toISOString(),
      work_item_id: workItemId2,
      kind: "intent_drift",
      source: "stop_hook",
      blocking_reasons: drift.reasons,
      advisories: drift.advisories,
      hops: driftHops([...drift.reasons, ...drift.advisories])
    });
    await store.appendMetricLine(workItemId2, JSON.stringify(record));
  } catch {}
}
function riskOf(workItem2) {
  const r4 = workItem2.declared_risk;
  return {
    non_local: !!r4?.non_local,
    irreversible: !!r4?.irreversible,
    unaudited: !!r4?.unaudited
  };
}
function oracleGapPending(workItem2, graph) {
  const assignmentInPlay = workItem2.acceptance_criteria.some((ac) => ac.oracle !== undefined);
  if (!assignmentInPlay)
    return false;
  const inPlay = new Set(graph.nodes.filter((n3) => n3.kind === "design").flatMap((n3) => n3.acceptance_refs));
  return workItem2.acceptance_criteria.some((ac) => inPlay.has(ac.id) && ac.oracle === undefined);
}
async function maybeRecordProcedurePunt(repoRoot, workItemId2, graph) {
  try {
    const signature2 = graph.nodes.filter((n3) => n3.owner === "implementer" && n3.status === "pending").map((n3) => n3.id).sort().join(",");
    if (signature2.length === 0)
      return;
    const store = new AutopilotStore(repoRoot);
    const existing = await store.readDecisions(workItemId2);
    if (existing.some((d2) => d2.decision === "procedure_punt_continued" && d2.node_id === signature2)) {
      return;
    }
    await store.appendDecision(workItemId2, {
      ts: new Date().toISOString(),
      node_id: signature2,
      decision: "procedure_punt_continued",
      reason: "Stop hook force-continued a routine procedure-punt pause (approval pending, no intent-conflict / high-risk / oracle-gap decision to yield for)"
    });
  } catch {}
}
var stopHandler = async (input) => {
  const raw = input.raw ?? {};
  if (raw.stop_hook_active === true)
    return { exitCode: 0 };
  const sessionId = typeof raw.session_id === "string" ? raw.session_id : undefined;
  if (!sessionId)
    return {
      exitCode: 0,
      stderr: `DITTO Stop completion gate did not run: no session_id was provided, so the completion/convergence gates could not be checked.
`
    };
  const pointer = await new SessionPointerStore(input.repoRoot).get(sessionId);
  if (!pointer)
    return { exitCode: 0 };
  let workItem2;
  try {
    workItem2 = await new WorkItemStore(input.repoRoot).get(pointer);
  } catch {
    return { exitCode: 0 };
  }
  const dir = localDir(input.repoRoot, "work-items", pointer);
  await maybeRunFitness(input.repoRoot, pointer, dir);
  const completion = await readArtifact(join72(dir, "completion.json"), completionContract, "completion.json");
  const conv = await readArtifact(join72(dir, "convergence.json"), convergence, "convergence.json");
  const pilot = await readArtifact(join72(dir, "autopilot.json"), autopilot, "autopilot.json");
  const intent = await readArtifact(join72(dir, "intent.json"), intentContract, "intent.json");
  const dialectics = await readDialecticLedgers(dir);
  const acgReview = await readArtifact(join72(dir, "acg-review.json"), acgReviewGraph, "acg-review.json");
  const assurance = await readArtifact(join72(dir, "assurance-snapshot.json"), acgAssuranceSnapshot, "assurance-snapshot.json");
  const impact = await readArtifact(join72(dir, "impact-graph.json"), acgImpactGraph, "impact-graph.json");
  const semantic = await readArtifact(join72(dir, "semantic-compatibility.json"), acgSemanticCompatibility, "semantic-compatibility.json");
  const knowledge = await readArtifact(join72(dir, "knowledge-gate.json"), knowledgeGateCarrier, "knowledge-gate.json");
  const decisionConflicts = await readArtifact(join72(dir, "decision-conflict.json"), decisionConflictCarrier, "decision-conflict.json");
  const directionFork = await readArtifact(join72(dir, "direction-fork.json"), directionForkCarrier, "direction-fork.json");
  const malformed = [
    completion,
    conv,
    pilot,
    intent,
    dialectics,
    acgReview,
    assurance,
    impact,
    semantic,
    knowledge,
    decisionConflicts,
    directionFork
  ].find((a4) => a4.status === "malformed");
  if (malformed && malformed.status === "malformed") {
    return {
      exitCode: 2,
      stderr: `DITTO Stop gate: ${malformed.name} is malformed (cannot verify completion). Fix or remove it before stopping.
`
    };
  }
  const reasons = [];
  const advisories = [];
  const forkGate = directionFork.status === "ok" ? directionForkGate(directionFork.data) : undefined;
  if (forkGate?.pass === true)
    return { exitCode: 0 };
  if (pilot.status === "ok" && pilot.data.approval_gate.status === "pending" && hasPendingMutatingNode(pilot.data)) {
    if (decisionConflicts.status === "ok" && decisionConflictRequiresApproval(decisionConflicts.data.conflicts)) {
      return { exitCode: 0 };
    }
    if (highRiskAssumption(riskOf(workItem2)))
      return { exitCode: 0 };
    if (oracleGapPending(workItem2, pilot.data))
      return { exitCode: 0 };
    await maybeRecordProcedurePunt(input.repoRoot, pointer, pilot.data);
    reasons.push(`autopilot approval is pending on a routine procedure-punt (no intent-conflict / high-risk / oracle-gap decision to yield for) \u2014 force-continuing; approve the plan ("ditto autopilot approve ${workItem2.id}") to stop being re-prompted`);
  }
  if (forkGate && forkGate.pass === false) {
    reasons.push(...forkGate.reasons.map((r4) => `direction fork incomplete \u2014 ${r4}`));
  }
  let completionWouldClose = false;
  if (completion.status === "ok") {
    const g4 = completionGate(workItem2, completion.data);
    if (!g4.pass)
      reasons.push(...g4.reasons);
    const e2 = completionEvidenceGate(completion.data);
    if (!e2.pass)
      reasons.push(...e2.reasons);
    completionWouldClose = g4.pass && e2.pass;
    const np = nonPassTerminationGate(completion.data);
    if (!np.pass)
      reasons.push(...np.reasons);
  }
  if (conv.status === "ok") {
    const g4 = convergenceGate(conv.data);
    if (!g4.pass)
      reasons.push(...g4.reasons);
  }
  if (pilot.status === "ok" && autopilotForcesContinuation(pilot.data)) {
    reasons.push("autopilot has runnable node(s); the work item is not complete yet");
  }
  reasons.push(...autopilotBypassForcesContinuation(workItem2, completion, pilot, completionWouldClose));
  if (completion.status === "ok" && completionWouldClose) {
    reasons.push(...residualResolvabilityForcesContinuation(completion.data, workItem2));
    reasons.push(...riskRecordForcesContinuation(completion.data, workItem2));
    const uncommitted = new Set(listChangedFiles(input.repoRoot));
    const uncommittedChanged = completion.data.changed_files.filter((f4) => uncommitted.has(f4));
    reasons.push(...landGate(workItem2.status, completion.data.final_verdict, uncommittedChanged).reasons);
  }
  if (intent.status === "ok" && pilot.status === "ok") {
    const d2 = intentDriftGate({
      intent: intent.data,
      workItem: workItem2,
      graph: pilot.data,
      ...completion.status === "ok" ? { completion: completion.data } : {}
    });
    if (!d2.pass)
      reasons.push(...d2.reasons.map((r4) => `intent drift \u2014 ${r4}`));
    advisories.push(...d2.advisories.map((r4) => `intent drift (advisory) \u2014 ${r4}`));
    await recordIntentDriftMetric(input.repoRoot, pointer, {
      reasons: d2.reasons,
      advisories: d2.advisories
    });
  }
  if (dialectics.status === "ok") {
    for (const d2 of dialectics.items)
      reasons.push(...dialecticForcesContinuation(d2, input.repoRoot));
  }
  if (acgReview.status === "ok") {
    reasons.push(...acgReviewForcesContinuation(acgReview.data));
  }
  if (assurance.status === "ok") {
    reasons.push(...assuranceSnapshotForcesContinuation(assurance.data));
  }
  if (impact.status === "ok") {
    reasons.push(...impactForcesContinuation(impact.data));
  }
  if (semantic.status === "ok") {
    reasons.push(...semanticForcesContinuation(semantic.data));
  }
  if (pilot.status === "ok") {
    reasons.push(...knowledgeForcesContinuation(pilot.data, knowledge.status === "ok" ? knowledge.data : undefined));
  }
  const dc = decisionConflictForcesContinuation(decisionConflicts.status === "ok" ? decisionConflicts.data : undefined);
  reasons.push(...dc.reasons);
  advisories.push(...dc.advisories);
  const advisoryBlock = advisories.length > 0 ? `DITTO Stop advisory (non-blocking) \u2014 ${advisories.length} item(s):
- ${advisories.join(`
- `)}
` : "";
  const attestation = completion.status === "ok" ? attestAcVerdicts(completion.data.acceptance.map((a4) => ({
    criterion_id: a4.criterion_id,
    verdict: a4.verdict,
    ...a4.notes !== undefined ? { notes: a4.notes } : {}
  }))) : [];
  const attestationBlock = attestation.length > 0 ? `DITTO Stop attestation (per-AC) \u2014 ${attestation.length} criterion/criteria:
${attestation.map((a4) => `- ${a4.criterion_id}: ${a4.state}${a4.basis ? ` \u2014 ${a4.basis}` : ""}`).join(`
`)}
` : "";
  if (reasons.length > 0) {
    return {
      exitCode: 2,
      stderr: `DITTO Stop gate: keep going \u2014 ${reasons.length} item(s) remain:
- ${reasons.join(`
- `)}
${advisoryBlock}${attestationBlock}`
    };
  }
  if (completion.status === "absent" && conv.status === "absent" && (pilot.status === "absent" || pilot.status === "ok" && isDegeneratePendingAutopilot(pilot.data)) && NON_TERMINAL_STATUSES.includes(workItem2.status)) {
    return {
      exitCode: 2,
      stderr: `DITTO Stop gate: work item ${workItem2.id} is ${workItem2.status} but has no real verification path (no completion.json / convergence.json, and no autopilot.json with a plan to run). Run /ditto:verify (writes completion.json) or transition the work item to done/abandoned before stopping.
`
    };
  }
  const nudge = computeSemanticNudge(input.repoRoot, workItem2, {
    semanticPresent: semantic.status === "ok",
    isNonTerminal: NON_TERMINAL_STATUSES.includes(workItem2.status)
  });
  const tail = `${advisoryBlock}${attestationBlock}${nudge ?? ""}`;
  return tail.length > 0 ? { exitCode: 0, stderr: tail } : { exitCode: 0 };
};

// src/hooks/user-prompt-submit.ts
import { join as join73 } from "path";
init_ditto_paths();
init_fs();
init_work_item_store();
var NON_TERMINAL = [
  "draft",
  "in_progress",
  "blocked",
  "partial",
  "unverified"
];
function classifyPromptAdvisory(prompt2) {
  const t3 = prompt2.trim().toLowerCase();
  if (/(\uD574\s*\uC918|\uD574\s*\uC8FC\uC138\uC694|\uD574\uB77C|\uD558\uB77C|\uAD6C\uD604|\uC218\uC815|\uCD94\uAC00|\uB9CC\uB4E4\uC5B4|\uACE0\uCCD0|\uBC14\uAFD4|\uC801\uC6A9|\uC0AD\uC81C|\uC81C\uAC70)/.test(t3)) {
    return "execution";
  }
  if (/(\uAE4C|\uB098\uC694|\uB294\uAC00|\uC778\uAC00|\uB2C8|\uB0D0|\uC744\uAE4C|\u3139\uAE4C|\u3134\uAC00)\s*[?\uFF1F]?\s*$/.test(t3) || /(\uBB34\uC5C7|\uBB50|\uC65C|\uC5B4\uB5BB\uAC8C|\uC5B4\uB5A4|\uC5B8\uC81C|\uC5B4\uB514|\uB204\uAC00|\uB204\uAD6C|\uC5B4\uB290|\uBA87)/.test(t3)) {
    return "question";
  }
  if (t3.endsWith("?") || /^(what|why|how|when|where|who|which|is|are|does|can|should)\b/.test(t3)) {
    return "question";
  }
  return "execution";
}
var CODEBASE_ANSWERABLE_PATTERNS = [
  /\bfile\b/i,
  /\bfiles\b/i,
  /\bpath\b/i,
  /\bfunction\b/i,
  /\bmethod\b/i,
  /\berror\b/i,
  /\bexception\b/i,
  /\btest\b/i,
  /\btests\b/i,
  /\blog\b/i,
  /\blogs\b/i,
  /\bclass\b/i,
  /\bmodule\b/i,
  /\bschema\b/i,
  /\.(ts|js|tsx|jsx|json|md|sh|py)\b/i,
  /\uD30C\uC77C|\uACBD\uB85C|\uB514\uB809\uD130\uB9AC|\uB514\uB809\uD1A0\uB9AC|\uD568\uC218|\uBA54\uC11C\uB4DC|\uBA54\uC18C\uB4DC|\uC624\uB958|\uC5D0\uB7EC|\uC608\uC678|\uBC84\uADF8|\uD14C\uC2A4\uD2B8|\uB85C\uADF8|\uD074\uB798\uC2A4|\uBAA8\uB4C8|\uC2A4\uD0A4\uB9C8|\uCF54\uB4DC|\uCEE4\uBC0B|\uD0C0\uC785/
];
function looksCodebaseAnswerable(prompt2) {
  return CODEBASE_ANSWERABLE_PATTERNS.some((re) => re.test(prompt2));
}
function tokens(s2) {
  return new Set(s2.toLowerCase().split(/[^a-z0-9\uAC00-\uD7A3]+/).filter((t3) => t3.length >= 3));
}
function duplicateSearch(prompt2, open3) {
  const promptTokens = tokens(prompt2);
  if (promptTokens.size === 0)
    return [];
  return open3.map((s2) => {
    let overlap = 0;
    for (const t3 of tokens(s2.title))
      if (promptTokens.has(t3))
        overlap++;
    return { id: s2.id, title: s2.title, overlap };
  }).filter((m4) => m4.overlap > 0).sort((a4, b3) => b3.overlap - a4.overlap);
}
var RESUME_KEYWORD = /\b(resume|reopen|switch to|work on)\b|\uC774\uC5B4\uC11C|\uC774\uC5B4\uBC1B|\uC7AC\uAC1C/i;
function explicitWorkItemRef(prompt2) {
  const m4 = prompt2.match(/\bwi_[a-z0-9]{8,}\b/i);
  if (!m4)
    return;
  const id = m4[0].toLowerCase();
  const leads = prompt2.trimStart().toLowerCase().startsWith(id);
  return leads || RESUME_KEYWORD.test(prompt2) ? id : undefined;
}
async function resolveActiveWorkItem(repoRoot, sessionId, prompt2) {
  const items = new WorkItemStore(repoRoot);
  const pointers = new SessionPointerStore(repoRoot);
  const pointed = await pointers.get(sessionId);
  const activeWorkItem = pointed !== null && await items.exists(pointed) ? await items.get(pointed) : undefined;
  const explicit = explicitWorkItemRef(prompt2);
  if (!activeWorkItem && explicit && await items.exists(explicit)) {
    await pointers.set(sessionId, explicit);
    return { workItem: await items.get(explicit), action: "loaded" };
  }
  if (activeWorkItem) {
    return { workItem: activeWorkItem, action: "loaded" };
  }
  const open3 = (await items.list()).filter((s2) => NON_TERMINAL.includes(s2.status));
  if (open3.length > 0) {
    const ids = open3.map((s2) => s2.id).join(", ");
    const matches = classifyPromptAdvisory(prompt2) === "execution" ? duplicateSearch(prompt2, open3) : [];
    const dupLine = matches.length > 0 ? ` Possible duplicates by title overlap: ${matches.map((m4) => `${m4.id} ("${m4.title}")`).join("; ")}.` : "";
    return {
      action: "ask",
      advisory: `No active work item pointer for this session and ${open3.length} open work item(s) exist (${ids}).${dupLine} Resume one explicitly, or create a NEW work item before acting \u2014 not picking arbitrarily.`
    };
  }
  return { action: "guide" };
}
function allAcceptancePlaceholders(item) {
  if (item.acceptance_criteria.length === 0)
    return false;
  return item.acceptance_criteria.every((ac) => ac.statement === PLACEHOLDER_AC_STATEMENT);
}
function hasHeavyRiskSignal(item) {
  const r4 = item.declared_risk;
  const declared = !!r4 && (r4.non_local === true || r4.irreversible === true || r4.unaudited === true);
  return declared || item.promoted_to_heavy === true;
}
async function intentHasRiskSignal(repoRoot, workItemId2) {
  try {
    const intents = new IntentStore(repoRoot);
    if (!await intents.exists(workItemId2))
      return false;
    return (await intents.get(workItemId2)).unknowns.length > 0;
  } catch {
    return false;
  }
}
function pendingHandoffHint(item) {
  return item.re_entry?.command;
}
async function logClassification(repoRoot, entry) {
  const dir = localDir(repoRoot, "logs");
  await ensureDir(dir);
  const path = join73(dir, "user-prompt.jsonl");
  const file = Bun.file(path);
  const existing = await file.exists() ? await file.text() : "";
  const prefix = existing.length === 0 || existing.endsWith(`
`) ? existing : `${existing}
`;
  await atomicWriteText(path, `${prefix}${JSON.stringify(entry)}
`);
}
var userPromptSubmitHandler = async (input) => {
  const raw = input.raw ?? {};
  const sessionId = typeof raw.session_id === "string" ? raw.session_id : undefined;
  const prompt2 = typeof raw.prompt === "string" ? raw.prompt : "";
  const classification = classifyPromptAdvisory(prompt2);
  if (!sessionId) {
    return contextOutput(charterProjection());
  }
  const resolved = await resolveActiveWorkItem(input.repoRoot, sessionId, prompt2);
  await logClassification(input.repoRoot, {
    ts: new Date().toISOString(),
    session_id: sessionId,
    classification,
    action: resolved.action,
    work_item_id: resolved.workItem?.id ?? null
  });
  const ctx = {};
  try {
    await new HandoffStore(input.repoRoot).sweepStaleActive();
    await new SessionPointerStore(input.repoRoot).sweepStale();
  } catch {}
  const item = resolved.workItem;
  if (item) {
    ctx.workItemId = item.id;
    ctx.workItemTitle = item.title;
    ctx.workItemStatus = item.status;
    const handoff2 = pendingHandoffHint(item);
    if (handoff2)
      ctx.pendingHandoff = handoff2;
    const placeholderOnly = allAcceptancePlaceholders(item);
    if (placeholderOnly)
      ctx.placeholderAcceptanceCriteria = true;
    const riskSignal = hasHeavyRiskSignal(item) || await intentHasRiskSignal(input.repoRoot, item.id);
    if ((placeholderOnly || riskSignal) && classification === "execution")
      ctx.deepInterviewDirective = true;
  }
  if (classification === "question" && looksCodebaseAnswerable(prompt2)) {
    ctx.selfAnswerHint = true;
  }
  if (resolved.advisory)
    ctx.advisory = resolved.advisory;
  if (resolved.action === "guide")
    ctx.workItemGuide = true;
  return contextOutput(charterProjection(ctx));
};
function contextOutput(text) {
  return {
    exitCode: 0,
    stdout: JSON.stringify({
      hookSpecificOutput: { hookEventName: "UserPromptSubmit", additionalContext: text }
    })
  };
}

// src/cli/commands/hook.ts
var HANDLERS = {
  "session-start": sessionStartHandler,
  "user-prompt-submit": userPromptSubmitHandler,
  "pre-tool-use": preToolUseHandler,
  "post-tool-use": postToolUseHandler,
  "pre-compact": preCompactHandler,
  stop: stopHandler
};
var HOOK_EVENTS = Object.keys(HANDLERS);
function parseHookHost(value) {
  if (value === undefined || value === null || value === "")
    return "claude-code";
  if (value === "claude-code" || value === "codex")
    return value;
  throw new Error(`invalid --host ${String(value)} (expected claude-code|codex)`);
}
var hookCommand = defineCommand({
  meta: {
    name: "hook",
    description: "Run a DITTO hook handler by event name (called from hooks.json; reads the event JSON on stdin)."
  },
  args: {
    event: {
      type: "positional",
      required: true,
      description: `Hook event: ${HOOK_EVENTS.join(" | ")}`
    },
    host: {
      type: "string",
      default: "claude-code",
      description: "Host whose hook envelope feeds stdin/env: claude-code | codex."
    }
  },
  run: async ({ args }) => {
    const handler = HANDLERS[args.event];
    if (!handler) {
      process.stderr.write(`ditto hook: unknown event "${args.event}"; expected one of: ${HOOK_EVENTS.join(", ")}
`);
      process.exit(2);
    }
    let host;
    try {
      host = parseHookHost(args.host);
    } catch (err) {
      process.stderr.write(`ditto hook: ${err instanceof Error ? err.message : String(err)}
`);
      process.exit(2);
    }
    await executeHook(handler, host);
  }
});

// src/cli/commands/impact.ts
import { join as join75 } from "path";

// src/acg/impact/codeql-analyzer.ts
import { join as join74 } from "path";
function isTestFile(path, language) {
  if (language === "java") {
    return path.includes("/test/") || /(Test|Tests|IT)\.java$/.test(path);
  }
  if (language === "kotlin") {
    return path.includes("/test/") || /(Test|Tests|IT)\.kt$/.test(path);
  }
  if (language === "python") {
    return /(^|\/)(test_[^/]+|[^/]+_test)\.py$/.test(path) || path.includes("/tests/");
  }
  return /\.(test|spec)\.[cm]?[jt]sx?$/.test(path);
}
function matchesInternalGlob(pkg, entries) {
  return entries.some((e2) => e2.type === "glob" && globToRegExp(e2.value).test(pkg));
}

class CodeqlImpactAnalyzer {
  target;
  deps;
  constructor(target, deps) {
    this.target = target;
    this.deps = deps;
  }
  async analyze(input) {
    const rows = await runRelationQuery({
      repoRoot: this.target.repoRoot,
      sourceRoot: input.sourceRoot,
      language: this.target.language,
      dbPath: join74(this.target.cacheDir, "db"),
      workDir: join74(this.target.cacheDir, `q-impact-${this.target.symbol}`),
      query: renderQuery(relationQueries(this.target.language).impact, this.target.symbol, this.target.declFile),
      ...this.target.buildMode ? { buildMode: this.target.buildMode } : {},
      ...this.target.buildCommand ? { buildCommand: this.target.buildCommand } : {},
      ...this.target.binary ? { binary: this.target.binary } : {}
    }, this.deps);
    const affected = [];
    for (const row of rows) {
      const [path, lineStr, raw] = row;
      if (!path || !raw)
        continue;
      const line = Number(lineStr);
      let kind;
      if (raw === "type")
        kind = "type_contract";
      else if (raw === "decl")
        kind = "external_surface";
      else
        kind = isTestFile(path, this.target.language) ? "test" : "direct_caller";
      affected.push({
        kind,
        path,
        symbol: this.target.symbol,
        reason: kind === "external_surface" ? "exported symbol \u2014 public surface (\uB2E8\uACC43 gate: exported must be surfaced)" : `references ${this.target.symbol} at line ${line}`
      });
    }
    return { affected, unresolved: await this.crossRepoUnresolved(input.sourceRoot) };
  }
  async crossRepoUnresolved(sourceRoot) {
    const entries = this.target.internalPackages ?? [];
    if (!entries.some((e2) => e2.type === "glob"))
      return [];
    const rows = await runRelationQuery({
      repoRoot: this.target.repoRoot,
      sourceRoot,
      language: this.target.language,
      dbPath: join74(this.target.cacheDir, "db"),
      workDir: join74(this.target.cacheDir, "q-xrepo"),
      query: relationQueries(this.target.language).unresolved,
      ...this.target.buildMode ? { buildMode: this.target.buildMode } : {},
      ...this.target.buildCommand ? { buildCommand: this.target.buildCommand } : {},
      ...this.target.binary ? { binary: this.target.binary } : {}
    }, this.deps);
    const seen = new Set;
    const unresolved = [];
    for (const row of rows) {
      const [path, pkg] = row;
      if (!path || !pkg || !matchesInternalGlob(pkg, entries))
        continue;
      const key = `${path}\x00${pkg}`;
      if (seen.has(key))
        continue;
      seen.add(key);
      unresolved.push({
        kind: "cross_repo",
        path,
        reason: `${pkg} resolves to a sibling module not in this single-module DB (cross_repo; static impact incomplete)`
      });
    }
    return unresolved;
  }
}

// src/acg/impact/impact-graph.ts
var journeyKinds2 = new Set(["ui_surface", "user_journey"]);
function buildImpactGraph(input, analysis) {
  const affected = analysis.affected.map((n3) => ({ handled: false, ...n3 }));
  const unresolved = [...analysis.unresolved];
  const hasJourneyNode = affected.some((n3) => journeyKinds2.has(n3.kind) && n3.journey_id);
  if (input.userExposed === true) {
    if (input.journeyId) {
      affected.push({
        kind: "user_journey",
        journey_id: input.journeyId,
        reason: "user-exposed change mapped to journey",
        handled: false
      });
    } else if (!hasJourneyNode) {
      unresolved.push({
        kind: "journey_unknown",
        path: input.changeTarget,
        reason: "user-exposed change with no JourneySpec mapping; a human must map the journey or declare no journey impact (default-deny, 20-contracts \xA72)"
      });
    }
  }
  return acgImpactGraph.parse({
    schema_version: "0.1.0",
    kind: "acg.impact-graph.v1",
    work_item_id: input.workItemId,
    produced_by: "agent",
    produced_at: input.producedAt,
    change_target: input.changeTarget,
    change_type: input.changeType,
    affected_nodes: affected,
    unresolved
  });
}
async function produceImpactGraph(input, analyzer, sourceRoot) {
  const analysis = await analyzer.analyze({ changeTarget: input.changeTarget, sourceRoot });
  return buildImpactGraph(input, analysis);
}

// src/cli/commands/impact.ts
init_ditto_paths();
init_fs();
var impactCommand = defineCommand({
  meta: {
    name: "impact",
    description: "Produce an ImpactGraph for a changed TS symbol (\uB2E8\uACC43, symbol resolution)"
  },
  args: {
    "work-item": { type: "string", description: "Work item id", required: true },
    file: { type: "string", description: "File declaring the changed symbol", required: true },
    symbol: { type: "string", description: "Changed exported symbol name", required: true },
    "change-type": {
      type: "string",
      description: "rename|signature|behavior|delete|add|move (default signature)"
    },
    "source-root": { type: "string", description: "Analysis source root (default <repo>/src)" },
    language: {
      type: "string",
      description: "CodeQL language: javascript|java|kotlin|python (default javascript). kotlin needs --build-command (Gradle) or autobuild."
    },
    "build-command": {
      type: "string",
      description: "Build command for manual build-mode (compiled langs; else buildless)"
    },
    "user-exposed": {
      type: "boolean",
      default: false,
      description: "Diff touches a user-facing surface (triggers default-deny journey check)"
    },
    "journey-id": { type: "string", description: "JourneySpec.id when the surface is mapped" },
    spec: {
      type: "string",
      description: "ArchitectureSpec (.yaml/.yml/.json) \u2014 its internal_packages drive cross_repo unresolved recording for sibling-module deps absent from a single-module DB"
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const changeType = args["change-type"] ?? "signature";
    try {
      const repoRoot = await resolveRepoRootForCreate();
      const sourceRoot = args["source-root"] ?? join75(repoRoot, "src");
      const language = args.language ?? "javascript";
      const buildCommand = args["build-command"];
      const buildMode = !buildCommand && language === "java" ? "none" : undefined;
      const internalPackages = await loadInternalPackages(repoRoot, args.spec);
      const guard = await runInternalPackagesGuard({
        language,
        entries: internalPackages,
        sourceRoot
      });
      if (guard.decision === "block") {
        writeError(`internal_packages guard: ${guard.reason}`);
        process.exit(USAGE_ERROR_EXIT);
        return;
      }
      if (guard.decision === "warn") {
        writeError(`internal_packages guard (warning): ${guard.reason}`);
      }
      const analyzer = new CodeqlImpactAnalyzer({
        symbol: args.symbol,
        declFile: args.file,
        language,
        repoRoot,
        cacheDir: codeqlCacheDir(repoRoot, language),
        internalPackages,
        ...buildMode ? { buildMode } : {},
        ...buildCommand ? { buildCommand } : {}
      }, makeRelationDeps());
      const graph = await produceImpactGraph({
        workItemId: args["work-item"],
        changeTarget: `${args.file}: ${args.symbol} (${changeType})`,
        changeType,
        producedAt: new Date().toISOString(),
        userExposed: args["user-exposed"],
        journeyId: args["journey-id"]
      }, analyzer, sourceRoot);
      const path = localDir(repoRoot, "work-items", args["work-item"], "impact-graph.json");
      await ensureDir(localDir(repoRoot, "work-items", args["work-item"]));
      await writeJson(path, acgImpactGraph, graph);
      if (format === "json") {
        writeJson2({
          work_item_id: args["work-item"],
          affected: graph.affected_nodes.length,
          unresolved: graph.unresolved.length,
          journey_unknown: graph.unresolved.filter((u6) => u6.kind === "journey_unknown").length,
          cross_repo: graph.unresolved.filter((u6) => u6.kind === "cross_repo").length
        });
      } else {
        writeHuman(`impact: ${graph.affected_nodes.length} affected, ${graph.unresolved.length} unresolved \u2192 impact-graph.json`);
      }
    } catch (err) {
      writeError(`impact failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});

