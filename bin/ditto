// src/core/e2e/failure-report.ts
import { isAbsolute as isAbsolute5, relative as relative8, resolve as resolve6 } from "path";
var FAILED_STATUSES = new Set(["failed", "timedOut", "interrupted"]);
var STEP_MARKER = /^\s*\/\/\s*@step\s+(\S+)\/([sb]\d+)\s*(.*)$/;
var ANSI = /\u001b\[[0-9;]*m/g;
function asDict(v2) {
  return v2 !== null && typeof v2 === "object" && !Array.isArray(v2) ? v2 : null;
}
function asArray2(v2) {
  return Array.isArray(v2) ? v2 : [];
}
function asString(v2) {
  return typeof v2 === "string" ? v2 : undefined;
}
function collectFailures(suite, rootDir, out) {
  for (const child of asArray2(suite.suites)) {
    const c3 = asDict(child);
    if (c3)
      collectFailures(c3, rootDir, out);
  }
  for (const specRaw of asArray2(suite.specs)) {
    const spec = asDict(specRaw);
    if (!spec)
      continue;
    const title = asString(spec.title) ?? "";
    const file = asString(spec.file) ?? "";
    const specFile = rootDir !== undefined ? resolve6(rootDir, file) : file;
    for (const testRaw of asArray2(spec.tests)) {
      const t2 = asDict(testRaw);
      if (!t2)
        continue;
      const results = asArray2(t2.results);
      const last = asDict(results[results.length - 1]);
      if (!last || !FAILED_STATUSES.has(asString(last.status) ?? ""))
        continue;
      const error = asDict(last.error) ?? asDict(asArray2(last.errors)[0]) ?? {};
      const trace = asArray2(last.attachments).map(asDict).find((a2) => a2 !== null && asString(a2.name) === "trace" && asString(a2.path) !== undefined);
      out.push({
        title,
        specFile,
        message: (asString(error.message) ?? "unknown failure").replace(ANSI, ""),
        stack: (asString(error.stack) ?? "").replace(ANSI, ""),
        ...trace ? { tracePath: asString(trace.path) } : {}
      });
    }
  }
}
function failingLine(stack, specFileAbsOrRel) {
  const base = specFileAbsOrRel.split("/").pop() ?? specFileAbsOrRel;
  for (const line of stack.split(`
`)) {
    const m2 = new RegExp(`${base.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}:(\\d+):\\d+`).exec(line);
    if (m2?.[1])
      return Number(m2[1]);
  }
  return;
}
function nearestStep(specText, line) {
  const lines = specText.split(`
`);
  for (let i2 = Math.min(line, lines.length) - 1;i2 >= 0; i2--) {
    const m2 = STEP_MARKER.exec(lines[i2] ?? "");
    if (m2?.[2]) {
      const dsl = (m2[3] ?? "").trim();
      return { step_id: m2[2], ...dsl !== "" ? { step_dsl_line: dsl } : {} };
    }
  }
  return;
}
function expectedActual(message) {
  const expected = /^Expected[^:\n]*:\s*(.+)$/m.exec(message)?.[1]?.trim();
  const actual = /^Received[^:\n]*:\s*(.+)$/m.exec(message)?.[1]?.trim();
  return { ...expected ? { expected } : {}, ...actual ? { actual } : {} };
}
async function buildFailureReport(reporter, options) {
  const root = asDict(reporter);
  if (!root)
    return [];
  const rootDir = asString(asDict(root.config)?.rootDir);
  const raw = [];
  collectFailures(root, rootDir, raw);
  const failures = [];
  for (const f3 of raw) {
    const spec_file = isAbsolute5(f3.specFile) ? relative8(options.repoRoot, f3.specFile) : f3.specFile;
    const sep5 = f3.title.indexOf(" \xB7 ");
    const journey_id = sep5 >= 0 ? f3.title.slice(0, sep5) : "";
    const case_name = sep5 >= 0 ? f3.title.slice(sep5 + " \xB7 ".length) : f3.title;
    let step;
    const line = failingLine(f3.stack, spec_file);
    if (line !== undefined) {
      const specText = await options.readSpec(spec_file);
      if (specText !== null)
        step = nearestStep(specText, line);
    }
    failures.push({
      journey_id,
      case_name,
      ...step ?? {},
      ...expectedActual(f3.message),
      message: f3.message,
      spec_file,
      replay: {
        headed_command: `npx playwright test ${spec_file} -g "${f3.title.replace(/[.*+?^${}()|[\]\\]/g, "\\$&").replaceAll('"', "\\\"")}" --headed`,
        ...f3.tracePath ? { trace_command: `npx playwright show-trace ${f3.tracePath}` } : {}
      }
    });
  }
  return failures;
}
function renderFailureLines(failure, journeyName) {
  const subject = journeyName ?? failure.journey_id;
  const where = failure.step_id !== undefined ? `\uB2E8\uACC4 [${failure.step_id}]${failure.step_dsl_line ? ` ${failure.step_dsl_line}` : ""}` : `\uCF00\uC774\uC2A4 ${failure.case_name}`;
  const what = failure.expected !== undefined && failure.actual !== undefined ? `${failure.expected}\uB97C \uAE30\uB300\uD588\uC9C0\uB9CC ${failure.actual}\uAC00 \uB098\uC654\uB2E4` : `\uC2E4\uD328 \u2014 ${failure.message.split(`
`)[0]}`;
  const lines = [
    `\uC5EC\uC815 ${subject}\uC758 ${where}\uC5D0\uC11C ${what}`,
    `  \uCF00\uC774\uC2A4: ${failure.case_name} (${failure.spec_file})`,
    `  \uC7AC\uC0DD(headed): ${failure.replay.headed_command}`
  ];
  lines.push(failure.replay.trace_command !== undefined ? `  trace \uBDF0\uC5B4: ${failure.replay.trace_command}` : "  trace \uBDF0\uC5B4: \uC774\uBC88 \uC2E4\uD589\uC5D0\uB294 trace\uAC00 \uC5C6\uB2E4 \u2014 \uC7AC\uC2E4\uD589 \uBA85\uB839\uC5D0 --trace on\uC744 \uBD99\uC774\uBA74 npx playwright show-trace <trace.zip>\uC73C\uB85C \uC7A5\uBA74\uC744 \uBCFC \uC218 \uC788\uB2E4");
  return lines;
}

