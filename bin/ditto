    });
  }
}).describe("One node result \u2014 caller judgment that the deterministic floor then enforces");
async function spliceTidyStage(repoRoot, workItemId2, implementNode, aps) {
  const wi = await new WorkItemStore(repoRoot).get(workItemId2);
  const diffStat = wi.started_at_sha ? collectTidyDiffStat(repoRoot, wi.started_at_sha) : { files: [] };
  const graph = await aps.get(workItemId2);
  const plan = planTidyOnImplementPass({
    implementNodeId: implementNode.id,
    diffStat,
    acceptanceIds: implementNode.acceptance_refs,
    existingNodeIds: graph.nodes.map((n2) => n2.id)
  });
  await writeTidyClassification(repoRoot, workItemId2, plan.classification);
  if (plan.nodes.length === 0)
    return [];
  await aps.addNodes(workItemId2, plan.nodes);
  return plan.nodes.map((n2) => n2.id);
}
var GATE_TIMEOUT_MS = 3000;
var GATE_CONCURRENCY = 4;
var GATE_FILE_CAP = 24;
async function surfaceLspDiagnostics(repoRoot, workItemId2, changedFiles) {
  const targets = changedFiles.map((file) => ({ file, language: lspLanguageForPath(file) })).filter((t2) => t2.language !== null);
  const serverByLang = new Map;
  const checkable = targets.filter(({ language }) => {
    let ok = serverByLang.get(language);
    if (ok === undefined) {
      ok = resolveServer(language) !== null;
      serverByLang.set(language, ok);
    }
    return ok;
  });
  if (checkable.length === 0)
    return [];
  const checked = checkable.slice(0, GATE_FILE_CAP);
  const truncated = checkable.length - checked.length;
  const surfaced = [];
  for (let i2 = 0;i2 < checked.length; i2 += GATE_CONCURRENCY) {
    const batch = await Promise.all(checked.slice(i2, i2 + GATE_CONCURRENCY).map(async ({ file, language }) => {
      const diags = await getDiagnostics(join29(repoRoot, file), {
        language,
        timeoutMs: GATE_TIMEOUT_MS
      });
      const errors3 = diags.filter((d2) => d2.severity === "error");
      return errors3.length > 0 ? { file, diagnostics: errors3 } : null;
    }));
    for (const r3 of batch)
      if (r3)
        surfaced.push(r3);
  }
  try {
    await ensureDir(localDir(repoRoot, "work-items", workItemId2));
    await atomicWriteText(localDir(repoRoot, "work-items", workItemId2, "lsp-diagnostics.json"), `${JSON.stringify({
      schema_version: "0.1.0",
      advisory: true,
      checked: checked.length,
      truncated,
      files: surfaced
    }, null, 2)}
`);
  } catch {}
  return surfaced;
}
async function planRequiresDecisionApproval(repoRoot, workItemId2) {
  let text;
  try {
    text = await readFile3(localDir(repoRoot, "work-items", workItemId2, "decision-conflict.json"), "utf8");
  } catch {
    return false;
  }
  try {
    const parsed = decisionConflictCarrier.safeParse(JSON.parse(text));
    return parsed.success && decisionConflictRequiresApproval(parsed.data.conflicts);
  } catch {
    return false;
  }
}
var ORACLE_UNSATISFIED_MARKER = "oracle-unsatisfied";
function oracleUnsatisfiedReason(unmet) {
  return `${ORACLE_UNSATISFIED_MARKER}: ${unmet.join("; ")}`;
}
function sameOracleFailureCount(decisions, nodeId, criterionIds) {
  const target = new Set(criterionIds);
  return decisions.filter((d2) => {
    if (d2.node_id !== nodeId)
      return false;
    if (!d2.reason.startsWith(ORACLE_UNSATISFIED_MARKER))
      return false;
    if (d2.criterion_ids === undefined)
      return true;
    return d2.criterion_ids.some((id) => target.has(id));
  }).length;
}
function unmetOracles(node2, payload, oracleById) {
  const inPlay = new Set(node2.acceptance_refs);
  const topLevel = payload.evidence_refs ?? [];
  const verdicts = payload.ac_verdicts ?? [];
  const passedAcs = verdicts.length > 0 ? verdicts.filter((v2) => v2.verdict === "pass").map((v2) => v2.criterion_id) : [...inPlay];
  const criterionIds = [];
  const reasons = [];
  for (const acId of passedAcs) {
    if (!inPlay.has(acId))
      continue;
    const oracle = oracleById.get(acId);
    if (oracle === undefined)
      continue;
    const perAc = verdicts.filter((v2) => v2.criterion_id === acId).flatMap((v2) => v2.evidence_refs ?? []);
    const closing = [...topLevel, ...perAc];
    const sat = oracleSatisfaction(acId, oracle, closing);
    if (!sat.pass) {
      criterionIds.push(acId);
      reasons.push(sat.reasons[0] ?? `${acId}: oracle unsatisfied`);
    }
  }
  return { criterionIds, reasons };
}
async function recordLoopTermination(aps, workItemId2, decisions, spec) {
  const lastTermination = decisions.filter((d2) => d2.decision === "loop_terminated").at(-1);
  if (lastTermination?.disposition === spec.disposition)
    return;
  await aps.appendDecision(workItemId2, {
    ts: spec.now.toISOString(),
    node_id: workItemId2,
    decision: "loop_terminated",
    disposition: spec.disposition,
    reason: `loop terminated (${spec.disposition}): ${spec.reason}`
  });
}
function isGatherableOracle(oracle) {
  return oracle !== undefined && (oracle.verification_method === "dynamic_test" || oracle.verification_method === "static_scan");
}
async function applyAutoResolveSplice(args) {
  const { aps, workItemId: workItemId2, node: node2, graph, trigger, evidenceRefs, guardReason, now } = args;
  const loopRoundsSoFar = totalForwardRounds(graph.nodes.map((n2) => n2.id));
  const loopCapHit = loopRoundsSoFar >= graph.caps.loop_rounds;
  const plan = loopCapHit ? {
    decision: "escalate",
    reason: `loop-level iteration cap reached (${loopRoundsSoFar} forward rounds \u2265 loop_rounds ${graph.caps.loop_rounds}) with an unresolved ${trigger} item on ${node2.id}; capped \u2260 converged, escalate rather than expand`
  } : planForwardReexpansion({
    reviewNode: node2,
    hasFindings: true,
    round: forwardRound(node2.id),
    budget: graph.caps.no_progress_rounds,
    trigger,
    ...args.blockedByOptionalTool ? { blockedByOptionalTool: args.blockedByOptionalTool } : {}
  });
  const passOutcome = (promoted) => ({
    node_id: node2.id,
    status: "passed",
    outcome: "pass",
    guard_contentful: true,
    decision: null,
    failure_class: null,
    cap_exceeded: false,
    reason: guardReason,
    promoted_node_ids: promoted,
    superseded_node_ids: []
  });
  if (plan.decision === "surface") {
    await aps.updateNode(workItemId2, node2.id, (n2) => ({
      ...n2,
      status: nodeTransition(n2.status, "pass"),
      evidence_refs: evidenceRefs ?? n2.evidence_refs
    }));
    await aps.appendDecision(workItemId2, {
      ts: now.toISOString(),
      node_id: node2.id,
      decision: "surface",
      resolvability: plan.resolvability,
      reason: plan.reason
    });
    return passOutcome([]);
  }
  if (plan.decision === "expand") {
    await aps.addNodes(workItemId2, plan.nodes, args.allowedAcceptanceIds);
    await aps.updateNode(workItemId2, node2.id, (n2) => ({
      ...n2,
      status: nodeTransition(n2.status, "pass"),
      evidence_refs: evidenceRefs ?? n2.evidence_refs
    }));
    return passOutcome(plan.nodes.map((n2) => n2.id));
  }
  const reason = plan.decision === "escalate" ? plan.reason : guardReason;
  await aps.updateNode(workItemId2, node2.id, (n2) => ({
    ...n2,
    status: nodeTransition(n2.status, "block")
  }));
  await aps.appendDecision(workItemId2, {
    ts: now.toISOString(),
    node_id: node2.id,
    failure_class: "user_decision_needed",
    decision: "escalate",
    reason,
    attempts: node2.attempts
  });
  return {
    node_id: node2.id,
    status: "blocked",
    outcome: "fail",
    guard_contentful: true,
    decision: "escalate",
    failure_class: "user_decision_needed",
    cap_exceeded: true,
    reason,
    promoted_node_ids: [],
    superseded_node_ids: []
  };
}
async function directPostDecisions(repoRoot, workItemId2) {
  try {
    await postUnpostedDecisions({
      client: createGhClient(),
      store: new WorkItemStore(repoRoot),
      aps: new AutopilotStore(repoRoot)
    }, workItemId2);
  } catch {}
}
async function recordResult(repoRoot, input) {
  const outcome = await recordResultCore(repoRoot, input);
  await directPostDecisions(repoRoot, input.workItemId);
  try {
    const graph = await new AutopilotStore(repoRoot).get(input.workItemId);
    const attachments = await pressureAttachments(repoRoot, input.workItemId, graph);
    return { ...outcome, ...attachments };
  } catch {
    return outcome;
  }
}
async function recordResultCore(repoRoot, input) {
  const aps = new AutopilotStore(repoRoot);
  const graph = await aps.get(input.workItemId);
  const intents = new IntentStore(repoRoot);
  const allowedAcceptanceIds = await intents.exists(input.workItemId) ? new Set((await intents.get(input.workItemId)).acceptance_criteria.map((c3) => c3.id)) : undefined;
  const node2 = graph.nodes.find((n2) => n2.id === input.payload.node_id);
  if (!node2) {
    throw new Error(`node ${input.payload.node_id} not found in autopilot graph for ${input.workItemId}`);
  }
  if (node2.status !== "running") {
    throw new Error(`node ${node2.id} is not running (status=${node2.status}); call next-node first to dispatch it`);
  }
  await new ActiveNodeLeaseStore(repoRoot).removeByNode(input.workItemId, node2.id);
  if (input.payload.direction_fork_stop !== undefined) {
    await ensureDir(localDir(repoRoot, "work-items", input.workItemId));
    await writeJson(localDir(repoRoot, "work-items", input.workItemId, "direction-fork.json"), directionForkCarrier, {
      schema_version: "0.1.0",
      mode: "autopilot",
      node_id: node2.id,
      purpose_change: input.payload.direction_fork_stop.purpose_change,
      no_clear_advantage: input.payload.direction_fork_stop.no_clear_advantage,
      intent_cannot_break_tie: input.payload.direction_fork_stop.intent_cannot_break_tie
    });
  }
  const guard = guardChildResult(input.payload.result_text);
  let contentful = guard.contentful;
  let outcome = input.payload.outcome;
  let failureClass = input.payload.failure_class;
  let guardReason = input.payload.reason ?? "";
  if (!guard.contentful) {
    outcome = "fail";
    failureClass = "fixable";
    guardReason = guard.reason;
  }
  if (contentful && outcome === "pass" && input.payload.envelope !== undefined) {
    const envGuard = guardOwnerEnvelope(input.payload.envelope);
    if (!envGuard.contentful) {
      contentful = false;
      outcome = "fail";
      failureClass = "fixable";
      guardReason = envGuard.reason;
    } else {
      const ownerGuard = guardEnvelopeOwnerMatch(input.payload.envelope, node2.owner);
      if (!ownerGuard.contentful) {
        contentful = false;
        outcome = "fail";
        failureClass = "fixable";
        guardReason = ownerGuard.reason;
      } else {
        const artifactGuard = await guardEnvelopeArtifact(input.payload.envelope, (p) => readFile3(join29(repoRoot, p), "utf8"));
        if (!artifactGuard.contentful) {
          contentful = false;
          outcome = "fail";
          failureClass = "fixable";
          guardReason = artifactGuard.reason;
        }
      }
    }
  }
  if (contentful && outcome === "pass") {
    const mut = guardMutatingEvidence(node2.owner, input.payload.outcome, input.payload.changed_files ?? []);
    if (!mut.contentful) {
      contentful = false;
      outcome = "fail";
      failureClass = "fixable";
      guardReason = mut.reason;
    }
  }
  if (contentful && outcome === "pass" && node2.kind === "design" && input.payload.plan_brief !== undefined) {
    const coverageRan = await new CoverageStore(repoRoot).exists(input.workItemId);
    if (!coverageRan) {
      contentful = false;
      outcome = "fail";
      failureClass = "fixable";
      guardReason = "design pass carried plan_brief but no coverage.json exists \u2014 run the pre-mortem coverage sweep (coverage-next \u2192 coverage-round until dry) before closing the plan stage (claim \u2260 proof)";
    }
  }
  if (contentful && outcome === "pass") {
    const acGuard = guardAcClosingEvidence({
      outcome: input.payload.outcome,
      ac_verdicts: input.payload.ac_verdicts ?? [],
      evidence_refs: input.payload.evidence_refs ?? []
    });
    if (!acGuard.contentful) {
      contentful = false;
      outcome = "fail";
      failureClass = "fixable";
      guardReason = acGuard.reason;
    }
  }
  if (contentful && outcome === "pass" && node2.kind !== "design") {
    const wi = await new WorkItemStore(repoRoot).get(input.workItemId);
    const oracleById = new Map(wi.acceptance_criteria.map((c3) => [c3.id, c3.oracle]));
    const unmet = unmetOracles(node2, input.payload, oracleById);
    if (unmet.reasons.length > 0) {
      const reason = oracleUnsatisfiedReason(unmet.reasons);
      const decisions = await aps.readDecisions(input.workItemId);
      const priorFailures = sameOracleFailureCount(decisions, node2.id, unmet.criterionIds);
      const k2 = graph.caps.oracle_failures_to_block;
      const blockNow = priorFailures + 1 >= k2;
      const event2 = blockNow ? "block" : "retry";
      await aps.updateNode(input.workItemId, node2.id, (n2) => ({
        ...n2,
        status: nodeTransition(n2.status, event2)
      }));
      await aps.appendDecision(input.workItemId, {
        ts: (input.now ?? new Date).toISOString(),
        node_id: node2.id,
        failure_class: blockNow ? "user_decision_needed" : "fixable",
        decision: blockNow ? "escalate" : "retry",
        reason: blockNow ? `${reason} (criterion ${unmet.criterionIds.join(", ")} failed its oracle ${priorFailures + 1}\u2265${k2} times \u2014 blocked, user decision needed)` : reason,
        attempts: node2.attempts,
        criterion_ids: unmet.criterionIds
      });
      return {
        node_id: node2.id,
        status: blockNow ? "blocked" : "pending",
        outcome: "fail",
        guard_contentful: true,
        decision: blockNow ? "escalate" : "retry",
        failure_class: blockNow ? "user_decision_needed" : "fixable",
        cap_exceeded: blockNow,
        reason,
        promoted_node_ids: [],
        superseded_node_ids: []
      };
    }
  }
  if (outcome === "pass") {
    const promotes = (input.payload.generated_nodes?.length ?? 0) > 0 || input.payload.plan_brief !== undefined;
    const autoResolves = (input.payload.residual_risks?.length ?? 0) > 0 || (input.payload.follow_ups?.length ?? 0) > 0;
    if (promotes && autoResolves) {
      throw new Error(`record-result payload for node ${node2.id} carries BOTH a subgraph-promotion signal (generated_nodes/plan_brief) AND an auto-resolve lane (residual_risks/follow_ups); these are mutually exclusive in one pass \u2014 an auto-resolve splice early-returns and would silently drop the promotion. Split them across separate record-result calls.`);
    }
    const fixpoint = input.payload.oracle_fixpoint_reopen;
    if (fixpoint !== undefined) {
      const target = graph.nodes.find((n2) => n2.id === fixpoint.target_node_id);
      if (target !== undefined && target.status === "passed") {
        const reason = oracleUnsatisfiedReason([
          `${fixpoint.criterion_id}: oracle marked closed but evidence mismatch (wrong-fixpoint reopen of ${target.id})`
        ]);
        const decisions = await aps.readDecisions(input.workItemId);
        const priorFailures = sameOracleFailureCount(decisions, target.id, [fixpoint.criterion_id]);
        const k2 = graph.caps.oracle_failures_to_block;
        const blockTarget = priorFailures + 1 >= k2;
        await aps.updateNode(input.workItemId, target.id, (n2) => ({
          ...n2,
          status: nodeTransition(n2.status, "reopen")
        }));
        if (blockTarget) {
          await aps.updateNode(input.workItemId, target.id, (n2) => ({
            ...n2,
            status: nodeTransition(n2.status, "block")
          }));
        }
        await aps.appendDecision(input.workItemId, {
          ts: (input.now ?? new Date).toISOString(),
          node_id: target.id,
          failure_class: blockTarget ? "user_decision_needed" : "fixable",
          decision: blockTarget ? "escalate" : "retry",
          reason: blockTarget ? `${reason} (criterion ${fixpoint.criterion_id} failed its oracle ${priorFailures + 1}\u2265${k2} times \u2014 blocked, user decision needed)` : reason,
          attempts: target.attempts,
          criterion_ids: [fixpoint.criterion_id]
        });
      }
    }
    if (node2.kind === "design" && input.payload.decision_conflicts !== undefined && input.payload.decision_conflicts.length > 0) {
      await ensureDir(localDir(repoRoot, "work-items", input.workItemId));
      await writeJson(localDir(repoRoot, "work-items", input.workItemId, "decision-conflict.json"), decisionConflictCarrier, {
        schema_version: "0.1.0",
        mode: "autopilot",
        conflicts: input.payload.decision_conflicts
      });
    }
    if ((node2.kind === "review" || node2.kind === "security") && input.payload.has_findings === true) {
      const loopRoundsSoFar = totalForwardRounds(graph.nodes.map((n2) => n2.id));
      const loopCapHit = loopRoundsSoFar >= graph.caps.loop_rounds;
      const plan = loopCapHit ? {
        decision: "escalate",
        reason: `loop-level iteration cap reached (${loopRoundsSoFar} forward rounds \u2265 loop_rounds ${graph.caps.loop_rounds}) with findings still open on ${node2.id}; capped \u2260 converged, escalate rather than expand`
      } : planForwardReexpansion({
        reviewNode: node2,
        hasFindings: true,
        round: forwardRound(node2.id),
        budget: graph.caps.converge_rounds
      });
      if (plan.decision === "expand") {
        await aps.addNodes(input.workItemId, plan.nodes, allowedAcceptanceIds);
        await aps.updateNode(input.workItemId, node2.id, (n2) => ({
          ...n2,
          status: nodeTransition(n2.status, "pass"),
          evidence_refs: input.payload.evidence_refs ?? n2.evidence_refs
        }));
        return {
          node_id: node2.id,
          status: "passed",
          outcome: "pass",
          guard_contentful: true,
          decision: null,
          failure_class: null,
          cap_exceeded: false,
          reason: guardReason,
          promoted_node_ids: plan.nodes.map((n2) => n2.id),
          superseded_node_ids: []
        };
      }
      const reason = plan.decision === "escalate" ? plan.reason : guardReason;
      await aps.updateNode(input.workItemId, node2.id, (n2) => ({
        ...n2,
        status: nodeTransition(n2.status, "block")
      }));
      await aps.appendDecision(input.workItemId, {
        ts: (input.now ?? new Date).toISOString(),
        node_id: node2.id,
        failure_class: "user_decision_needed",
        decision: "escalate",
        reason,
        attempts: node2.attempts
      });
      return {
        node_id: node2.id,
        status: "blocked",
        outcome: "fail",
        guard_contentful: true,
        decision: "escalate",
        failure_class: "user_decision_needed",
        cap_exceeded: true,
        reason,
        promoted_node_ids: [],
        superseded_node_ids: []
      };
    }
    if (node2.kind === "verify") {
      const wi = await new WorkItemStore(repoRoot).get(input.workItemId);
      const oracleById = new Map(wi.acceptance_criteria.map((c3) => [c3.id, c3.oracle]));
      const inPlay = new Set(node2.acceptance_refs);
      const gatherableUnverified = (input.payload.ac_verdicts ?? []).some((v2) => v2.verdict === "unverified" && inPlay.has(v2.criterion_id) && isGatherableOracle(oracleById.get(v2.criterion_id)));
      if (gatherableUnverified) {
        return applyAutoResolveSplice({
          aps,
          workItemId: input.workItemId,
          node: node2,
          graph,
          trigger: "reverify",
          evidenceRefs: input.payload.evidence_refs,
          guardReason,
          now: input.now ?? new Date,
          allowedAcceptanceIds,
          ...input.payload.blocked_by_tool ? { blockedByOptionalTool: input.payload.blocked_by_tool } : {}
        });
      }
    }
    const residualRisks = input.payload.residual_risks ?? [];
    if (residualRisks.length > 0) {
      const now = input.now ?? new Date;
      const isAutoFix = (r3) => r3.resolvability === undefined || r3.resolvability === "agent_resolvable";
      for (const r3 of residualRisks.filter((r4) => !isAutoFix(r4))) {
        await aps.appendDecision(input.workItemId, {
          ts: now.toISOString(),
          node_id: node2.id,
          decision: "surface",
          ...r3.resolvability ? { resolvability: r3.resolvability } : {},
          reason: `surface residual risk in-flow (${r3.resolvability}): ${r3.risk}`
        });
      }
      const autoFix = residualRisks.filter(isAutoFix);
      if (autoFix.length > 0) {
        const outcome2 = await applyAutoResolveSplice({
          aps,
          workItemId: input.workItemId,
          node: node2,
          graph,
          trigger: "risk_fix",
          evidenceRefs: input.payload.evidence_refs,
          guardReason,
          now,
          allowedAcceptanceIds,
          ...input.payload.blocked_by_tool ? { blockedByOptionalTool: input.payload.blocked_by_tool } : {}
        });
        if (outcome2.status === "passed" && outcome2.promoted_node_ids.length > 0) {
          for (const r3 of autoFix) {
            await aps.appendDecision(input.workItemId, {
              ts: now.toISOString(),
              node_id: node2.id,
              decision: "auto_fix",
              resolvability: "agent_resolvable",
              reason: `auto-fix residual risk: ${r3.risk}`
            });
          }
        }
        return outcome2;
      }
    }
    const followUps = input.payload.follow_ups ?? [];
    if (followUps.length > 0) {
      const now = input.now ?? new Date;
      const outOfScope = followUps.filter((f3) => !f3.in_scope);
      const inScope = followUps.filter((f3) => f3.in_scope);
      if (outOfScope.length > 0) {
        await aps.appendDecision(input.workItemId, {
          ts: now.toISOString(),
          node_id: node2.id,
          decision: "batch_escalate",
          resolvability: "out_of_scope",
          reason: `batch-escalate ${outOfScope.length} out-of-scope follow-up(s) for separate materialization (loop signals only, does not drive \u2014 R9): ${outOfScope.map((f3) => f3.item).join("; ")}`
        });
      }
      if (inScope.length > 0) {
        return applyAutoResolveSplice({
          aps,
          workItemId: input.workItemId,
          node: node2,
          graph,
          trigger: "follow_up",
          evidenceRefs: input.payload.evidence_refs,
          guardReason,
          now,
          allowedAcceptanceIds,
          ...input.payload.blocked_by_tool ? { blockedByOptionalTool: input.payload.blocked_by_tool } : {}
        });
      }
    }
    const directionFork = input.payload.direction_fork;
    if (directionFork) {
      const intent = await intents.exists(input.workItemId) ? await intents.get(input.workItemId) : undefined;
      if (intent) {
        const workItem2 = await new WorkItemStore(repoRoot).get(input.workItemId);
        const currentGraph = await aps.get(input.workItemId);
        const drift = intentDriftGate({ intent, workItem: workItem2, graph: currentGraph });
        if (drift.reasons.length === 0) {
          await aps.appendDecision(input.workItemId, {
            ts: (input.now ?? new Date).toISOString(),
            node_id: node2.id,
            decision: "direction",
            reason: `autonomous direction fork resolved with a clear advantage; frozen purpose preserved (AC id-set conserved): ${directionFork.trigger}`,
            direction_record: {
              fork_node_id: node2.id,
              trigger: directionFork.trigger,
              options: directionFork.options,
              choice: directionFork.choice,
              intent_basis: directionFork.intent_basis,
              blast_radius: directionFork.blast_radius,
              reverse_cost: directionFork.reverse_cost
            }
          });
        }
      }
    }
    const proposals = input.payload.generated_nodes ?? [];
    let promotedNodeIds = [];
    let supersededNodeIds = [];
    if (proposals.length > 0) {
      const promoted = proposalsToNodes(proposals);
      await aps.addNodes(input.workItemId, promoted, allowedAcceptanceIds);
      promotedNodeIds = promoted.map((n2) => n2.id);
      const barrierFrontier = promotedImplementFrontier(promoted);
      if (barrierFrontier.length > 0) {
        const beforeSupersede = await aps.get(input.workItemId);
        const barrier = beforeSupersede.nodes.find((n2) => n2.kind === "test");
        if (barrier) {
          await aps.updateNode(input.workItemId, barrier.id, (n2) => ({
            ...n2,
            depends_on: barrierFrontier
          }));
        }
      }
      const grown = await aps.get(input.workItemId);
      supersededNodeIds = supersededByPromotion(grown.nodes, node2.id, promoted);
      if (supersededNodeIds.length > 0) {
        await aps.removeNodes(input.workItemId, supersededNodeIds);
      }
    }
    let designEvidenceRefs;
    if (node2.kind === "design" && input.payload.plan_brief !== undefined) {
      const pb = input.payload.plan_brief;
      const requireApproval = await planRequiresDecisionApproval(repoRoot, input.workItemId);
      const assignments = input.payload.ac_oracles ?? [];
      let oracleAssignmentIncomplete = false;
      if (assignments.length > 0) {
        const byCriterion = new Map(assignments.map((a2) => [a2.criterion_id, a2.oracle]));
        const current2 = await new WorkItemStore(repoRoot).get(input.workItemId);
        const currentById = new Map(current2.acceptance_criteria.map((ac) => [ac.id, ac]));
        for (const [criterionId, candidate] of byCriterion) {
          const mismatch = validateAcOracle({ id: criterionId }, candidate);
          if (!mismatch.ok) {
            throw new Error(mismatch.reasons.join("; "));
          }
          const existing = currentById.get(criterionId)?.oracle;
          if (existing !== undefined) {
            const frozen = assertOracleFrozen(existing, candidate);
            if (!frozen.ok) {
              throw new Error(frozen.reasons.join("; "));
            }
          }
        }
        const updated = await new WorkItemStore(repoRoot).update(input.workItemId, (w2) => ({
          ...w2,
          acceptance_criteria: w2.acceptance_criteria.map((ac) => {
            const assigned = byCriterion.get(ac.id);
            return assigned !== undefined ? { ...ac, oracle: assigned } : ac;
          })
        }));
        const inPlay = new Set(node2.acceptance_refs);
        oracleAssignmentIncomplete = updated.acceptance_criteria.some((ac) => inPlay.has(ac.id) && ac.oracle === undefined);
      }
      const grownGraph = await aps.get(input.workItemId);
      const workItem2 = await new WorkItemStore(repoRoot).get(input.workItemId);
      const planIntent = await intents.exists(input.workItemId) ? await intents.get(input.workItemId) : undefined;
      const drift = planIntent ? intentDriftGate({ intent: planIntent, workItem: workItem2, graph: grownGraph }) : { reasons: ["no intent.json \u2014 frozen purpose cannot be confirmed"] };
      const purposePreserving = drift.reasons.length === 0;
      const declaredRisk2 = workItem2.declared_risk ?? {};
      const highRisk = highRiskAssumption({
        non_local: declaredRisk2.non_local ?? false,
        irreversible: declaredRisk2.irreversible ?? false,
        unaudited: declaredRisk2.unaudited ?? false
      });
      const patch = producePlanGate({
        changeSurface: pb.change_surface,
        brief: {
          interface_changes: pb.interface_changes,
          dod: pb.dod,
          test_scenarios: pb.test_scenarios
        },
        tierInputs: pb.tier_inputs,
        requireApproval,
        oracleAssignmentIncomplete,
        purposePreserving,
        highRisk
      });
      const current = await aps.get(input.workItemId);
      await aps.write(input.workItemId, {
        ...current,
        approval_gate: {
          ...current.approval_gate,
          status: patch.status,
          change_surface: patch.change_surface,
          plan_brief: patch.plan_brief
        }
      });
      const coverageStore = new CoverageStore(repoRoot);
      if (await coverageStore.exists(input.workItemId)) {
        const caller = input.payload.evidence_refs ?? [];
        const coverageRel = coverageStore.relMapPath(input.workItemId);
        if (!caller.some((e2) => e2.path === coverageRel)) {
          designEvidenceRefs = [
            ...caller,
            {
              kind: "file",
              path: coverageRel,
              summary: "pre-mortem coverage sweep artifact (plan-stage close)"
            }
          ];
        }
      }
      const grownAfterSupersede = await aps.get(input.workItemId);
      const retroId = `${node2.id}-retro`;
      const retroExists = grownAfterSupersede.nodes.some((n2) => n2.id === retroId);
      const terminalVerifyIds = grownAfterSupersede.nodes.filter((n2) => n2.kind === "verify").filter((v2) => !grownAfterSupersede.nodes.some((m2) => m2.depends_on.includes(v2.id))).map((v2) => v2.id);
      if (!retroExists && terminalVerifyIds.length > 0) {
        const [retroNode] = proposalsToNodes([
          {
            id: retroId,
            kind: "retro",
            purpose: "Retrospect on the run and record measurements",
            depends_on: terminalVerifyIds,
            acceptance_refs: []
          }
        ]);
        if (retroNode)
          await aps.addNodes(input.workItemId, [retroNode], allowedAcceptanceIds);
      }
    }
    await aps.updateNode(input.workItemId, node2.id, (n2) => ({
      ...n2,
      status: nodeTransition(n2.status, "pass"),
      evidence_refs: designEvidenceRefs ?? input.payload.evidence_refs ?? n2.evidence_refs,
      ac_verdicts: input.payload.ac_verdicts ?? n2.ac_verdicts
    }));
    const reported = input.payload.changed_files ?? [];
    if (reported.length > 0) {
      await new WorkItemStore(repoRoot).update(input.workItemId, (w2) => {
        const existing = new Set(w2.changed_files);
        const additions = reported.filter((p) => !existing.has(p));
        return additions.length > 0 ? { ...w2, changed_files: [...w2.changed_files, ...additions] } : w2;
      });
    }
    let lspAdvisory;
    if (isMutatingNode(node2) && reported.length > 0) {
      const surfaced = await surfaceLspDiagnostics(repoRoot, input.workItemId, reported);
      if (surfaced.length > 0)
        lspAdvisory = surfaced;
    }
    if (node2.kind === "implement") {
      const tidyPromoted = await spliceTidyStage(repoRoot, input.workItemId, node2, aps);
      promotedNodeIds = [...promotedNodeIds, ...tidyPromoted];
    }
    if (node2.kind === "retro") {
      try {
        const ctx = await collectRetroContext(repoRoot, input.workItemId, graph);
        const now = (input.now ?? new Date).toISOString();
        let retroSources = [];
        try {
          const wi = await new WorkItemStore(repoRoot).get(input.workItemId);
          const manifestSources = await new MemorySourceStore(repoRoot).list();
          retroSources = codeSourceIdsForPaths(manifestSources, wi.changed_files);
        } catch {}
        await absorbRetroMemory(new MemoryEventStore(repoRoot), ctx.narrative, {
          createdAt: now,
          actorRole: node2.owner,
          sources: retroSources
        });
        await new RetroMetricLedger(repoRoot).append({ work_item_id: input.workItemId, metrics: ctx.metrics }, now);
      } catch {}
    }
    return {
      node_id: node2.id,
      status: "passed",
      outcome: "pass",
      guard_contentful: true,
      decision: null,
      failure_class: null,
      cap_exceeded: false,
      reason: guardReason,
      promoted_node_ids: promotedNodeIds,
      superseded_node_ids: supersededNodeIds,
      ...lspAdvisory ? { lsp_advisory: lspAdvisory } : {}
    };
  }
  if (contentful && node2.kind === "refactor" && input.payload.tidy_bug_found === true) {
    const implementDep = graph.nodes.find((n2) => node2.depends_on.includes(n2.id) && n2.kind === "implement");
    const reason = implementDep !== undefined ? `tidy found a bug \u2014 returning implement node ${implementDep.id} to pending (not fixing here, not retrying the tidy node in place) (ac-4)` : "tidy found a bug but no implement node found in depends_on \u2014 tidy node failed without reopening (ac-4)";
    await aps.updateNode(input.workItemId, node2.id, (n2) => ({
      ...n2,
      status: nodeTransition(n2.status, "fail")
    }));
    if (implementDep !== undefined) {
      await aps.updateNode(input.workItemId, implementDep.id, (n2) => ({
        ...n2,
        status: nodeTransition(n2.status, "reopen")
      }));
    }
    await aps.appendDecision(input.workItemId, {
      ts: (input.now ?? new Date).toISOString(),
      node_id: node2.id,
      failure_class: "fixable",
      decision: "escalate",
      reason,
      attempts: node2.attempts
    });
    return {
      node_id: node2.id,
      status: "failed",
      outcome: "fail",
      guard_contentful: contentful,
      decision: "escalate",
      failure_class: "fixable",
      cap_exceeded: false,
      reason,
      promoted_node_ids: [],
      superseded_node_ids: []
    };
  }
  const klass = failureClass;
  const { decision, cap_exceeded } = decideOnFailure(klass, node2.attempts, graph.caps);
  let event;
  let attempts = node2.attempts;
  switch (decision) {
    case "retry":
      event = "retry";
      attempts = { ...node2.attempts, fix: node2.attempts.fix + 1 };
      break;
    case "switch_approach":
      event = "retry";
      attempts = { ...node2.attempts, switch: node2.attempts.switch + 1 };
      break;
    default:
      event = cap_exceeded ? "fail" : "block";
      break;
  }
  const nextStatus = nodeTransition(node2.status, event);
  await aps.updateNode(input.workItemId, node2.id, (n2) => ({
    ...n2,
    status: nodeTransition(n2.status, event),
    attempts
  }));
  await aps.appendDecision(input.workItemId, {
    ts: (input.now ?? new Date).toISOString(),
    node_id: node2.id,
    failure_class: klass,
    decision,
    reason: guardReason || `${klass} \u2192 ${decision}`,
    attempts
  });
  return {
    node_id: node2.id,
    status: nextStatus,
    outcome: "fail",
    guard_contentful: contentful,
    decision,
    failure_class: klass,
    cap_exceeded,
    reason: guardReason,
    promoted_node_ids: [],
    superseded_node_ids: []
  };
}

// src/core/cite-gate.ts
init_ditto_paths();
import { readFile as readFile4, readdir as readdir12 } from "fs/promises";
import { join as join30 } from "path";
var CITE_RE = /\bdecision:|\bADR-\d/i;
var ABSTAIN_RE = /\babstain|none\s+(?:of\s+the\s+)?(?:governing\s+)?decisions?\s+apply|none\s+apply/i;
function evidenceText(node2) {
  return node2.evidence_refs.map((e2) => [e2.summary, e2.command, e2.path].filter(Boolean).join(" ")).join(" ");
}
function citedOrAbstained(node2) {
  const text = evidenceText(node2);
  return CITE_RE.test(text) || ABSTAIN_RE.test(text);
}
async function checkCiteGate(repoRoot, input) {
  const report = await readUsageReport(repoRoot, input.workItemId);
  const pushedNodeIds = [
    ...new Set(report.records.filter((r3) => r3.actionable).map((r3) => r3.node_id))
  ].sort();
  if (pushedNodeIds.length === 0) {
    return { verdict: "skip", pushed_node_ids: [], warnings: [] };
  }
  const byId = new Map(input.graph.nodes.map((n2) => [n2.id, n2]));
  const warnings = [];
  for (const id of pushedNodeIds) {
    const node2 = byId.get(id);
    if (!node2 || !citedOrAbstained(node2)) {
      warnings.push({
        node_id: id,
        message: `\uB178\uB4DC ${id}\uB294 \uAC70\uBC84\uB2DD \uACB0\uC815 push\uB97C \uBC1B\uC558\uC73C\uB098 \uCD9C\uB825\uC774 \uACB0\uC815\uC744 \uC778\uC6A9(cite)\uD558\uC9C0\uB3C4 \uBA85\uC2DC\uC801\uC73C\uB85C \uAE30\uAD8C(abstain)\uD558\uC9C0\uB3C4 \uC54A\uC558\uB2E4 \u2014 \uACB0\uC815 \uBB34\uC2DC \uAC00\uB2A5\uC131(advisory, ac-2)`
      });
    }
  }
  return {
    verdict: warnings.length > 0 ? "warning" : "pass",
    pushed_node_ids: pushedNodeIds,
    warnings
  };
}
function crossValidateCite(cite, measurement, options = {}) {
  const rate = measurement.reproposal_rate;
  const baseline = options.baseline_reproposal_rate;
  let combined;
  if (cite.verdict !== "pass") {
    combined = "not-applicable";
  } else if (baseline === undefined) {
    combined = "cannot-confirm";
  } else if (rate <= baseline) {
    combined = "confirmed";
  } else {
    combined = "cited-but-unvalidated";
  }
  return {
    combined,
    cite_verdict: cite.verdict,
    reproposal_rate: rate,
    ...baseline !== undefined ? { baseline_reproposal_rate: baseline } : {},
    advisory: true
  };
}
function conflictsFromHits(pushedNodeIds, report) {
  return report.reproposal_hits.map((h2) => {
    const node_id = pushedNodeIds[h2.candidate_index] ?? "?";
    return {
      node_id,
      adr_id: h2.adr_id,
      rejected_alternative: h2.item,
      matched_token: h2.matched_token,
      message: `\uB178\uB4DC ${node_id} \uCD9C\uB825\uC774 ${h2.adr_id}\uAC00 \uAE30\uAC01\uD55C \uB300\uC548 "${h2.item.slice(0, 60)}"\uC744(\uB97C) \uC7AC\uC81C\uC548\uD560 \uC218 \uC788\uC74C (matched: "${h2.matched_token}", advisory\xB7FN\uC6B0\uC120)`
    };
  });
}
function citeNeedsReproposalMeasurement(verdict2) {
  return verdict2 === "pass";
}
async function loadAdrBodies(repoRoot) {
  const adrDir = join30(dittoDir(repoRoot), "knowledge", "adr");
  let names;
  try {
    names = (await readdir12(adrDir)).filter((n2) => n2.endsWith(".md")).sort();
  } catch {
    return [];
  }
  return Promise.all(names.map(async (n2) => ({ id: n2, body: await readFile4(join30(adrDir, n2), "utf8") })));
}
async function detectActiveConflicts(repoRoot, input) {
  const report = await readUsageReport(repoRoot, input.workItemId);
  const pushedNodeIds = [
    ...new Set(report.records.filter((r3) => r3.actionable).map((r3) => r3.node_id))
  ].sort();
  if (pushedNodeIds.length === 0)
    return [];
  const byId = new Map(input.graph.nodes.map((n2) => [n2.id, n2]));
  const candidates = pushedNodeIds.map((id) => {
    const node2 = byId.get(id);
    return node2 ? evidenceText(node2) : "";
  });
  const adrs = await loadAdrBodies(repoRoot);
  return conflictsFromHits(pushedNodeIds, measureHallucination(adrs, candidates));
}

