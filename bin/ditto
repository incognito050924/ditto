    }).optional()
  }).describe("One coverage interrogation round handed back to the deterministic Manager (\xA75)");
  coverageTaxonomyConfig = exports_external.object({
    disabled: exports_external.array(exports_external.string().min(1)).optional().describe("Floor category ids to turn off for this project (ac-10)"),
    disabled_reasons: exports_external.record(exports_external.string().min(1), exports_external.string().min(1)).optional().describe("Optional disable justification per floor-category id (wi_260707phi, ac-3)"),
