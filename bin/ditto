function repoRel(repoRoot, abs) {
  return relative18(repoRoot, abs).split(sep8).join("/");
}
function slugFromJourney(journeyPath) {
  const base = basename4(journeyPath);
  return base.endsWith(".journey.md") ? base.slice(0, -".journey.md".length) : base.replace(/\.[^.]+$/, "");
}
async function loadBlockBodies(journeyAbs, useBlocks) {
  const out = {};
  const blocksDir = join68(dirname14(journeyAbs), "blocks");
  for (const id of useBlocks) {
    try {
      const text = await readFile16(join68(blocksDir, `${id}.block.md`), "utf8");
      out[id] = { body: splitFrontMatter(text)?.body ?? text };
    } catch {}
  }
  return out;
}
function buildRedactionRule(fm) {
  const secretVars = fm.secret_vars;
  const credentialRefs = [...Object.values(fm.auth?.credentials ?? {})];
  const seedData = fm.seed?.data_ref;
  if (seedData && /^(env|secret):/.test(seedData))
    credentialRefs.push(seedData);
  const envValues = {};
  for (const v2 of secretVars) {
    const val = process.env[v2];
    if (val)
      envValues[v2] = val;
  }
  for (const ref of credentialRefs) {
    const m4 = /^(?:env|secret):(.+)$/.exec(ref);
    const name = m4?.[1];
    if (!name)
      continue;
    const val = process.env[name];
    if (val)
      envValues[name] = val;
  }
  return { secretVars, credentialRefs, envValues };
}
async function readJourney(journeyAbs) {
  const text = await readFile16(journeyAbs, "utf8");
  const parsed = parseJourneyDoc(text);
  if (!parsed.ok)
    return { ok: false, error: parsed.error };
  return {
    ok: true,
    frontMatter: parsed.frontMatter,
    body: splitFrontMatter(text)?.body ?? "",
    text
  };
}
function buildGenerateInput(params) {
  const { repoRoot, host, journey, journeyText, journeyAbs, slug, digest, projection } = params;
  return {
    repoRoot,
    host,
    journeyId: journey.id,
    plan: projection.plan,
    planMap: projection.map,
    planAssertions: projection.assertions,
    dslOriginal: journeyText,
    header: {
      sourcePath: repoRel(repoRoot, journeyAbs),
      digest,
      kind: "journey",
      id: journey.id
    },
    specPath: `e2e/generated/${slug}.spec.ts`,
    planPath: `specs/${slug}.plan.md`
  };
}
var e2ePlan = defineCommand({
