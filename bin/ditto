var commandLogEntry = exports_external.object({
  ts: isoDateTime,
  kind: exports_external.literal("command").describe("Discriminator; only command entries are currently defined"),
  command: exports_external.string().min(1).describe("Exact command line as executed"),
  exit_code: exports_external.number().int(),
  duration_ms: exports_external.number().int().nonnegative().optional(),
  sha256: sha256.optional().describe("Hash of captured output when stored as artifact"),
  output_path: relativePath.optional().describe("Repo-relative path to the captured stdout/stderr file if stored separately"),
  work_item_id: exports_external.string().regex(/^wi_[a-z0-9]{8,}$/).optional().describe("Work item that owns this log entry; redundant with file location but kept for self-contained replay"),
  criterion_id: exports_external.string().optional().describe("Acceptance criterion this command was meant to verify, if any")
}).describe("One line of .ditto/local/work-items/<id>/evidence/commands.jsonl");
var editLogEntry = exports_external.object({
  ts: isoDateTime,
  kind: exports_external.literal("edit").describe("Discriminator for file-mutation tool entries"),
  tool: exports_external.enum(["Edit", "Write", "MultiEdit"]).describe("The file-mutation tool that produced this change"),
  file_path: exports_external.string().min(1).describe("Path of the edited/written file as the tool received it"),
  work_item_id: exports_external.string().regex(/^wi_[a-z0-9]{8,}$/).optional().describe("Work item that owns this log entry; redundant with file location")
}).describe("One line of .ditto/local/work-items/<id>/evidence/edits.jsonl. Records Edit/Write/MultiEdit " + "tool use so evidence collection is not command-only (V6); audit of what files a node touched.");

// src/core/evidence-store.ts
init_ditto_paths();
init_fs();

class EvidenceStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  workItemDir(workItemId2) {
    return localDir(this.repoRoot, "work-items", workItemId2);
  }
  evidenceDir(workItemId2) {
    return join49(this.workItemDir(workItemId2), "evidence");
  }
  commandsPath(workItemId2) {
    return join49(this.evidenceDir(workItemId2), "commands.jsonl");
  }
  evidenceIndexPath(workItemId2) {
    return join49(this.workItemDir(workItemId2), "evidence-index.json");
  }
  async appendCommand(workItemId2, entry) {
    const parsed = commandLogEntry.parse(entry);
    await ensureDir(this.evidenceDir(workItemId2));
    const path = this.commandsPath(workItemId2);
    const file = Bun.file(path);
    const existing = await file.exists() ? await file.text() : "";
    const trimmed = existing.length === 0 || existing.endsWith(`
`) ? existing : `${existing}
`;
    const line = JSON.stringify(parsed);
    await atomicWriteText(path, `${trimmed}${line}
`);
    return parsed;
  }
  async readAll(workItemId2) {
    const path = this.commandsPath(workItemId2);
    const file = Bun.file(path);
    if (!await file.exists())
      return [];
    const text = await file.text();
    const lines = text.split(`
`).filter((l2) => l2.length > 0);
    return lines.map((line, idx) => {
      try {
        return commandLogEntry.parse(JSON.parse(line));
      } catch (err) {
        throw new Error(`commands.jsonl ${path}:${idx + 1} invalid: ${String(err)}`);
      }
    });
  }
  async readIndex(workItemId2) {
    const path = this.evidenceIndexPath(workItemId2);
    if (!await Bun.file(path).exists()) {
      return { schema_version: "0.1.0", work_item_id: workItemId2, records: [] };
    }
    return readJson(path, evidenceIndex);
  }
  async appendRecord(workItemId2, record) {
    const current = await this.readIndex(workItemId2);
    const next = {
      schema_version: "0.1.0",
      work_item_id: workItemId2,
      records: [...current.records, evidenceRecord.parse(record)]
    };
    await ensureDir(this.workItemDir(workItemId2));
    return writeJson(this.evidenceIndexPath(workItemId2), evidenceIndex, next);
  }
}
function sha256Hex2(content) {
  const hash = createHash6("sha256");
  hash.update(content);
  return hash.digest("hex");
}

// src/cli/commands/codeql.ts
init_fs();
async function drainStream2(stream) {
  return new Response(stream).text();
}
function composeEnv2(base, set, unset) {
  const env2 = {};
  for (const [k2, v2] of Object.entries(base))
    if (v2 !== undefined)
      env2[k2] = v2;
  for (const [k2, v2] of Object.entries(set))
    env2[k2] = v2;
  for (const k2 of unset)
    delete env2[k2];
  return env2;
}
function defaultLedgerDeps(repoRoot) {
  const evidence = new EvidenceStore(repoRoot);
  const ledgerStore = new AcgReviewStore(repoRoot);
  return {
    spawn: ({ binary, args, repoRoot: root, cwd, env: env2 }) => {
      const proc = Bun.spawn([binary, ...args], {
        cwd: cwd === "." ? root : cwd,
        env: composeEnv2(process.env, env2.set, env2.unset),
        stdout: "pipe",
        stderr: "pipe",
        stdin: "ignore"
      });
      return {
        entrypoint: binary,
        stdout: proc.stdout,
        stderr: proc.stderr,
        completion: proc.exited.then((code) => ({ exit_code: code, model_reported: null }))
      };
    },
    readText: (path) => Bun.file(path).text(),
    fileExists: (path) => Bun.file(path).exists(),
    drain: drainStream2,
    appendRecord: (workItemId2, record) => evidence.appendRecord(workItemId2, record),
    sha256: sha256Hex2,
    now: () => new Date().toISOString(),
    collectExtensions: defaultDoctorDeps.collectExtensions,
    cliAvailable: defaultDoctorDeps.cliAvailable,
    genReviewId: () => generateId("rv", async () => false),
    persistReviewerOutput: async (workItemId2, output) => {
      const path = localDir(repoRoot, "work-items", workItemId2, "reviewer-output.json");
      await ensureDir(localDir(repoRoot, "work-items", workItemId2));
      await writeJson(path, reviewerOutput, output);
    },
    persistLedger: async (workItemId2, graph) => {
      await ledgerStore.write(workItemId2, graph);
    },
    persistDataflowDoDs: async (workItemId2, dods) => {
      const path = localDir(repoRoot, "work-items", workItemId2, "dataflow-dod.json");
      await ensureDir(localDir(repoRoot, "work-items", workItemId2));
      await atomicWriteText(path, `${JSON.stringify({ schema_version: "0.1.0", dods }, null, 2)}
`);
    }
  };
}
function defaultSuite(language) {
  return `codeql/${language}-queries:codeql-suites/${language}-security-extended.qls`;
}
async function gitHeadSha2(repoRoot) {
  try {
    const proc = Bun.spawnSync(["git", "rev-parse", "HEAD"], { cwd: repoRoot });
    const sha = proc.stdout?.toString().trim();
    if (sha && /^[0-9a-f]{7,40}$/.test(sha))
      return sha;
  } catch {}
  return "workingdir000";
}
var reviewSubcommand = defineCommand({
  meta: {
    name: "review",
    description: "Run CodeQL (doctor-gated) and project findings into the acg-review.json risk ledger the Stop gate reads"
  },
  args: {
    "work-item": {
      type: "string",
      description: "Work item id to write the ledger under",
      required: true
    },
    "source-root": { type: "string", description: "Analysis source root (default: <repo>/src)" },
    language: { type: "string", description: "CodeQL language (default: javascript)" },
    suite: { type: "string", description: "Query suite spec (default: <lang>-security-extended)" },
    "build-command": {
      type: "string",
      description: "Build command for manual build-mode (compiled langs)"
    },
    "build-verified": {
      type: "boolean",
      default: false,
      description: "Assert a clean build was reproduced (unblocks compiled languages)"
    },
    binary: { type: "string", description: "CodeQL binary (default 'codeql' on PATH)" },
    download: { type: "boolean", default: true, description: "Auto-download query packs" },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    try {
      const repoRoot = await resolveRepoRootForCreate();
      const language = args.language ?? "javascript";
      const sourceRoot = args["source-root"] ?? join50(repoRoot, "src");
      const commitSha = await gitHeadSha2(repoRoot);
      const key = cacheKey(commitSha, language);
      const dbPath = localDir(repoRoot, "cache", "codeql", key, "db");
      const sarifPath = localDir(repoRoot, "work-items", args["work-item"], "evidence", `codeql-${key}.sarif`);
      await ensureDir(localDir(repoRoot, "cache", "codeql", key));
      await ensureDir(localDir(repoRoot, "work-items", args["work-item"], "evidence"));
      const res = await runCodeqlReviewToLedger({
        workItemId: args["work-item"],
        repoRoot,
        sourceRoot,
        language,
        commitSha,
        dbPath,
        sarifPath,
        suite: args.suite ?? defaultSuite(language),
        buildCommand: args["build-command"],
        buildVerified: args["build-verified"],
        binary: args.binary,
        download: args.download
      }, defaultLedgerDeps(repoRoot));
      if (format === "json") {
        writeJson2(res);
      } else if (res.gated) {
        writeHuman(`codeql review GATED \u2014 doctor\u5148\u884C blocked, no analysis/ledger. Fix first:
${res.doctor.findings.map((f3) => `  ${f3.severity}	${f3.kind}	${f3.message}`).join(`
`)}`);
      } else {
        const dodLines = res.dataflowDoDs.map((d2) => `  DoD ${d2.rule_id}: GIVEN ${d2.given} WHEN ${d2.when} THEN ${d2.then}`).join(`
`);
        writeHuman(`codeql review: ${res.findings} finding(s), verdict=${res.verdict}, ${res.highRiskWithoutEvidence} high-risk without evidence \u2192 acg-review.json ${res.ledgerWritten ? "written" : "not written"}${res.dataflowDoDs.length > 0 ? `
${res.dataflowDoDs.length} dataflow DoD(s) \u2192 dataflow-dod.json
${dodLines}` : ""}`);
      }
      if (res.gated)
        process.exit(USAGE_ERROR_EXIT);
    } catch (err) {
      writeError(`codeql review failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var codeqlCommand = defineCommand({
  meta: {
    name: "codeql",
    description: "CodeQL deterministic provider \u2014 analyze and feed the ACG gate"
  },
  subCommands: { review: reviewSubcommand }
});

