];
var TEMPLATE_SUFFIXES = [".example", ".sample", ".template", ".dist", ".tmpl"];
function isTemplatePath(p2) {
  return TEMPLATE_SUFFIXES.some((s2) => p2.endsWith(s2));
}
function isSecretPath(p2) {
  if (isTemplatePath(p2))
    return false;
  return SECRET_PATTERNS.some((re) => re.test(p2));
}
var METADATA_VERBS = new Set([
