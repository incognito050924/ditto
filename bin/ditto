// src/schemas/acg-architecture-spec.ts
init_zod();
var acgConventions = exports_external.object({
  formatter: exports_external.object({ cmd: exports_external.string().min(1), on_violation: exports_external.enum(["block", "warn"]).default("block") }).optional(),
  linter: exports_external.object({ cmd: exports_external.string().min(1), on_violation: exports_external.enum(["block", "warn"]).default("block") }).optional(),
  naming: exports_external.object({ rule: exports_external.string().min(1), evaluator: exports_external.enum(["deterministic", "llm_judged"]) }).optional(),
  approved_patterns: exports_external.array(exports_external.string().min(1)).default([]),
  exceptions: exports_external.array(exports_external.object({ rule: exports_external.string().min(1), path: exports_external.string().min(1), reason: exports_external.string().min(1) })).default([])
}).describe("Style/quality consistency policy \u2014 deterministic enforcement substrate (\xA71.1(1))");
var acgInternalPackage = exports_external.object({
  type: exports_external.enum(["glob", "path"]),
  value: exports_external.string().min(1)
}).describe("Internal sibling-module descriptor \u2014 `glob`: package-name glob for cross_repo classification; " + "`path`: repo-relative glob locating the local sibling artifact (JAR) for the JVM guard");
var acgArchitectureSpec = exports_external.object({
  ...acgCatalogEnvelope("acg.architecture-spec.v1"),
  layers: exports_external.record(exports_external.string(), exports_external.object({ can_call: exports_external.array(exports_external.string()).default([]) })).default({}).describe("Layer name \u2192 allowed call targets"),
  public_surfaces: exports_external.array(exports_external.string().min(1)).default([]),
  internal_packages: exports_external.array(acgInternalPackage).default([]).describe("Internal sibling-module descriptors. `glob` entries are package-name globs (e.g. " + '"kr.co.ecoletree.boxwood.domain.**"): a statically unresolved dep (NOT fromSource) whose ' + "package matches one is a sibling module absent from this single-module DB \u2192 recorded as " + "ImpactGraph.unresolved{cross_repo}; non-matching packages are third-party (Spring/JDK) and " + "ignored. `path` entries are repo-relative globs locating the local sibling artifacts " + '(e.g. "**/libs/*.jar"): the JVM guard blocks when such a JAR exists but the declaration ' + "has a gap (no glob, or a JAR not covered by a path entry)."),
  forbidden_dependencies: exports_external.array(exports_external.object({ from: exports_external.string().min(1), to: exports_external.string().min(1), reason: exports_external.string().min(1) })).default([]),
  ownership: exports_external.array(exports_external.object({ module: exports_external.string().min(1), owner: exports_external.string().min(1) })).default([]),
  module_invariants: exports_external.array(exports_external.string().min(1)).default([]).describe("Generalizable invariants \u2014 FitnessFunction promotion candidates"),
  conventions: acgConventions.optional()
}).describe("ACG ArchitectureSpec \u2014 layers, surfaces, forbidden deps, conventions");

// src/acg/architecture/propose.ts
function layerOf(repoRelPath) {
  const parts = repoRelPath.split("/");
  return parts[0] === "src" && parts.length > 2 ? parts[1] : undefined;
}
function buildCandidateSpec(obs, producedAt) {
  return acgArchitectureSpec.parse({
    schema_version: "0.1.0",
    kind: "acg.architecture-spec.v1",
    produced_by: "agent",
    produced_at: producedAt,
    layers: Object.fromEntries([...new Set(obs.layers)].sort().map((l2) => [l2, { can_call: [] }])),
    public_surfaces: [...new Set(obs.publicSurfaces)].sort(),
    forbidden_dependencies: [],
    module_invariants: []
  });
}
async function walkTsFiles(repoRoot, dir, acc) {
  let entries;
  try {
    entries = await readdir4(dir, { withFileTypes: true });
  } catch {
    return;
  }
  for (const e2 of entries) {
    if (e2.name === "node_modules" || e2.name.startsWith("."))
      continue;
    const full = join9(dir, e2.name);
    if (e2.isDirectory())
      await walkTsFiles(repoRoot, full, acc);
    else if (/\.[cm]?tsx?$/.test(e2.name) && !/\.(test|spec)\./.test(e2.name))
      acc.push(relative3(repoRoot, full));
  }
}
async function observeArchitecture(repoRoot, sourceRoot, edgeAnalyzer) {
  const files = [];
  await walkTsFiles(repoRoot, sourceRoot, files);
  const edges = await edgeAnalyzer.edges({ changedFiles: files, sourceRoot });
  const layers = new Set;
  for (const f3 of files) {
    const l2 = layerOf(f3);
    if (l2)
      layers.add(l2);
  }
  const publicSurfaces = new Set;
  for (const e2 of edges) {
    if (!e2.to.startsWith("src/"))
      continue;
    const fromLayer = layerOf(e2.from);
    const toLayer = layerOf(`${e2.to}.ts`);
    if (fromLayer && toLayer && fromLayer !== toLayer)
      publicSurfaces.add(e2.to);
  }
  return { layers: [...layers], publicSurfaces: [...publicSurfaces] };
}

// src/acg/architecture/ratify.ts
function ratifyCandidateSpec(candidate, opts) {
  if (candidate.produced_by === "user") {
    throw new Error("ratify: spec is already authoritative (produced_by=user) \u2014 nothing to ratify");
  }
  return acgArchitectureSpec.parse({
    ...candidate,
    produced_by: "user",
    produced_at: opts.ratifiedAt,
    forbidden_dependencies: opts.forbidden
  });
}

