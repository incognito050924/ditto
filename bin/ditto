        writeError(err.message);
        process.exit(USAGE_ERROR_EXIT);
        return;
      }
      writeError(`classify stage failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
