var select2 = (t3) => {
  const a4 = (i2, m4) => {
    const s2 = i2.label ?? String(i2.value);
    switch (m4) {
      case "disabled":
        return `${styleText2("gray", S_RADIO_INACTIVE)} ${c4(s2, (n3) => styleText2("gray", n3))}${i2.hint ? ` ${styleText2("dim", `(${i2.hint ?? "disabled"})`)}` : ""}`;
      case "selected":
        return `${c4(s2, (n3) => styleText2("dim", n3))}`;
      case "active":
        return `${styleText2("green", S_RADIO_ACTIVE)} ${s2}${i2.hint ? ` ${styleText2("dim", `(${i2.hint})`)}` : ""}`;
      case "cancelled":
        return `${c4(s2, (n3) => styleText2(["strikethrough", "dim"], n3))}`;
      default:
        return `${styleText2("dim", S_RADIO_INACTIVE)} ${c4(s2, (n3) => styleText2("dim", n3))}`;
    }
  };
  return new a3({
    options: t3.options,
    signal: t3.signal,
    input: t3.input,
    output: t3.output,
    initialValue: t3.initialValue,
    render() {
      const i2 = t3.withGuide ?? settings.withGuide, m4 = `${symbol(this.state)}  `, s2 = `${symbolBar(this.state)}  `, n3 = wrapTextWithPrefix(t3.output, t3.message, s2, m4), u6 = `${i2 ? `${styleText2("gray", S_BAR)}
` : ""}${n3}
`;
      switch (this.state) {
        case "submit": {
          const r4 = i2 ? `${styleText2("gray", S_BAR)}  ` : "", o4 = wrapTextWithPrefix(t3.output, a4(this.options[this.cursor], "selected"), r4);
          return `${u6}${o4}`;
        }
        case "cancel": {
          const r4 = i2 ? `${styleText2("gray", S_BAR)}  ` : "", o4 = wrapTextWithPrefix(t3.output, a4(this.options[this.cursor], "cancelled"), r4);
          return `${u6}${o4}${i2 ? `
${styleText2("gray", S_BAR)}` : ""}`;
        }
        default: {
          const r4 = i2 ? `${styleText2("cyan", S_BAR)}  ` : "", o4 = u6.split(`
`).length, $ = formatInstructionFooter(SELECT_INSTRUCTIONS, i2), h3 = $.join(`
`), b3 = $.length + 1;
          return `${u6}${r4}${limitOptions({
            output: t3.output,
            cursor: this.cursor,
            options: this.options,
            maxItems: t3.maxItems,
            columnPadding: r4.length,
            rowPadding: o4 + b3,
            style: (p2, x2) => a4(p2, p2.disabled ? "disabled" : x2 ? "active" : "inactive")
          }).join(`
${r4}`)}
${h3}
`;
        }
      }
    }
  }).prompt();
