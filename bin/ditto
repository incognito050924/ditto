// src/core/work-item-handoff.ts
import { join as join65 } from "path";
init_ditto_paths();
init_fs();
class InvalidBaseRefError extends Error {
  ref;
  constructor(ref) {
    super(`--base "${ref}" is not a valid git ref in this repository`);
    this.ref = ref;
    this.name = "InvalidBaseRefError";
  }
}

class InvalidHeadRefError extends Error {
  ref;
  constructor(ref) {
    super(`--head "${ref}" is not a valid git ref in this repository`);
    this.ref = ref;
    this.name = "InvalidHeadRefError";
  }
}
function pickBaseRef(repoRoot, candidates) {
  for (const ref of candidates) {
    const proc = Bun.spawnSync(["git", "rev-parse", "--verify", "--quiet", `${ref}^{commit}`], {
      cwd: repoRoot,
      stdout: "pipe",
      stderr: "pipe"
    });
    if (proc.exitCode === 0)
      return ref;
  }
  return null;
}
function collectChangedFiles(repoRoot, base, head) {
  const set = new Set;
  if (base !== null) {
    const headSpec = head ?? "HEAD";
    const diff = Bun.spawnSync(["git", "diff", "--name-only", "--diff-filter=ACMR", `${base}...${headSpec}`], { cwd: repoRoot, stdout: "pipe", stderr: "pipe" });
    if (diff.exitCode === 0) {
      const text = diff.stdout?.toString() ?? "";
      for (const line of text.split(`
`)) {
        const t2 = line.trim();
        if (t2.length > 0)
          set.add(t2);
      }
    }
  }
  if (head === null) {
    const status = Bun.spawnSync(["git", "status", "--porcelain"], {
      cwd: repoRoot,
      stdout: "pipe",
      stderr: "pipe"
    });
    if (status.exitCode === 0) {
      const text = status.stdout?.toString() ?? "";
      for (const line of text.split(`
`)) {
        const trimmed = line.replace(/^..\s*/, "").trim();
        if (trimmed.length === 0)
          continue;
        const arrow = trimmed.indexOf(" -> ");
        const path = arrow === -1 ? trimmed : trimmed.slice(arrow + 4);
        set.add(path);
      }
    }
  }
  return Array.from(set).filter((p) => !p.startsWith("/") && !p.includes(".."));
}
function buildCompletion2(item, declaredAt, changedFiles, declaredBy, unverifiedExtras = [], prior, graphAcceptance) {
  const acceptance = graphAcceptance ?? item.acceptance_criteria.map((ac) => ({
    criterion_id: ac.id,
    verdict: ac.verdict,
    evidence: ac.evidence
  }));
  const allPass = acceptance.every((a2) => a2.verdict === "pass");
  const blockedByUnverified = unverifiedExtras.some((u3) => !u3.out_of_scope);
  const final = allPass && !blockedByUnverified ? "pass" : "partial";
  const handoffPath = `.ditto/local/handoff/${item.id}.md`;
  const builtSummary = allPass ? `${item.title} \u2014 \uBAA8\uB4E0 acceptance criterion\uC774 pass\uB85C \uAE30\uB85D\uB418\uC5C8\uB2E4.` : `${item.title} \u2014 \uC77C\uBD80 acceptance criterion\uC774 \uBE44-pass \uC0C1\uD0DC\uB85C partial \uD578\uB4DC\uC624\uD504\uB41C\uB2E4.`;
  const verifications = prior && prior.verifications.length > 0 ? prior.verifications : [];
  const builtRisks = item.risks.map((r3) => r3.description);
  const remaining_risks = builtRisks.length === 0 && prior && prior.remaining_risks.length > 0 ? prior.remaining_risks : builtRisks;
  const summary = prior && prior.final_verdict === final ? prior.summary : builtSummary;
  const base = {
    schema_version: "0.1.0",
    work_item_id: item.id,
    declared_by: declaredBy,
    declared_at: declaredAt,
    summary,
    changed_files: changedFiles,
    acceptance,
    verifications,
    unverified: unverifiedExtras,
    remaining_risks,
    final_verdict: final,
    next_handoff_path: handoffPath
  };
  return completionContract.parse(base);
}
async function writeWorkItemHandoff(repoRoot, store, workId, options = {}, now = new Date) {
  const item = await store.get(workId);
  let baseUsed;
  if (options.base !== undefined) {
    const verified = pickBaseRef(repoRoot, [options.base]);
    if (verified === null) {
      throw new InvalidBaseRefError(options.base);
    }
    baseUsed = verified;
  } else {
    const candidates = [];
    if (item.started_at_sha)
      candidates.push(item.started_at_sha);
    candidates.push("origin/main", "origin/master", "main", "master");
    baseUsed = pickBaseRef(repoRoot, candidates);
  }
  let headUsed = null;
  if (options.head !== undefined) {
    const verifiedHead = pickBaseRef(repoRoot, [options.head]);
    if (verifiedHead === null) {
      throw new InvalidHeadRefError(options.head);
    }
    headUsed = verifiedHead;
  }
  const collected = collectChangedFiles(repoRoot, baseUsed, headUsed);
  const unverifiedExtras = [];
  if (collected.length === 0 && (item.runs.length > 0 || item.acceptance_criteria.some((a2) => a2.evidence.length > 0))) {
    unverifiedExtras.push({
      item: "changed_files not recorded",
      reason: baseUsed === null ? "no base ref (--base, origin/main, origin/master, main, master) usable and work item has runs/evidence; fill manually or pass --base" : `git diff against ${baseUsed} returned no files but work item has runs/evidence`,
      out_of_scope: false
    });
  }
  const selfArtifacts = [
    `.ditto/local/work-items/${workId}/completion.json`,
    `.ditto/local/work-items/${workId}/work-item.json`
  ];
  const merged = Array.from(new Set([...collected, ...selfArtifacts])).sort();
  const completionPath = localDir(repoRoot, "work-items", workId, "completion.json");
  let prior;
  const priorFile = Bun.file(completionPath);
  if (await priorFile.exists()) {
    try {
      const parsed = completionContract.safeParse(JSON.parse(await priorFile.text()));
      if (parsed.success)
        prior = parsed.data;
    } catch {
      prior = undefined;
    }
  }
  let graphAcceptance;
  const autopilotStore = new AutopilotStore(repoRoot);
  if (await autopilotStore.exists(workId)) {
    const graph = await autopilotStore.get(workId);
    const acIds = item.acceptance_criteria.map((c3) => c3.id);
    graphAcceptance = deriveAcVerdicts(graph, acIds).map((v2) => ({
      criterion_id: v2.criterion_id,
      verdict: v2.verdict,
      evidence: v2.evidence ?? [],
      ...v2.notes ? { notes: v2.notes } : {}
    }));
  }
  const completion = buildCompletion2(item, now.toISOString(), merged, options.declaredBy ?? "main", unverifiedExtras, prior, graphAcceptance);
  const effectiveReEntry = completion.final_verdict === "pass" ? undefined : item.re_entry ?? {
    command: `ditto work resume ${item.id}`,
    fresh_evidence_needed: ["\uBBF8pass acceptance\uC5D0 \uB300\uD55C \uAC80\uC99D \uACB0\uACFC"]
  };
  await writeJson(completionPath, completionContract, completion);
  const failedOrUnverified = [
    ...completion.acceptance.filter((a2) => a2.verdict !== "pass").map((a2) => `${a2.criterion_id} [${a2.verdict}]`),
    ...completion.unverified.map((u3) => `${u3.item} \u2014 ${u3.reason}${u3.out_of_scope ? " (out_of_scope)" : ""}`)
  ];
  const handoffArtifact = buildHandoff({
    workItem: item,
    fromContext: `ditto work handoff (declared_by=${options.declaredBy ?? "main"})`,
    currentState: `final_verdict=${completion.final_verdict}; ${completion.summary}`,
    changedFiles: merged,
    failedOrUnverified,
    ...effectiveReEntry?.command ? { openThreads: [effectiveReEntry.command] } : {},
    nextFirstCheck: effectiveReEntry?.fresh_evidence_needed?.[0] ?? "work item\uACFC acceptance\uB97C \uC7AC\uD655\uC778\uD558\uACE0 \uC5F4\uB9B0 \uB178\uB4DC\uB97C \uC7AC\uAC1C\uD55C\uB2E4.",
    now
  });
  const hstore = new HandoffStore(repoRoot);
  const handoffRel = completion.final_verdict === "pass" ? await hstore.writeArchived(handoffArtifact, now) : await hstore.write(handoffArtifact);
  const handoffPath = join65(repoRoot, handoffRel);
  await store.update(workId, (cur) => {
    const { re_entry: _existingReEntry, ...rest } = cur;
    if (completion.final_verdict === "pass") {
      return {
        ...rest,
        changed_files: merged,
        status: "done",
        closed_at: now.toISOString()
      };
    }
    return {
      ...rest,
      changed_files: merged,
      status: "partial",
      re_entry: effectiveReEntry
    };
  });
  return { completion, completionPath, handoffPath, collectedChangedFiles: merged, baseUsed };
}

// src/schemas/acg-semantic-scan-observation.ts
init_zod();
var acgSemanticScanObservationChange = exports_external.object({
  file: exports_external.string().min(1),
  symbol: exports_external.string().min(1),
  before: exports_external.string().min(1),
  after: exports_external.string().min(1)
});
var acgSemanticScanObservation = exports_external.object({
  ...acgChangeEnvelope("acg.semantic-scan-observation.v1"),
  base_used: exports_external.string().min(1).describe("Git ref the scan diffed against"),
  language: exports_external.string().min(1),
  source_root: exports_external.string().min(1),
  fingerprint: exports_external.string().min(1).describe("sha256(base sha + diff) \u2014 re-run skips when unchanged"),
  change_count: exports_external.number().int().min(0),
  changes: exports_external.array(acgSemanticScanObservationChange).default([])
}).describe("ACG SemanticScanObservation \u2014 non-gated record of observed signature changes");

// src/hooks/semantic-nudge.ts
var SEMANTIC_SOURCE_EXTENSIONS = [".ts", ".tsx", ".js", ".jsx", ".java", ".kt", ".py"];
function filterSourceFiles(files) {
  return files.filter((f3) => !f3.endsWith(".d.ts") && SEMANTIC_SOURCE_EXTENSIONS.some((ext) => f3.endsWith(ext)));
}
function semanticScanNudge(input) {
  if (!input.isNonTerminal)
    return null;
  if (input.semanticPresent)
    return null;
  if (input.base === null)
    return null;
  if (input.changedSourceFiles.length === 0)
    return null;
  if (input.observationChangeCount === null) {
    return `DITTO semantic check: ${input.changedSourceFiles.length} changed source file(s) vs ${input.base} but no current semantic-scan-observation.json. Run \`ditto semantic observe --work-item ${input.workItemId} --base ${input.base}\` to check exported-signature changes.
`;
  }
  if (input.observationChangeCount === 0)
    return null;
  return `DITTO semantic check: ${input.observationChangeCount} observed exported-signature change(s) (semantic-scan-observation.json) not yet resolved. Promote any meaning-breaking change with \`ditto semantic detect\` + \`ditto semantic verdict\`, or declare it intended.
`;
}
function computeSemanticNudge(repoRoot, workItem2, opts) {
  const base = pickBaseRef(repoRoot, workItemBaseCandidates(workItem2));
  const changedSourceFiles = base ? filterSourceFiles(listChangedFilesVsRef(repoRoot, base)) : [];
  return semanticScanNudge({
    workItemId: workItem2.id,
    isNonTerminal: opts.isNonTerminal,
    semanticPresent: opts.semanticPresent,
    base,
    changedSourceFiles,
    observationChangeCount: base ? freshObservationChangeCount(repoRoot, workItem2.id, base) : null
  });
}
function freshObservationChangeCount(repoRoot, workItemId2, base) {
  try {
    const path = localDir(repoRoot, "work-items", workItemId2, "semantic-scan-observation.json");
    const parsed = acgSemanticScanObservation.safeParse(JSON.parse(readFileSync4(path, "utf8")));
    if (!parsed.success)
      return null;
    const fingerprintNow = computeScanFingerprint(gitRevParse(repoRoot, base), diffVsRef(repoRoot, base));
    return parsed.data.fingerprint === fingerprintNow ? parsed.data.change_count : null;
  } catch {
    return null;
  }
}

// src/hooks/stop.ts
var ADMISSIBLE_SEVERITIES = new Set(["critical", "high"]);
function dialecticForcesContinuation(d2) {
  const reasons = [];
  const verdict2 = d2.synthesizer.verdict;
  if (verdict2 === "reject" || verdict2 === "blocked") {
    reasons.push(`dialectic ${d2.review_id} verdict=${verdict2}; deliberation not resolved`);
  }
  if (verdict2 === "revise" && d2.round < d2.input.constraints.max_rounds && d2.synthesizer.required_edits.length > 0) {
    reasons.push(`dialectic ${d2.review_id}: verdict=revise at round ${d2.round}/${d2.input.constraints.max_rounds} with ${d2.synthesizer.required_edits.length} required_edits open \u2014 re-deliberate next round`);
  }
  const resolved = new Set([
    ...d2.synthesizer.accepted_objections,
    ...d2.synthesizer.rejected_objections.map((r3) => r3.objection)
  ]);
  for (const obj of d2.opponent.objections) {
    const admissible = obj.maps_to.trim().length > 0 && ADMISSIBLE_SEVERITIES.has(obj.severity);
    const idResolved = obj.id !== undefined && resolved.has(obj.id);
    if (admissible && !resolved.has(obj.claim) && !idResolved) {
      reasons.push(`dialectic ${d2.review_id}: admissible objection unresolved \u2014 ${obj.claim}`);
    }
  }
  return reasons;
}
var NON_TERMINAL_STATUSES = [
  "draft",
  "in_progress",
  "blocked",
  "partial",
  "unverified"
];
async function readArtifact(path, schema, name) {
  let text;
  try {
    text = await readFile15(path, "utf8");
  } catch {
    return { status: "absent" };
  }
  try {
    const parsed = schema.safeParse(JSON.parse(text));
    if (!parsed.success)
      return { status: "malformed", name };
    return { status: "ok", data: parsed.data };
  } catch {
    return { status: "malformed", name };
  }
}
async function readDialecticLedgers(dir) {
  const reviewsDir = join66(dir, "reviews");
  let names;
  try {
    names = await readdir20(reviewsDir);
  } catch {
    return { status: "ok", items: [] };
  }
  const files = names.filter((n2) => /^dialectic-.*\.json$/.test(n2)).sort();
  const items = [];
  for (const name of files) {
    const read = await readArtifact(join66(reviewsDir, name), dialectic, `reviews/${name}`);
    if (read.status === "malformed")
      return { status: "malformed", name: read.name };
    if (read.status === "ok")
      items.push(read.data);
  }
  return { status: "ok", items };
}
function hasPendingMutatingNode(a2) {
  return a2.nodes.some((n2) => n2.owner === "implementer" && n2.status === "pending");
}
function isDegeneratePendingAutopilot(a2) {
  return a2.approval_gate.status === "pending" && !hasPendingMutatingNode(a2);
}
function hasRunnableNode(a2) {
  const byId = new Map(a2.nodes.map((n2) => [n2.id, n2]));
  const depsPassed = (n2) => n2.depends_on.every((d2) => byId.get(d2)?.status === "passed");
  return a2.nodes.some((n2) => n2.status === "running" || n2.status === "pending" && depsPassed(n2));
}
function autopilotForcesContinuation(a2) {
  if (a2.approval_gate.status === "pending")
    return false;
  return hasRunnableNode(a2);
}
function autopilotHasNoPlan(pilot) {
  if (pilot.status === "absent")
    return true;
  if (pilot.status === "ok")
    return !pilot.data.nodes.some((n2) => n2.owner === "implementer");
  return false;
}
function autopilotBypassForcesContinuation(workItem2, completion, pilot, completionWouldClose) {
  if (completion.status !== "ok" || !completionWouldClose)
    return [];
  if (!autopilotHasNoPlan(pilot))
    return [];
  if (!NON_TERMINAL_STATUSES.includes(workItem2.status))
    return [];
  if (workItem2.autopilot_exempt === true)
    return [];
  const changedCode = completion.data.changed_files.length > 0 || workItem2.changed_files.length > 0;
  if (!changedCode)
    return [];
  return [
    `work item ${workItem2.id} changed code but is closing on completion.json alone, without going through autopilot (no real plan was ever run). Non-trivial work should run finalize \u2192 bootstrap \u2192 autopilot drive (ditto autopilot bootstrap ${workItem2.id}, then the autopilot skill). To close without autopilot, run "ditto autopilot exempt ${workItem2.id}" or transition the work item to done/abandoned.`
  ];
}
function acgReviewForcesContinuation(graph) {
  const reasons = [];
  for (const file of graph.files) {
    if (file.risk === "high" && file.evidence === undefined) {
      const id = file.path ?? file.journey_id ?? "(unidentified)";
      reasons.push(`acg review: high-risk change without evidence \u2014 ${id} (${file.risk_reason})`);
    }
  }
  return reasons;
}
function assuranceSnapshotForcesContinuation(snapshot) {
  const reasons = [];
  for (const r3 of snapshot.results) {
    if (r3.outcome === "fail") {
      const n2 = r3.new_violations ?? r3.violations ?? 0;
      reasons.push(`fitness: ${r3.function_id} failed \u2014 ${n2} blocking violation(s)`);
    }
  }
  return reasons;
}
function impactForcesContinuation(graph) {
  return graph.unresolved.map((u3) => `impact: unresolved ${u3.kind} \u2014 ${u3.path} (${u3.reason})`);
}
function semanticForcesContinuation(sem) {
  return sem.changes.flatMap((change) => {
    const v2 = change.verdict;
    const where = `${change.before} \u2192 ${change.after}`;
    if (v2.semantic_safe === "unverified") {
      return [
        `semantic: meaning compatibility unverified for ${where} \u2014 verify or declare intended`
      ];
    }
    if (v2.semantic_safe === "no" && v2.intended_breaking !== true) {
      return [`semantic: unintended meaning break ${where} (was: ${change.old_meaning})`];
    }
    return [];
  });
}
function isKnowledgeNode(n2) {
  return n2.kind === "knowledge" || n2.owner === "knowledge-curator";
}
var TERMINAL_NODE_STATUSES = new Set(["passed", "failed", "blocked"]);
function knowledgeForcesContinuation(graph, carrier) {
  const hasTerminalKnowledgeNode = graph.nodes.some((n2) => isKnowledgeNode(n2) && TERMINAL_NODE_STATUSES.has(n2.status));
  if (!hasTerminalKnowledgeNode || carrier === undefined)
    return [];
  const g3 = knowledgeUpdateGate(carrier.triggers, carrier.delta);
  return g3.pass ? [] : g3.reasons.map((r3) => `knowledge update \u2014 ${r3}`);
}
function residualResolvabilityForcesContinuation(completion, workItem2) {
  const acceptanceIds = workItem2.acceptance_criteria.map((c3) => c3.id);
  return resolvabilityBlockers(completion.unverified, acceptanceIds).map((b2) => b2.userDecision ? `residual deferred_needs_user_ok \u2014 ${b2.item}: ${b2.reason}` : `residual blocks pass-close \u2014 ${b2.item}: ${b2.reason}`);
}
function decisionConflictForcesContinuation(carrier) {
  if (carrier === undefined)
    return { reasons: [], advisories: [] };
  const { dispositions } = decisionConflictGate(carrier.conflicts, carrier.mode);
  const line = (d2) => `${d2.conflict.adr_id} (${d2.conflict.kind}/${d2.conflict.level}) \u2192 ${d2.route}: ${d2.conflict.basis}`;
  const blocks = (d2) => d2.route === "block" || d2.route === "ask_user";
  return {
    reasons: dispositions.filter(blocks).map((d2) => `decision conflict \u2014 ${line(d2)}`),
    advisories: dispositions.filter((d2) => !blocks(d2)).map((d2) => `decision conflict (disclosed, agent followed ADR) \u2014 ${line(d2)}`)
  };
}
async function maybeRunFitness(repoRoot, workItemId2, dir) {
  try {
    const fns = await new FitnessFunctionStore(repoRoot).read(workItemId2);
    if (!fns || fns.length === 0)
      return;
    const ctx = {
      trigger: "per_change",
      changeRef: workItemId2,
      riskKnown: false,
      producedAt: new Date().toISOString()
    };
    const verdictsPath2 = join66(dir, "fitness-verdicts.json");
    const provider = await Bun.file(verdictsPath2).exists() ? compositeProvider(repoRoot, verdictsPath2) : commandProvider(repoRoot);
    const snapshot = await runFitness(fns, ctx, provider);
    await ensureDir(dir);
    await writeJson(join66(dir, "assurance-snapshot.json"), acgAssuranceSnapshot, snapshot);
  } catch {}
}
var DRIFT_HOPS = ["H1", "H2", "H3"];
function driftHops(lines) {
  return DRIFT_HOPS.filter((h2) => lines.some((l2) => l2.includes(`${h2}:`)));
}
async function recordIntentDriftMetric(repoRoot, workItemId2, drift) {
  if (drift.reasons.length === 0 && drift.advisories.length === 0)
    return;
  try {
    const store = new WorkItemStore(repoRoot);
    const last = (await store.readMetrics(workItemId2)).at(-1);
    if (last && JSON.stringify(last.blocking_reasons) === JSON.stringify(drift.reasons) && JSON.stringify(last.advisories) === JSON.stringify(drift.advisories)) {
      return;
    }
    const record = intentMetric.parse({
      ts: new Date().toISOString(),
      work_item_id: workItemId2,
      kind: "intent_drift",
      source: "stop_hook",
      blocking_reasons: drift.reasons,
      advisories: drift.advisories,
      hops: driftHops([...drift.reasons, ...drift.advisories])
    });
    await store.appendMetricLine(workItemId2, JSON.stringify(record));
  } catch {}
}
var stopHandler = async (input) => {
  const raw = input.raw ?? {};
  if (raw.stop_hook_active === true)
    return { exitCode: 0 };
  const sessionId = typeof raw.session_id === "string" ? raw.session_id : undefined;
  if (!sessionId)
    return {
      exitCode: 0,
      stderr: `DITTO Stop completion gate did not run: no session_id was provided, so the completion/convergence gates could not be checked.
`
    };
  const pointer = await new SessionPointerStore(input.repoRoot).get(sessionId);
  if (!pointer)
    return { exitCode: 0 };
  let workItem2;
  try {
    workItem2 = await new WorkItemStore(input.repoRoot).get(pointer);
  } catch {
    return { exitCode: 0 };
  }
  const dir = localDir(input.repoRoot, "work-items", pointer);
  await maybeRunFitness(input.repoRoot, pointer, dir);
  const completion = await readArtifact(join66(dir, "completion.json"), completionContract, "completion.json");
  const conv = await readArtifact(join66(dir, "convergence.json"), convergence, "convergence.json");
  const pilot = await readArtifact(join66(dir, "autopilot.json"), autopilot, "autopilot.json");
  const intent = await readArtifact(join66(dir, "intent.json"), intentContract, "intent.json");
  const dialectics = await readDialecticLedgers(dir);
  const acgReview = await readArtifact(join66(dir, "acg-review.json"), acgReviewGraph, "acg-review.json");
  const assurance = await readArtifact(join66(dir, "assurance-snapshot.json"), acgAssuranceSnapshot, "assurance-snapshot.json");
  const impact = await readArtifact(join66(dir, "impact-graph.json"), acgImpactGraph, "impact-graph.json");
  const semantic = await readArtifact(join66(dir, "semantic-compatibility.json"), acgSemanticCompatibility, "semantic-compatibility.json");
  const knowledge = await readArtifact(join66(dir, "knowledge-gate.json"), knowledgeGateCarrier, "knowledge-gate.json");
  const decisionConflicts = await readArtifact(join66(dir, "decision-conflict.json"), decisionConflictCarrier, "decision-conflict.json");
  const malformed = [
    completion,
    conv,
    pilot,
    intent,
    dialectics,
    acgReview,
    assurance,
    impact,
    semantic,
    knowledge,
    decisionConflicts
  ].find((a2) => a2.status === "malformed");
  if (malformed && malformed.status === "malformed") {
    return {
      exitCode: 2,
      stderr: `DITTO Stop gate: ${malformed.name} is malformed (cannot verify completion). Fix or remove it before stopping.
`
    };
  }
  if (pilot.status === "ok" && pilot.data.approval_gate.status === "pending" && hasPendingMutatingNode(pilot.data)) {
    return { exitCode: 0 };
  }
  const reasons = [];
  const advisories = [];
  let completionWouldClose = false;
  if (completion.status === "ok") {
    const g3 = completionGate(workItem2, completion.data);
    if (!g3.pass)
      reasons.push(...g3.reasons);
    const e2 = completionEvidenceGate(completion.data);
    if (!e2.pass)
      reasons.push(...e2.reasons);
    completionWouldClose = g3.pass && e2.pass;
  }
  if (conv.status === "ok") {
    const g3 = convergenceGate(conv.data);
    if (!g3.pass)
      reasons.push(...g3.reasons);
  }
  if (pilot.status === "ok" && autopilotForcesContinuation(pilot.data)) {
    reasons.push("autopilot has runnable node(s); the work item is not complete yet");
  }
  reasons.push(...autopilotBypassForcesContinuation(workItem2, completion, pilot, completionWouldClose));
  if (completion.status === "ok" && completionWouldClose) {
    reasons.push(...residualResolvabilityForcesContinuation(completion.data, workItem2));
  }
  if (intent.status === "ok" && pilot.status === "ok") {
    const d2 = intentDriftGate({
      intent: intent.data,
      workItem: workItem2,
      graph: pilot.data,
      ...completion.status === "ok" ? { completion: completion.data } : {}
    });
    if (!d2.pass)
      reasons.push(...d2.reasons.map((r3) => `intent drift \u2014 ${r3}`));
    advisories.push(...d2.advisories.map((r3) => `intent drift (advisory) \u2014 ${r3}`));
    await recordIntentDriftMetric(input.repoRoot, pointer, {
      reasons: d2.reasons,
      advisories: d2.advisories
    });
  }
  if (dialectics.status === "ok") {
    for (const d2 of dialectics.items)
      reasons.push(...dialecticForcesContinuation(d2));
  }
  if (acgReview.status === "ok") {
    reasons.push(...acgReviewForcesContinuation(acgReview.data));
  }
  if (assurance.status === "ok") {
    reasons.push(...assuranceSnapshotForcesContinuation(assurance.data));
  }
  if (impact.status === "ok") {
    reasons.push(...impactForcesContinuation(impact.data));
  }
  if (semantic.status === "ok") {
    reasons.push(...semanticForcesContinuation(semantic.data));
  }
  if (pilot.status === "ok") {
    reasons.push(...knowledgeForcesContinuation(pilot.data, knowledge.status === "ok" ? knowledge.data : undefined));
  }
  const dc = decisionConflictForcesContinuation(decisionConflicts.status === "ok" ? decisionConflicts.data : undefined);
  reasons.push(...dc.reasons);
  advisories.push(...dc.advisories);
  const advisoryBlock = advisories.length > 0 ? `DITTO Stop advisory (non-blocking) \u2014 ${advisories.length} item(s):
- ${advisories.join(`
- `)}
` : "";
  if (reasons.length > 0) {
    return {
      exitCode: 2,
      stderr: `DITTO Stop gate: keep going \u2014 ${reasons.length} item(s) remain:
- ${reasons.join(`
- `)}
${advisoryBlock}`
    };
  }
  if (completion.status === "absent" && conv.status === "absent" && (pilot.status === "absent" || pilot.status === "ok" && isDegeneratePendingAutopilot(pilot.data)) && NON_TERMINAL_STATUSES.includes(workItem2.status)) {
    return {
      exitCode: 2,
      stderr: `DITTO Stop gate: work item ${workItem2.id} is ${workItem2.status} but has no real verification path (no completion.json / convergence.json, and no autopilot.json with a plan to run). Run /ditto:verify (writes completion.json) or transition the work item to done/abandoned before stopping.
`
    };
  }
  const nudge = computeSemanticNudge(input.repoRoot, workItem2, {
    semanticPresent: semantic.status === "ok",
    isNonTerminal: NON_TERMINAL_STATUSES.includes(workItem2.status)
  });
  const tail = `${advisoryBlock}${nudge ?? ""}`;
  return tail.length > 0 ? { exitCode: 0, stderr: tail } : { exitCode: 0 };
};

// src/hooks/user-prompt-submit.ts
import { join as join67 } from "path";

// src/core/charter.ts
var PRIME_DIRECTIVE = [
  "DITTO prime directive:",
  "- Preserve the original request. Do not grow scope (IntentContract); do not shrink it or split one request into many work items without user approval.",
  "- The hook does not blindly auto-create a work item on every prompt \u2014 YOU do the deciding. Make a 1st-pass judgment per request: a request that produces an artifact OR makes an irreversible codebase change should become a work item; simple tasks, handoff, and git operations are exceptions (no work item). When it should, confirm the creation intent with the user, then register it YOURSELF by running `ditto work start` \u2014 you (the agent) create it automatically; the user does not type the command.",
  "- If a request slips past this judgment, just handle it as normal work; you may still register one with `ditto work start` if it turns out to warrant tracking. There is no hard backstop.",
  "- Ask the user only what only the user can answer (QuestionGate); answer the rest from code/docs/web yourself.",
  "- Completion is gated by evidence, not by claim: every acceptance criterion must be closed with evidence before final_verdict=pass.",
  "- Internal checkpoint completion is not a final answer; the whole work item is the bar."
].join(`
`);
var PLACEHOLDER_AC_STATEMENT = "TBD \u2014 derive observable criteria during interview/planning";
var WORK_ITEM_GUIDE_ADVISORY = 'No active work item. Make the 1st-pass judgment yourself: if this request produces an artifact or makes an irreversible codebase change, it should become a work item (simple tasks, handoff, git ops are exceptions). If so, confirm the intent with the user, then register it YOURSELF by running `ditto work start "<goal>" --request "<verbatim request>"` \u2014 you create it automatically, the user does not type the command. Otherwise just proceed as normal work.';
var PLACEHOLDER_AC_ADVISORY = "acceptance criteria are placeholders \u2014 narrow them via /ditto:deep-interview before acting (IntentContract)";
var DEEP_INTERVIEW_DIRECTIVE = "Run /ditto:deep-interview now \u2014 placeholder acceptance criteria + execution intent detected. Recommended; may be skipped if the request is small or reversible (IntentContract entry).";
var SELF_ANSWER_HINT = "self-answer from code/docs/web first before asking \u2014 this prompt looks answerable without user input (QuestionGate).";
function charterProjection(ctx = {}) {
  const lines = [PRIME_DIRECTIVE];
  if (ctx.workItemId) {
    const head = `Active work item: ${ctx.workItemId}`;
    const detail = [
      ctx.workItemTitle ? `title="${ctx.workItemTitle}"` : null,
      ctx.workItemStatus ? `status=${ctx.workItemStatus}` : null
    ].filter(Boolean).join(", ");
    lines.push("", detail ? `${head} (${detail})` : head);
  }
  if (ctx.handoffBodies && ctx.handoffBodies.length > 0) {
    lines.push("", "== Pending handoff (auto-loaded from .ditto/local/handoff/, now archived) ==");
    for (const body of ctx.handoffBodies)
      lines.push("", body);
  }
  if (ctx.pendingHandoff)
    lines.push(`Pending handoff/re-entry: ${ctx.pendingHandoff}`);
  if (ctx.placeholderAcceptanceCriteria)
    lines.push("", `\u26A0 ${PLACEHOLDER_AC_ADVISORY}`);
  if (ctx.deepInterviewDirective)
    lines.push("", `\u25B6 ${DEEP_INTERVIEW_DIRECTIVE}`);
  if (ctx.selfAnswerHint)
    lines.push("", `\u26A0 ${SELF_ANSWER_HINT}`);
  if (ctx.workItemGuide)
    lines.push("", `\u26A0 ${WORK_ITEM_GUIDE_ADVISORY}`);
  if (ctx.advisory)
    lines.push("", `\u26A0 ${ctx.advisory}`);
  return lines.join(`
`);
}

// src/hooks/user-prompt-submit.ts
init_ditto_paths();
init_fs();
var NON_TERMINAL = [
  "draft",
  "in_progress",
  "blocked",
  "partial",
  "unverified"
];
function classifyPromptAdvisory(prompt2) {
  const t2 = prompt2.trim().toLowerCase();
  if (/(\uD574\s*\uC918|\uD574\s*\uC8FC\uC138\uC694|\uD574\uB77C|\uD558\uB77C|\uAD6C\uD604|\uC218\uC815|\uCD94\uAC00|\uB9CC\uB4E4\uC5B4|\uACE0\uCCD0|\uBC14\uAFD4|\uC801\uC6A9|\uC0AD\uC81C|\uC81C\uAC70)/.test(t2)) {
    return "execution";
  }
  if (/(\uAE4C|\uB098\uC694|\uB294\uAC00|\uC778\uAC00|\uB2C8|\uB0D0|\uC744\uAE4C|\u3139\uAE4C|\u3134\uAC00)\s*[?\uFF1F]?\s*$/.test(t2) || /(\uBB34\uC5C7|\uBB50|\uC65C|\uC5B4\uB5BB\uAC8C|\uC5B4\uB5A4|\uC5B8\uC81C|\uC5B4\uB514|\uB204\uAC00|\uB204\uAD6C|\uC5B4\uB290|\uBA87)/.test(t2)) {
    return "question";
  }
  if (t2.endsWith("?") || /^(what|why|how|when|where|who|which|is|are|does|can|should)\b/.test(t2)) {
    return "question";
  }
  return "execution";
}
var CODEBASE_ANSWERABLE_PATTERNS = [
  /\bfile\b/i,
  /\bfiles\b/i,
  /\bpath\b/i,
  /\bfunction\b/i,
  /\bmethod\b/i,
  /\berror\b/i,
  /\bexception\b/i,
  /\btest\b/i,
  /\btests\b/i,
  /\blog\b/i,
  /\blogs\b/i,
  /\bclass\b/i,
  /\bmodule\b/i,
  /\bschema\b/i,
  /\.(ts|js|tsx|jsx|json|md|sh|py)\b/i,
  /\uD30C\uC77C|\uACBD\uB85C|\uB514\uB809\uD130\uB9AC|\uB514\uB809\uD1A0\uB9AC|\uD568\uC218|\uBA54\uC11C\uB4DC|\uBA54\uC18C\uB4DC|\uC624\uB958|\uC5D0\uB7EC|\uC608\uC678|\uBC84\uADF8|\uD14C\uC2A4\uD2B8|\uB85C\uADF8|\uD074\uB798\uC2A4|\uBAA8\uB4C8|\uC2A4\uD0A4\uB9C8|\uCF54\uB4DC|\uCEE4\uBC0B|\uD0C0\uC785/
];
function looksCodebaseAnswerable(prompt2) {
  return CODEBASE_ANSWERABLE_PATTERNS.some((re) => re.test(prompt2));
}
function tokens(s2) {
  return new Set(s2.toLowerCase().split(/[^a-z0-9\uAC00-\uD7A3]+/).filter((t2) => t2.length >= 3));
}
function duplicateSearch(prompt2, open2) {
  const promptTokens = tokens(prompt2);
  if (promptTokens.size === 0)
    return [];
  return open2.map((s2) => {
    let overlap = 0;
    for (const t2 of tokens(s2.title))
      if (promptTokens.has(t2))
        overlap++;
    return { id: s2.id, title: s2.title, overlap };
  }).filter((m2) => m2.overlap > 0).sort((a2, b2) => b2.overlap - a2.overlap);
}
async function resolveActiveWorkItem(repoRoot, sessionId, prompt2) {
  const items = new WorkItemStore(repoRoot);
  const pointers = new SessionPointerStore(repoRoot);
  const pointed = await pointers.get(sessionId);
  if (pointed && await items.exists(pointed)) {
    return { workItem: await items.get(pointed), action: "loaded" };
  }
  const open2 = (await items.list()).filter((s2) => NON_TERMINAL.includes(s2.status));
  if (open2.length > 0) {
    const ids = open2.map((s2) => s2.id).join(", ");
    const matches = classifyPromptAdvisory(prompt2) === "execution" ? duplicateSearch(prompt2, open2) : [];
    const dupLine = matches.length > 0 ? ` Possible duplicates by title overlap: ${matches.map((m2) => `${m2.id} ("${m2.title}")`).join("; ")}.` : "";
    return {
      action: "ask",
      advisory: `No active work item pointer for this session and ${open2.length} open work item(s) exist (${ids}).${dupLine} Resume one explicitly, or create a NEW work item before acting \u2014 not picking arbitrarily.`
    };
  }
  return { action: "guide" };
}
function allAcceptancePlaceholders(item) {
  if (item.acceptance_criteria.length === 0)
    return false;
  return item.acceptance_criteria.every((ac) => ac.statement === PLACEHOLDER_AC_STATEMENT);
}
function pendingHandoffHint(item) {
  return item.re_entry?.command;
}
async function logClassification(repoRoot, entry) {
  const dir = localDir(repoRoot, "logs");
  await ensureDir(dir);
  const path = join67(dir, "user-prompt.jsonl");
  const file = Bun.file(path);
  const existing = await file.exists() ? await file.text() : "";
  const prefix = existing.length === 0 || existing.endsWith(`
`) ? existing : `${existing}
`;
  await atomicWriteText(path, `${prefix}${JSON.stringify(entry)}
`);
}
var userPromptSubmitHandler = async (input) => {
  const raw = input.raw ?? {};
  const sessionId = typeof raw.session_id === "string" ? raw.session_id : undefined;
  const prompt2 = typeof raw.prompt === "string" ? raw.prompt : "";
  const classification = classifyPromptAdvisory(prompt2);
  if (!sessionId) {
    return contextOutput(charterProjection());
  }
  const resolved = await resolveActiveWorkItem(input.repoRoot, sessionId, prompt2);
  await logClassification(input.repoRoot, {
    ts: new Date().toISOString(),
    session_id: sessionId,
    classification,
    action: resolved.action,
    work_item_id: resolved.workItem?.id ?? null
  });
  const ctx = {};
  try {
    const hstore = new HandoffStore(input.repoRoot);
    const active = await hstore.listActive();
    if (active.length > 0) {
      ctx.handoffBodies = active.map((a2) => a2.body);
      await hstore.consume();
    }
  } catch {}
  const item = resolved.workItem;
  if (item) {
    ctx.workItemId = item.id;
    ctx.workItemTitle = item.title;
    ctx.workItemStatus = item.status;
    const handoff2 = pendingHandoffHint(item);
    if (handoff2)
      ctx.pendingHandoff = handoff2;
    const placeholderOnly = allAcceptancePlaceholders(item);
    if (placeholderOnly)
      ctx.placeholderAcceptanceCriteria = true;
    if (placeholderOnly && classification === "execution")
      ctx.deepInterviewDirective = true;
  }
  if (classification === "question" && looksCodebaseAnswerable(prompt2)) {
    ctx.selfAnswerHint = true;
  }
  if (resolved.advisory)
    ctx.advisory = resolved.advisory;
  if (resolved.action === "guide")
    ctx.workItemGuide = true;
  return contextOutput(charterProjection(ctx));
};
function contextOutput(text) {
  return {
    exitCode: 0,
    stdout: JSON.stringify({
      hookSpecificOutput: { hookEventName: "UserPromptSubmit", additionalContext: text }
    })
  };
}

// src/cli/commands/hook.ts
var HANDLERS = {
  "user-prompt-submit": userPromptSubmitHandler,
  "pre-tool-use": preToolUseHandler,
  "post-tool-use": postToolUseHandler,
  "pre-compact": preCompactHandler,
  stop: stopHandler
};
var HOOK_EVENTS = Object.keys(HANDLERS);
function parseHookHost(value) {
  if (value === undefined || value === null || value === "")
    return "claude-code";
  if (value === "claude-code" || value === "codex")
    return value;
  throw new Error(`invalid --host ${String(value)} (expected claude-code|codex)`);
}
var hookCommand = defineCommand({
  meta: {
    name: "hook",
    description: "Run a DITTO hook handler by event name (called from hooks.json; reads the event JSON on stdin)."
  },
  args: {
    event: {
      type: "positional",
      required: true,
      description: `Hook event: ${HOOK_EVENTS.join(" | ")}`
    },
    host: {
      type: "string",
      default: "claude-code",
      description: "Host whose hook envelope feeds stdin/env: claude-code | codex."
    }
  },
  run: async ({ args }) => {
    const handler = HANDLERS[args.event];
    if (!handler) {
      process.stderr.write(`ditto hook: unknown event "${args.event}"; expected one of: ${HOOK_EVENTS.join(", ")}
`);
      process.exit(2);
    }
    let host;
    try {
      host = parseHookHost(args.host);
    } catch (err) {
      process.stderr.write(`ditto hook: ${err instanceof Error ? err.message : String(err)}
`);
      process.exit(2);
    }
    await executeHook(handler, host);
  }
});

// src/cli/commands/impact.ts
import { join as join69 } from "path";

// src/acg/impact/codeql-analyzer.ts
import { join as join68 } from "path";
function isTestFile(path, language) {
  if (language === "java") {
    return path.includes("/test/") || /(Test|Tests|IT)\.java$/.test(path);
  }
  if (language === "kotlin") {
    return path.includes("/test/") || /(Test|Tests|IT)\.kt$/.test(path);
  }
  if (language === "python") {
    return /(^|\/)(test_[^/]+|[^/]+_test)\.py$/.test(path) || path.includes("/tests/");
  }
  return /\.(test|spec)\.[cm]?[jt]sx?$/.test(path);
}
function matchesInternalGlob(pkg, entries) {
  return entries.some((e2) => e2.type === "glob" && globToRegExp(e2.value).test(pkg));
}

class CodeqlImpactAnalyzer {
  target;
  deps;
  constructor(target, deps) {
    this.target = target;
    this.deps = deps;
  }
  async analyze(input) {
    const rows = await runRelationQuery({
      repoRoot: this.target.repoRoot,
      sourceRoot: input.sourceRoot,
      language: this.target.language,
      dbPath: join68(this.target.cacheDir, "db"),
      workDir: join68(this.target.cacheDir, `q-impact-${this.target.symbol}`),
      query: renderQuery(relationQueries(this.target.language).impact, this.target.symbol, this.target.declFile),
      ...this.target.buildMode ? { buildMode: this.target.buildMode } : {},
      ...this.target.buildCommand ? { buildCommand: this.target.buildCommand } : {},
      ...this.target.binary ? { binary: this.target.binary } : {}
    }, this.deps);
    const affected = [];
    for (const row of rows) {
      const [path, lineStr, raw] = row;
      if (!path || !raw)
        continue;
      const line = Number(lineStr);
      let kind;
      if (raw === "type")
        kind = "type_contract";
      else if (raw === "decl")
        kind = "external_surface";
      else
        kind = isTestFile(path, this.target.language) ? "test" : "direct_caller";
      affected.push({
        kind,
        path,
        symbol: this.target.symbol,
        reason: kind === "external_surface" ? "exported symbol \u2014 public surface (\uB2E8\uACC43 gate: exported must be surfaced)" : `references ${this.target.symbol} at line ${line}`
      });
    }
    return { affected, unresolved: await this.crossRepoUnresolved(input.sourceRoot) };
  }
  async crossRepoUnresolved(sourceRoot) {
    const entries = this.target.internalPackages ?? [];
    if (!entries.some((e2) => e2.type === "glob"))
      return [];
    const rows = await runRelationQuery({
      repoRoot: this.target.repoRoot,
      sourceRoot,
      language: this.target.language,
      dbPath: join68(this.target.cacheDir, "db"),
      workDir: join68(this.target.cacheDir, "q-xrepo"),
      query: relationQueries(this.target.language).unresolved,
      ...this.target.buildMode ? { buildMode: this.target.buildMode } : {},
      ...this.target.buildCommand ? { buildCommand: this.target.buildCommand } : {},
      ...this.target.binary ? { binary: this.target.binary } : {}
    }, this.deps);
    const seen = new Set;
    const unresolved = [];
    for (const row of rows) {
      const [path, pkg] = row;
      if (!path || !pkg || !matchesInternalGlob(pkg, entries))
        continue;
      const key = `${path}\x00${pkg}`;
      if (seen.has(key))
        continue;
      seen.add(key);
      unresolved.push({
        kind: "cross_repo",
        path,
        reason: `${pkg} resolves to a sibling module not in this single-module DB (cross_repo; static impact incomplete)`
      });
    }
    return unresolved;
  }
}

// src/acg/impact/impact-graph.ts
var journeyKinds2 = new Set(["ui_surface", "user_journey"]);
function buildImpactGraph(input, analysis) {
  const affected = analysis.affected.map((n2) => ({ handled: false, ...n2 }));
  const unresolved = [...analysis.unresolved];
  const hasJourneyNode = affected.some((n2) => journeyKinds2.has(n2.kind) && n2.journey_id);
  if (input.userExposed === true) {
    if (input.journeyId) {
      affected.push({
        kind: "user_journey",
        journey_id: input.journeyId,
        reason: "user-exposed change mapped to journey",
        handled: false
      });
    } else if (!hasJourneyNode) {
      unresolved.push({
        kind: "journey_unknown",
        path: input.changeTarget,
        reason: "user-exposed change with no JourneySpec mapping; a human must map the journey or declare no journey impact (default-deny, 20-contracts \xA72)"
      });
    }
  }
  return acgImpactGraph.parse({
    schema_version: "0.1.0",
    kind: "acg.impact-graph.v1",
    work_item_id: input.workItemId,
    produced_by: "agent",
    produced_at: input.producedAt,
    change_target: input.changeTarget,
    change_type: input.changeType,
    affected_nodes: affected,
    unresolved
  });
}
async function produceImpactGraph(input, analyzer, sourceRoot) {
  const analysis = await analyzer.analyze({ changeTarget: input.changeTarget, sourceRoot });
  return buildImpactGraph(input, analysis);
}

