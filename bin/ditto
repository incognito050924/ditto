function synthesizeDecisionId(decision, index) {
  return createHash2("sha1").update(`${index} ${JSON.stringify(decision)}`).digest("hex");
}
function isDecisivePost(decision) {
  return decision.failure_class === "user_decision_needed" || decision.decision === "escalate" || decision.decision === "batch_escalate" || decision.disposition === "blocked";
}

class AutopilotStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  dir(workItemId2) {
    return localDir(this.repoRoot, "work-items", workItemId2);
  }
  graphPath(workItemId2) {
    return join14(this.dir(workItemId2), "autopilot.json");
  }
  decisionsPath(workItemId2) {
    return join14(this.dir(workItemId2), "autopilot-decisions.jsonl");
  }
  async exists(workItemId2) {
    return Bun.file(this.graphPath(workItemId2)).exists();
  }
  async get(workItemId2) {
    return readJson(this.graphPath(workItemId2), autopilot);
  }
  async write(workItemId2, graph) {
    await ensureDir(this.dir(workItemId2));
    return writeJson(this.graphPath(workItemId2), autopilot, graph);
  }
  async updateNode(workItemId2, nodeId, mutator) {
    const graph = await this.get(workItemId2);
    let found = false;
    const nodes = graph.nodes.map((node) => {
      if (node.id !== nodeId)
        return node;
      found = true;
      const next = mutator(node);
      if (next.id !== node.id) {
        throw new Error(`updateNode mutator changed node id from ${node.id} to ${next.id}`);
      }
      return next;
    });
    if (!found)
      throw new Error(`node ${nodeId} not found in autopilot graph for ${workItemId2}`);
    return writeJson(this.graphPath(workItemId2), autopilot, { ...graph, nodes });
  }
  async addNodes(workItemId2, newNodes, allowedAcceptanceIds) {
    const graph = await this.get(workItemId2);
    validateNodeAddition(graph.nodes, newNodes, allowedAcceptanceIds);
    return writeJson(this.graphPath(workItemId2), autopilot, {
      ...graph,
      nodes: [...graph.nodes, ...newNodes]
    });
  }
  async removeNodes(workItemId2, ids) {
    if (ids.length === 0)
      return this.get(workItemId2);
    const graph = await this.get(workItemId2);
    const removal = new Set(ids);
    for (const id of ids) {
      const node = graph.nodes.find((n2) => n2.id === id);
      if (!node)
        throw new Error(`cannot remove unknown node: ${id}`);
      if (node.status !== "pending")
        throw new Error(`cannot remove node not pending: ${id}`);
    }
    const survivors = graph.nodes.filter((n2) => !removal.has(n2.id));
    for (const n2 of survivors) {
      for (const dep of n2.depends_on) {
        if (removal.has(dep)) {
          throw new Error(`removal would leave dangling depends_on: ${n2.id} -> ${dep}`);
        }
      }
    }
    return writeJson(this.graphPath(workItemId2), autopilot, { ...graph, nodes: survivors });
  }
  async updateApprovalGate(workItemId2, mutator) {
    const graph = await this.get(workItemId2);
    return writeJson(this.graphPath(workItemId2), autopilot, {
      ...graph,
      approval_gate: mutator(graph.approval_gate)
    });
  }
  async appendDecision(workItemId2, decision) {
    await ensureDir(this.dir(workItemId2));
    await appendFile(this.decisionsPath(workItemId2), `${JSON.stringify(decision)}
`, "utf8");
  }
  async readDecisions(workItemId2) {
    const path = this.decisionsPath(workItemId2);
    const file = Bun.file(path);
    if (!await file.exists()) {
      decisionCache.delete(path);
      return [];
    }
    const text = await file.text();
    return parseDecisionsIncremental(path, text);
  }
}
var decisionCache = new Map;
function hashPrefix(bytes) {
  return createHash2("sha1").update(bytes).digest("hex");
}
function parseLines(block) {
  return block.split(`
`).filter((line) => line.trim().length > 0).map((line) => JSON.parse(line));
}
function parseDecisionsIncremental(path, text) {
  const prefixEnd = text.lastIndexOf(`
`) + 1;
  const prefix = text.slice(0, prefixEnd);
  const remainder = text.slice(prefixEnd);
  const cached = decisionCache.get(path);
  let decisions;
  if (cached !== undefined && prefixEnd >= cached.size && hashPrefix(text.slice(0, cached.size)) === cached.hash) {
    decisions = cached.decisions.concat(parseLines(text.slice(cached.size, prefixEnd)));
  } else {
    decisions = parseLines(prefix);
  }
  decisionCache.set(path, { size: prefixEnd, hash: hashPrefix(prefix), decisions });
  const tail = parseLines(remainder);
  return tail.length > 0 ? decisions.concat(tail) : decisions;
}

