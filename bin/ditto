var toPosix2 = (p2) => p2.split(sep7).join("/");
async function readOrNull(path) {
  try {
    return await readFile15(path, "utf8");
  } catch {
    return null;
  }
}
async function runLifecycleAction(repoRoot, req) {
  if (!req.confirmedByUser) {
    return {
      ok: false,
      refusal: "\uAC31\uC2E0\xB7\uC0AD\uC81C\uB294 \uC0AC\uC6A9\uC790 \uD655\uC778\uC744 \uAC70\uCCD0\uC57C \uD55C\uB2E4 \u2014 --confirmed-by-user \uC5C6\uC774 \uAC70\uBD80 (\uC5D0\uC774\uC804\uD2B8 \uB2E8\uB3C5 \uACB0\uC815 \uAE08\uC9C0)"
    };
  }
  const journeyAbs = resolve14(repoRoot, req.journeyFile);
  const repoRel = relative17(resolve14(repoRoot), journeyAbs);
  if (repoRel.startsWith("..") || isAbsolute10(repoRel)) {
    return {
      ok: false,
      refusal: `journey \uACBD\uB85C\uAC00 \uC800\uC7A5\uC18C \uBC16\uC744 \uAC00\uB9AC\uD0A8\uB2E4(${req.journeyFile}) \u2014 \uC218\uBA85\uC8FC\uAE30 \uC9D1\uD589\uC740 \uC800\uC7A5\uC18C \uC548\uC758 \uD30C\uC0DD \uD14C\uC2A4\uD2B8\uC5D0\uB9CC \uC801\uC6A9\uB41C\uB2E4`
    };
  }
  const journeyName = basename3(journeyAbs);
  if (!journeyName.endsWith(".journey.md")) {
    return { ok: false, refusal: `journey \uD30C\uC77C\uC774 \uC544\uB2C8\uB2E4(*.journey.md \uC544\uB2D8): ${req.journeyFile}` };
  }
  const journeyText = await readOrNull(journeyAbs);
  if (journeyText === null) {
    return { ok: false, refusal: `journey \uD30C\uC77C\uC744 \uC77D\uC744 \uC218 \uC5C6\uB2E4: ${req.journeyFile}` };
  }
  const parsed = parseJourneyDoc(journeyText);
  if (!parsed.ok) {
    return { ok: false, refusal: `journey DSL \uD30C\uC2F1 \uC2E4\uD328: ${parsed.error}` };
  }
  const slug = journeyName.slice(0, -".journey.md".length);
  const generatedDir = resolve14(dirname13(journeyAbs), "..", "generated");
  const specAbs = join67(generatedDir, `${slug}.spec.ts`);
  const rel = (abs) => toPosix2(relative17(repoRoot, abs));
  const specText = await readOrNull(specAbs);
  if (specText === null) {
    return {
      ok: false,
      refusal: `generated spec \uBD80\uC7AC(${rel(specAbs)}) \u2014 DSL \uD30C\uC0DD\uBB3C\uC784\uC744 \uD655\uC778\uD560 \uC218 \uC5C6\uC5B4 \uAC70\uBD80\uD55C\uB2E4`
    };
  }
  if (!isDittoGenerated(specText)) {
    return {
      ok: false,
      refusal: `${rel(specAbs)}\uB294 @ditto-generated \uB9C8\uCEE4\uAC00 \uC5C6\uB294 \uC218\uB3D9 \uD30C\uC77C \u2014 \uC218\uBA85\uC8FC\uAE30 \uC9D1\uD589\uC740 DSL \uD30C\uC0DD \uD14C\uC2A4\uD2B8\uC5D0\uB9CC \uC801\uC6A9\uB41C\uB2E4`
    };
  }
  const supportDir = join67(generatedDir, "support");
  const helperOf = (blockId) => join67(supportDir, `${blockId}.block.ts`);
  for (const blockId of parsed.frontMatter.uses_blocks) {
    const helperText = await readOrNull(helperOf(blockId));
    if (helperText !== null && !isDittoGenerated(helperText)) {
      return {
        ok: false,
        refusal: `${rel(helperOf(blockId))}\uB294 @ditto-generated \uB9C8\uCEE4\uAC00 \uC5C6\uB294 \uC218\uB3D9 \uD30C\uC77C \u2014 \uAC70\uBD80\uD55C\uB2E4`
      };
    }
  }
  const journeyId = parsed.frontMatter.id;
  const ledgerPath = lifecycleLedgerPath(repoRoot, req.workItemId);
  const decided_at = new Date().toISOString();
  const base = {
    journey_id: journeyId,
    journey_file: rel(journeyAbs),
    confirmed_by_user: true,
    ...req.reason !== undefined ? { reason: req.reason } : {},
    decided_at
  };
  if (req.action === "update") {
    const stale = await detectStale(journeyAbs, specAbs, rel(journeyAbs));
    await appendDecision(ledgerPath, {
      action: "update",
      ...base,
      deleted_files: [],
      preserved_helpers: []
    });
    return {
      ok: true,
      action: "update",
      journey_id: journeyId,
      deleted_files: [],
      preserved_helpers: [],
      stale,
      ledger_path: ledgerPath
    };
  }
  const headerJourney = /^\s*(?:\/\/|\*)?\s*@ditto-journey\s+(\S+)\s*$/m.exec(specText)?.[1];
  const headerSource = /^\s*(?:\/\/|\*)?\s*@ditto-source\s+(\S+)\s*$/m.exec(specText)?.[1];
  const specIdentifiesJourney = headerJourney !== undefined ? headerJourney === journeyId : headerSource === rel(journeyAbs);
  if (!specIdentifiesJourney) {
    return {
      ok: false,
      refusal: `${rel(specAbs)} \uD5E4\uB354\uAC00 \uC774 journey\uB97C \uAC00\uB9AC\uD0A4\uC9C0 \uC54A\uB294\uB2E4 (@ditto-journey ${headerJourney ?? "\uC5C6\uC74C"} / @ditto-source ${headerSource ?? "\uC5C6\uC74C"} \u2260 ${journeyId} \xB7 ${rel(journeyAbs)}) \u2014 \uC0AD\uC81C \uAC70\uBD80`
    };
  }
  const journeysDir = dirname13(journeyAbs);
  const referencedElsewhere = new Set;
  for (const name of (await readdir19(journeysDir)).filter((n3) => n3.endsWith(".journey.md"))) {
    const otherAbs = join67(journeysDir, name);
    if (otherAbs === journeyAbs)
      continue;
    const other = await readOrNull(otherAbs);
    if (other === null)
      continue;
    const otherParsed = parseJourneyDoc(other);
    if (!otherParsed.ok) {
      for (const b3 of parsed.frontMatter.uses_blocks) {
        if (other.includes(b3))
          referencedElsewhere.add(b3);
      }
      continue;
    }
    for (const b3 of otherParsed.frontMatter.uses_blocks)
      referencedElsewhere.add(b3);
  }
  const deleted = [];
  const preserved = [];
  await unlink3(specAbs);
  deleted.push(rel(specAbs));
  for (const blockId of parsed.frontMatter.uses_blocks) {
    const helperAbs = helperOf(blockId);
    if (await readOrNull(helperAbs) === null)
      continue;
    if (referencedElsewhere.has(blockId)) {
      preserved.push(rel(helperAbs));
    } else {
      await unlink3(helperAbs);
      deleted.push(rel(helperAbs));
    }
  }
  await unlink3(journeyAbs);
  deleted.push(rel(journeyAbs));
  await appendDecision(ledgerPath, {
    action: "delete",
    ...base,
    deleted_files: deleted,
    preserved_helpers: preserved
  });
  return {
    ok: true,
    action: "delete",
    journey_id: journeyId,
    deleted_files: deleted,
    preserved_helpers: preserved,
    ledger_path: ledgerPath
  };
}

// src/core/e2e/plan-adapter.ts
var stepLine2 = /^\s*\d+\.\s+\[([sb]\d+)\]\s*(?:\(([^)]*)\)\s*)?(.*\S)?\s*$/;
var CRED_REF2 = /^(env|secret):(.+)$/;
function parseSteps(body) {
  const steps = [];
  for (const line of body.split(`
`)) {
    const m4 = stepLine2.exec(line);
    if (!m4?.[1])
      continue;
    const rest = (m4[3] ?? "").trim();
    const colon = rest.indexOf(":");
    const verb = colon >= 0 ? rest.slice(0, colon).trim() : "";
    const object = colon >= 0 ? rest.slice(colon + 1).trim() : rest;
    steps.push({ id: m4[1], condition: m4[2]?.trim() || undefined, verb, object });
  }
  return steps;
}
function parseCaseTable(body) {
  const lines = body.split(`
`);
  const start = lines.findIndex((l2) => /^##\s*\uCF00\uC774\uC2A4\s*$/.test(l2.trim()));
  if (start < 0)
    return { names: [], rows: {} };
  const names = [];
  const rows = {};
  let columns = [];
  let sawHeader = false;
  for (let i3 = start + 1;i3 < lines.length; i3++) {
    const line = (lines[i3] ?? "").trim();
    if (line.startsWith("#"))
      break;
    if (!line.startsWith("|")) {
      if (names.length > 0 || sawHeader)
        break;
      if (line === "")
        continue;
      break;
    }
    if (/^\|[\s\-:|]+\|?$/.test(line))
      continue;
    const cells = line.split("|").slice(1, -1).map((c5) => c5.trim());
    if (!sawHeader) {
      sawHeader = true;
      columns = cells;
      continue;
    }
    const caseName = cells[0];
    if (!caseName)
      continue;
    names.push(caseName);
    const row = {};
    columns.forEach((col, idx) => {
      row[col] = cells[idx] ?? "";
    });
    rows[caseName] = row;
  }
  return { names, rows };
}
var UNSET_CELL = "\u2014";
function isCellSet(v2) {
  return v2 !== undefined && v2.trim() !== "" && v2.trim() !== UNSET_CELL;
}
function stepActiveInCase(condition, caseName, caseRow) {
  if (!condition)
    return true;
  const caseMatch = /^\uCF00\uC774\uC2A4\s*:\s*(.+)$/.exec(condition);
  if (caseMatch)
    return caseMatch[1]?.trim() === caseName;
  const presence = /^(.+?)\s*(\uC788\uC74C|\uC5C6\uC74C)$/.exec(condition);
  if (presence) {
    const present = isCellSet(caseRow[presence[1]?.trim() ?? ""]);
    return presence[2] === "\uC788\uC74C" ? present : !present;
  }
  return true;
}
function substituteVars(text, caseRow, secretVars, resolveVar) {
  return text.replace(/\{([^}]+)\}/g, (_m, raw) => {
    const key = String(raw).trim();
    const direct = caseRow[key];
    const value = isCellSet(direct) ? direct : resolveVar?.(key);
    if (!isCellSet(value)) {
      return secretVars.includes(key) ? `<env:${key}>` : `{${key}}`;
    }
    return value;
  });
}
function distinctColumnValues(col, table, resolveVar) {
  const set = new Set;
  for (const name of table.names) {
    const v2 = table.rows[name]?.[col];
    if (v2 && v2.trim() !== "")
      set.add(v2);
  }
  const rv = resolveVar?.(col);
  if (rv)
    set.add(rv);
  return [...set];
}
function projectJourneyToPlan(input) {
  const { journey, body, sourcePath, digest, resolveVar } = input;
  const blocks = input.blocks ?? {};
  const secretVars = journey.secret_vars;
  const table = parseCaseTable(body);
  const steps = parseSteps(body);
  const seedRef = journey.seed?.spec_ref ?? "e2e/seed.spec.ts";
  const map = {};
  const assertions = {};
  const out = [];
  out.push(`# ${journey.name} Test Plan`);
  out.push(`<!-- @ditto-plan v1 \xB7 source: ${sourcePath} \xB7 digest: ${digest} -->`);
  out.push("");
  out.push("## Application Overview");
  out.push("");
  out.push(journey.implementation_intent);
  const bullets = [...journey.constraints];
  if (journey.seed)
    bullets.push(`Precondition: run \`${seedRef}\``);
  if (journey.initial_state) {
    const s2 = journey.initial_state;
    bullets.push(`Precondition: ${s2.description}${s2.setup_ref ? ` (run \`${s2.setup_ref}\`)` : ""}`);
  }
  if (journey.auth) {
    if (journey.auth.login_block) {
      bullets.push(`Precondition: run \`${journey.auth.login_block}\` (authentication)`);
    } else {
      const roles = Object.keys(journey.auth.credentials);
      if (roles.length)
        bullets.push(`Precondition: authenticate as ${roles.join(", ")}`);
    }
  }
  if (bullets.length) {
    out.push("");
    out.push("**Constraints:**");
    for (const b3 of bullets)
      out.push(`- ${b3}`);
  }
  out.push("");
  out.push("## Test Scenarios");
  let scenarioNo = 0;
  scenarioNo += 1;
  const scenarioMap = {};
  const scenarioAssertions = {};
  map[scenarioNo] = scenarioMap;
  assertions[scenarioNo] = scenarioAssertions;
  out.push("");
  out.push(`### ${scenarioNo}. ${journey.name}`);
  out.push(`**Seed:** \`${seedRef}\``);
  const cases = table.names.length ? table.names : ["\uAE30\uBCF8"];
  cases.forEach((caseName, ci) => {
    const caseRow = table.rows[caseName] ?? {};
    const caseMap = {};
    const assertIds = [];
    scenarioMap[caseName] = caseMap;
    scenarioAssertions[caseName] = assertIds;
    const stepLines = [];
    const expected = [];
    let planStepN = 0;
    const emitAction = (id, verb, obj) => {
      planStepN += 1;
      stepLines.push(`${planStepN}. ${verb}: ${obj}`);
      caseMap[planStepN] = id;
    };
    const emitAssertion = (id, obj) => {
      expected.push(obj);
      assertIds.push(id);
    };
    for (const step of steps) {
      if (!stepActiveInCase(step.condition, caseName, caseRow))
        continue;
      if (step.verb === "\uBE14\uB85D") {
        for (const bstep of parseSteps(blocks[step.object]?.body ?? "")) {
          const obj2 = substituteVars(bstep.object, caseRow, secretVars, resolveVar);
          if (bstep.verb === "\uD655\uC778")
            emitAssertion(bstep.id, obj2);
          else
            emitAction(bstep.id, bstep.verb, obj2);
        }
        continue;
      }
      const obj = substituteVars(step.object, caseRow, secretVars, resolveVar);
      if (step.verb === "\uD655\uC778")
        emitAssertion(step.id, obj);
      else
        emitAction(step.id, step.verb, obj);
    }
    out.push("");
    out.push(`#### ${scenarioNo}.${ci + 1} ${caseName}`);
    out.push("**Steps:**");
    for (const l2 of stepLines)
      out.push(l2);
    out.push("");
    out.push("**Expected Results:**");
    for (const e2 of expected)
      out.push(`- ${e2}`);
  });
  for (const edge of journey.edge_cases) {
    scenarioNo += 1;
    map[scenarioNo] = { \u{ae30}\u{bcf8}: {} };
    assertions[scenarioNo] = { \u{ae30}\u{bcf8}: [] };
    out.push("");
    out.push(`### ${scenarioNo}. ${edge.case}`);
    out.push(`**Seed:** \`${seedRef}\``);
    out.push("");
    out.push(`#### ${scenarioNo}.1 \uAE30\uBCF8`);
    out.push("**Steps:**");
    out.push(`1. ${edge.case}`);
    out.push("");
    out.push("**Expected Results:**");
    out.push(`- ${edge.handling}`);
  }
  for (const fs of journey.failure_states) {
    scenarioNo += 1;
    map[scenarioNo] = { \u{ae30}\u{bcf8}: {} };
    assertions[scenarioNo] = { \u{ae30}\u{bcf8}: [] };
    out.push("");
    out.push(`### ${scenarioNo}. ${fs.trigger}`);
    out.push(`**Seed:** \`${seedRef}\``);
    out.push("");
    out.push(`#### ${scenarioNo}.1 \uAE30\uBCF8`);
    out.push("**Steps:**");
    out.push(`1. ${fs.trigger}`);
    out.push("");
    out.push("**Expected Results:**");
    out.push(`- ${fs.expected}`);
  }
  let plan = `${out.join(`
`)}
`;
  const credRefs = Object.values(journey.auth?.credentials ?? {});
  const seedDataRef = journey.seed?.data_ref;
  const seedSecretRef = seedDataRef && CRED_REF2.test(seedDataRef) ? seedDataRef : undefined;
  const envRefs = [...credRefs, ...seedSecretRef ? [seedSecretRef] : []];
  const redactions = [];
  for (const col of secretVars) {
    for (const value of distinctColumnValues(col, table, resolveVar)) {
      const r4 = redactForPlan(plan, {
        secretVars: [col],
        credentialRefs: [],
        envValues: { [col]: value }
      });
      plan = r4.text;
      redactions.push(...r4.redactions);
    }
  }
  for (const ref of envRefs) {
    const key = CRED_REF2.exec(ref)?.[2];
    if (!key)
      continue;
    const value = resolveVar?.(key);
    if (!value)
      continue;
    const r4 = redactForPlan(plan, {
      secretVars: [],
      credentialRefs: [ref],
      envValues: { [key]: value }
    });
    plan = r4.text;
    redactions.push(...r4.redactions);
  }
  const guardEnv = {};
  let gi = 0;
  for (const col of secretVars) {
    for (const value of distinctColumnValues(col, table, resolveVar)) {
      guardEnv[`${col}#${gi++}`] = value;
    }
  }
  for (const ref of envRefs) {
    const key = CRED_REF2.exec(ref)?.[2];
    if (!key)
      continue;
    const value = resolveVar?.(key);
    if (value)
      guardEnv[key] = value;
  }
  assertNoPlaintextSecret(plan, { secretVars, credentialRefs: envRefs, envValues: guardEnv });
  return { plan, map, assertions, redactions };
}

// src/cli/commands/e2e.ts
init_fs();
var e2eRunSpec = exports_external.object({
  journey: exports_external.string().min(1),
  url: exports_external.string().min(1),
  steps: exports_external.array(e2eStep).default([]),
  assertions: exports_external.array(exports_external.object({ description: exports_external.string().min(1) })).default([])
});
var e2eRun = defineCommand({
  meta: {
    name: "run",
    description: "Run one browser user journey and write its e2eJourney artifact"
  },
  args: {
    runId: { type: "string", description: "Run id \u2192 .ditto/local/runs/<runId>/", required: true },
    json: {
      type: "string",
      description: "JSON spec: {journey,url,steps,assertions}",
      required: true
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let raw;
    try {
      raw = JSON.parse(args.json);
    } catch (err) {
      writeError(`--json is not valid JSON: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const parsed = e2eRunSpec.safeParse(raw);
    if (!parsed.success) {
      writeError("--json failed schema validation:");
      for (const issue of parsed.error.issues) {
        writeError(`  - ${issue.path.join(".") || "(root)"}: ${issue.message}`);
      }
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    try {
      const repoRoot = await resolveRepoRootForCreate();
      const result2 = await runJourney(repoRoot, args.runId, parsed.data);
      const runDir2 = localDir(repoRoot, "runs", args.runId);
      await mkdir9(runDir2, { recursive: true });
      await atomicWriteText(join68(runDir2, "journey.json"), `${JSON.stringify(result2.journey, null, 2)}
`);
      if (format === "json") {
        writeJson2(result2);
      } else {
        writeHuman(`e2e run ${result2.run_id}: ${result2.journey.result}`);
        writeHuman(`  artifact: .ditto/local/runs/${result2.run_id}/journey.json`);
        if (!result2.probe.available)
          writeHuman(`  (blocked: ${result2.probe.reason})`);
      }
    } catch (err) {
      writeError(`e2e run failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var e2eApplicable = defineCommand({
  meta: {
    name: "applicable",
    description: "Decide whether axis-3 (browser E2E) applies to this target, or is N/A (no web UI)"
  },
  args: {
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    try {
      const repoRoot = await resolveRepoRootForCreate();
      const result2 = evaluateAxis3FromRepo(defaultApplicabilityDeps(repoRoot));
      if (format === "json") {
        writeJson2(result2);
      } else {
        writeHuman(`axis-3 e2e: ${result2.applicable ? "APPLICABLE" : "N/A"} \u2014 ${result2.reason}`);
        if (!result2.applicable) {
          writeHuman(`  covered by: ${result2.covered_by.join("; ")}`);
        }
      }
    } catch (err) {
      writeError(`e2e applicable failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var e2eConformance = defineCommand({
  meta: {
    name: "conformance",
    description: "Check DSL step \u2194 generated @step marker traceability + digest freshness"
  },
  args: {
    journey: { type: "string", description: "Path to <slug>.journey.md", required: true },
    "blocks-dir": {
      type: "string",
      description: "Dir with <block-id>.block.md files (default: <journey dir>/blocks)"
    },
    generated: { type: "string", description: "Path to generated <slug>.spec.ts", required: true },
    "support-dir": {
      type: "string",
      description: "Dir with generated support helpers (default: <generated dir>/support)"
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    try {
      const journeyAbs = resolve15(args.journey);
      const generatedAbs = resolve15(args.generated);
      const blocksDir = resolve15(args["blocks-dir"] ?? join68(dirname14(journeyAbs), "blocks"));
      const supportDir = resolve15(args["support-dir"] ?? join68(dirname14(generatedAbs), "support"));
      const journeyText = await readFile16(journeyAbs, "utf8");
      const generatedText = await readFile16(generatedAbs, "utf8");
      const blockTexts = {};
      try {
        for (const name of await readdir20(blocksDir)) {
          if (!name.endsWith(".block.md"))
            continue;
          blockTexts[name.slice(0, -".block.md".length)] = await readFile16(join68(blocksDir, name), "utf8");
        }
      } catch {}
      const supportTexts = [];
      try {
        for (const name of await readdir20(supportDir)) {
          if (!name.endsWith(".ts"))
            continue;
          supportTexts.push(await readFile16(join68(supportDir, name), "utf8"));
        }
      } catch {}
      const report = checkStepConformance({ journeyText, blockTexts, generatedText, supportTexts });
      const repoRoot = await resolveRepoRootForCreate();
      const repoRel = (abs) => relative18(repoRoot, abs).split(sep8).join("/");
      const stale = [];
      const journeyVerdict = await detectStale(journeyAbs, generatedAbs, repoRel(journeyAbs));
      if (journeyVerdict.stale)
        stale.push(`${args.generated}: ${journeyVerdict.reason}`);
      const parsedJourney = parseJourneyDoc(journeyText);
      if (parsedJourney.ok) {
        for (const blockId of parsedJourney.frontMatter.uses_blocks) {
          if (blockTexts[blockId] === undefined)
            continue;
          const helperAbs = join68(supportDir, `${blockId}.block.ts`);
          const blockMdAbs = join68(blocksDir, `${blockId}.block.md`);
          const verdict2 = await detectStale(blockMdAbs, helperAbs, repoRel(blockMdAbs));
          if (verdict2.stale)
            stale.push(`support/${blockId}.block.ts: ${verdict2.reason}`);
        }
      }
      const ok = report.ok && stale.length === 0;
      if (format === "json") {
        writeJson2({ ...report, ok, stale });
      } else {
        writeHuman(`e2e conformance: ${ok ? "OK" : "FAIL"}`);
        writeHuman(`  required: ${report.required.length}, found: ${report.found.length}`);
        for (const ref of report.missing)
          writeHuman(`  missing marker: ${ref}`);
        for (const err of report.errors)
          writeHuman(`  error: ${err}`);
        for (const s2 of stale)
          writeHuman(`  stale: ${s2}`);
      }
      if (!ok)
        process.exit(RUNTIME_ERROR_EXIT);
    } catch (err) {
      writeError(`e2e conformance failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
