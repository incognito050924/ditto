var finalizeCmd = defineCommand({
  meta: {
    name: "finalize",
    description: "Lock the interview: write intent.json, mirror AC into work item, bootstrap autopilot"
  },
  args: {
    workItem: { type: "string", description: "Work item id (wi_*)", required: true },
    json: {
      type: "string",
      description: "JSON payload matching finalizePayload schema",
      required: true
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let raw;
    try {
      raw = parseJsonArg(args.json);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const parsed = finalizePayload.safeParse(raw);
    if (!parsed.success) {
      writeError("--json failed schema validation:");
      for (const issue of parsed.error.issues) {
        writeError(`  - ${issue.path.join(".") || "(root)"}: ${issue.message}`);
      }
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await resolveRepoRootForCreate();
    try {
      const result2 = await finalizeInterview(repoRoot, {
        workItemId: args.workItem,
        payload: parsed.data
      });
      if (result2.status === "not_ready") {
        writeError("interview is not ready; cannot finalize:");
        for (const r3 of result2.gate.reasons)
          writeError(`  - ${r3}`);
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      if (result2.status === "not_confirmed") {
        writeError("readiness gate passed (1\uCC28) but the user has not confirmed the intent (2\uCC28 \uAC8C\uC774\uD2B8): " + "capture the user confirmation (user_confirmation.confirmed=true with their statement) and re-run finalize");
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      if (format === "json") {
        writeJson2({
          work_item_id: result2.intent.work_item_id,
          intent_path: `.ditto/local/work-items/${result2.intent.work_item_id}/intent.json`,
          autopilot_id: result2.autopilot.autopilot_id,
          autopilot_path: `.ditto/local/work-items/${result2.intent.work_item_id}/autopilot.json`,
          approval_gate: result2.autopilot.approval_gate.status,
          node_ids: result2.autopilot.nodes.map((n2) => n2.id),
          acceptance_criteria: result2.intent.acceptance_criteria.map((ac) => ac.id)
        });
      } else {
        writeHuman(`Finalized interview for ${result2.intent.work_item_id}`);
        writeHuman(`  intent:        .ditto/local/work-items/${result2.intent.work_item_id}/intent.json`);
        writeHuman(`  autopilot:     ${result2.autopilot.autopilot_id}`);
        writeHuman(`  approval_gate: ${result2.autopilot.approval_gate.status}`);
        writeHuman(`  acceptance:    ${result2.intent.acceptance_criteria.map((ac) => ac.id).join(", ")}`);
        writeHuman(`  nodes:         ${result2.autopilot.nodes.map((n2) => n2.id).join(" -> ")}`);
      }
    } catch (err) {
      writeError(`finalize failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
