// src/hooks/runtime.ts
var KILL_SWITCH = "DITTO_SKIP_HOOKS";
async function runHook(handler, input) {
  if (input.env[KILL_SWITCH])
    return { exitCode: 0 };
  try {
    return await handler(input);
  } catch (err) {
    const message = err instanceof Error ? err.message : String(err);
    return { exitCode: 0, stderr: `ditto hook error (fail-open): ${message}
` };
  }
}

// src/hooks/io.ts
async function readStdinJson() {
  try {
    const text = await Bun.stdin.text();
    if (text.trim().length === 0)
      return null;
    return JSON.parse(text);
  } catch {
    return null;
  }
}
async function resolveRepoRoot(host, raw) {
  const cwd = typeof raw?.cwd === "string" ? raw.cwd : undefined;
  const start = host === "codex" ? cwd ?? process.cwd() : process.env.CLAUDE_PROJECT_DIR ?? cwd ?? process.cwd();
  return resolveRepoRootForCreate(start);
}
async function executeHook(handler, host = "claude-code") {
  const raw = await readStdinJson();
  const input = {
    raw,
    repoRoot: await resolveRepoRoot(host, raw),
    env: process.env,
    host
  };
  const out = await runHook(handler, input);
  if (out.stdout)
    process.stdout.write(out.stdout);
  if (out.stderr)
    process.stderr.write(out.stderr);
  process.exit(out.exitCode);
}

