    schema_version: schemaVersion,
    run_id: exports_external.string().regex(/^cleanup-\d{8}-\d{6}(-[a-z0-9]+)?$/, "run id must be cleanup-<YYYYMMDD-HHMMSS> with an optional collision suffix").describe("Stable identifier for one classify run"),
    created_at: isoDateTime,
