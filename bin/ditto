import { readFile as readFile18, readdir as readdir25 } from "fs/promises";
import { join as join80, relative as relative20 } from "path";
function bootstrapEventId(key) {
  return `memevt_${sha256Hex(key).slice(0, 12)}`;
}
function gitHeadSha3(repoRoot) {
  const proc = Bun.spawnSync(["git", "rev-parse", "HEAD"], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (proc.exitCode !== 0)
    return null;
  const sha = (proc.stdout?.toString() ?? "").trim();
  return /^[a-f0-9]{40}$/.test(sha) ? sha : null;
}
function wordCount(s2) {
  return s2.split(/\s+/).filter((w2) => w2.length > 0).length;
}
function markdownTitle(body) {
  const lines = body.split(`
`);
  for (const line of lines) {
    const m4 = line.match(/^#\s+(.+)$/);
    if (m4?.[1])
      return m4[1].trim();
  }
  for (const line of lines) {
    if (line.trim().length > 0)
      return line.trim();
  }
  return "";
}
function adrGist(body) {
  const title = markdownTitle(body);
  const sections = [];
  const lines = body.split(`
`);
  let capturing = false;
  let captured = [];
  const flush = () => {
    if (captured.length > 0)
      sections.push(captured.join(`
`).trim());
    captured = [];
  };
  for (const line of lines) {
    const heading = line.match(/^##\s+(.+)$/);
    if (heading) {
      flush();
      const name = heading[1]?.trim() ?? "";
      capturing = /\uACB0\uC815|\uADFC\uAC70|\uB300\uC548|\uAE30\uAC01|\uD3D0\uAE30|\uCCA0\uD68C|\uC7AC\uAC80\uD1A0|\uBCC0\uACBD\s*\uC870\uAC74|decision|rationale|alternative|reject/i.test(name);
      continue;
    }
    if (capturing)
      captured.push(line);
  }
  flush();
  const gist = sections.join(`

`).trim();
  const text = gist.length > 0 ? `${title}

${gist}` : title;
  return text.slice(0, 4000);
}
function parseGovernedPaths(body) {
  const line = body.split(`
`).find((l2) => /^[-*\s]*\uAD00\uB828\s*:/.test(l2));
  if (!line)
    return [];
  return line.replace(/^[-*\s]*\uAD00\uB828\s*:/, "").split(",").map((s2) => s2.trim().replace(/\s*\(.*$/, "").replace(/`/g, "").trim()).filter((s2) => /^(src|tests|scripts)\//.test(s2));
}
function emptyResult() {
  return { sourcesAdded: [], sourcesSkipped: [], eventsAppended: [], eventsSkipped: [] };
}
function merge(into, from) {
  into.sourcesAdded.push(...from.sourcesAdded);
  into.sourcesSkipped.push(...from.sourcesSkipped);
  into.eventsAppended.push(...from.eventsAppended);
  into.eventsSkipped.push(...from.eventsSkipped);
}
async function writeSourceIdempotent(store, source, result2) {
  if (await store.exists(source.source_id)) {
    const prior = await store.get(source.source_id);
    if (prior.content_hash === source.content_hash) {
      result2.sourcesSkipped.push(source.source_id);
      return;
    }
  }
  await store.write(source);
  result2.sourcesAdded.push(source.source_id);
}
async function appendEventGraceful(store, event, result2) {
  try {
    await store.append(event);
    result2.eventsAppended.push(event.event_id);
  } catch (err) {
    if (err instanceof MemoryEventExistsError) {
      result2.eventsSkipped.push(event.event_id);
      return;
    }
    throw err;
  }
}
async function listMarkdown(dir) {
  let entries;
  try {
    entries = await readdir25(dir);
  } catch {
    return [];
  }
  return entries.filter((n3) => n3.endsWith(".md")).sort().map((n3) => join80(dir, n3));
}
async function bootstrapIngest(repoRoot, options = {}) {
  const now = (options.now ?? new Date).toISOString();
  const head = gitHeadSha3(repoRoot);
  const revision = head ?? `bootstrap:${now}`;
  const sourceStore = new MemorySourceStore(repoRoot);
  const eventStore = new MemoryEventStore(repoRoot);
  const result2 = emptyResult();
  merge(result2, await ingestAdrs(repoRoot, sourceStore, eventStore, now, revision, head));
  merge(result2, await ingestGlossary(repoRoot, sourceStore, eventStore, now, revision, head));
  merge(result2, await ingestHandoffs(repoRoot, sourceStore, eventStore, now, revision, head));
  return result2;
}
async function ingestAdrs(repoRoot, sourceStore, eventStore, now, revision, head) {
  const result2 = emptyResult();
  const dir = join80(dittoDir(repoRoot), "knowledge", "adr");
  for (const abs of await listMarkdown(dir)) {
    const body = await readFile18(abs, "utf8");
    const rel = relative20(repoRoot, abs);
    const sourceId = sourceIdForPath(rel);
    const source = {
      schema_version: "0.1.0",
      source_id: sourceId,
      source_type: "spec",
      path: rel,
      content_hash: sha256Hex(body),
      captured_at: now,
      revision,
      sensitivity: "internal",
      word_count: wordCount(body),
      ...head ? { git_commit: head } : {}
    };
    await writeSourceIdempotent(sourceStore, source, result2);
    const text = adrGist(body) || markdownTitle(body) || rel;
    const event = {
      schema_version: "0.1.0",
      event_id: bootstrapEventId(`adr:${sourceId}`),
      event_type: "decision",
      actor: { kind: "agent", role: "bootstrap" },
      text,
      created_at: now,
      status: "approved",
      sources: [sourceId],
      confidence_kind: "EXTRACTED",
      sensitivity: "internal",
      approved_by: "bootstrap",
      decided_at: now,
      governs: parseGovernedPaths(body)
    };
    await appendEventGraceful(eventStore, event, result2);
  }
  return result2;
}
async function ingestGlossary(repoRoot, sourceStore, eventStore, now, revision, head) {
  const result2 = emptyResult();
  const abs = join80(dittoDir(repoRoot), "knowledge", "glossary.json");
  let raw;
  try {
    raw = await readFile18(abs, "utf8");
  } catch {
    return result2;
  }
  let parsed;
  try {
    parsed = JSON.parse(raw);
  } catch {
    return result2;
  }
  const rel = relative20(repoRoot, abs);
  const sourceId = sourceIdForPath(rel);
  const source = {
    schema_version: "0.1.0",
    source_id: sourceId,
    source_type: "spec",
    path: rel,
    content_hash: sha256Hex(raw),
    captured_at: now,
    revision,
    sensitivity: "internal",
    word_count: wordCount(raw),
    ...head ? { git_commit: head } : {}
  };
  await writeSourceIdempotent(sourceStore, source, result2);
  for (const entry of parsed.entries ?? []) {
    if (!entry?.term)
      continue;
    const definition = entry.definition ?? "";
    const aliases = (entry.aliases ?? []).join(", ");
    const text = [`${entry.term}: ${definition}`, aliases ? `aliases: ${aliases}` : ""].filter((s2) => s2.length > 0).join(`
`).slice(0, 4000);
    const event = {
      schema_version: "0.1.0",
      event_id: bootstrapEventId(`glossary:${sourceId}:${entry.term}`),
      event_type: "observation",
      actor: { kind: "agent", role: "bootstrap" },
      text,
      created_at: now,
      status: "approved",
      sources: [sourceId],
      confidence_kind: "EXTRACTED",
      sensitivity: "internal",
      approved_by: "bootstrap",
      decided_at: now
    };
    await appendEventGraceful(eventStore, event, result2);
  }
  return result2;
}
function handoffGist(body) {
  const parts = [];
  const fence = body.match(/^---\n([\s\S]*?)\n---/);
  if (fence?.[1]) {
    try {
      const meta = JSON.parse(fence[1].trim());
      for (const key of ["original_intent", "current_state", "next_first_check"]) {
        const v2 = meta[key];
        if (typeof v2 === "string" && v2.length > 0)
          parts.push(`${key}: ${v2}`);
      }
      const decisions = meta.decisions_made;
      if (Array.isArray(decisions) && decisions.length > 0) {
        parts.push(`decisions: ${decisions.map((d2) => String(d2)).join("; ")}`);
      }
      const failed = meta.failed_or_unverified;
      if (Array.isArray(failed) && failed.length > 0) {
        parts.push(`failed_or_unverified: ${failed.map((d2) => String(d2)).join("; ")}`);
      }
    } catch {}
  }
  if (parts.length === 0) {
    const title = markdownTitle(body);
    if (title)
      parts.push(title);
  }
  return parts.join(`
`).slice(0, 4000);
}
async function ingestHandoffs(repoRoot, sourceStore, eventStore, now, revision, head) {
  const result2 = emptyResult();
  const dir = localDir(repoRoot, "handoff", "archive");
  for (const abs of await listMarkdown(dir)) {
    const body = await readFile18(abs, "utf8");
    const rel = relative20(repoRoot, abs);
    const sourceId = sourceIdForPath(rel);
    const source = {
      schema_version: "0.1.0",
      source_id: sourceId,
      source_type: "note",
      path: rel,
      content_hash: sha256Hex(body),
      captured_at: now,
      revision,
      sensitivity: "internal",
      word_count: wordCount(body),
      ...head ? { git_commit: head } : {}
    };
    await writeSourceIdempotent(sourceStore, source, result2);
    const text = handoffGist(body) || markdownTitle(body) || rel;
    const event = {
      schema_version: "0.1.0",
      event_id: bootstrapEventId(`handoff:${sourceId}`),
      event_type: "observation",
      actor: { kind: "agent", role: "bootstrap" },
      text,
      created_at: now,
      status: "approved",
      sources: [sourceId],
      confidence_kind: "EXTRACTED",
      sensitivity: "internal",
      approved_by: "bootstrap",
      decided_at: now
    };
    await appendEventGraceful(eventStore, event, result2);
  }
  return result2;
}

