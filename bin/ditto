    oracle_verdicts: exports_external.array(oracleVerdict).describe("Raw oracle verdicts (ENFORCE set), pre-correlation"),
    labeler_labels: exports_external.array(labelerLabel).describe("Raw verdict-blind labeler labels (JUDGE set), pre-correlation"),
    tally: exports_external.object({
      claims: exports_external.number().int().nonnegative().describe("Total raw claims considered"),
      oracle: exports_external.object({
        confirmed: exports_external.number().int().nonnegative(),
        refuted: exports_external.number().int().nonnegative(),
        advisory_unverified: exports_external.number().int().nonnegative()
      }).describe("Oracle outcome counts (ENFORCE set)"),
      labeler: exports_external.object({
        real: exports_external.number().int().nonnegative(),
        fabricated: exports_external.number().int().nonnegative()
      }).describe("Labeler label counts (JUDGE set)")
    }).describe("Deterministic CORRELATE slot \u2014 computed by ditto code over the two independent sets (never by either agent); the fabrication-rate before/after measurement reads this (n9)")
  }).describe("Oracle-verdict + labeler audit sidecar (oracle-provenance.json) \u2014 mirrors relevanceProvenance (wi_260706n4w ac-4/ac-5)");
  coverageChildInput = exports_external.object({
    id: exports_external.string().min(1),
    parent_id: exports_external.string().min(1),
    label: exports_external.string().min(1),
    origin: exports_external.enum(["derived", "discovered"]),
    depth_weight: exports_external.number()
  });
  coverageRoundPayload = exports_external.object({
    node_id: exports_external.string().min(1),
    derived_nodes: exports_external.array(coverageChildInput).default([]),
