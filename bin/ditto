class RunStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  runDir(id) {
    return localDir(this.repoRoot, "runs", id);
  }
  manifestPath(id) {
    return join54(this.runDir(id), "manifest.json");
  }
  async exists(id) {
    try {
      await stat9(this.manifestPath(id));
      return true;
    } catch {
      return false;
    }
  }
  pathFor(id, kind) {
    return join54(this.runDir(id), kind);
  }
  async create(input, now = new Date) {
    const id = await generateId("run", (candidate) => this.exists(candidate));
    const nowIso = now.toISOString();
    const draft = {
      schema_version: "0.1.0",
      id,
      work_item_id: input.work_item_id,
      provider: input.provider,
      entrypoint: input.entrypoint,
      model_reported: input.model_reported,
      profile: input.profile,
      cwd: input.cwd,
      ...input.prompt_path !== undefined ? { prompt_path: input.prompt_path } : {},
      git_before: input.git_before,
      changed_files: [],
      exit_code: null,
      started_at: nowIso,
      verifications: [],
      unverified: []
    };
    await ensureDir(this.runDir(id));
    return writeJson(this.manifestPath(id), runManifest, draft);
  }
  async get(id) {
    return readJson(this.manifestPath(id), runManifest);
  }
  async update(id, mutator) {
    const current = await this.get(id);
    const next = mutator(current);
    if (next.id !== current.id) {
      throw new Error(`update mutator changed run id from ${current.id} to ${next.id}`);
    }
    return writeJson(this.manifestPath(id), runManifest, next);
  }
}

// src/core/context-packet.ts
init_work_item_store();

class ContextBuildUsageError extends Error {
  constructor(message) {
    super(message);
    this.name = "ContextBuildUsageError";
  }
}
function defaultOutputPath(workItemId2) {
  return `.ditto/local/work-items/${workItemId2}/context-packet.md`;
}
function validateOutputPath(path) {
  const parsed = relativePath.safeParse(path);
  if (!parsed.success) {
    throw new ContextBuildUsageError(`invalid --output path: ${parsed.error.issues[0]?.message}`);
  }
  return parsed.data;
}
async function buildContextPacket(repoRoot, input) {
  const workStore = new WorkItemStore(repoRoot);
  const runStore = new RunStore(repoRoot);
  const item = await workStore.get(input.work_item_id);
  const git = captureGitState(repoRoot);
  const outputPath = validateOutputPath(input.output_path ?? defaultOutputPath(item.id));
  const runs = await Promise.all(item.runs.map(async (id) => {
    try {
      return await runStore.get(id);
    } catch {
      return null;
    }
  }));
  const lines = [
    `# ${item.title}`,
    "",
    "## Goal",
    "",
    item.goal,
    "",
    "## Acceptance Criteria",
    "",
    ...item.acceptance_criteria.map((criterion) => {
      return `- ${criterion.id} [${criterion.verdict}] ${criterion.statement}`;
    }),
    "",
    "## Git State",
    "",
    `- head: ${git.head}`,
    `- branch: ${git.branch || "(unknown)"}`,
    `- dirty: ${git.dirty}`,
    "",
    "## Runs",
    "",
    ...runs.length === 0 ? ["- none"] : runs.map((run2, index) => {
      const id = item.runs[index] ?? "(unknown)";
      return run2 === null ? `- ${id}: missing` : `- ${run2.id}: exit_code=${run2.exit_code}`;
    }),
    ""
  ];
  const content = `${lines.join(`
`)}`;
  await atomicWriteText(join55(repoRoot, outputPath), content);
  return {
    work_item_id: item.id,
    output_path: outputPath,
    content
  };
}

