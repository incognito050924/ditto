  }).describe("Where a node/edge came from \u2014 required so the graph stays regenerable (report \xA75.2)");
  memoryNode = exports_external.object({
    id: exports_external.string().min(1).describe("Canonical id, e.g. artifact:<path> or symbol:<path>#<qualified_name>"),
    node_type: memoryNodeType,
    name: exports_external.string().min(1),
    file_type: exports_external.enum(["code", "document", "paper", "image"]).optional(),
    source_id: memorySourceId.optional(),
    source_revision: exports_external.string().min(1).optional(),
    source_span: exports_external.string().optional(),
    properties: exports_external.record(exports_external.unknown()).default({}),
    provenance: memoryProvenance.optional()
  }).describe("One graph node");
  memoryEdge = exports_external.object({
    id: exports_external.string().min(1),
    from: exports_external.string().min(1).describe("source node id"),
    to: exports_external.string().min(1).describe("target node id"),
    edge_type: memoryEdgeType,
    confidence_kind: memoryConfidenceKind,
    confidence_score: exports_external.number().min(0).max(1),
    properties: exports_external.record(exports_external.unknown()).default({}),
    provenance: memoryProvenance,
    weight: exports_external.number().positive().default(1),
    valid_from: isoDateTime.optional(),
    valid_to: isoDateTime.optional(),
    expires_at: isoDateTime.optional().describe("TTL for inferred candidates (report \xA76.5)"),
    requires_review: exports_external.boolean().default(false),
    used_as_evidence: exports_external.boolean().default(false)
  }).superRefine((edge, ctx) => enforceConfidenceBands(edge.confidence_kind, edge.confidence_score, ctx)).describe("One directed graph edge with provenance and calibrated confidence");
  memoryHyperedge = exports_external.object({
    id: exports_external.string().min(1),
    label: exports_external.string().min(1),
    nodes: exports_external.array(exports_external.string().min(1)).min(3).describe("3+ node ids participating together"),
    relation: memoryHyperedgeRelation,
    confidence_kind: memoryConfidenceKind,
    confidence_score: exports_external.number().min(0).max(1),
    provenance: memoryProvenance
  }).superRefine((h2, ctx) => enforceConfidenceBands(h2.confidence_kind, h2.confidence_score, ctx)).describe("N-ary relation among 3+ nodes (companion \xA74-1)");
  memoryGraphIr = exports_external.object({
    schema_version: schemaVersion,
    ir_version: graphIrVersion,
    generated_at: isoDateTime,
    extraction_run_id: extractionRunId,
    nodes: exports_external.array(memoryNode).default([]),
    edges: exports_external.array(memoryEdge).default([]),
    hyperedges: exports_external.array(memoryHyperedge).default([])
  }).describe("Compiled intermediate representation between extractors and projections \u2014 regenerable, never SoT (report \xA73.3)");
});

