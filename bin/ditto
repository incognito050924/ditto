    try {
      const result2 = await finalizeTechSpec(repoRoot, {
        workItemId: args.workItem,
        payload: parsed.data
      });
      if (result2.status !== "finalized") {
        switch (result2.status) {
          case "not_started":
            writeError("tech-spec was never started for this work item \u2014 run `ditto tech-spec start` first");
            break;
          case "doc_missing":
            writeError(`spec document not found: ${result2.doc_path}`);
            break;
          case "compile_rejected":
            writeError("spec document failed to compile (fail-closed):");
            for (const r3 of result2.reasons)
              writeError(`  - ${r3}`);
            break;
          case "interview_not_ready":
            writeError("an interview happened and its readiness gate is still blocked \u2014 finalize never bypasses it:");
            for (const r3 of result2.gate.reasons)
              writeError(`  - ${r3}`);
            break;
          case "not_confirmed":
            writeError("the user has not confirmed the intent (2\uCC28 \uAC8C\uC774\uD2B8, \uBAA8\uB4DC \uBD88\uBCC0): capture user_confirmation.confirmed=true with their statement and re-run");
            break;
        }
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      if (format === "json") {
        writeJson2({
          work_item_id: result2.intent.work_item_id,
          intent_path: `.ditto/local/work-items/${result2.intent.work_item_id}/intent.json`,
          source_digest: result2.intent.source_digest,
          autopilot_id: result2.autopilot.autopilot_id,
          approval_gate: result2.autopilot.approval_gate.status,
          acceptance_criteria: result2.intent.acceptance_criteria.map((ac) => ac.id),
          review_coverage: result2.state.finalized?.review_coverage ?? []
        });
      } else {
        writeHuman(`Finalized tech-spec for ${result2.intent.work_item_id}`);
        writeHuman(`  intent:        .ditto/local/work-items/${result2.intent.work_item_id}/intent.json`);
        writeHuman(`  source_digest: ${result2.intent.source_digest?.sha256.slice(0, 12)}\u2026 (${result2.intent.source_digest?.doc_path})`);
        writeHuman(`  autopilot:     ${result2.autopilot.autopilot_id} (gate: ${result2.autopilot.approval_gate.status})`);
        writeHuman(`  acceptance:    ${result2.intent.acceptance_criteria.map((ac) => ac.id).join(", ")}`);
        const cov = result2.state.finalized?.review_coverage ?? [];
        const reviewed = cov.filter((c3) => c3.review === "reviewed").length;
        writeHuman(`  review:        ${reviewed}/${cov.length} sections reviewed (rest pending/skipped \u2014 recorded honestly)`);
      }
    } catch (err) {
      writeError(`finalize failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
