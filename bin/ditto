function relationQueries(language) {
  const q2 = RELATION_QUERIES[language];
  if (!q2) {
    const supported = Object.keys(RELATION_QUERIES).join(", ");
    throw new Error(`CodeQL relation queries not bound for language '${language}' (supported: ${supported})`);
  }
  return q2;
}
function qlpackYml(language) {
  return `name: ditto/acg-relations
version: 0.0.1
dependencies:
  codeql/${codeqlExtractorLanguage(language)}-all: "*"
`;
}
function buildQueryRunArgs(input) {
  return [
    "query",
    "run",
    `--database=${input.dbPath}`,
    `--output=${input.bqrsOut}`,
    input.queryPath
  ];
}
function buildBqrsDecodeArgs(bqrsPath, csvOut) {
  return ["bqrs", "decode", "--format=csv", `--output=${csvOut}`, bqrsPath];
}
function parseCsvLine(line) {
  const out = [];
  let cur = "";
  let inQ = false;
  for (let i2 = 0;i2 < line.length; i2++) {
    const c3 = line[i2];
    if (c3 === '"') {
      if (inQ && line[i2 + 1] === '"') {
        cur += '"';
        i2++;
      } else
        inQ = !inQ;
    } else if (c3 === "," && !inQ) {
      out.push(cur);
      cur = "";
    } else
      cur += c3;
  }
  out.push(cur);
  return out;
}
function parseCsvRows(csv) {
  const lines = csv.split(`
`).filter((l2) => l2.length > 0);
  if (lines.length <= 1)
    return [];
  return lines.slice(1).map(parseCsvLine);
}
var CODEQL_BINARY2 = "codeql";
async function runRelationQuery(input, deps) {
  const binary = input.binary ?? CODEQL_BINARY2;
  const env2 = { set: {}, unset: ["LGTM_INDEX_FILTERS"] };
  if (!await deps.dirExists(input.dbPath)) {
    await deps.ensureDir(dirname3(input.dbPath));
    const buildMode = input.buildMode ?? selectBuildMode(input.language, input.buildCommand);
    const create = deps.spawn({
      binary,
      args: buildCreateArgs({
        dbPath: input.dbPath,
        language: input.language,
        sourceRoot: input.sourceRoot,
        buildMode,
        ...input.buildCommand ? { buildCommand: input.buildCommand } : {}
      }),
      repoRoot: input.repoRoot,
      cwd: ".",
      env: env2
    });
    await Promise.all([deps.drain(create.stderr), deps.drain(create.stdout)]);
    const done = await create.completion;
    if (done.exit_code !== 0) {
      throw new Error(`codeql database create failed (exit ${done.exit_code}${done.error ? `: ${done.error}` : ""})`);
    }
  }
  await deps.ensureDir(input.workDir);
  await deps.writeText(join8(input.workDir, "qlpack.yml"), qlpackYml(input.language));
  const queryPath = join8(input.workDir, "relation.ql");
  await deps.writeText(queryPath, input.query);
  const bqrsOut = join8(input.workDir, "relation.bqrs");
  const run = deps.spawn({
    binary,
    args: buildQueryRunArgs({ dbPath: input.dbPath, queryPath, bqrsOut }),
    repoRoot: input.repoRoot,
    cwd: ".",
    env: env2
  });
  await Promise.all([deps.drain(run.stderr), deps.drain(run.stdout)]);
  const runDone = await run.completion;
  if (runDone.exit_code !== 0) {
    throw new Error(`codeql query run failed (exit ${runDone.exit_code}${runDone.error ? `: ${runDone.error}` : ""})`);
  }
  const csvOut = join8(input.workDir, "relation.csv");
  const decode = deps.spawn({
    binary,
    args: buildBqrsDecodeArgs(bqrsOut, csvOut),
    repoRoot: input.repoRoot,
    cwd: ".",
    env: env2
  });
  await Promise.all([deps.drain(decode.stderr), deps.drain(decode.stdout)]);
  const decodeDone = await decode.completion;
  if (decodeDone.exit_code !== 0) {
    throw new Error(`codeql bqrs decode failed (exit ${decodeDone.exit_code}${decodeDone.error ? `: ${decodeDone.error}` : ""})`);
  }
  return parseCsvRows(await deps.readText(csvOut));
}
async function resolveSymbolDeclFiles(input, deps) {
  const rows = await runRelationQuery({ ...input, query: renderQuery(relationQueries(input.language).symbolDecl, input.symbol) }, deps);
  const files = rows.map((r3) => r3[0]).filter((p) => p !== undefined && p.length > 0);
  return [...new Set(files)];
}

// src/acg/boundary/codeql-edges.ts
function stripModuleExt(target, language) {
  if (language === "java")
    return target.replace(/\.java$/, "");
  if (language === "kotlin")
    return target.replace(/\.kt$/, "");
  if (language === "python")
    return target.replace(/\.py$/, "");
  return target.replace(/\.[cm]?[jt]sx?$/, "");
}

class CodeqlEdgeAnalyzer {
  config;
  deps;
  constructor(config, deps) {
    this.config = config;
    this.deps = deps;
  }
  async edges(input) {
    const rows = await runRelationQuery({
      repoRoot: this.config.repoRoot,
      sourceRoot: input.sourceRoot,
      language: this.config.language,
      dbPath: join9(this.config.cacheDir, "db"),
      workDir: join9(this.config.cacheDir, "q-edges"),
      query: renderEdgeQuery(input.changedFiles, this.config.language),
      ...this.config.buildMode ? { buildMode: this.config.buildMode } : {},
      ...this.config.buildCommand ? { buildCommand: this.config.buildCommand } : {},
      ...this.config.binary ? { binary: this.config.binary } : {}
    }, this.deps);
    const edges = [];
    const seen = new Set;
    for (const row of rows) {
      const [from, to] = row;
      if (!from || !to)
        continue;
      const normTo = stripModuleExt(to, this.config.language);
      const key = `${from}\x00${normTo}`;
      if (seen.has(key))
        continue;
      seen.add(key);
      edges.push({ from, to: normTo });
    }
    return edges;
  }
}

// src/acg/internal-packages.ts
import { readdir as readdir3 } from "fs/promises";
import { join as join10, relative as relative2 } from "path";

// src/acg/boundary/boundary.ts
function globToRegExp(glob) {
  let out = "";
  for (let i2 = 0;i2 < glob.length; i2++) {
    const c3 = glob[i2];
    if (c3 === "*") {
      if (glob[i2 + 1] === "*") {
        out += ".*";
        i2++;
      } else {
        out += "[^/]*";
      }
    } else if (".+?^${}()|[]\\".includes(c3)) {
      out += `\\${c3}`;
    } else {
      out += c3;
    }
  }
  return new RegExp(`^${out}$`);
}
function matchesGlob(path, glob) {
  return globToRegExp(glob).test(path);
}
function pathToLayer(path, layers) {
  const segments = path.split("/");
  for (const layer of Object.keys(layers)) {
    if (segments.includes(layer))
      return layer;
  }
  return;
}
function checkEdge(edge, spec) {
  const violations = [];
  for (const rule of spec.forbidden_dependencies) {
    if (matchesGlob(edge.from, rule.from) && matchesGlob(edge.to, rule.to)) {
      violations.push({
        rule: "forbidden_dependency",
        from: edge.from,
        to: edge.to,
        reason: rule.reason
      });
    }
  }
  const fromLayer = pathToLayer(edge.from, spec.layers);
  const toLayer = pathToLayer(edge.to, spec.layers);
  if (fromLayer && toLayer && fromLayer !== toLayer) {
    const canCall = spec.layers[fromLayer]?.can_call ?? [];
    if (!canCall.includes(toLayer)) {
      violations.push({
        rule: "layer",
        from: edge.from,
        to: edge.to,
        reason: `layer '${fromLayer}' may not call '${toLayer}' (can_call: [${canCall.join(", ")}])`
      });
    }
  }
  return violations;
}
function checkBoundary(spec, edges) {
  return edges.flatMap((e2) => checkEdge(e2, spec));
}

// src/acg/internal-packages.ts
init_fs();
var JVM_LANGUAGES = new Set(["java", "kotlin"]);
function isJvmLanguage(language) {
  return JVM_LANGUAGES.has(language);
}
function evaluateInternalPackages(input) {
  if (!isJvmLanguage(input.language)) {
    return {
      decision: "ok",
      reason: "non-JVM language \u2014 sibling-JAR cross_repo guard not applicable"
    };
  }
  const hasGlobs = input.entries.some((e2) => e2.type === "glob");
  const pathEntries = input.entries.filter((e2) => e2.type === "path");
  const uncovered = input.localJars.filter((jar) => !pathEntries.some((p) => globToRegExp(p.value).test(jar)));
  if (input.localJars.length > 0 && (!hasGlobs || uncovered.length > 0)) {
    const why = !hasGlobs ? "no glob entry declares which sibling packages to record as cross_repo" : `local JAR(s) not covered by any path entry: ${uncovered.join(", ")}`;
    return {
      decision: "block",
      reason: `${input.localJars.length} local JAR(s) present but internal_packages has a gap (${why}). Sibling-module impact would be silently dropped. Declare it with 'ditto architecture internal-packages --glob <pkg.**> --path <libs/*.jar>'.`
    };
  }
  if (!hasGlobs) {
    return {
      decision: "warn",
      reason: "JVM analysis without internal_packages glob entries \u2014 cross_repo recording is inactive. " + "Declare it if this module has sibling-module (JAR) dependencies."
    };
  }
  return { decision: "ok", reason: "internal_packages glob declared; local JARs covered" };
}
function withInternalPackages(existing, entries, producedAt) {
  const base = existing ?? acgArchitectureSpec.parse({
    schema_version: "0.1.0",
    kind: "acg.architecture-spec.v1",
    produced_by: "user",
    produced_at: producedAt
  });
  return { ...base, internal_packages: entries };
}
var SKIP_DIRS = new Set([
  "node_modules",
  ".git",
  ".ditto",
  "target",
  "build",
  "dist",
  ".gradle",
  "out"
]);
async function scanLocalJars(root, maxDepth = 6) {
  const out = [];
  async function walk(dir, depth) {
    if (depth > maxDepth)
      return;
    let entries;
    try {
      entries = await readdir3(dir, { withFileTypes: true });
    } catch {
      return;
    }
    for (const e2 of entries) {
      const full = join10(dir, e2.name);
      if (e2.isDirectory()) {
        if (!SKIP_DIRS.has(e2.name))
          await walk(full, depth + 1);
      } else if (e2.isFile() && e2.name.endsWith(".jar")) {
        out.push(relative2(root, full));
      }
    }
  }
  await walk(root, 0);
  return out.sort();
}
async function loadInternalPackages(repoRoot, specArg) {
  if (specArg) {
    return (await readArchitectureSpec(specArg, acgArchitectureSpec)).internal_packages;
  }
  try {
    const spec = await readArchitectureSpec(join10(repoRoot, ".ditto", "architecture-spec.json"), acgArchitectureSpec);
    return spec.internal_packages;
  } catch {
    return [];
  }
}
async function runInternalPackagesGuard(input) {
  if (!isJvmLanguage(input.language)) {
    return {
      decision: "ok",
      reason: "non-JVM language \u2014 sibling-JAR cross_repo guard not applicable"
    };
  }
  const localJars = await scanLocalJars(input.sourceRoot);
  return evaluateInternalPackages({ language: input.language, entries: input.entries, localJars });
}
function parseJvmCodeqlCommand(cmd) {
  if (!/\bditto\b/.test(cmd) || !/\b(impact|boundary)\b/.test(cmd))
    return;
  const lang = cmd.match(/--language[=\s]+(\w+)/);
  if (!lang || lang[1] !== "java" && lang[1] !== "kotlin")
    return;
  const sr = cmd.match(/--source-root[=\s]+(\S+)/);
  return sr ? { sourceRoot: sr[1] } : {};
}

// src/core/codeql/host-deps.ts
init_ditto_paths();
init_fs();
import { existsSync } from "fs";
async function drainStream(stream) {
  return new Response(stream).text();
}
function composeEnv(base, set, unset) {
  const env2 = {};
  for (const [k2, v2] of Object.entries(base))
    if (v2 !== undefined)
      env2[k2] = v2;
  for (const [k2, v2] of Object.entries(set))
    env2[k2] = v2;
  for (const k2 of unset)
    delete env2[k2];
  return env2;
}
function makeRelationDeps() {
  return {
    spawn: ({ binary, args, repoRoot, cwd, env: env2 }) => {
      const proc = Bun.spawn([binary, ...args], {
        cwd: cwd === "." ? repoRoot : cwd,
        env: composeEnv(process.env, env2.set, env2.unset),
        stdout: "pipe",
        stderr: "pipe",
        stdin: "ignore"
      });
      return {
        entrypoint: binary,
        stdout: proc.stdout,
        stderr: proc.stderr,
        completion: proc.exited.then((code) => ({ exit_code: code, model_reported: null }))
      };
    },
    readText: (path) => Bun.file(path).text(),
    fileExists: (path) => Bun.file(path).exists(),
    drain: drainStream,
    writeText: async (path, content) => {
      await Bun.write(path, content);
    },
    ensureDir: (path) => ensureDir(path),
    dirExists: async (path) => existsSync(path)
  };
}
function codeqlCacheDir(repoRoot, language) {
  const res = Bun.spawnSync(["git", "rev-parse", "HEAD"], { cwd: repoRoot });
  const sha = res.exitCode === 0 ? new TextDecoder().decode(res.stdout).trim() : "working-tree";
  return localDir(repoRoot, "cache", "codeql", cacheKey(sha, language));
}

// src/cli/commands/architecture.ts
init_fs();
function csv(value) {
  return (value ?? "").split(",").map((s2) => s2.trim()).filter((s2) => s2.length > 0);
}
function asArray(value) {
  if (value === undefined)
    return [];
  return Array.isArray(value) ? value : [value];
}
function parseForbidden(tokens) {
  return tokens.map((t2) => {
    const parts = t2.split(",").map((s2) => s2.trim());
    const [from, to, ...rest] = parts;
    const reason = rest.join(",").trim();
    if (!from || !to || !reason) {
      throw new Error(`--forbid: expected "from,to,reason", got "${t2}"`);
    }
    return { from, to, reason };
  });
}
var architectureCommand = defineCommand({
  meta: {
    name: "architecture",
    description: "ACG ArchitectureSpec tools (agent candidate proposal)"
  },
  subCommands: {
    propose: defineCommand({
      meta: {
        name: "propose",
        description: "Propose a NON-AUTHORITATIVE candidate ArchitectureSpec from the import graph (human ratifies)"
      },
      args: {
        "source-root": { type: "string", description: "Analysis source root (default <repo>/src)" },
        output: { type: "string", description: "Output format: human|json", default: "json" },
        write: {
          type: "boolean",
          default: false,
          description: "Also save to .ditto/architecture-spec.json (forbidden_scope layer/surface \uC9D1\uD589 \uC785\uB825)"
        }
      },
      run: async ({ args }) => {
        let format;
        try {
          format = parseOutputFormat(args.output);
        } catch (err) {
          writeError(err instanceof Error ? err.message : String(err));
          process.exit(USAGE_ERROR_EXIT);
          return;
        }
        const repoRoot = await resolveRepoRootForCreate();
        const sourceRoot = args["source-root"] ?? join11(repoRoot, "src");
        const edgeAnalyzer = new CodeqlEdgeAnalyzer({ language: "javascript", repoRoot, cacheDir: codeqlCacheDir(repoRoot, "javascript") }, makeRelationDeps());
        const obs = await observeArchitecture(repoRoot, sourceRoot, edgeAnalyzer);
        const candidate = buildCandidateSpec(obs, new Date().toISOString());
        if (args.write) {
          await ensureDir(join11(repoRoot, ".ditto"));
          await writeJson(join11(repoRoot, ".ditto", "architecture-spec.json"), acgArchitectureSpec, candidate);
        }
        if (format === "json") {
          writeJson2(candidate);
        } else {
          writeHuman(`candidate ArchitectureSpec (NON-AUTHORITATIVE, produced_by=agent): ${Object.keys(candidate.layers).length} layer(s), ${candidate.public_surfaces.length} public surface(s), 0 forbidden_dependencies (declare rules by hand).`);
        }
      }
    }),
    ratify: defineCommand({
      meta: {
        name: "ratify",
        description: "Promote a candidate ArchitectureSpec (produced_by=agent) to authoritative (produced_by=user); forbidden_dependencies come ONLY from --forbid"
      },
      args: {
        spec: {
          type: "string",
          description: "Candidate spec path (default .ditto/architecture-spec.json)"
        },
        forbid: {
          type: "string",
          description: `Forbidden dependency "from,to,reason" (repeatable). Rules are the human's \u2014 never auto-derived from observation.`
        },
        output: { type: "string", description: "Output format: human|json", default: "human" }
      },
      run: async ({ args }) => {
        let format;
        try {
          format = parseOutputFormat(args.output);
        } catch (err) {
