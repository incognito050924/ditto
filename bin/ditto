// src/core/resource-routing.ts
import { readdirSync as readdirSync4 } from "fs";
import { join as join89 } from "path";
var GLOBAL_PREFIX = "GLOBAL_";
function routeResource(filename, ctx) {
  if (filename.startsWith(GLOBAL_PREFIX)) {
    const destName = filename.slice(GLOBAL_PREFIX.length);
    return {
      scope: "global",
      destName,
      destPath: join89(ctx.homeDir, ".claude", destName)
    };
  }
  return {
    scope: "project",
    destName: filename,
    destPath: join89(ctx.projectRoot, filename)
  };
}
function discoverResources(resourcesDir) {
  try {
    return readdirSync4(resourcesDir, { withFileTypes: true }).filter((entry) => entry.isFile()).map((entry) => entry.name);
  } catch {
    return [];
  }
}

// src/core/setup.ts
var CODEX_MARKETPLACE_NAME = "ditto-local";
var CODEX_PLUGIN_NAME = "ditto";
var CODEX_PLUGIN_DEST_REL = join90(".agents", "plugins", CODEX_PLUGIN_NAME);
var CODEX_BIN_NAME = "ditto";
function setupHosts(host) {
  if (host === "codex")
    return new Set(["codex"]);
  if (host === "both")
    return new Set(["claude-code", "codex"]);
  return new Set(["claude-code"]);
}
function resourceDecisions(resourcesDir, projectRoot, homeDir, codexHome, hosts) {
  const out = [];
  const files = discoverResources(resourcesDir);
  if (hosts.has("claude-code")) {
    for (const filename of files) {
      const decision = routeResource(filename, { projectRoot, homeDir });
      out.push({ host: "claude-code", filename, ...decision });
    }
  }
  if (hosts.has("codex")) {
    for (const filename of files) {
      if (filename === "AGENTS.md") {
        out.push({
          host: "codex",
          filename,
          scope: "project",
          destPath: join90(projectRoot, "AGENTS.md")
        });
      } else if (filename === "GLOBAL_AGENTS.md") {
        out.push({
          host: "codex",
          filename,
          scope: "global",
          destPath: join90(codexHome, "AGENTS.md")
        });
      }
    }
  }
  const seen = new Set;
  return out.filter((d2) => {
    const key = d2.destPath;
    if (seen.has(key))
      return false;
    seen.add(key);
    return true;
  });
}
function codexMarketplaceEntry() {
  return {
    name: CODEX_PLUGIN_NAME,
    source: {
      source: "local",
      path: `./${CODEX_PLUGIN_DEST_REL.replaceAll("\\", "/")}`
    },
    policy: {
      installation: "AVAILABLE",
      authentication: "ON_INSTALL"
    },
    category: "Productivity",
    interface: {
      displayName: "DITTO"
    }
  };
}
async function readMarketplace(path) {
  const raw = await readJsonIfExists(path);
  if (raw === null)
    return { name: CODEX_MARKETPLACE_NAME, plugins: [] };
  if (typeof raw !== "object" || raw === null || Array.isArray(raw)) {
    throw new Error(`${path} is not a JSON object`);
  }
  return raw;
}
async function writeCodexMarketplace(path) {
  const marketplace = await readMarketplace(path);
  const plugins = Array.isArray(marketplace.plugins) ? marketplace.plugins : [];
  const nextEntry = codexMarketplaceEntry();
  const nextPlugins = plugins.filter((p2) => p2?.name !== CODEX_PLUGIN_NAME);
  nextPlugins.push(nextEntry);
  nextPlugins.sort((a4, b3) => String(a4.name ?? "").localeCompare(String(b3.name ?? "")));
  await atomicWriteText(path, `${JSON.stringify({
    name: typeof marketplace.name === "string" ? marketplace.name : CODEX_MARKETPLACE_NAME,
    ...marketplace,
    plugins: nextPlugins
  }, null, 2)}
`);
}
async function installCodexAgents(pluginRoot, projectRoot) {
  const srcDir = join90(pluginRoot, ".codex", "agents");
  if (!await fileExists(srcDir)) {
    throw new Error(`codex custom agents not found at ${srcDir}; run build:codex-plugin first`);
  }
  const destDir = join90(projectRoot, ".codex", "agents");
  await ensureDir(destDir);
  let count = 0;
  for (const file of await listFiles(srcDir)) {
    if (!file.id.endsWith(".toml"))
      continue;
    await cp(file.path, join90(destDir, file.id));
    count += 1;
  }
  return count;
}
function codexDittoCommand(installedPluginDir) {
  return `"${join90(installedPluginDir, "bin", CODEX_BIN_NAME).replaceAll("\\", "/")}"`;
}
function rewriteCodexDittoReferences(text, dittoCommand) {
  return text.replace(/"\$\{CLAUDE_PLUGIN_ROOT\}\/bin\/ditto(?:\.exe)?"/g, dittoCommand).replace(/\$\{CLAUDE_PLUGIN_ROOT\}\/bin\/ditto(?:\.exe)?/g, dittoCommand).replace(/`ditto(?=\s)/g, `\`${dittoCommand}`);
}
async function rewriteCodexTextFile(path, dittoCommand) {
  const before = await readFile20(path, "utf8");
  const after = rewriteCodexDittoReferences(before, dittoCommand);
  if (after !== before)
    await writeFile6(path, after);
}
function rewriteCodexAgentTomlReferences(text, dittoCommand) {
  return text.replace(/(\bdeveloper_instructions\s*=\s*""")([\s\S]*?)("""\s*)/, (_match, open3, body, close) => `${open3}${rewriteCodexDittoReferences(body, dittoCommand)}${close}`);
}
async function rewriteCodexAgentTomlFile(path, dittoCommand) {
  const before = await readFile20(path, "utf8");
  const after = rewriteCodexAgentTomlReferences(before, dittoCommand);
  if (after !== before)
    await writeFile6(path, after);
}
async function rewriteCodexInstalledReferences(installedPluginDir) {
  const dittoCommand = codexDittoCommand(installedPluginDir);
  for (const dir of await listDirectories(join90(installedPluginDir, "skills"))) {
    const skillPath = join90(dir.path, "SKILL.md");
    if (await fileExists(skillPath))
      await rewriteCodexTextFile(skillPath, dittoCommand);
  }
  for (const file of await listFiles(join90(installedPluginDir, ".codex", "agents"))) {
    if (file.id.endsWith(".toml"))
      await rewriteCodexAgentTomlFile(file.path, dittoCommand);
  }
}
async function writeCodexSurfaceCatalog(projectRoot) {
  const surfaceCatalogPath = join90(projectRoot, ".ditto", "local", "surfaces.codex.json");
  await ensureDir(join90(projectRoot, ".ditto", "local"));
  const catalog = await generateSurfaceCatalog([codexHostAdapter], projectRoot, "surfaces.codex.json");
  await atomicWriteText(surfaceCatalogPath, `${JSON.stringify(catalog, null, 2)}
`);
  return surfaceCatalogPath;
}
async function writeCodexPluginStatus(projectRoot) {
  const statusPath = join90(projectRoot, ".ditto", "local", "codex-plugin-status.json");
  const enableCommands = [
    `codex plugin marketplace add ${JSON.stringify(projectRoot)}`,
    `codex plugin add ${CODEX_PLUGIN_NAME}@${CODEX_MARKETPLACE_NAME}`
  ];
  await atomicWriteText(statusPath, `${JSON.stringify({
    schema_version: "0.1.0",
    plugin: CODEX_PLUGIN_NAME,
    marketplace: CODEX_MARKETPLACE_NAME,
    status: "needs_user_action",
    reason: "setup prepared the target-local Codex marketplace, but Codex has not been asked to install this plugin in CODEX_HOME",
    commands: enableCommands
  }, null, 2)}
`);
  return { statusPath, enableCommands };
}
async function installCodexSurface(opts) {
  const { pluginRoot, projectRoot } = opts;
  const manifestPath = join90(pluginRoot, ".codex-plugin", "plugin.json");
  if (!await fileExists(manifestPath)) {
    throw new Error(`codex plugin manifest not found at ${manifestPath}; run build:codex-plugin first`);
  }
  const installedPluginDir = join90(projectRoot, CODEX_PLUGIN_DEST_REL);
  if (resolve24(pluginRoot) === resolve24(installedPluginDir)) {
    throw new Error(`codex plugin source is already the installed plugin directory: ${installedPluginDir}`);
  }
  await rm3(installedPluginDir, { recursive: true, force: true });
  await ensureDir(join90(projectRoot, ".agents", "plugins"));
  await cp(pluginRoot, installedPluginDir, { recursive: true });
  await rewriteCodexInstalledReferences(installedPluginDir);
  const marketplacePath = join90(projectRoot, ".agents", "plugins", "marketplace.json");
  await writeCodexMarketplace(marketplacePath);
  const agentsInstalled = await installCodexAgents(installedPluginDir, projectRoot);
  const surfaceCatalogPath = await writeCodexSurfaceCatalog(projectRoot);
  const { statusPath, enableCommands } = await writeCodexPluginStatus(projectRoot);
  return {
    pluginRoot,
    installedPluginDir,
    marketplacePath,
    surfaceCatalogPath,
    statusPath,
    pluginLoadStatus: "needs_user_action",
    enableCommands,
    agentsDir: join90(projectRoot, ".codex", "agents"),
    agentsInstalled
  };
}
async function installResource(decision, resourcesDir) {
  const common = {
    host: decision.host,
    filename: decision.filename,
    scope: decision.scope,
    destPath: decision.destPath
  };
  const name = basename6(decision.destPath);
  if (name === "AGENTS.md") {
    const existed = await fileExists(decision.destPath);
    if (!existed) {
      const body2 = await readFile20(join90(resourcesDir, decision.filename), "utf8");
      await atomicWriteText(decision.destPath, body2);
      return { ...common, status: "written", backupPath: null };
    }
    const current = await readFile20(decision.destPath, "utf8");
    const unwrapped = unwrapManagedBlock(current);
    if (unwrapped !== current) {
      const backupPath = await writeBackupOnce(decision.destPath);
      await atomicWriteText(decision.destPath, unwrapped);
      return { ...common, status: "written", backupPath };
    }
    return { ...common, status: "kept", backupPath: null };
  }
  if (name === "CLAUDE.md") {
    const sourcePath = join90(dirname18(decision.destPath), "AGENTS.md");
    const projectionBody = await fileExists(sourcePath) ? await readFile20(sourcePath, "utf8") : await readFile20(join90(resourcesDir, decision.filename), "utf8");
    const applied2 = await applyManagedFile(decision.destPath, projectionBody, "AGENTS.md");
    return {
      ...common,
      status: applied2.kind === "ok" ? "written" : "corrupted",
      backupPath: applied2.kind === "ok" ? applied2.backupPath : null
    };
  }
  const body = await readFile20(join90(resourcesDir, decision.filename), "utf8");
  const applied = await applyManagedFile(decision.destPath, body, decision.filename);
  return {
    ...common,
    status: applied.kind === "ok" ? "written" : "corrupted",
    backupPath: applied.kind === "ok" ? applied.backupPath : null
  };
}
var PUSH_GATE_HOOK_MARKER = "ditto:managed:pre-push";
var PUSH_GATE_HOOK_BACKUP_SUFFIX = ".ditto-backup";
function defaultHookTemplatePath(resourcesDir) {
  return join90(dirname18(resourcesDir), "hooks", "pre-push");
}
function customHooksPath(cwd) {
  try {
    const v2 = execFileSync6("git", ["config", "--get", "core.hooksPath"], {
      cwd,
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"]
    }).trim();
    return v2.length > 0 ? v2 : null;
  } catch {
    return null;
  }
}
function gitHooksDir(cwd) {
  const p2 = execFileSync6("git", ["rev-parse", "--git-path", "hooks"], {
    cwd,
    encoding: "utf8",
    stdio: ["ignore", "pipe", "ignore"]
  }).trim();
  return isAbsolute16(p2) ? p2 : join90(cwd, p2);
}
async function installPushGateHook(opts) {
  const { projectRoot, hookTemplatePath } = opts;
  const hooksPath = customHooksPath(projectRoot);
  if (hooksPath !== null) {
    return {
      status: "refused-hookspath",
      hookPath: "",
      backupPath: null,
      message: `core.hooksPath is set to "${hooksPath}" (custom hooks dir, e.g. husky/lefthook). ditto will not write .git/hooks/pre-push (git would ignore it) nor repoint core.hooksPath (that would disable your hooks). Add the ditto pre-push call to "${hooksPath}/pre-push" manually: it should pipe stdin into \`ditto push-gate\`.`
    };
  }
  let hooksDir;
  try {
    hooksDir = gitHooksDir(projectRoot);
  } catch {
    return {
      status: "no-git-repo",
      hookPath: "",
      backupPath: null,
      message: `${projectRoot} is not a git repository \u2014 a pre-push hook cannot be installed. Run \`git init\` (or \`ditto setup\` from inside the repo), then re-run setup.`
    };
  }
  const hookPath = join90(hooksDir, "pre-push");
  const backupPath = `${hookPath}${PUSH_GATE_HOOK_BACKUP_SUFFIX}`;
  const template = bakeWorkspaceRoot(await readFile20(hookTemplatePath, "utf8"), opts.workspaceRoot);
  await ensureDir(hooksDir);
  if (!await fileExists(hookPath)) {
    await writeHookFile(hookPath, template);
    return { status: "installed", hookPath, backupPath: null, message: null };
  }
  const existing = await readFile20(hookPath, "utf8");
  if (existing.includes(PUSH_GATE_HOOK_MARKER)) {
    await writeHookFile(hookPath, template);
    return { status: "refreshed", hookPath, backupPath: null, message: null };
  }
  if (await fileExists(backupPath)) {
    return {
      status: "refused-existing",
      hookPath,
      backupPath,
      message: `${hookPath} is a non-ditto pre-push hook and ${backupPath} already exists \u2014 refusing to overwrite either. Remove/merge them manually, or pipe stdin into \`ditto push-gate\` from your existing hook.`
    };
  }
  await rename5(hookPath, backupPath);
  await writeHookFile(hookPath, template);
  return { status: "backed-up", hookPath, backupPath, message: null };
}
function bakeWorkspaceRoot(template, workspaceRoot) {
  if (workspaceRoot === undefined || workspaceRoot === "")
    return template;
  const baked = template.replace(/^WS_ROOT=""$/m, `WS_ROOT=${JSON.stringify(resolve24(workspaceRoot))}`);
  if (baked === template) {
    throw new Error('pre-push template is missing the substitutable `WS_ROOT=""` line \u2014 cannot pin the workspace root for a sub-repo install');
  }
  return baked;
}
async function writeHookFile(hookPath, body) {
  await writeFile6(hookPath, body);
  await chmod(hookPath, 493);
}
async function setup(opts) {
  const { resourcesDir, projectRoot, homeDir, now } = opts;
  const codexHome = opts.codexHome ?? join90(homeDir, ".codex");
  const hosts = setupHosts(opts.host);
  const decisions = resourceDecisions(resourcesDir, projectRoot, homeDir, codexHome, hosts);
  const ordered = [
    ...decisions.filter((d2) => basename6(d2.destPath) !== "CLAUDE.md"),
    ...decisions.filter((d2) => basename6(d2.destPath) === "CLAUDE.md")
  ];
  const resources = [];
  for (const decision of ordered) {
    resources.push(await installResource(decision, resourcesDir));
  }
  const scaffold = await initScaffold(projectRoot, now);
  const allowlistPath = join90(projectRoot, ".claude", "settings.json");
  const allowlistApplied = hosts.has("claude-code");
  if (allowlistApplied)
    await allowlistSettingsFile(allowlistPath);
  const codex = hosts.has("codex") ? await installCodexSurface({
    pluginRoot: opts.pluginRoot ?? resolve24(resourcesDir, "..", ".."),
    projectRoot
  }) : null;
  const pushGateHook = opts.pushGate ? await installPushGateHook({
    projectRoot,
    hookTemplatePath: opts.hookTemplatePath ?? defaultHookTemplatePath(resourcesDir)
  }) : null;
  return { resources, scaffold, allowlistPath, allowlistApplied, codex, pushGateHook };
}

// src/cli/resources.ts
import { existsSync as existsSync14 } from "fs";
import { dirname as dirname19, join as join91, resolve as resolve25 } from "path";
import { fileURLToPath as fileURLToPath2 } from "url";
function resolveResourcesDir(from) {
  if (process.env.CLAUDE_PLUGIN_ROOT) {
    return join91(process.env.CLAUDE_PLUGIN_ROOT, "resources", "managed");
  }
  const start = from ?? dirname19(fileURLToPath2(import.meta.url));
  let dir = start;
  for (;; ) {
    const candidate = join91(dir, "resources", "managed");
    if (existsSync14(candidate))
      return candidate;
    const parent = dirname19(dir);
    if (parent === dir)
      break;
    dir = parent;
  }
  return join91(resolve25(start, "..", ".."), "resources", "managed");
}

// src/cli/wizard/agent-link-step.ts
var PSEUDO_OWNERS2 = new Set(["driver", "main-session"]);
var ROLE_OPTIONS = nodeOwner.options.filter((role) => !PSEUDO_OWNERS2.has(role)).map((role) => ({ label: role, value: role }));
async function runAgentLinkStep(io, deps) {
  const agents = await deps.loadAgents();
  const discovered = agents.map((a4) => ({
    ...a4,
    role: recommendVariantRole(a4.name, a4.description)
  }));
  if (discovered.length === 0)
    return { discovered, written: [], skipped: [] };
  const choices = discovered.map((a4) => ({
    label: `${a4.name} \u2192 ${a4.role}${a4.description ? ` (${a4.description})` : ""}`,
    value: a4.name,
    checked: false
  }));
  const picked = new Set(await multiSelect(io, "\uD504\uB85C\uC81D\uD2B8 agent\uB97C ditto role\uC5D0 \uC5F0\uACB0", choices));
  const linked = discovered.filter((a4) => picked.has(a4.name));
  if (linked.length === 0)
    return { discovered, written: [], skipped: [] };
  const roleByName = new Map(linked.map((a4) => [a4.name, a4.role]));
  const overrideChoices = linked.map((a4) => ({
    label: `${a4.name} (\uCD94\uCC9C: ${a4.role})`,
    value: a4.name,
    checked: false
  }));
  const toOverride = new Set(await multiSelect(io, "\uCD94\uCC9C role\uC744 \uBC14\uAFC0 agent (\uC5C6\uC73C\uBA74 Enter)", overrideChoices));
  for (const a4 of linked) {
    if (!toOverride.has(a4.name))
      continue;
    const role = await select(io, `'${a4.name}' role \uC120\uD0DD (\uCD94\uCC9C: ${a4.role})`, ROLE_OPTIONS, a4.role);
    roleByName.set(a4.name, role);
  }
  const approved = linked.map((a4) => ({
    name: a4.name,
    role: roleByName.get(a4.name) ?? a4.role,
    description: a4.description,
    match: []
  }));
  const result2 = await deps.writeVariants(approved);
  return { discovered, written: result2.written, skipped: result2.skipped };
}

// src/cli/wizard/provision-step.ts
async function planProvisioning(registry2, detectedLanguages) {
  const provisioners = [
    ...registry2.tools.values(),
    ...detectedLanguages.map((lang) => registry2.lsp.get(lang)).filter((p2) => p2 !== undefined)
  ];
  const out = [];
  for (const p2 of provisioners) {
    const present = await p2.resolveExisting() !== null;
    out.push({
      id: p2.id,
      label: p2.label,
      present,
      recommended: !present,
      install: p2.install,
      manual: p2.manual
    });
  }
  return out;
}
async function runProvisionStep(io, registry2, sourceRoot, deps) {
  const detected = await deps.detect(sourceRoot);
  const languages = detected.map((d2) => d2.language);
  const unservicedLanguages = languages.filter((lang) => !registry2.lsp.has(lang));
  const plan = await planProvisioning(registry2, languages);
  const present = plan.filter((c5) => c5.present);
  const absent = plan.filter((c5) => !c5.present);
  const outcomes = present.map((c5) => ({
    id: c5.id,
    action: "already-present",
    message: `${c5.label}: \uC774\uBBF8 \uC124\uCE58\uB428`
  }));
  if (absent.length === 0) {
    return { outcomes, unservicedLanguages };
  }
  const choices = absent.map((c5) => ({
    label: c5.label,
    value: c5.id,
    checked: c5.recommended
  }));
  const picked = new Set(await multiSelect(io, "\uBD84\uC11D/\uC5B8\uC5B4 \uB3C4\uAD6C \u2014 \uC124\uCE58\uD560 \uD56D\uBAA9", choices));
  for (const c5 of absent) {
    if (!picked.has(c5.id)) {
      outcomes.push({
        id: c5.id,
        action: "skipped",
        message: `${c5.label}: \uAC74\uB108\uB700(\uD544\uC694 \uC2DC \uAE30\uB2A5 degrade)`
      });
      continue;
    }
    const result2 = await c5.install();
    const action = result2.status === "installed" ? "installed" : result2.status === "already-present" ? "already-present" : "failed";
    outcomes.push({
      id: c5.id,
      action,
      message: `${c5.label}: ${result2.message}`,
      ...result2.manual ? { manual: result2.manual } : {}
    });
  }
  return { outcomes, unservicedLanguages };
}

// src/cli/wizard/setup-wizard.ts
var HOST_OPTIONS = [
  { label: "Claude Code", value: "claude-code" },
  { label: "Codex", value: "codex" },
  { label: "\uB458 \uB2E4(both)", value: "both" }
];
var MEMORY_OPTIONS = [
  { label: "gitignore-\uB3C5\uB9BD (\uB2E8\uC21C, \uBD80\uBAA8 git\uC5D0\uC11C \uC81C\uC678)", value: "gitignore" },
  { label: "submodule (\uD300 \uC7AC\uD604 \u2014 \uC6D0\uACA9 \uC120\uD589, \uC218\uB3D9 \uC548\uB0B4)", value: "submodule" }
];
async function runSetupWizard(io, deps) {
  const host = await select(io, "Host \uC120\uD0DD", HOST_OPTIONS, "claude-code");
  const setupResult = await deps.setup(host);
  const provision = await deps.runProvision(io);
  const agents = await deps.runAgentLink(io, host);
  let memory = { mode: "in-project", result: null };
  const separate = await confirm(io, "memory\uB97C \uBCC4\uB3C4 git \uC800\uC7A5\uC18C\uB85C \uBD84\uB9AC\uD560\uAE4C?", false);
  if (separate) {
    const mode = await select(io, "memory \uBD84\uB9AC \uBC29\uC2DD", MEMORY_OPTIONS, "gitignore");
    memory = { mode, result: await deps.separateMemory(mode) };
  }
  return { host, setup: setupResult, provision, memory, agents };
}

// src/cli/commands/setup.ts
async function provisionToolsNonInteractive(projectRoot) {
  const io = {
    isTTY: false,
    ask: async () => "",
    write: (t3) => {
      process.stdout.write(t3);
    }
  };
  const summary = await runProvisionStep(io, defaultRegistry(), projectRoot, {
    detect: detectLspLanguages
  });
  writeHuman("tools:");
  for (const o4 of summary.outcomes)
    writeHuman(`  ${o4.action}	${o4.message}`);
  if (summary.unservicedLanguages.length > 0) {
    writeHuman(`  \uAC10\uC9C0\uB410\uC73C\uB098 \uC11C\uBC84 \uBBF8\uB4F1\uB85D: ${summary.unservicedLanguages.join(", ")}`);
  }
}
async function provisionRecipeTools(registry2, toolIds) {
  const outcomes = [];
  for (const id of toolIds) {
    const p2 = registry2.tools.get(id) ?? registry2.lsp.get(id);
    if (!p2) {
      outcomes.push({ id, action: "skipped", message: `${id}: \uB4F1\uB85D\uB41C provisioner \uC5C6\uC74C \u2014 \uAC74\uB108\uB700` });
      continue;
    }
    if (await p2.resolveExisting() !== null) {
      outcomes.push({ id, action: "already-present", message: `${p2.label}: \uC774\uBBF8 \uC124\uCE58\uB428` });
      continue;
    }
    const r4 = await p2.install();
    const action = r4.status === "installed" ? "installed" : r4.status === "already-present" ? "already-present" : "failed";
    outcomes.push({
      id,
      action,
      message: `${p2.label}: ${r4.message}`,
      ...r4.manual ? { manual: r4.manual } : {}
    });
  }
  return outcomes;
}
function isRecipePresent(cliPath, resolved) {
  return cliPath !== undefined || Object.keys(resolved).length > 0;
}
async function runRecipeSetup(recipe2, host, deps) {
  if (recipe2.memory === "submodule") {
    throw new Error("headless recipe\uB294 memory: submodule\uB97C \uC790\uB3D9\uD654\uD560 \uC218 \uC5C6\uB2E4(\uC6D0\uACA9 \uC120\uD589 \uD544\uC694) \u2014 memory: gitignore\uB97C \uC4F0\uAC70\uB098 \uB300\uD654\uD615 setup\uC73C\uB85C \uBD84\uB9AC\uD558\uB77C");
  }
  const setupResult = await deps.setup(host);
  const tools = recipe2.tools && recipe2.tools.length > 0 ? await deps.provisionTools(recipe2.tools) : [];
  const variants = (recipe2.agents ?? []).map((a4) => ({
    name: a4.name,
    role: a4.role,
    description: "",
    match: []
  }));
  const agents = variants.length > 0 ? await deps.writeVariants(variants) : { written: [], skipped: [] };
  let memory = { mode: "in-project", result: null };
  if (recipe2.memory === "gitignore") {
    memory = { mode: "gitignore", result: await deps.separateMemory("gitignore") };
  }
  let githubSeed = { seeded: false, reason: "no-backlog" };
  if (recipe2.backlog) {
    try {
      githubSeed = await deps.seedGithubConfig(recipe2.backlog);
    } catch {
      githubSeed = { seeded: false };
    }
  }
  return { host, setup: setupResult, tools, agents, memory, githubSeed };
}
function parseSetupHost(value) {
  if (value === undefined || value === null || value === "")
    return "claude-code";
  if (value === "claude-code" || value === "codex" || value === "both")
    return value;
  throw new Error(`invalid --host ${String(value)} (expected claude-code|codex|both)`);
}
function includesCodex(host) {
  return host === "codex" || host === "both";
}
async function resolveCodexPluginRoot(resourcesDir, projectRoot) {
  const currentPluginRoot = resolve26(resourcesDir, "..", "..");
  const sibling = join92(dirname20(currentPluginRoot), "codex-plugin");
  if (await fileExists(join92(sibling, ".codex-plugin", "plugin.json")))
    return sibling;
  const currentDist = join92(currentPluginRoot, "dist", "codex-plugin");
  if (await fileExists(join92(currentDist, ".codex-plugin", "plugin.json")))
    return currentDist;
  const projectDist = join92(projectRoot, "dist", "codex-plugin");
  if (await fileExists(join92(projectDist, ".codex-plugin", "plugin.json")))
    return projectDist;
  if (await fileExists(join92(currentPluginRoot, ".codex", "agents")))
    return currentPluginRoot;
  return currentPluginRoot;
}
async function discoverClaudeAgents(projectRoot) {
  const inventory = await claudeCodeHostAdapter.loadSurfaceInventory(projectRoot);
  const agents = inventory.localSurfaces.filter((s2) => s2.kind === "agent");
  const out = [];
  for (const a4 of agents) {
    let description = "";
    try {
      const text = await Bun.file(a4.path).text();
      const m4 = /^description:\s*(.+)$/m.exec(text);
      if (m4)
        description = (m4[1] ?? "").trim();
    } catch {}
    out.push({ name: a4.id, description });
  }
  return out;
}
async function discoverCodexAgents(projectRoot) {
  const inventory = await codexHostAdapter.loadSurfaceInventory(projectRoot);
  const agents = inventory.localSurfaces.filter((s2) => s2.kind === "agent");
  const out = [];
  for (const a4 of agents) {
    let text = "";
    try {
      text = await Bun.file(a4.path).text();
    } catch {}
    if (/ditto agent-projection/.test(text))
      continue;
    let description = "";
    const m4 = /^description\s*=\s*"([^"]*)"\s*$/m.exec(text);
    if (m4)
      description = (m4[1] ?? "").trim();
    out.push({ name: a4.id, description });
  }
  return out;
}
async function discoverProjectAgents(projectRoot, host) {
  const claude = host === "claude-code" || host === "both" ? await discoverClaudeAgents(projectRoot) : [];
  const codex = host === "codex" || host === "both" ? await discoverCodexAgents(projectRoot) : [];
  const seen = new Set(claude.map((a4) => a4.name));
  return [...claude, ...codex.filter((a4) => !seen.has(a4.name))];
}
async function runWizard(resourcesDir, projectRoot) {
  const io = createStdioPromptIO();
  try {
    const result2 = await runSetupWizard(io, {
      projectRoot,
      sourceRoot: projectRoot,
      setup: async (host) => setup({
        resourcesDir,
        projectRoot,
        homeDir: homedir13(),
        ...process.env.CODEX_HOME ? { codexHome: process.env.CODEX_HOME } : {},
        now: new Date,
        host,
        ...includesCodex(host) ? { pluginRoot: await resolveCodexPluginRoot(resourcesDir, projectRoot) } : {}
      }),
      runProvision: (promptIo) => runProvisionStep(promptIo, defaultRegistry(), projectRoot, { detect: detectLspLanguages }),
      separateMemory: (mode) => separateMemoryRepo(defaultMemorySeparateDeps(projectRoot), mode),
      runAgentLink: (promptIo, host) => runAgentLinkStep(promptIo, {
        loadAgents: () => discoverProjectAgents(projectRoot, host),
        writeVariants: (variants) => writeAgentVariants(projectRoot, variants)
      })
    });
    writeHuman(`setup: installed into ${projectRoot} (host=${result2.host})`);
    writeHuman(`.ditto/: ${result2.setup.scaffold.alreadyInitialized ? "already initialized" : "created"} \xB7 allowlist: ${result2.setup.allowlistApplied ? result2.setup.allowlistPath : "skipped"}`);
    writeHuman("tools:");
    for (const o4 of result2.provision.outcomes)
      writeHuman(`  ${o4.action}	${o4.message}`);
    if (result2.provision.unservicedLanguages.length > 0) {
      writeHuman(`  \uAC10\uC9C0\uB410\uC73C\uB098 \uC11C\uBC84 \uBBF8\uB4F1\uB85D: ${result2.provision.unservicedLanguages.join(", ")}`);
    }
    if (result2.agents.discovered.length > 0) {
      writeHuman("project agents:");
      for (const a4 of result2.agents.discovered)
        writeHuman(`  ${a4.name} \u2192 ${a4.role}`);
      writeHuman(`  linked: ${result2.agents.written.length ? result2.agents.written.join(", ") : "(none)"}${result2.agents.skipped.length ? ` \xB7 skipped(existing): ${result2.agents.skipped.join(", ")}` : ""}`);
    }
    if (result2.memory.result) {
      writeHuman(`memory: ${result2.memory.mode} \u2014 ${result2.memory.result.message}`);
      for (const line of result2.memory.result.manual ?? [])
        writeHuman(`  ${line}`);
    } else {
      writeHuman("memory: \uD504\uB85C\uC81D\uD2B8 git\uC5D0 \uD3EC\uD568(\uAE30\uBCF8)");
    }
    writeHuman("safety hook: PreToolUse \uD65C\uC131(\uD50C\uB7EC\uADF8\uC778 \uC804\uC5ED) \u2014 \uC815\uC0C1 \uBA85\uB839 \uC624\uD0D0 \uC2DC DITTO_SKIP_HOOKS=1 prefix");
  } finally {
    io.close();
  }
}
var setupCommand = defineCommand({
  meta: {
    name: "setup",
    description: "Install ditto managed resources, scaffold .ditto/, and allowlist the target project"
  },
  args: {
    dir: {
      type: "string",
      required: false,
      description: "Target project directory; defaults to the nearest .ditto/.git root or cwd"
    },
    target: {
      type: "positional",
      required: false,
      description: "Target project directory; same as --dir"
    },
    host: {
      type: "string",
      required: false,
      description: "Host surface to install: claude-code|codex|both (default: claude-code)"
    },
    yes: {
      type: "boolean",
      required: false,
      default: false,
      description: "Non-interactive: skip the wizard, use defaults/flags (CI/agent)"
    },
    tools: {
      type: "boolean",
      required: false,
      default: false,
      description: "Non-interactive only: also provision detected tools (codeql/playwright/LSP)"
    },
    recipe: {
      type: "string",
      required: false,
      description: "Path to a recipe.yaml that drives all 4 setup stages headlessly (overrides discovery)"
    }
  },
  run: async ({ args }) => {
    try {
      const host = parseSetupHost(args.host);
      const targetDir = typeof args.dir === "string" ? args.dir : args.target;
      const projectRoot = targetDir ? resolve26(targetDir) : await resolveRepoRootForCreate();
      const resourcesDir = resolveResourcesDir();
      const pluginRoot = resolve26(resourcesDir, "..", "..");
      if (pluginRoot === projectRoot) {
        writeHuman(`setup: skipped (self-host \u2014 target IS the ditto repo at ${projectRoot})`);
        return;
      }
      const cliRecipePath = typeof args.recipe === "string" ? args.recipe : undefined;
      const resolvedRecipe = await loadResolvedRecipe(projectRoot, cliRecipePath, (origin, msg) => writeError(`recipe ignored (${origin} recipe.yaml malformed): ${msg}`));
      if (isRecipePresent(cliRecipePath, resolvedRecipe)) {
        const recipeHost2 = resolvedRecipe.host ?? host;
        const summary = await runRecipeSetup(resolvedRecipe, recipeHost2, {
          setup: async (h3) => setup({
            resourcesDir,
            projectRoot,
            homeDir: homedir13(),
            ...process.env.CODEX_HOME ? { codexHome: process.env.CODEX_HOME } : {},
            now: new Date,
            host: h3,
            ...resolvedRecipe.push_gate ? { pushGate: resolvedRecipe.push_gate } : {},
            ...includesCodex(h3) ? { pluginRoot: await resolveCodexPluginRoot(resourcesDir, projectRoot) } : {}
          }),
          provisionTools: (ids) => provisionRecipeTools(defaultRegistry(), ids),
          writeVariants: (variants) => writeAgentVariants(projectRoot, variants),
          separateMemory: (mode) => separateMemoryRepo(defaultMemorySeparateDeps(projectRoot), mode),
          seedGithubConfig: (github) => seedGithubConfigIfAbsent(projectRoot, github, () => writeError("github backlog seed skipped: \uAC1C\uC778 .ditto/local/config.json malformed/invalid \u2014 \uBB34\uC2DC(fail-closed)"))
        });
        writeHuman(`setup: installed into ${projectRoot} (host=${summary.host}, recipe-driven)`);
        writeHuman(`.ditto/: ${summary.setup.scaffold.alreadyInitialized ? "already initialized" : "created"} \xB7 allowlist: ${summary.setup.allowlistApplied ? summary.setup.allowlistPath : "skipped"}`);
        if (summary.tools.length > 0) {
          writeHuman("tools:");
          for (const o4 of summary.tools)
            writeHuman(`  ${o4.action}	${o4.message}`);
        }
        if (summary.agents.written.length > 0 || summary.agents.skipped.length > 0) {
          writeHuman(`agents linked: ${summary.agents.written.length ? summary.agents.written.join(", ") : "(none)"}${summary.agents.skipped.length ? ` \xB7 skipped(existing): ${summary.agents.skipped.join(", ")}` : ""}`);
        }
        if (summary.memory.result) {
          writeHuman(`memory: ${summary.memory.mode} \u2014 ${summary.memory.result.message}`);
        } else {
          writeHuman("memory: \uD504\uB85C\uC81D\uD2B8 git\uC5D0 \uD3EC\uD568(\uAE30\uBCF8)");
        }
        const hook = summary.setup.pushGateHook;
        if (hook) {
          writeHuman(`push-gate hook: ${hook.status} \u2192 ${hook.hookPath || "(not installed)"}`);
          if (hook.message)
            writeHuman(`  ${hook.message}`);
        }
        if (summary.githubSeed.reason !== "no-backlog") {
          const s2 = summary.githubSeed;
          writeHuman(`github backlog: ${s2.seeded ? "seeded personal github config" : `skipped (${s2.reason ?? "write failed"})`}`);
        }
        return;
      }
      if (process.stdin.isTTY && !args.yes) {
        await runWizard(resourcesDir, projectRoot);
        return;
      }
      const result2 = await setup({
        resourcesDir,
        projectRoot,
        homeDir: homedir13(),
        ...process.env.CODEX_HOME ? { codexHome: process.env.CODEX_HOME } : {},
        now: new Date,
        host,
        ...includesCodex(host) ? { pluginRoot: await resolveCodexPluginRoot(resourcesDir, projectRoot) } : {}
      });
      writeHuman(`setup: installed into ${projectRoot} (host=${host})`);
      for (const r4 of result2.resources) {
        const tag = r4.status === "corrupted" ? "SKIPPED (corrupted markers)" : r4.status === "kept" ? `\u2192 ${r4.destPath} (kept existing source)` : `\u2192 ${r4.destPath}`;
        const bak = r4.backupPath ? ` (backup ${r4.backupPath})` : "";
        writeHuman(`  ${r4.filename} [${r4.host}/${r4.scope}] ${tag}${bak}`);
      }
      if (result2.codex) {
        writeHuman(`  codex marketplace \u2192 ${result2.codex.marketplacePath}`);
        writeHuman(`  codex plugin copy \u2192 ${result2.codex.installedPluginDir}`);
        writeHuman(`  codex surface catalog \u2192 ${result2.codex.surfaceCatalogPath}`);
        writeHuman(`  codex agents \u2192 ${result2.codex.agentsDir} (${result2.codex.agentsInstalled})`);
        writeHuman(`  codex plugin status \u2192 ${result2.codex.pluginLoadStatus}`);
        writeHuman("  codex enable commands:");
        for (const command of result2.codex.enableCommands)
          writeHuman(`    ${command}`);
      }
      writeHuman(`.ditto/: ${result2.scaffold.alreadyInitialized ? "already initialized" : "created"} \xB7 allowlist: ${result2.allowlistApplied ? result2.allowlistPath : "skipped"}`);
      if (args.tools)
        await provisionToolsNonInteractive(projectRoot);
    } catch (err) {
      writeError(`setup failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});

// src/cli/commands/teardown.ts
import { rm as rm5 } from "fs/promises";
import { homedir as homedir14 } from "os";
import { join as join94, resolve as resolve27 } from "path";
