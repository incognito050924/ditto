// src/schemas/acg-review-graph.ts
var journeyRoles = ["ui", "user_journey"];
var acgReviewFile = exports_external.object({
  path: exports_external.string().min(1).optional().describe("Code location; required unless role is a journey"),
  journey_id: exports_external.string().optional().describe("JourneySpec.id; required when role is ui/user_journey (OBJ-52)"),
  role: exports_external.enum([
    "test_fixture",
    "private_helper",
    "service_logic",
    "public_api",
    "migration",
    "auth",
    "payment",
    "data_deletion",
    "config",
    "ui",
    "user_journey"
  ]).optional(),
  risk: exports_external.enum(["low", "medium", "high"]),
  risk_reason: exports_external.string().min(1).describe("Empty reason = invalid classification"),
  evidence: exports_external.object({
    kind: acgEvidenceKind,
    ref: exports_external.string().optional().describe("e2e \u2192 JourneyRun (acg.journey-run.v1) reference")
  }).optional().describe("Evidence; may be omitted when unresolved=true"),
  unresolved: exports_external.boolean().default(false).describe("Evidence-absence marker (OBJ-53). NOT an evidenceRef.kind \u2014 a separate flag")
}).superRefine((value, ctx) => {
  const isJourney = journeyRoles.includes(value.role ?? "");
  if (isJourney && !value.journey_id) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "ui/user_journey role requires journey_id",
      path: ["journey_id"]
    });
  }
  if (!isJourney && !value.path) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "non-journey file requires path",
      path: ["path"]
    });
  }
}).describe("One risk-classified file/flow in the review graph");
var acgReviewGraph = exports_external.object({
  kind: exports_external.literal("acg.review-graph.v1"),
  files: exports_external.array(acgReviewFile).default([]),
  human_review_set: exports_external.array(exports_external.string().min(1)).default([]).describe("Exceptions a human must judge \u2014 not the whole diff")
}).describe("ACG ReviewGraph \u2014 acg_review extension object on reviewer-output (D3)");

// src/acg/review/acg-review-adapter.ts
function severityToRisk(severity2) {
  switch (severity2) {
    case "critical":
    case "high":
      return "high";
    case "medium":
      return "medium";
    default:
      return "low";
  }
}
function fileIdentity(file) {
  return file.path ?? file.journey_id;
}
function projectReviewerOutputToAcgReview(output) {
  const findingFiles = output.findings.filter((finding) => finding.file !== undefined).map((finding) => ({
    path: finding.file,
    risk: severityToRisk(finding.severity),
    risk_reason: finding.reason,
    unresolved: false
  }));
  const unresolvedFiles = output.unverified.map((u3) => ({
    path: u3.item,
    risk: "low",
    risk_reason: u3.reason,
    unresolved: true
  }));
  const draft = {
    kind: "acg.review-graph.v1",
    files: [...findingFiles, ...unresolvedFiles],
    human_review_set: []
  };
  const parsed = acgReviewGraph.parse(draft);
  const reviewSet = [];
  for (const file of parsed.files) {
    if (file.risk === "high" || file.unresolved === true) {
      const id = fileIdentity(file);
      if (id !== undefined && !reviewSet.includes(id)) {
        reviewSet.push(id);
      }
    }
  }
  return acgReviewGraph.parse({ ...draft, human_review_set: reviewSet });
}

// src/core/acg-review-store.ts
