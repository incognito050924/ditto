  oracleVerdictOutcome = exports_external.enum(["confirmed", "refuted", "advisory_unverified"]).describe("Exit 3-way verdict: confirmed = claim held (absence: exit 1); refuted = claim contradicted (absence: exit 0); advisory_unverified = could not decide \u2014 never coerced to absent (wi_260706n4w ac-2)");
