// src/core/github-progress.ts
import { createHash as createHash3 } from "crypto";

// src/core/github-redaction.ts
import { relative as relative6 } from "path";
var TOKEN_PATTERNS = [
  /gh[pousr]_[A-Za-z0-9]{20,}/g,
  /github_pat_[A-Za-z0-9_]{20,}/g,
  /\bAKIA[0-9A-Z]{16}\b/g,
  /\b[A-Za-z0-9_-]*(?:secret|token|api[_-]?key|password)[A-Za-z0-9_-]*\s*[:=]\s*\S+/gi
];
var WI_ID = /\bwi_[a-z0-9]+\b/g;
var ABS_PATH = /(?<![:\w])(?:\/[A-Za-z0-9._@-]+)+/g;
function relativizePaths(text, repoRoot) {
  return text.replace(ABS_PATH, (match) => {
    if (repoRoot && (match === repoRoot || match.startsWith(`${repoRoot}/`))) {
      return relative6(repoRoot, match) || ".";
    }
    const base = match.slice(match.lastIndexOf("/") + 1);
    return base || match;
  });
}
function scrubTokens(text) {
  let out = text;
  for (const re of TOKEN_PATTERNS)
    out = out.replace(re, "[redacted]");
  return out;
}
function sanitizeFragment(text, repoRoot = process.cwd()) {
  const firstLine = text.split(`
`)[0] ?? "";
  const out = scrubTokens(relativizePaths(firstLine, repoRoot)).replace(WI_ID, "");
  return out.replace(/\s{2,}/g, " ").trim();
}
function sanitizeBranchCoordinate(branch, repoRoot = process.cwd()) {
  const firstLine = branch.split(`
`)[0] ?? "";
  const out = scrubTokens(relativizePaths(firstLine, repoRoot)).replace(/\bwi_([a-z0-9]+)\b/g, "$1");
  return out.replace(/\s{2,}/g, " ").trim();
}
function buildPublicSafeSummary(fields) {
  const root = fields.repoRoot ?? process.cwd();
  const lines = [
    "## ditto: work item result",
    "",
    sanitizeFragment(fields.summaryLine, root)
  ];
  if (fields.sha)
    lines.push("", `commit: \`${fields.sha}\``);
  if (fields.finalVerdict)
    lines.push("", `final_verdict: \`${fields.finalVerdict}\``);
  if (fields.acVerdicts.length > 0) {
    lines.push("", "Acceptance criteria:");
    for (const ac of fields.acVerdicts)
      lines.push(`- ${ac.id} [${ac.verdict}]`);
  }
  return lines.join(`
`);
}

// src/core/github-progress.ts
function synthesizeFollowUpId(fu, index) {
  return createHash3("sha1").update(`followup ${index} ${JSON.stringify(fu)}`).digest("hex");
}
async function resolveTarget(store, workItemId2) {
  const item = await store.get(workItemId2);
  if (item.github_issue) {
    return {
      repo: item.github_issue.repo,
      number: item.github_issue.number,
      prefix: "",
      link_owner_id: workItemId2
    };
  }
  if (item.parent_id) {
    const parent = await store.get(item.parent_id);
    if (parent.github_issue) {
      return {
        repo: parent.github_issue.repo,
        number: parent.github_issue.number,
        prefix: `[${workItemId2}] `,
        link_owner_id: item.parent_id
      };
    }
  }
  return null;
}
function decisionLabel(d2) {
  const parts = [d2.decision];
  if (d2.disposition)
    parts.push(d2.disposition);
  if (d2.failure_class)
    parts.push(d2.failure_class);
  return parts.join("/");
}
function buildProgressComment(workItemId2, prefix, decisions, followUps) {
  const lines = [`## ${prefix}ditto: autopilot decisions \u2014 ${workItemId2}`, ""];
  for (const { d: d2 } of decisions) {
    lines.push(`- ${d2.ts} \xB7 \`${decisionLabel(d2)}\` \u2014 ${sanitizeFragment(d2.reason)}`);
  }
  for (const { fu } of followUps) {
    const link = fu.materialized_wi ? ` (${fu.materialized_wi})` : "";
    lines.push(`- follow-up bug${link} \u2014 ${sanitizeFragment(fu.note)}`);
  }
  return lines.join(`
`);
}
async function postUnpostedDecisions(deps, workItemId2) {
  const target = await resolveTarget(deps.store, workItemId2);
  if (!target) {
    return {
      kind: "skipped",
      posted_ids: [],
      comment_count: 0,
      notice: `${workItemId2} has no linked GitHub issue (own or parent) \u2014 progress post skipped.`
    };
  }
  const linkOwner = await deps.store.get(target.link_owner_id);
  const postedSet = new Set(linkOwner.github_issue?.posted_decision_ids ?? []);
  const decisions = await deps.aps.readDecisions(workItemId2);
  const unposted = decisions.map((d2, i2) => ({ d: d2, id: synthesizeDecisionId(d2, i2) })).filter(({ d: d2, id }) => isDecisivePost(d2) && !postedSet.has(id));
  const sourceItem = await deps.store.get(workItemId2);
  const unpostedFollowUps = (sourceItem.follow_ups ?? []).map((fu, i2) => ({ fu, id: synthesizeFollowUpId(fu, i2) })).filter(({ fu, id }) => fu.kind === "bug" && !fu.resolved && !postedSet.has(id));
  if (unposted.length === 0 && unpostedFollowUps.length === 0) {
    return { kind: "no_new", posted_ids: [], comment_count: 0, target };
  }
  const body = buildProgressComment(workItemId2, target.prefix, unposted, unpostedFollowUps);
  const res = deps.client.issueComment(target.repo, target.number, body);
  if (!res.ok) {
    return {
      kind: "degraded",
      posted_ids: [],
      comment_count: 1,
      target,
      notice: `issue comment degraded (${res.reason}) \u2014 decisions held for a later sync, not marked.`
    };
  }
  const newIds = [...unposted.map((u3) => u3.id), ...unpostedFollowUps.map((u3) => u3.id)];
  for (const decisionId of newIds) {
    await deps.store.recordGithubPost(target.link_owner_id, { posted_decision_id: decisionId });
  }
  return { kind: "posted", posted_ids: newIds, comment_count: 1, target };
}

