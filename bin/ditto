    "test_fixture",
    "private_helper",
    "service_logic",
    "public_api",
    "migration",
    "auth",
    "payment",
    "data_deletion",
    "config",
    "ui",
    "user_journey"
  ]).optional(),
  risk: exports_external.enum(["low", "medium", "high"]),
  risk_reason: exports_external.string().min(1).describe("Empty reason = invalid classification"),
