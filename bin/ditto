// src/core/resource-routing.ts
import { readdirSync as readdirSync3 } from "fs";
import { join as join79 } from "path";
var GLOBAL_PREFIX = "GLOBAL_";
function routeResource(filename, ctx) {
  if (filename.startsWith(GLOBAL_PREFIX)) {
    const destName = filename.slice(GLOBAL_PREFIX.length);
    return {
      scope: "global",
      destName,
      destPath: join79(ctx.homeDir, ".claude", destName)
    };
  }
  return {
    scope: "project",
    destName: filename,
    destPath: join79(ctx.projectRoot, filename)
  };
}
function discoverResources(resourcesDir) {
  try {
    return readdirSync3(resourcesDir, { withFileTypes: true }).filter((entry) => entry.isFile()).map((entry) => entry.name);
  } catch {
    return [];
  }
}

// src/core/setup.ts
var CODEX_MARKETPLACE_NAME = "ditto-local";
var CODEX_PLUGIN_NAME = "ditto";
var CODEX_PLUGIN_DEST_REL = join80(".agents", "plugins", CODEX_PLUGIN_NAME);
var CODEX_BIN_NAME = "ditto";
function setupHosts(host) {
  if (host === "codex")
    return new Set(["codex"]);
  if (host === "both")
    return new Set(["claude-code", "codex"]);
  return new Set(["claude-code"]);
}
function resourceDecisions(resourcesDir, projectRoot, homeDir, hosts) {
  const out = [];
  const files = discoverResources(resourcesDir);
  if (hosts.has("claude-code")) {
    for (const filename of files) {
      const decision = routeResource(filename, { projectRoot, homeDir });
      out.push({ host: "claude-code", filename, ...decision });
    }
  }
  if (hosts.has("codex")) {
    for (const filename of files) {
      if (filename === "AGENTS.md") {
        out.push({
          host: "codex",
          filename,
          scope: "project",
          destPath: join80(projectRoot, "AGENTS.md")
        });
      } else if (filename === "GLOBAL_AGENTS.md") {
        out.push({
          host: "codex",
          filename,
          scope: "global",
          destPath: join80(homeDir, ".codex", "AGENTS.md")
        });
      }
    }
  }
  const seen = new Set;
  return out.filter((d2) => {
    const key = d2.destPath;
    if (seen.has(key))
      return false;
    seen.add(key);
    return true;
  });
}
function codexMarketplaceEntry() {
  return {
    name: CODEX_PLUGIN_NAME,
    source: {
      source: "local",
      path: `./${CODEX_PLUGIN_DEST_REL.replaceAll("\\", "/")}`
    },
    policy: {
      installation: "AVAILABLE",
      authentication: "ON_INSTALL"
    },
    category: "Productivity",
    interface: {
      displayName: "DITTO"
    }
  };
}
async function readMarketplace(path) {
  const raw = await readJsonIfExists(path);
  if (raw === null)
    return { name: CODEX_MARKETPLACE_NAME, plugins: [] };
  if (typeof raw !== "object" || raw === null || Array.isArray(raw)) {
    throw new Error(`${path} is not a JSON object`);
  }
  return raw;
}
async function writeCodexMarketplace(path) {
  const marketplace = await readMarketplace(path);
  const plugins = Array.isArray(marketplace.plugins) ? marketplace.plugins : [];
  const nextEntry = codexMarketplaceEntry();
  const nextPlugins = plugins.filter((p) => p?.name !== CODEX_PLUGIN_NAME);
  nextPlugins.push(nextEntry);
  nextPlugins.sort((a2, b2) => String(a2.name ?? "").localeCompare(String(b2.name ?? "")));
  await atomicWriteText(path, `${JSON.stringify({
    name: typeof marketplace.name === "string" ? marketplace.name : CODEX_MARKETPLACE_NAME,
    ...marketplace,
    plugins: nextPlugins
  }, null, 2)}
`);
}
async function installCodexAgents(pluginRoot, projectRoot) {
  const srcDir = join80(pluginRoot, ".codex", "agents");
  if (!await fileExists(srcDir)) {
    throw new Error(`codex custom agents not found at ${srcDir}; run build:codex-plugin first`);
  }
  const destDir = join80(projectRoot, ".codex", "agents");
  await ensureDir(destDir);
  let count = 0;
  for (const file of await listFiles(srcDir)) {
    if (!file.id.endsWith(".toml"))
      continue;
    await cp(file.path, join80(destDir, file.id));
    count += 1;
  }
  return count;
}
function codexDittoCommand(installedPluginDir) {
  return `"${join80(installedPluginDir, "bin", CODEX_BIN_NAME).replaceAll("\\", "/")}"`;
}
function rewriteCodexDittoReferences(text, dittoCommand) {
  return text.replace(/"\$\{CLAUDE_PLUGIN_ROOT\}\/bin\/ditto(?:\.exe)?"/g, dittoCommand).replace(/\$\{CLAUDE_PLUGIN_ROOT\}\/bin\/ditto(?:\.exe)?/g, dittoCommand).replace(/`ditto(?=\s)/g, `\`${dittoCommand}`);
}
async function rewriteCodexTextFile(path, dittoCommand) {
  const before = await readFile18(path, "utf8");
  const after = rewriteCodexDittoReferences(before, dittoCommand);
  if (after !== before)
    await writeFile4(path, after);
}
function rewriteCodexAgentTomlReferences(text, dittoCommand) {
  return text.replace(/(\bdeveloper_instructions\s*=\s*""")([\s\S]*?)("""\s*)/, (_match, open2, body, close) => `${open2}${rewriteCodexDittoReferences(body, dittoCommand)}${close}`);
}
async function rewriteCodexAgentTomlFile(path, dittoCommand) {
  const before = await readFile18(path, "utf8");
  const after = rewriteCodexAgentTomlReferences(before, dittoCommand);
  if (after !== before)
    await writeFile4(path, after);
}
async function rewriteCodexInstalledReferences(installedPluginDir) {
  const dittoCommand = codexDittoCommand(installedPluginDir);
  for (const dir of await listDirectories(join80(installedPluginDir, "skills"))) {
    const skillPath = join80(dir.path, "SKILL.md");
    if (await fileExists(skillPath))
      await rewriteCodexTextFile(skillPath, dittoCommand);
  }
  for (const file of await listFiles(join80(installedPluginDir, ".codex", "agents"))) {
    if (file.id.endsWith(".toml"))
      await rewriteCodexAgentTomlFile(file.path, dittoCommand);
  }
}
async function writeCodexSurfaceCatalog(projectRoot) {
  const surfaceCatalogPath = join80(projectRoot, ".ditto", "local", "surfaces.codex.json");
  await ensureDir(join80(projectRoot, ".ditto", "local"));
  const catalog = await generateSurfaceCatalog([codexHostAdapter], projectRoot, "surfaces.codex.json");
  await atomicWriteText(surfaceCatalogPath, `${JSON.stringify(catalog, null, 2)}
`);
  return surfaceCatalogPath;
}
async function writeCodexPluginStatus(projectRoot) {
  const statusPath = join80(projectRoot, ".ditto", "local", "codex-plugin-status.json");
  const enableCommands = [
    `codex plugin marketplace add ${JSON.stringify(projectRoot)}`,
    `codex plugin add ${CODEX_PLUGIN_NAME}@${CODEX_MARKETPLACE_NAME}`
  ];
  await atomicWriteText(statusPath, `${JSON.stringify({
    schema_version: "0.1.0",
    plugin: CODEX_PLUGIN_NAME,
    marketplace: CODEX_MARKETPLACE_NAME,
    status: "needs_user_action",
    reason: "setup prepared the target-local Codex marketplace, but Codex has not been asked to install this plugin in CODEX_HOME",
    commands: enableCommands
  }, null, 2)}
`);
  return { statusPath, enableCommands };
}
async function installCodexSurface(opts) {
  const { pluginRoot, projectRoot } = opts;
  const manifestPath = join80(pluginRoot, ".codex-plugin", "plugin.json");
  if (!await fileExists(manifestPath)) {
    throw new Error(`codex plugin manifest not found at ${manifestPath}; run build:codex-plugin first`);
  }
  const installedPluginDir = join80(projectRoot, CODEX_PLUGIN_DEST_REL);
  if (resolve19(pluginRoot) === resolve19(installedPluginDir)) {
    throw new Error(`codex plugin source is already the installed plugin directory: ${installedPluginDir}`);
  }
  await rm3(installedPluginDir, { recursive: true, force: true });
  await ensureDir(join80(projectRoot, ".agents", "plugins"));
  await cp(pluginRoot, installedPluginDir, { recursive: true });
  await rewriteCodexInstalledReferences(installedPluginDir);
  const marketplacePath = join80(projectRoot, ".agents", "plugins", "marketplace.json");
  await writeCodexMarketplace(marketplacePath);
  const agentsInstalled = await installCodexAgents(installedPluginDir, projectRoot);
  const surfaceCatalogPath = await writeCodexSurfaceCatalog(projectRoot);
  const { statusPath, enableCommands } = await writeCodexPluginStatus(projectRoot);
  return {
    pluginRoot,
    installedPluginDir,
    marketplacePath,
    surfaceCatalogPath,
    statusPath,
    pluginLoadStatus: "needs_user_action",
    enableCommands,
    agentsDir: join80(projectRoot, ".codex", "agents"),
    agentsInstalled
  };
}
async function installResource(decision, resourcesDir) {
  const common = {
    host: decision.host,
    filename: decision.filename,
    scope: decision.scope,
    destPath: decision.destPath
  };
  const name = basename4(decision.destPath);
  if (name === "AGENTS.md") {
    const existed = await fileExists(decision.destPath);
    if (!existed) {
      const body2 = await readFile18(join80(resourcesDir, decision.filename), "utf8");
      await atomicWriteText(decision.destPath, body2);
    }
    return { ...common, status: existed ? "kept" : "written", backupPath: null };
  }
  if (name === "CLAUDE.md") {
    const sourcePath = join80(dirname14(decision.destPath), "AGENTS.md");
    const projectionBody = await fileExists(sourcePath) ? await readFile18(sourcePath, "utf8") : await readFile18(join80(resourcesDir, decision.filename), "utf8");
    const applied2 = await applyManagedFile(decision.destPath, projectionBody, "AGENTS.md");
    return {
      ...common,
      status: applied2.kind === "ok" ? "written" : "corrupted",
      backupPath: applied2.kind === "ok" ? applied2.backupPath : null
    };
  }
  const body = await readFile18(join80(resourcesDir, decision.filename), "utf8");
  const applied = await applyManagedFile(decision.destPath, body, decision.filename);
  return {
    ...common,
    status: applied.kind === "ok" ? "written" : "corrupted",
    backupPath: applied.kind === "ok" ? applied.backupPath : null
  };
}
async function setup(opts) {
  const { resourcesDir, projectRoot, homeDir, now } = opts;
  const hosts = setupHosts(opts.host);
  const decisions = resourceDecisions(resourcesDir, projectRoot, homeDir, hosts);
  const ordered = [
    ...decisions.filter((d2) => basename4(d2.destPath) !== "CLAUDE.md"),
    ...decisions.filter((d2) => basename4(d2.destPath) === "CLAUDE.md")
  ];
  const resources = [];
  for (const decision of ordered) {
    resources.push(await installResource(decision, resourcesDir));
  }
  const scaffold = await initScaffold(projectRoot, now);
  const allowlistPath = join80(projectRoot, ".claude", "settings.json");
  const allowlistApplied = hosts.has("claude-code");
  if (allowlistApplied)
    await allowlistSettingsFile(allowlistPath);
  const codex = hosts.has("codex") ? await installCodexSurface({
    pluginRoot: opts.pluginRoot ?? resolve19(resourcesDir, "..", ".."),
    projectRoot
  }) : null;
  return { resources, scaffold, allowlistPath, allowlistApplied, codex };
}

// src/cli/resources.ts
import { existsSync as existsSync11 } from "fs";
import { dirname as dirname15, join as join81, resolve as resolve20 } from "path";
import { fileURLToPath as fileURLToPath2 } from "url";
function resolveResourcesDir(from) {
  if (process.env.CLAUDE_PLUGIN_ROOT) {
    return join81(process.env.CLAUDE_PLUGIN_ROOT, "resources", "managed");
  }
  const start = from ?? dirname15(fileURLToPath2(import.meta.url));
  let dir = start;
  for (;; ) {
    const candidate = join81(dir, "resources", "managed");
    if (existsSync11(candidate))
      return candidate;
    const parent = dirname15(dir);
    if (parent === dir)
      break;
    dir = parent;
  }
  return join81(resolve20(start, "..", ".."), "resources", "managed");
}

// src/cli/wizard/agent-link-step.ts
var PSEUDO_OWNERS = new Set(["driver", "main-session"]);
var ROLE_OPTIONS = nodeOwner.options.filter((role) => !PSEUDO_OWNERS.has(role)).map((role) => ({ label: role, value: role }));
async function runAgentLinkStep(io, deps) {
  const agents = await deps.loadAgents();
  const discovered = agents.map((a2) => ({
    ...a2,
    role: recommendVariantRole(a2.name, a2.description)
  }));
  if (discovered.length === 0)
    return { discovered, written: [], skipped: [] };
  const choices = discovered.map((a2) => ({
    label: `${a2.name} \u2192 ${a2.role}${a2.description ? ` (${a2.description})` : ""}`,
    value: a2.name,
    checked: false
  }));
  const picked = new Set(await multiSelect(io, "\uD504\uB85C\uC81D\uD2B8 agent\uB97C ditto role\uC5D0 \uC5F0\uACB0", choices));
  const approved = [];
  for (const a2 of discovered) {
    if (!picked.has(a2.name))
      continue;
    const role = await select(io, `'${a2.name}' role \uC120\uD0DD (\uCD94\uCC9C: ${a2.role})`, ROLE_OPTIONS, a2.role);
    approved.push({ name: a2.name, role, description: a2.description, match: [] });
  }
  if (approved.length === 0)
    return { discovered, written: [], skipped: [] };
  const result2 = await deps.writeVariants(approved);
  return { discovered, written: result2.written, skipped: result2.skipped };
}

// src/cli/wizard/provision-step.ts
async function planProvisioning(registry2, detectedLanguages) {
  const provisioners = [
    ...registry2.tools.values(),
    ...detectedLanguages.map((lang) => registry2.lsp.get(lang)).filter((p) => p !== undefined)
  ];
  const out = [];
  for (const p of provisioners) {
    const present = await p.resolveExisting() !== null;
    out.push({
      id: p.id,
      label: p.label,
      present,
      recommended: !present,
      install: p.install,
      manual: p.manual
    });
  }
  return out;
}
async function runProvisionStep(io, registry2, sourceRoot, deps) {
  const detected = await deps.detect(sourceRoot);
  const languages = detected.map((d2) => d2.language);
  const unservicedLanguages = languages.filter((lang) => !registry2.lsp.has(lang));
  const plan = await planProvisioning(registry2, languages);
  const present = plan.filter((c3) => c3.present);
  const absent = plan.filter((c3) => !c3.present);
  const outcomes = present.map((c3) => ({
    id: c3.id,
    action: "already-present",
    message: `${c3.label}: \uC774\uBBF8 \uC124\uCE58\uB428`
  }));
  if (absent.length === 0) {
    return { outcomes, unservicedLanguages };
  }
  const choices = absent.map((c3) => ({
    label: c3.label,
    value: c3.id,
    checked: c3.recommended
  }));
  const picked = new Set(await multiSelect(io, "\uBD84\uC11D/\uC5B8\uC5B4 \uB3C4\uAD6C \u2014 \uC124\uCE58\uD560 \uD56D\uBAA9", choices));
  for (const c3 of absent) {
    if (!picked.has(c3.id)) {
      outcomes.push({
        id: c3.id,
        action: "skipped",
        message: `${c3.label}: \uAC74\uB108\uB700(\uD544\uC694 \uC2DC \uAE30\uB2A5 degrade)`
      });
      continue;
    }
    const result2 = await c3.install();
    const action = result2.status === "installed" ? "installed" : result2.status === "already-present" ? "already-present" : "failed";
    outcomes.push({
      id: c3.id,
      action,
      message: `${c3.label}: ${result2.message}`,
      ...result2.manual ? { manual: result2.manual } : {}
    });
  }
  return { outcomes, unservicedLanguages };
}

// src/cli/wizard/setup-wizard.ts
var HOST_OPTIONS = [
  { label: "Claude Code", value: "claude-code" },
  { label: "Codex", value: "codex" },
  { label: "\uB458 \uB2E4(both)", value: "both" }
];
var MEMORY_OPTIONS = [
  { label: "gitignore-\uB3C5\uB9BD (\uB2E8\uC21C, \uBD80\uBAA8 git\uC5D0\uC11C \uC81C\uC678)", value: "gitignore" },
  { label: "submodule (\uD300 \uC7AC\uD604 \u2014 \uC6D0\uACA9 \uC120\uD589, \uC218\uB3D9 \uC548\uB0B4)", value: "submodule" }
];
async function runSetupWizard(io, deps) {
  const host = await select(io, "Host \uC120\uD0DD", HOST_OPTIONS, "claude-code");
  const setupResult = await deps.setup(host);
  const provision = await deps.runProvision(io);
  const agents = await deps.runAgentLink(io, host);
  let memory = { mode: "in-project", result: null };
  const separate = await confirm(io, "memory\uB97C \uBCC4\uB3C4 git \uC800\uC7A5\uC18C\uB85C \uBD84\uB9AC\uD560\uAE4C?", false);
  if (separate) {
    const mode = await select(io, "memory \uBD84\uB9AC \uBC29\uC2DD", MEMORY_OPTIONS, "gitignore");
    memory = { mode, result: await deps.separateMemory(mode) };
  }
  return { host, setup: setupResult, provision, memory, agents };
}

// src/cli/commands/setup.ts
async function provisionToolsNonInteractive(projectRoot) {
  const io = {
    isTTY: false,
    ask: async () => "",
    write: (t2) => {
      process.stdout.write(t2);
    }
  };
  const summary = await runProvisionStep(io, defaultRegistry(), projectRoot, {
    detect: detectLspLanguages
  });
  writeHuman("tools:");
  for (const o3 of summary.outcomes)
    writeHuman(`  ${o3.action}	${o3.message}`);
  if (summary.unservicedLanguages.length > 0) {
    writeHuman(`  \uAC10\uC9C0\uB410\uC73C\uB098 \uC11C\uBC84 \uBBF8\uB4F1\uB85D: ${summary.unservicedLanguages.join(", ")}`);
  }
}
function parseSetupHost(value) {
  if (value === undefined || value === null || value === "")
    return "claude-code";
  if (value === "claude-code" || value === "codex" || value === "both")
    return value;
  throw new Error(`invalid --host ${String(value)} (expected claude-code|codex|both)`);
}
function includesCodex(host) {
  return host === "codex" || host === "both";
}
async function resolveCodexPluginRoot(resourcesDir, projectRoot) {
  const currentPluginRoot = resolve21(resourcesDir, "..", "..");
  const sibling = join82(dirname16(currentPluginRoot), "codex-plugin");
  if (await fileExists(join82(sibling, ".codex-plugin", "plugin.json")))
    return sibling;
  const currentDist = join82(currentPluginRoot, "dist", "codex-plugin");
  if (await fileExists(join82(currentDist, ".codex-plugin", "plugin.json")))
    return currentDist;
  const projectDist = join82(projectRoot, "dist", "codex-plugin");
  if (await fileExists(join82(projectDist, ".codex-plugin", "plugin.json")))
    return projectDist;
  if (await fileExists(join82(currentPluginRoot, ".codex", "agents")))
    return currentPluginRoot;
  return currentPluginRoot;
}
async function discoverClaudeAgents(projectRoot) {
  const inventory = await claudeCodeHostAdapter.loadSurfaceInventory(projectRoot);
  const agents = inventory.localSurfaces.filter((s2) => s2.kind === "agent");
  const out = [];
  for (const a2 of agents) {
    let description = "";
    try {
      const text = await Bun.file(a2.path).text();
      const m2 = /^description:\s*(.+)$/m.exec(text);
      if (m2)
        description = (m2[1] ?? "").trim();
    } catch {}
    out.push({ name: a2.id, description });
  }
  return out;
}
async function discoverCodexAgents(projectRoot) {
  const inventory = await codexHostAdapter.loadSurfaceInventory(projectRoot);
  const agents = inventory.localSurfaces.filter((s2) => s2.kind === "agent");
  const out = [];
  for (const a2 of agents) {
    let text = "";
    try {
      text = await Bun.file(a2.path).text();
    } catch {}
    if (/ditto agent-projection/.test(text))
      continue;
    let description = "";
    const m2 = /^description\s*=\s*"([^"]*)"\s*$/m.exec(text);
    if (m2)
      description = (m2[1] ?? "").trim();
    out.push({ name: a2.id, description });
  }
  return out;
}
async function discoverProjectAgents(projectRoot, host) {
  const claude = host === "claude-code" || host === "both" ? await discoverClaudeAgents(projectRoot) : [];
  const codex = host === "codex" || host === "both" ? await discoverCodexAgents(projectRoot) : [];
  const seen = new Set(claude.map((a2) => a2.name));
  return [...claude, ...codex.filter((a2) => !seen.has(a2.name))];
}
async function runWizard(resourcesDir, projectRoot) {
  const io = createStdioPromptIO();
  try {
    const result2 = await runSetupWizard(io, {
      projectRoot,
      sourceRoot: projectRoot,
      setup: async (host) => setup({
        resourcesDir,
        projectRoot,
        homeDir: homedir10(),
        now: new Date,
        host,
        ...includesCodex(host) ? { pluginRoot: await resolveCodexPluginRoot(resourcesDir, projectRoot) } : {}
      }),
      runProvision: (promptIo) => runProvisionStep(promptIo, defaultRegistry(), projectRoot, { detect: detectLspLanguages }),
      separateMemory: (mode) => separateMemoryRepo(defaultMemorySeparateDeps(projectRoot), mode),
      runAgentLink: (promptIo, host) => runAgentLinkStep(promptIo, {
        loadAgents: () => discoverProjectAgents(projectRoot, host),
        writeVariants: (variants) => writeAgentVariants(projectRoot, variants)
      })
    });
    writeHuman(`setup: installed into ${projectRoot} (host=${result2.host})`);
    writeHuman(`.ditto/: ${result2.setup.scaffold.alreadyInitialized ? "already initialized" : "created"} \xB7 allowlist: ${result2.setup.allowlistApplied ? result2.setup.allowlistPath : "skipped"}`);
    writeHuman("tools:");
    for (const o3 of result2.provision.outcomes)
      writeHuman(`  ${o3.action}	${o3.message}`);
    if (result2.provision.unservicedLanguages.length > 0) {
      writeHuman(`  \uAC10\uC9C0\uB410\uC73C\uB098 \uC11C\uBC84 \uBBF8\uB4F1\uB85D: ${result2.provision.unservicedLanguages.join(", ")}`);
    }
    if (result2.agents.discovered.length > 0) {
      writeHuman("project agents:");
      for (const a2 of result2.agents.discovered)
        writeHuman(`  ${a2.name} \u2192 ${a2.role}`);
      writeHuman(`  linked: ${result2.agents.written.length ? result2.agents.written.join(", ") : "(none)"}${result2.agents.skipped.length ? ` \xB7 skipped(existing): ${result2.agents.skipped.join(", ")}` : ""}`);
    }
    if (result2.memory.result) {
      writeHuman(`memory: ${result2.memory.mode} \u2014 ${result2.memory.result.message}`);
      for (const line of result2.memory.result.manual ?? [])
        writeHuman(`  ${line}`);
    } else {
      writeHuman("memory: \uD504\uB85C\uC81D\uD2B8 git\uC5D0 \uD3EC\uD568(\uAE30\uBCF8)");
    }
    writeHuman("safety hook: PreToolUse \uD65C\uC131(\uD50C\uB7EC\uADF8\uC778 \uC804\uC5ED) \u2014 \uC815\uC0C1 \uBA85\uB839 \uC624\uD0D0 \uC2DC DITTO_SKIP_HOOKS=1 prefix");
  } finally {
    io.close();
  }
}
var setupCommand = defineCommand({
  meta: {
    name: "setup",
    description: "Install ditto managed resources, scaffold .ditto/, and allowlist the target project"
  },
  args: {
    dir: {
      type: "string",
      required: false,
      description: "Target project directory; defaults to the nearest .ditto/.git root or cwd"
    },
    target: {
      type: "positional",
      required: false,
      description: "Target project directory; same as --dir"
    },
    host: {
      type: "string",
      required: false,
      description: "Host surface to install: claude-code|codex|both (default: claude-code)"
    },
    yes: {
      type: "boolean",
      required: false,
      default: false,
      description: "Non-interactive: skip the wizard, use defaults/flags (CI/agent)"
    },
    tools: {
      type: "boolean",
      required: false,
      default: false,
      description: "Non-interactive only: also provision detected tools (codeql/playwright/LSP)"
    }
  },
  run: async ({ args }) => {
    try {
      const host = parseSetupHost(args.host);
      const targetDir = typeof args.dir === "string" ? args.dir : args.target;
      const projectRoot = targetDir ? resolve21(targetDir) : await resolveRepoRootForCreate();
      const resourcesDir = resolveResourcesDir();
      const pluginRoot = resolve21(resourcesDir, "..", "..");
      if (pluginRoot === projectRoot) {
        writeHuman(`setup: skipped (self-host \u2014 target IS the ditto repo at ${projectRoot})`);
        return;
      }
      if (process.stdin.isTTY && !args.yes) {
        await runWizard(resourcesDir, projectRoot);
        return;
      }
      const result2 = await setup({
        resourcesDir,
        projectRoot,
        homeDir: homedir10(),
        now: new Date,
        host,
        ...includesCodex(host) ? { pluginRoot: await resolveCodexPluginRoot(resourcesDir, projectRoot) } : {}
      });
      writeHuman(`setup: installed into ${projectRoot} (host=${host})`);
      for (const r3 of result2.resources) {
        const tag = r3.status === "corrupted" ? "SKIPPED (corrupted markers)" : r3.status === "kept" ? `\u2192 ${r3.destPath} (kept existing source)` : `\u2192 ${r3.destPath}`;
        const bak = r3.backupPath ? ` (backup ${r3.backupPath})` : "";
        writeHuman(`  ${r3.filename} [${r3.host}/${r3.scope}] ${tag}${bak}`);
      }
      if (result2.codex) {
        writeHuman(`  codex marketplace \u2192 ${result2.codex.marketplacePath}`);
        writeHuman(`  codex plugin copy \u2192 ${result2.codex.installedPluginDir}`);
        writeHuman(`  codex surface catalog \u2192 ${result2.codex.surfaceCatalogPath}`);
        writeHuman(`  codex agents \u2192 ${result2.codex.agentsDir} (${result2.codex.agentsInstalled})`);
        writeHuman(`  codex plugin status \u2192 ${result2.codex.pluginLoadStatus}`);
        writeHuman("  codex enable commands:");
        for (const command of result2.codex.enableCommands)
          writeHuman(`    ${command}`);
      }
      writeHuman(`.ditto/: ${result2.scaffold.alreadyInitialized ? "already initialized" : "created"} \xB7 allowlist: ${result2.allowlistApplied ? result2.allowlistPath : "skipped"}`);
      if (args.tools)
        await provisionToolsNonInteractive(projectRoot);
    } catch (err) {
      writeError(`setup failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});

// src/cli/commands/teardown.ts
import { rm as rm4 } from "fs/promises";
import { homedir as homedir11 } from "os";
import { join as join84, resolve as resolve22 } from "path";
init_fs();

// src/core/teardown.ts
init_fs();
import { copyFile as copyFile2, readFile as readFile19 } from "fs/promises";
import { join as join83 } from "path";
var BACKUP_SUFFIX2 = ".ditto_bak";
async function teardown(opts) {
  const { resourcesDir, projectRoot, homeDir } = opts;
  const files = [];
  for (const filename of discoverResources(resourcesDir)) {
    const decision = routeResource(filename, { projectRoot, homeDir });
    const action = await teardownFile(decision.destPath);
    files.push({ filename, scope: decision.scope, destPath: decision.destPath, action });
  }
  const allowlistPath = join83(projectRoot, ".claude", "settings.json");
  await unallowlistSettingsFile(allowlistPath);
  return { files, allowlistPath };
}
async function teardownFile(destPath) {
  if (!await Bun.file(destPath).exists())
    return "left-untouched";
  const current = await readFile19(destPath, "utf8");
  const stripped = stripManagedBlock(current);
  if (stripped.kind === "ok") {
    await atomicWriteText(destPath, stripped.content);
    return "stripped";
  }
  const bakPath = `${destPath}${BACKUP_SUFFIX2}`;
  if (await Bun.file(bakPath).exists()) {
    await copyFile2(bakPath, destPath);
    return "restored-from-backup";
  }
  return "left-untouched";
}

// src/cli/commands/teardown.ts
async function shouldPurge(flagPurge) {
  if (flagPurge)
    return true;
  if (!process.stdin.isTTY)
    return false;
  const io = createStdioPromptIO();
  try {
    return await confirm(io, ".ditto/ \uB370\uC774\uD130(work-item \uC774\uB825\xB7\uBA54\uBAA8\uB9AC)\uAE4C\uC9C0 \uC601\uAD6C \uC0AD\uC81C\uD560\uAE4C?", false);
  } finally {
    io.close();
  }
}
var teardownCommand = defineCommand({
  meta: {
    name: "uninstall",
    description: "Undo ditto setup: strip managed blocks (preserving user content), remove the allow rule; keeps .ditto/ (alias: teardown)"
  },
  args: {
    dir: {
      type: "string",
      required: false,
      description: "Target project directory; defaults to the nearest .ditto/.git root or cwd"
    },
    purge: {
      type: "boolean",
      required: false,
      default: false,
      description: "Also delete .ditto/ (work-item history + memory) \u2014 irreversible; default keeps it"
    }
  },
  run: async ({ args }) => {
    try {
      const projectRoot = args.dir ? resolve22(args.dir) : await resolveRepoRootForCreate();
      const resourcesDir = resolveResourcesDir();
      const pluginRoot = resolve22(resourcesDir, "..", "..");
      if (pluginRoot === projectRoot) {
        writeHuman(`uninstall: skipped (self-host \u2014 target IS the ditto repo at ${projectRoot})`);
        return;
      }
      const result2 = await teardown({ resourcesDir, projectRoot, homeDir: homedir11() });
      if (result2.files.length === 0) {
        writeError(`uninstall failed: no managed resources found at ${resourcesDir}`);
        process.exit(RUNTIME_ERROR_EXIT);
      }
      writeHuman(`uninstall: reverted ${projectRoot}`);
      for (const f3 of result2.files) {
        writeHuman(`  ${f3.filename} [${f3.scope}] ${f3.action} \u2192 ${f3.destPath}`);
      }
      const purge = await shouldPurge(Boolean(args.purge));
      if (purge) {
        const dittoDir2 = join84(projectRoot, ".ditto");
        await rm4(dittoDir2, { recursive: true, force: true });
        writeHuman(`allowlist: removed Bash(ditto:*) from ${result2.allowlistPath} \xB7 .ditto/ PURGED (${dittoDir2})`);
      } else {
        writeHuman(`allowlist: removed Bash(ditto:*) from ${result2.allowlistPath} \xB7 .ditto/ kept`);
      }
    } catch (err) {
      writeError(`uninstall failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});

// src/cli/commands/tech-spec.ts
init_fs();
function parseJsonArg2(raw) {
  try {
    return JSON.parse(raw);
  } catch (err) {
    throw new Error(`--json is not valid JSON: ${err instanceof Error ? err.message : String(err)}`);
  }
}
var PERFORMANCE_VALUES = ["glance", "quick", "standard", "deep", "exhaustive"];
var EFFORT_VALUES = ["low", "medium", "high", "inherit"];
var GATE_MODE_VALUES = ["confirm", "draft"];
var GRANULARITY_VALUES = ["low", "medium", "high"];
function intArg(raw, label2, min, max) {
  const n2 = Number(raw);
  if (!Number.isInteger(n2) || n2 < min || n2 > max) {
    throw new Error(`--${label2} must be an integer in [${min}, ${max}]; got "${raw}"`);
  }
  return n2;
}
function enumArg(raw, label2, values) {
  if (!values.includes(raw)) {
    throw new Error(`--${label2} must be ${values.join("|")}; got "${raw}"`);
  }
  return raw;
}
function parseQuestionConfigArgs(args, configRaw) {
  const raw = {};
  const intensity = args.intensity;
  if (intensity !== undefined)
    raw.intensity = intArg(intensity, "intensity", 0, 100);
  const generators = args.generators;
  if (generators !== undefined)
    raw.generators = intArg(generators, "generators", 1, 6);
  const maxQuestions = args["max-questions"];
  if (maxQuestions !== undefined)
    raw.max_questions = intArg(maxQuestions, "max-questions", 0, 1e6);
  const maxRounds = args["max-rounds"];
  if (maxRounds !== undefined)
    raw.max_rounds = intArg(maxRounds, "max-rounds", 0, 1e6);
  const performance = args.performance;
  if (performance !== undefined) {
    raw.performance = enumArg(performance, "performance", PERFORMANCE_VALUES);
  }
  const effort = args["generator-effort"];
  if (effort !== undefined) {
    raw.generator_effort = enumArg(effort, "generator-effort", EFFORT_VALUES);
  }
  const gateMode = args["gate-mode"];
  if (gateMode !== undefined) {
    raw.gate_mode = enumArg(gateMode, "gate-mode", GATE_MODE_VALUES);
  }
  const granularity = args.granularity;
  if (granularity !== undefined) {
    raw.granularity = enumArg(granularity, "granularity", GRANULARITY_VALUES);
  }
  const threshold = args.threshold;
  if (threshold !== undefined) {
    const t2 = Number(threshold);
    if (!Number.isFinite(t2) || t2 < 0 || t2 > 1) {
      throw new Error(`--threshold must be a number in [0, 1]; got "${threshold}"`);
    }
    raw.threshold = t2;
  }
  return resolveQuestionConfig(raw, configRaw);
}
