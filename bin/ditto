// src/core/gh-client.ts
import { execFileSync as execFileSync3 } from "child_process";
var DEFAULT_GH_TIMEOUT_MS = 30000;
var defaultGhExec = (args, timeoutMs) => {
  try {
    const stdout3 = execFileSync3("gh", args, {
      encoding: "utf8",
      timeout: timeoutMs,
      stdio: ["ignore", "pipe", "pipe"],
      maxBuffer: 16 * 1024 * 1024
    });
    return { exitCode: 0, stdout: stdout3, stderr: "" };
  } catch (err) {
    const e2 = err;
    if (e2.code === "ENOENT")
      return { exitCode: null, stdout: "", stderr: "", spawnError: "absent" };
    if (e2.killed && e2.signal === "SIGTERM") {
      return { exitCode: null, stdout: "", stderr: "", spawnError: "timeout" };
    }
    const stdout3 = e2.stdout == null ? "" : e2.stdout.toString();
    const stderr2 = e2.stderr == null ? "" : e2.stderr.toString();
    return { exitCode: e2.status ?? 1, stdout: stdout3, stderr: stderr2 };
  }
};
function classifyGhFailure(result2) {
  if (result2.spawnError === "absent")
    return "absent";
  if (result2.spawnError === "timeout")
    return "timeout";
  const text = `${result2.stderr}
${result2.stdout}`.toLowerCase();
  if (/not logged in|gh auth login|authentication required|no oauth token|requires authentication/.test(text)) {
    return "unauthenticated";
  }
  if (/rate limit|secondary rate limit|429|retry-after/.test(text)) {
    return "rate_limited";
  }
  if (/http 403|permission|not accessible by|must have admin|forbidden|insufficient/.test(text)) {
    return "insufficient_perm";
  }
  if (/unknown command|unknown flag|no such (sub)?command|accepts \d+ arg|not a gh command/.test(text)) {
    return "unknown_command";
  }
  return "nonzero";
}
function parseAssigneeLogins(viewValue) {
  const assignees = viewValue?.assignees;
  if (!Array.isArray(assignees))
    return [];
  return assignees.map((a2) => a2?.login).filter((l2) => typeof l2 === "string" && l2.length > 0);
}
function invocationOk(result2) {
  return result2.spawnError == null && result2.exitCode === 0;
}
function degradationFor(result2) {
  const detail = (result2.stderr || result2.stdout || "").trim().slice(0, 200);
  return { ok: false, reason: classifyGhFailure(result2), detail };
}
function run(exec, args, timeoutMs) {
  const result2 = exec(args, timeoutMs);
  if (!invocationOk(result2))
    return degradationFor(result2);
  return { ok: true, value: result2.stdout };
}
function runJson(exec, args, timeoutMs) {
  const r3 = run(exec, args, timeoutMs);
  if ("reason" in r3)
    return r3;
  try {
    return { ok: true, value: JSON.parse(r3.value) };
  } catch {
    return { ok: false, reason: "unparseable", detail: r3.value.slice(0, 200) };
  }
}
function toVoid(r3) {
  if ("reason" in r3)
    return r3;
  return { ok: true, value: undefined };
}
function createGhClient(exec = defaultGhExec, timeoutMs = DEFAULT_GH_TIMEOUT_MS) {
  return {
    issueView: (repo, issueNumber) => runJson(exec, [
      "issue",
      "view",
      String(issueNumber),
      "-R",
      repo,
      "--json",
      "number,title,state,body,url,assignees"
    ], timeoutMs),
    issueComment: (repo, issueNumber, body) => toVoid(run(exec, ["issue", "comment", String(issueNumber), "-R", repo, "--body", body], timeoutMs)),
    issueClose: (repo, issueNumber) => toVoid(run(exec, ["issue", "close", String(issueNumber), "-R", repo], timeoutMs)),
    issueAddAssignee: (repo, issueNumber, assignee) => toVoid(run(exec, ["issue", "edit", String(issueNumber), "-R", repo, "--add-assignee", assignee], timeoutMs)),
    issueRemoveAssignee: (repo, issueNumber, assignee) => toVoid(run(exec, ["issue", "edit", String(issueNumber), "-R", repo, "--remove-assignee", assignee], timeoutMs)),
    projectItemAdd: (owner, projectNumber, contentUrl) => runJson(exec, [
      "project",
      "item-add",
      String(projectNumber),
      "--owner",
      owner,
      "--url",
      contentUrl,
      "--format",
      "json"
    ], timeoutMs),
    projectItemEdit: (edit) => toVoid(run(exec, [
      "project",
      "item-edit",
      "--project-id",
      edit.projectId,
      "--id",
      edit.itemId,
      "--field-id",
      edit.fieldId,
      "--single-select-option-id",
      edit.optionId
    ], timeoutMs)),
    projectFieldList: (owner, projectNumber) => runJson(exec, ["project", "field-list", String(projectNumber), "--owner", owner, "--format", "json"], timeoutMs),
    projectItemList: (owner, projectNumber) => runJson(exec, ["project", "item-list", String(projectNumber), "--owner", owner, "--format", "json"], timeoutMs),
    projectView: (owner, projectNumber) => runJson(exec, ["project", "view", String(projectNumber), "--owner", owner, "--format", "json"], timeoutMs),
    apiGraphql: (query, fields) => {
      const args = ["api", "graphql", "-f", `query=${query}`];
      for (const [k2, v2] of Object.entries(fields ?? {}))
        args.push("-F", `${k2}=${v2}`);
      return runJson(exec, args, timeoutMs);
    }
  };
}

