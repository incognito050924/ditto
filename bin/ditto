// src/acg/semantic/scan-observation.ts
function workItemBaseCandidates(workItem2) {
  const candidates = [];
  if (workItem2.started_at_sha)
    candidates.push(workItem2.started_at_sha);
  candidates.push("origin/main", "origin/master", "main", "master");
  return candidates;
}
function computeScanFingerprint(baseSha, diffText) {
  return sha256Hex2(`${baseSha}
${diffText}`);
}
function buildScanObservation(input) {
  return {
    schema_version: "0.1.0",
    kind: "acg.semantic-scan-observation.v1",
    work_item_id: input.workItemId,
    produced_by: "agent",
    produced_at: input.producedAt,
    base_used: input.baseUsed,
    language: input.language,
    source_root: input.sourceRoot,
    fingerprint: input.fingerprint,
    change_count: input.changes.length,
    changes: input.changes.map((c3) => ({
      file: c3.file,
      symbol: c3.symbol,
      before: c3.before,
      after: c3.after
    }))
  };
}

