    answer_value: exports_external.number().min(0).max(1).describe("How much the spec changes depending on the answer [0..1]")
  }).describe("The gate 4-dimension score for one candidate question");
  scoredQuestion = exports_external.object({
    text: exports_external.string().min(1),
    property: questionProperty,
    why_matters: exports_external.string().optional(),
    user_explanation: exports_external.string().optional(),
    background: exports_external.string().optional(),
    grounding: exports_external.string().optional(),
    scores: questionScore,
    rationale: exports_external.string().optional().describe("Why selected (present on selected questions)")
  }).describe("One candidate question with its gate score");
  questionRoundPayload = exports_external.object({
    round: exports_external.number().int().positive().describe("1-based round index within the interview"),
    section: exports_external.string().optional().describe("Target spec section this round filled"),
    generator_count: exports_external.number().int().positive().default(2).describe("N generators fanned out (--generators default 2, range 1..6; wi_260619yfw)"),
    threshold: exports_external.number().optional().describe("Fixed selection threshold used this round (\xA79 #4)"),
    dry: exports_external.boolean().describe("Gate found no candidate above the threshold \u2192 round/interview ends (\xA79 #4)"),
    selected: exports_external.array(scoredQuestion).default([]).describe("Questions selected to ask the user"),
    all_scored: exports_external.array(scoredQuestion).default([]).describe("Every candidate with its score (durable score trail for later tuning)"),
    novelty: exports_external.boolean().optional().describe("Whether this round added admissible novelty (deterministic; wi_260708yut)")
  }).superRefine((val, ctx) => {
    if (val.dry && val.selected.length > 0) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        path: ["selected"],
        message: "dry=true \uB77C\uC6B4\uB4DC\uB294 selected\uAC00 \uBE44\uC5B4 \uC788\uC5B4\uC57C \uD55C\uB2E4 (\uC784\uACC4 \uC774\uC0C1 \uC9C8\uBB38 \uBD80\uC7AC\uAC00 dry\uC758 \uC815\uC758)"
      });
    }
    if (!val.dry && val.selected.length === 0) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        path: ["dry"],
        message: "selected\uAC00 \uBE44\uC5B4 \uC788\uC73C\uBA74 dry=true\uC5EC\uC57C \uD55C\uB2E4 (\uC120\uC815\uB41C \uC9C8\uBB38\uC774 \uC5C6\uB294 \uB77C\uC6B4\uB4DC\uB294 dry)"
      });
    }
  });
  questionRound = exports_external.object({
    ts: isoDateTime,
    work_item_id: workItemId,
    round: exports_external.number().int().positive(),
    section: exports_external.string().optional(),
    generator_count: exports_external.number().int().positive().default(2),
    threshold: exports_external.number().optional(),
    dry: exports_external.boolean(),
    selected: exports_external.array(scoredQuestion).default([]),
    all_scored: exports_external.array(scoredQuestion).default([]),
    novelty: exports_external.boolean().optional()
  }).describe("One line of .ditto/local/work-items/<id>/question-rounds.jsonl");
});

// src/schemas/coverage.ts
function isDecidableOraclePattern(pattern) {
  return pattern.length > 0 && pattern.length <= ORACLE_PATTERN_MAX_LENGTH && ORACLE_PATTERN_TOKEN_RE.test(pattern);
}
function isFarFieldEscape(kind) {
  return FAR_FIELD_ESCAPE_KINDS.includes(kind);
}
var coverageOrigin, coverageNodeState, coverageDisposition, DEFAULT_COVERAGE_DISPOSITION = "code-verify", coverageNode, coverageTier, coverageMap, rawRelevanceJudgment, relevanceRefute, relevanceProvenance, oracleMode, ORACLE_PATTERN_TOKEN_RE, ORACLE_PATTERN_MAX_LENGTH = 200, oracleClaim, oracleVerdictOutcome, oracleEnforcementTier, oracleAdvisoryReason, oracleVerdict, labelerLabel, oracleProvenance, coverageChildInput, coverageRoundPayload, coverageTaxonomyConfig, coverageFeedback, coverageFaultKind, FAR_FIELD_ESCAPE_KINDS, coverageFeedbackEntry;
var init_coverage = __esm(() => {
  init_zod();
  init_common();
  coverageOrigin = exports_external.enum(["seed", "derived", "discovered"]).describe("How a coverage node entered the tree (\xA73.2)");
