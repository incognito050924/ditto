// src/core/git.ts
import { execFileSync as execFileSync2 } from "child_process";
function captureGitState(cwd) {
  let head = "0".repeat(40);
  let branch = "";
  let dirty = false;
  let untracked_count = 0;
  try {
    head = execFileSync2("git", ["rev-parse", "HEAD"], { cwd, encoding: "utf8" }).trim();
  } catch {}
  try {
    branch = execFileSync2("git", ["rev-parse", "--abbrev-ref", "HEAD"], {
      cwd,
      encoding: "utf8"
    }).trim();
  } catch {}
  try {
    const status = execFileSync2("git", ["status", "--porcelain"], { cwd, encoding: "utf8" });
    const lines = status.split(`
`).filter((line) => line.length > 0);
    dirty = lines.length > 0;
    untracked_count = lines.filter((line) => line.startsWith("??")).length;
  } catch {}
  return { head, branch, dirty, untracked_count };
}
function listChangedFiles(cwd, options = {}) {
  try {
    const status = execFileSync2("git", ["status", "--porcelain"], { cwd, encoding: "utf8" });
    return status.split(`
`).filter((line) => line.length > 0).map((line) => line.slice(3).trim()).filter((path) => path.length > 0).filter((path) => !options.excludeDittoRuns || !path.startsWith(".ditto/local/runs/")).sort();
  } catch {
    return [];
  }
}
function listChangedFilesVsRef(cwd, ref) {
  try {
    const out = execFileSync2("git", ["diff", "--name-only", ref, "--"], { cwd, encoding: "utf8" });
    return out.split(`
`).map((l2) => l2.trim()).filter((p) => p.length > 0).sort();
  } catch {
    return [];
  }
}
function diffVsRef(cwd, ref) {
  try {
    return execFileSync2("git", ["diff", ref, "--"], { cwd, encoding: "utf8" });
  } catch {
    return "";
  }
}
function gitRevParse(cwd, ref) {
  return execFileSync2("git", ["rev-parse", ref], { cwd, encoding: "utf8" }).trim();
}
function addDetachedWorktree(cwd, path, ref) {
  execFileSync2("git", ["worktree", "add", "--detach", "--force", path, ref], {
    cwd,
    stdio: ["ignore", "ignore", "pipe"]
  });
}
function removeWorktree(cwd, path) {
  try {
    execFileSync2("git", ["worktree", "remove", "--force", path], {
      cwd,
      stdio: ["ignore", "ignore", "pipe"]
    });
  } catch {}
}
function captureGitDiff(cwd) {
  try {
    return execFileSync2("git", ["diff", "--binary", "HEAD"], { cwd, encoding: "utf8" });
  } catch {
    try {
      return execFileSync2("git", ["diff", "--binary"], { cwd, encoding: "utf8" });
    } catch {
      return "";
    }
  }
}

// src/core/memory-ir.ts
var SUPPORTED_AFFECTED_KINDS = new Set([
  "direct_caller",
  "transitive_caller",
  "type_contract",
  "generated_client",
  "test",
  "doc",
  "external_surface",
  "ui_surface",
  "user_journey"
]);
var JOURNEY_KINDS = new Set(["ui_surface", "user_journey"]);
function normalizePath(path) {
  return path.replace(/\.[cm]?[jt]sx?$/, "").replace(/\.(java|kt|py)$/, "");
}
function artifactNodeId(path) {
  return `artifact:${path}`;
}

// src/core/memory-reduce.ts
import { createHash } from "crypto";
function reduceEvents(events) {
  const byTarget = new Map;
  for (const e2 of events) {
    if (!e2.supersedes)
      continue;
    const arr = byTarget.get(e2.supersedes);
    if (arr)
      arr.push(e2);
    else
      byTarget.set(e2.supersedes, [e2]);
  }
  const memo = new Map;
  const effective = (e2) => {
    const cached = memo.get(e2.event_id);
    if (cached !== undefined)
      return cached;
    memo.set(e2.event_id, false);
    const result2 = e2.status === "approved" || (byTarget.get(e2.event_id) ?? []).some((f3) => effective(f3));
    memo.set(e2.event_id, result2);
    return result2;
  };
  const supersededIds = new Set;
  for (const e2 of events) {
    if (e2.supersedes && effective(e2))
      supersededIds.add(e2.supersedes);
  }
  const approvedHeads = events.filter((e2) => !supersededIds.has(e2.event_id) && e2.status === "approved").sort((a2, b2) => a2.event_id < b2.event_id ? -1 : a2.event_id > b2.event_id ? 1 : 0);
  const setHash = createHash("sha256").update(approvedHeads.map((e2) => e2.event_id).join(`
`)).digest("hex");
  return { approvedHeads, setHash };
}

// src/core/memory-project.ts
init_memory_scan();
init_memory_store();
var SCHEMA_VERSION = "0.1.0";
var SEMANTIC_RUN_ID = "xrun_decisions";
function projectionIdFor(key) {
  return `proj_${sha256Hex(key).slice(0, 12)}`;
}
function eventNodeId(eventId) {
  return `decision:${eventId}`;
}
function projectEventNodes(approved, secretSourceIds = new Set, codeSourcePaths = new Map) {
  const nodes = [];
  const edges = [];
  const sourceNodeIds = new Set;
  const artifactNodeIds = new Set;
  for (const e2 of approved) {
    if (e2.sensitivity === "secret")
      continue;
    const isDecision = e2.event_type === "decision";
    const nodeId = eventNodeId(e2.event_id);
    nodes.push({
      id: nodeId,
      node_type: isDecision ? "Decision" : "Episode",
      name: e2.text.slice(0, 120),
      properties: {
        event_id: e2.event_id,
        event_type: e2.event_type,
        decided_at: e2.decided_at ?? ""
      },
      provenance: {
        extraction_run_id: SEMANTIC_RUN_ID,
        extracted_by: "human",
        schema_version: SCHEMA_VERSION,
        ...e2.sources[0] ? { source_id: e2.sources[0] } : {}
      }
    });
    const edgeType = isDecision ? "RATIONALE_FOR" : "MENTIONS";
    for (const sourceId of e2.sources) {
      if (secretSourceIds.has(sourceId))
        continue;
      const sourceNodeId = `source:${sourceId}`;
      if (!sourceNodeIds.has(sourceNodeId)) {
        sourceNodeIds.add(sourceNodeId);
        nodes.push({
          id: sourceNodeId,
          node_type: "Source",
          name: sourceId,
          properties: {},
          provenance: {
            source_id: sourceId,
            extraction_run_id: SEMANTIC_RUN_ID,
            extracted_by: "human",
            schema_version: SCHEMA_VERSION
          }
        });
      }
      const edgeId = `${edgeType.toLowerCase()}:${sourceId}->${nodeId}`;
      edges.push({
        id: edgeId,
        from: sourceNodeId,
        to: nodeId,
        edge_type: edgeType,
        confidence_kind: "EXTRACTED",
        confidence_score: 1,
        properties: {},
        provenance: {
          source_id: sourceId,
          extraction_run_id: SEMANTIC_RUN_ID,
          extracted_by: "human",
          schema_version: SCHEMA_VERSION
        },
        weight: 1,
        requires_review: false,
        used_as_evidence: false
      });
      if (!isDecision) {
        const codePath = codeSourcePaths.get(sourceId);
        if (codePath !== undefined) {
          const artId = artifactNodeId(normalizePath(codePath));
          if (!artifactNodeIds.has(artId)) {
            artifactNodeIds.add(artId);
            nodes.push({
              id: artId,
              node_type: "Artifact",
              name: codePath,
              properties: {},
              provenance: {
                extraction_run_id: SEMANTIC_RUN_ID,
                extracted_by: "human",
                schema_version: SCHEMA_VERSION,
                source_id: sourceId
              }
            });
          }
          edges.push({
            id: `mentions:${artId}->${nodeId}`,
            from: nodeId,
            to: artId,
            edge_type: "MENTIONS",
            confidence_kind: "EXTRACTED",
            confidence_score: 1,
            properties: {},
            provenance: {
              extraction_run_id: SEMANTIC_RUN_ID,
              extracted_by: "human",
              schema_version: SCHEMA_VERSION,
              source_id: sourceId
            },
            weight: 1,
            requires_review: false,
            used_as_evidence: false
          });
        }
      }
    }
    if (isDecision) {
      for (const rawPath of e2.governs) {
        const artId = artifactNodeId(normalizePath(rawPath));
        const groundingSource = e2.sources[0];
        if (!artifactNodeIds.has(artId)) {
          artifactNodeIds.add(artId);
          nodes.push({
            id: artId,
            node_type: "Artifact",
            name: artId.slice("artifact:".length),
            properties: {},
            provenance: {
              extraction_run_id: SEMANTIC_RUN_ID,
              extracted_by: "human",
              schema_version: SCHEMA_VERSION,
              ...groundingSource ? { source_id: groundingSource } : {}
            }
          });
        }
        edges.push({
          id: `rationale_for:${artId}->${nodeId}`,
          from: artId,
          to: nodeId,
          edge_type: "RATIONALE_FOR",
          confidence_kind: "EXTRACTED",
          confidence_score: 1,
          properties: {},
          provenance: {
            extraction_run_id: SEMANTIC_RUN_ID,
            extracted_by: "human",
            schema_version: SCHEMA_VERSION,
            ...groundingSource ? { source_id: groundingSource } : {}
          },
          weight: 1,
          requires_review: false,
          used_as_evidence: false
        });
      }
    }
  }
  const byId = (a2, b2) => a2.id < b2.id ? -1 : a2.id > b2.id ? 1 : 0;
  return { nodes: nodes.sort(byId), edges: edges.sort(byId) };
}
function buildServingGraph(nodes, edges, meta) {
  const adjacency = {};
  for (const e2 of edges) {
    const bucket = adjacency[e2.from] ?? [];
    bucket.push({ to: e2.to, edge_type: e2.edge_type });
    adjacency[e2.from] = bucket;
  }
  for (const id of Object.keys(adjacency)) {
    adjacency[id]?.sort((a2, b2) => a2.to < b2.to ? -1 : a2.to > b2.to ? 1 : a2.edge_type < b2.edge_type ? -1 : 1);
  }
  return {
    projection_id: meta.projection_id,
    generated_at: meta.generated_at,
    nodes: [...nodes].sort((a2, b2) => a2.id < b2.id ? -1 : a2.id > b2.id ? 1 : 0).map((n2) => ({ id: n2.id, node_type: n2.node_type, name: n2.name })),
    adjacency
  };
}
function renderWiki(nodes, edges, meta) {
  const lines = [];
  lines.push("# Memory Graph (generated \u2014 do not edit)");
  lines.push("");
  lines.push(`> projection: ${meta.projection_id} \xB7 generated: ${meta.generated_at}`);
  lines.push("> One-way projection from graph-ir.json. Fix the source/extractor and regenerate.");
  lines.push("");
  lines.push(`## Nodes (${nodes.length})`);
  lines.push("");
  const outgoing = new Map;
  for (const e2 of edges) {
    const bucket = outgoing.get(e2.from);
    if (bucket)
      bucket.push(e2);
    else
      outgoing.set(e2.from, [e2]);
  }
  for (const n2 of [...nodes].sort((a2, b2) => a2.id < b2.id ? -1 : 1)) {
    lines.push(`### ${n2.name}`);
    lines.push(`- id: \`${n2.id}\``);
    lines.push(`- type: ${n2.node_type}`);
    const out = outgoing.get(n2.id) ?? [];
    if (out.length > 0) {
      lines.push("- edges:");
      for (const e2 of [...out].sort((a2, b2) => a2.to < b2.to ? -1 : 1)) {
        lines.push(`  - ${e2.edge_type} \u2192 \`${e2.to}\` (${e2.confidence_kind})`);
      }
    }
    lines.push("");
  }
  return `${lines.join(`
`)}
`;
}
async function projectMemory(repoRoot, options = {}) {
  const now = (options.now ?? new Date).toISOString();
  const ir = await new MemoryGraphIrStore(repoRoot).read();
  const events = await new MemoryEventStore(repoRoot).list();
  const sources = await new MemorySourceStore(repoRoot).list();
  const { approvedHeads, setHash } = reduceEvents(events);
  const secretSourceIds = new Set(sources.filter((s2) => s2.sensitivity === "secret").map((s2) => s2.source_id));
  const codeSourcePaths = new Map;
  for (const s2 of sources) {
    if (s2.source_type === "code" && s2.path)
      codeSourcePaths.set(s2.source_id, s2.path);
  }
  const eventGraph = projectEventNodes(approvedHeads, secretSourceIds, codeSourcePaths);
  const nodes = [...ir?.nodes ?? [], ...eventGraph.nodes];
  const edges = [...ir?.edges ?? [], ...eventGraph.edges];
  const projectionId = projectionIdFor(`${ir?.ir_version ?? "noir"}:${setHash}`);
  const serving = buildServingGraph(nodes, edges, {
    projection_id: projectionId,
    generated_at: now
  });
  const wiki = renderWiki(nodes, edges, { projection_id: projectionId, generated_at: now });
  const sourceRevisions = [...sources].sort((a2, b2) => a2.source_id < b2.source_id ? -1 : 1).map((s2) => ({
    source_id: s2.source_id,
    ...s2.path ? { path: s2.path } : {},
    hash: s2.content_hash,
    revision: s2.revision,
    ...s2.git_commit ? { git_commit: s2.git_commit } : {}
  }));
  const manifest = {
    schema_version: SCHEMA_VERSION,
    projection_id: projectionId,
    generated_at: now,
    graph_ir_version: ir?.ir_version ?? "ir_empty",
    serving_version: setHash,
    extractor_versions: {},
    source_revisions: sourceRevisions,
    ...approvedHeads.length > 0 ? { memory_event_until: approvedHeads[approvedHeads.length - 1]?.event_id } : {},
    dirty_sources: []
  };
  const store = new MemoryProjectionStore(repoRoot);
  await store.writeServing(serving);
  await store.writeWiki("index.md", wiki);
  await store.writeManifest(manifest);
  return {
    manifest,
    serving,
    set_hash: setHash,
    node_count: nodes.length,
    edge_count: edges.length
  };
}

class MemoryEventNotPendingError extends Error {
  eventId;
  status;
  constructor(eventId, status) {
    super(`event ${eventId} is not pending (status=${status}); only pending events can be approved`);
    this.eventId = eventId;
    this.status = status;
    this.name = "MemoryEventNotPendingError";
  }
}

class MemoryEventAlreadyDecidedError extends Error {
  eventId;
  decidedBy;
  constructor(eventId, decidedBy) {
    super(`event ${eventId} is already decided by ${decidedBy}; it cannot be approved or rejected again`);
    this.eventId = eventId;
    this.decidedBy = decidedBy;
    this.name = "MemoryEventAlreadyDecidedError";
  }
}

class MemorySelfApprovalError extends Error {
  eventId;
  constructor(eventId) {
    super(`event ${eventId} was proposed by an agent; it requires approval by a user`);
    this.eventId = eventId;
    this.name = "MemorySelfApprovalError";
  }
}
async function proposeEvent(repoRoot, input, options = {}) {
  const now = (options.now ?? new Date).toISOString();
  const store = new MemoryEventStore(repoRoot);
  const eventId = await generateId("memevt", (candidate) => store.get(candidate).then(() => true, () => false));
  const actor = input.actor ?? { kind: "agent" };
  const requestedKind = input.confidence_kind ?? "EXTRACTED";
  const confidenceKind = actor.kind === "agent" && requestedKind === "EXTRACTED" ? "INFERRED" : requestedKind;
  const draft = memoryEvent.parse({
    schema_version: "0.1.0",
    event_id: eventId,
    event_type: input.event_type,
    actor,
    text: input.text,
    created_at: now,
    status: "pending",
    sources: input.sources ?? [],
    confidence_kind: confidenceKind,
    sensitivity: input.sensitivity ?? "internal"
  });
  return store.append(draft);
}
async function approveEvent(repoRoot, eventId, options) {
  const store = new MemoryEventStore(repoRoot);
  const original = await store.get(eventId);
  if (original.status !== "pending") {
    throw new MemoryEventNotPendingError(eventId, original.status);
  }
  const existing = await store.list();
  const priorDecision = existing.find((e2) => e2.supersedes === eventId);
  if (priorDecision) {
    throw new MemoryEventAlreadyDecidedError(eventId, priorDecision.event_id);
  }
  const approverKind = options.approverKind ?? "agent";
  if (original.actor.kind === "agent" && approverKind === "agent") {
    throw new MemorySelfApprovalError(eventId);
  }
  const now = (options.now ?? new Date).toISOString();
  const decisionId = await generateId("memevt", (candidate) => store.get(candidate).then(() => true, () => false));
  const decision = memoryEvent.parse({
    ...original,
    event_id: decisionId,
    created_at: now,
    status: options.reject ? "rejected" : "approved",
    approved_by: options.by,
    decided_at: now,
    supersedes: original.event_id
  });
  const written = await store.append(decision);
  const projection = await projectMemory(repoRoot, options.now ? { now: options.now } : {});
  return { decision: written, projection };
}
function countUndecidedPending(events) {
  const superseded = new Set;
  for (const e2 of events) {
    if (e2.supersedes)
      superseded.add(e2.supersedes);
  }
  return events.filter((e2) => e2.status === "pending" && !superseded.has(e2.event_id)).length;
}
function headOf(repo) {
  try {
    const sha = gitRevParse(repo, "HEAD");
    return /^[a-f0-9]{40}$/.test(sha) ? sha : null;
  } catch {
    return null;
  }
}
function isRepoDirty(repo, isRoot) {
  const changed = listChangedFiles(repo);
  const relevant = isRoot ? changed.filter((p) => !p.startsWith(".ditto/")) : changed;
  return relevant.length > 0;
}
async function detectAxis2(repoRoot, revisions, currentHash) {
  const root = resolve4(repoRoot);
  const owningRepoOf = new Map;
  const sourcesByRepo = new Map;
  const nonGit = [];
  for (const r3 of revisions) {
    if (!r3.git_commit) {
      nonGit.push(r3);
      continue;
    }
    const owner = r3.path ? await findOwningRepo(resolve4(root, r3.path), root) ?? root : root;
    const key = resolve4(owner);
    owningRepoOf.set(r3.source_id, key);
    const bucket = sourcesByRepo.get(key) ?? [];
    bucket.push(r3);
    sourcesByRepo.set(key, bucket);
  }
  const driftedRepos = new Set;
  const driftedSources = new Set;
  let sawDrift = false;
  let sawDirty = false;
  for (const [repo, revs] of sourcesByRepo) {
    const isRoot = repo === root;
    const head = headOf(repo);
    const drift = head !== null && revs.some((r3) => r3.git_commit !== head);
    const dirty = isRepoDirty(repo, isRoot);
    if (!drift && !dirty)
      continue;
    if (drift)
      sawDrift = true;
    if (dirty)
      sawDirty = true;
    driftedRepos.add(repo);
    for (const r3 of revs)
      driftedSources.add(r3.source_id);
  }
  for (const r3 of nonGit) {
    const now = currentHash.get(r3.source_id);
    if (now !== undefined && now !== r3.hash)
      driftedSources.add(r3.source_id);
  }
  const driftedRepoPaths = [...driftedRepos].map((abs) => abs === root ? "." : relativeFromRoot(root, abs)).sort();
  return {
    freshness: sawDrift ? "code_drift" : sawDirty ? "code_dirty" : null,
    drifted_repos: driftedRepoPaths,
    drifted_sources: [...driftedSources].sort()
  };
}
function relativeFromRoot(root, abs) {
  const rel = abs.startsWith(`${root}/`) ? abs.slice(root.length + 1) : abs;
  return rel || ".";
}
async function memoryStatus(repoRoot) {
  const events = await new MemoryEventStore(repoRoot).list();
  const { setHash: currentSetHash } = reduceEvents(events);
  const pendingCount = countUndecidedPending(events);
  const manifest = await new MemoryProjectionStore(repoRoot).readManifest();
  if (!manifest) {
    return {
      freshness: "absent",
      dirty_sources: [],
      drifted_repos: [],
      drifted_sources: [],
      pending_count: pendingCount,
      current_set_hash: currentSetHash
    };
  }
  const sources = await new MemorySourceStore(repoRoot).list();
  const recordedHash = new Map;
  for (const r3 of manifest.source_revisions)
    recordedHash.set(r3.source_id, r3.hash);
  const currentHash = new Map;
  for (const s2 of sources)
    currentHash.set(s2.source_id, s2.content_hash);
  const dirty = [];
  for (const s2 of sources) {
    const recorded = recordedHash.get(s2.source_id);
    if (recorded === undefined || recorded !== s2.content_hash)
      dirty.push(s2.source_id);
  }
  dirty.sort();
  const axis2 = await detectAxis2(repoRoot, manifest.source_revisions, currentHash);
  const eventSetStale = manifest.serving_version !== currentSetHash;
  const axis1Stale = eventSetStale || dirty.length > 0;
  const freshness2 = axis2.freshness === "code_drift" ? "code_drift" : axis1Stale ? "stale" : axis2.freshness === "code_dirty" ? "code_dirty" : "fresh";
  return {
    freshness: freshness2,
    dirty_sources: dirty,
    drifted_repos: axis2.drifted_repos,
    drifted_sources: axis2.drifted_sources,
    pending_count: pendingCount,
    current_set_hash: currentSetHash,
    ...manifest.serving_version !== undefined ? { recorded_set_hash: manifest.serving_version } : {},
    projection_id: manifest.projection_id,
    generated_at: manifest.generated_at
  };
}

// src/core/memory-query.ts
import { appendFile, readFile } from "fs/promises";
import { basename, dirname as dirname6, isAbsolute as isAbsolute2, join as join23 } from "path";
init_ditto_paths();
init_fs();

// src/core/memory-measure.ts
var REJECTED_HEADING = /^##\s*\uB300\uC548/;
var HEADING = /^##\s/;
var BULLET = /^\s*[-*]\s+/;
var INVARIANT_KEYWORD = /\uBD88\uBCC0\uC2DD|invariant/i;
var RELATED_LINE = /^[-*\s]*\uAD00\uB828\s*:/;
function extractRejectedAlternatives(adrBody) {
  const items = [];
  let capturing = false;
  for (const raw of adrBody.split(`
`)) {
    if (HEADING.test(raw)) {
      capturing = REJECTED_HEADING.test(raw);
      continue;
    }
    if (!capturing)
      continue;
    if (BULLET.test(raw)) {
      items.push(raw.replace(BULLET, "").trim());
    } else if (raw.trim().length > 0 && items.length > 0) {
      items[items.length - 1] = `${items[items.length - 1]} ${raw.trim()}`;
    }
  }
  return items.filter((i2) => i2.length > 0);
}
function extractInvariants(adrBody) {
  return adrBody.split(`
`).map((l2) => l2.trim()).filter((l2) => l2.length > 0 && !l2.startsWith("#") && !RELATED_LINE.test(l2) && INVARIANT_KEYWORD.test(l2));
}
function salientTokens(item) {
  const bold = item.match(/\*\*(.+?)\*\*/);
  const lead = bold?.[1] ?? item;
  const tokens = new Set;
  for (const m2 of lead.matchAll(/\(([^)]+)\)/g)) {
    for (const t2 of (m2[1] ?? "").split(/[\s,/]+/)) {
      if (t2.length >= 3)
        tokens.add(t2.toLowerCase());
    }
  }
  for (const m2 of lead.matchAll(/[A-Za-z][A-Za-z0-9]{3,}/g)) {
    tokens.add(m2[0].toLowerCase());
  }
  return [...tokens];
}
function measureHallucination(adrs, candidates) {
  const without = [];
  let rejectedTotal = 0;
  let invariantsTotal = 0;
  let withSection = 0;
  const lowerCandidates = candidates.map((c3) => c3.toLowerCase());
  const hits = [];
  for (const adr of adrs) {
    const rejected = extractRejectedAlternatives(adr.body);
    invariantsTotal += extractInvariants(adr.body).length;
    if (rejected.length === 0) {
      without.push(adr.id);
    } else {
      withSection += 1;
      rejectedTotal += rejected.length;
      for (const item of rejected) {
        const tokens = salientTokens(item);
        for (let ci = 0;ci < lowerCandidates.length; ci += 1) {
          const matched = tokens.find((t2) => lowerCandidates[ci]?.includes(t2));
          if (matched) {
            hits.push({ adr_id: adr.id, item, matched_token: matched, candidate_index: ci });
            break;
          }
        }
      }
    }
  }
  const detected = hits.length;
  return {
    adrs_total: adrs.length,
    adrs_with_rejected_section: withSection,
    adrs_without_rejected_section: without,
    rejected_alternatives_total: rejectedTotal,
    invariants_total: invariantsTotal,
    candidates_total: candidates.length,
    reproposals_detected: detected,
    reproposal_rate: rejectedTotal === 0 ? 0 : detected / rejectedTotal,
    reproposal_hits: hits,
    invariant_violations_computed: false
  };
}

// src/core/memory-query.ts
init_memory_store();

class MemoryProjectionAbsentError extends Error {
  constructor() {
    super("no serving graph projected yet; run `ditto memory project` first");
    this.name = "MemoryProjectionAbsentError";
  }
}

class MemoryNodeNotFoundError extends Error {
  nodeId;
  constructor(nodeId) {
    super(`node "${nodeId}" not found in the serving graph`);
    this.nodeId = nodeId;
    this.name = "MemoryNodeNotFoundError";
  }
}
async function readFreshness(repoRoot) {
  const status = await memoryStatus(repoRoot);
  return {
    projection_id: status.projection_id ?? "",
    generated_at: status.generated_at ?? "",
    freshness: status.freshness,
    dirty_sources: status.dirty_sources,
    drifted_repos: status.drifted_repos,
    drifted_sources: status.drifted_sources
  };
}
function pullUsageLogPath(repoRoot) {
  return localDir(repoRoot, "memory", "pull-usage.jsonl");
}
async function recordPullQuery(repoRoot, record) {
  const path = pullUsageLogPath(repoRoot);
  await ensureDir(dirname6(path));
  await appendFile(path, `${JSON.stringify(record)}
`, "utf8");
}
async function readPullUsage(repoRoot) {
  const path = pullUsageLogPath(repoRoot);
  if (!await Bun.file(path).exists())
    return [];
  const text = await Bun.file(path).text();
  return text.split(`
`).filter((line) => line.trim().length > 0).map((line) => JSON.parse(line));
}
function neighborsOf(graph, id) {
  const out = [];
  for (const e2 of graph.adjacency[id] ?? []) {
    out.push({ to: e2.to, edge_type: e2.edge_type, direction: "out" });
  }
  for (const [from, edges] of Object.entries(graph.adjacency)) {
    for (const e2 of edges) {
      if (e2.to === id)
        out.push({ to: from, edge_type: e2.edge_type, direction: "in" });
    }
  }
  return out;
}
function queryNeighbors(graph, node2, depth) {
  const present = new Set(graph.nodes.map((n2) => n2.id));
  if (!present.has(node2))
    throw new MemoryNodeNotFoundError(node2);
  const seen = new Set([node2]);
  let frontier = [node2];
  for (let hop = 0;hop < depth; hop++) {
    const next = [];
    for (const id of frontier) {
      for (const nb of neighborsOf(graph, id)) {
        if (!seen.has(nb.to)) {
          seen.add(nb.to);
          next.push(nb.to);
        }
      }
    }
    frontier = next;
    if (frontier.length === 0)
      break;
  }
  seen.delete(node2);
  return { root: node2, depth, neighbors: [...seen].sort() };
}
function bodyTokens(s2) {
  return new Set(s2.toLowerCase().split(/[^a-z0-9\uAC00-\uD7A3]+/).filter((t2) => t2.length >= 3));
}
function searchEventBodies(query, events) {
  const q2 = query.trim().toLowerCase();
  if (q2.length === 0)
    return [];
  const qTokens = bodyTokens(query);
  const out = [];
  for (const e2 of events) {
    const body = e2.text.toLowerCase();
    let hit = body.includes(q2);
    if (!hit) {
      const bTokens = bodyTokens(e2.text);
      for (const t2 of qTokens) {
        if (bTokens.has(t2)) {
          hit = true;
          break;
        }
      }
    }
    if (hit)
      out.push({ source_id: e2.sources[0] ?? "", event_id: e2.event_id });
  }
  return out;
}
async function queryBodies(repoRoot, query) {
  const events = await new MemoryEventStore(repoRoot).list();
  const visible = reduceEvents(events).approvedHeads.filter((e2) => e2.sensitivity !== "secret");
  const matches = searchEventBodies(query, visible);
  const freshness2 = await readFreshness(repoRoot);
  return { query, matches, ...freshness2 };
}
function symbolFilePath(symbolId) {
  const bare = symbolId.startsWith("symbol:") ? symbolId.slice("symbol:".length) : symbolId;
  const hashIdx = bare.indexOf("#");
  return hashIdx === -1 ? { path: bare, name: bare } : { path: bare.slice(0, hashIdx), name: bare.slice(hashIdx + 1) };
}
function stripExt(path) {
  return path.replace(/\.[cm]?[jt]sx?$/, "").replace(/\.(java|kt|py)$/, "");
}
function assembleSymbolBrief(symbolId, decisions) {
  const { path } = symbolFilePath(symbolId);
  const file = stripExt(path);
  const items = [];
  const rejected = [];
  const invariants = [];
  const adrs = [];
  for (const d2 of decisions) {
    const cited = d2.governs.some((g3) => {
      const gn = stripExt(g3);
      return gn.includes("*") ? globToRegExp(gn).test(file) : gn === file;
    });
    const mentioned = !cited && d2.body.includes(path);
    if (!cited && !mentioned)
      continue;
    adrs.push(d2.adr_id);
    items.push({
      adr_id: d2.adr_id,
      tag: cited ? "EXTRACTED" : "INFERRED",
      coverage: cited ? "cite" : "fallback"
    });
    rejected.push(...extractRejectedAlternatives(d2.body));
    invariants.push(...extractInvariants(d2.body));
  }
  const coverage = items.some((i2) => i2.coverage === "cite") ? "cite" : items.length > 0 ? "fallback" : "\uBBF8\uBC1C\uACAC";
  return {
    symbol: symbolId,
    governing_adrs: adrs,
    rejected_alternatives: rejected,
    invariants,
    items,
    coverage
  };
}
async function loadGoverningDecisions(repoRoot) {
  const events = await new MemoryEventStore(repoRoot).list();
  const approved = reduceEvents(events).approvedHeads.filter((e2) => e2.sensitivity !== "secret");
  const sources = await new MemorySourceStore(repoRoot).list();
  const pathOf = new Map(sources.map((s2) => [s2.source_id, s2.path]));
  const byNodeId = new Map;
  for (const e2 of approved) {
    if (e2.event_type !== "decision")
      continue;
    const sourceId = e2.sources[0];
    const rel = sourceId ? pathOf.get(sourceId) : undefined;
    let body = e2.text;
    if (rel) {
      try {
        body = await readFile(isAbsolute2(rel) ? rel : join23(repoRoot, rel), "utf8");
      } catch {}
    }
    byNodeId.set(`decision:${e2.event_id}`, {
      adr_id: rel ? basename(rel) : e2.event_id,
      body,
      governs: e2.governs
    });
  }
  return byNodeId;
}
async function querySymbolBrief(repoRoot, symbolId) {
  const decisions = [...(await loadGoverningDecisions(repoRoot)).values()];
  const brief = assembleSymbolBrief(symbolId, decisions);
  const freshness2 = await readFreshness(repoRoot);
  return { ...brief, ...freshness2 };
}
async function queryDecisionBriefs(repoRoot, decisionNodeIds) {
  const byNodeId = await loadGoverningDecisions(repoRoot);
  return decisionNodeIds.map(({ id, summary }) => {
    const decision = byNodeId.get(id);
    if (!decision) {
      return {
        id,
        summary,
        rejected_alternatives: [],
        invariants: [],
        tag: "\uBBF8\uBC1C\uACAC",
        coverage: "\uBBF8\uBC1C\uACAC"
      };
    }
    const symbolKey = `symbol:${decision.governs[0] ?? id}#${id}`;
    const brief = assembleSymbolBrief(symbolKey, [decision]);
    return {
      id,
      summary,
      rejected_alternatives: brief.rejected_alternatives,
      invariants: brief.invariants,
      tag: brief.items[0]?.tag ?? "\uBBF8\uBC1C\uACAC",
      coverage: brief.coverage
    };
  });
}
function shortestPath(graph, from, to) {
  const present = new Set(graph.nodes.map((n2) => n2.id));
  if (!present.has(from))
    throw new MemoryNodeNotFoundError(from);
  if (!present.has(to))
    throw new MemoryNodeNotFoundError(to);
  if (from === to)
    return { from, to, path: [from] };
  const prev = new Map;
  const visited = new Set([from]);
  const queue2 = [from];
  while (queue2.length > 0) {
    const cur = queue2.shift();
    for (const nb of neighborsOf(graph, cur)) {
      if (visited.has(nb.to))
        continue;
      visited.add(nb.to);
      prev.set(nb.to, cur);
      if (nb.to === to) {
        const path = [to];
        let step = to;
        while (step !== from) {
          step = prev.get(step);
          path.push(step);
        }
        return { from, to, path: path.reverse() };
      }
      queue2.push(nb.to);
    }
  }
  return { from, to, path: null };
}
function explainNode(graph, node2) {
  const found = graph.nodes.find((n2) => n2.id === node2);
  if (!found)
    throw new MemoryNodeNotFoundError(node2);
  const edges = neighborsOf(graph, node2).sort((a2, b2) => a2.to < b2.to ? -1 : a2.to > b2.to ? 1 : a2.edge_type < b2.edge_type ? -1 : 1);
  return { node: { id: found.id, node_type: found.node_type, name: found.name }, edges };
}
function auditCounts(graph, dirtySources) {
  const referenced = new Set;
  const seenEdges = new Set;
  let duplicate = 0;
  let contradiction = 0;
  for (const [from, edges] of Object.entries(graph.adjacency)) {
    for (const e2 of edges) {
      referenced.add(from);
      referenced.add(e2.to);
      const key = `${from}\x00${e2.to}\x00${e2.edge_type}`;
      if (seenEdges.has(key))
        duplicate++;
      else
        seenEdges.add(key);
      if (e2.edge_type === "CONTRADICTS")
        contradiction++;
    }
  }
  let orphan = 0;
  for (const n2 of graph.nodes) {
    if (!referenced.has(n2.id))
      orphan++;
  }
  return { orphan, stale: dirtySources.length, duplicate, contradiction };
}

class MemoryAuditLogStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  path() {
    return join23(dittoDir(this.repoRoot), "memory", "audit-log.jsonl");
  }
  async append(entry) {
    const p = this.path();
    await ensureDir(dirname6(p));
    await appendFile(p, `${JSON.stringify(entry)}
`, "utf8");
  }
  async list() {
    const p = this.path();
    if (!await Bun.file(p).exists())
      return [];
    const text = await Bun.file(p).text();
    return text.split(`
`).filter((line) => line.trim().length > 0).map((line) => JSON.parse(line));
  }
}
async function runAudit(repoRoot, options = {}) {
  const graph = await new MemoryProjectionStore(repoRoot).readServing();
  if (!graph)
    throw new MemoryProjectionAbsentError;
  const fresh = await readFreshness(repoRoot);
  let edgeCount = 0;
  for (const edges of Object.values(graph.adjacency))
    edgeCount += edges.length;
  const entry = {
    audited_at: (options.now ?? new Date).toISOString(),
    projection_id: fresh.projection_id,
    freshness: fresh.freshness,
    node_count: graph.nodes.length,
    edge_count: edgeCount,
    counts: auditCounts(graph, fresh.dirty_sources)
  };
  const store = new MemoryAuditLogStore(repoRoot);
  await store.append(entry);
  const history = await store.list();
  return { entry, history_length: history.length };
}

// src/core/memory-warmstart.ts
init_memory_store();
function isWarmStartOwner(owner) {
  return owner === "researcher" || owner === "planner";
}
function warmStartEnabled() {
  return isMemoryEnabled() && process.env.DITTO_MEMORY_WARMSTART !== "0";
}
var RELATED_NODE_CAP = 8;
function tokensOf(text) {
  return (text.toLowerCase().match(/[a-z0-9]+/g) ?? []).filter((t2) => t2.length >= 4);
}
function coverageRoots(graph, workItem2) {
  const want = new Set([...tokensOf(workItem2.title), ...tokensOf(workItem2.goal)]);
  if (want.size === 0)
    return [];
  const roots = [];
  for (const n2 of graph.nodes) {
    const have = new Set([...tokensOf(n2.id), ...tokensOf(n2.name)]);
    if ([...have].some((t2) => want.has(t2)))
      roots.push(n2.id);
  }
  return roots.sort();
}
async function recordUsage(repoRoot, record) {
  const path = usageLogPath(repoRoot, record.work_item_id);
  await ensureDir(dirname7(path));
  await appendFile2(path, `${JSON.stringify(record)}
`, "utf8");
}
function usageLogPath(repoRoot, workItemId2) {
  return localDir(repoRoot, "work-items", workItemId2, "memory", "warmstart-usage.jsonl");
}
async function readUsageReport(repoRoot, workItemId2) {
  const path = usageLogPath(repoRoot, workItemId2);
  let records = [];
  if (await Bun.file(path).exists()) {
    const text = await Bun.file(path).text();
    records = text.split(`
`).filter((line) => line.trim().length > 0).map((line) => JSON.parse(line));
  }
  const hitNodeTypes = {};
  for (const r3 of records) {
    for (const [t2, n2] of Object.entries(r3.hit_node_types ?? {})) {
      hitNodeTypes[t2] = (hitNodeTypes[t2] ?? 0) + n2;
    }
  }
  return {
    opportunities: records.filter((r3) => r3.opportunity).length,
    attempts: records.filter((r3) => r3.attempt).length,
    hits: records.filter((r3) => r3.hit).length,
    actionable: records.filter((r3) => r3.actionable).length,
    hit_node_types: hitNodeTypes,
    records
  };
}
async function warmStartMemoryContext(repoRoot, node2, workItem2, options = {}) {
  if (!isWarmStartOwner(node2.owner) || !warmStartEnabled())
    return;
  const now = (options.now ?? new Date).toISOString();
  const base = {
    ts: now,
    work_item_id: workItem2.id,
    node_id: node2.id,
    owner: node2.owner,
    opportunity: true,
    attempt: false,
    hit: false,
    actionable: false
  };
  try {
    const status = await memoryStatus(repoRoot);
    base.freshness = status.freshness;
    if (status.freshness !== "fresh" && status.freshness !== "code_dirty") {
      await recordUsage(repoRoot, base);
      return;
    }
    const graph = await new MemoryProjectionStore(repoRoot).readServing();
    if (!graph || graph.nodes.length === 0) {
      await recordUsage(repoRoot, base);
      return;
    }
    const roots = coverageRoots(graph, workItem2);
    if (roots.length === 0) {
      await recordUsage(repoRoot, base);
      return;
    }
    base.attempt = true;
    const related = new Set;
    for (const root of roots) {
      related.add(root);
      for (const nb of queryNeighbors(graph, root, 2).neighbors)
        related.add(nb);
    }
    const relatedNodes = [...related].sort().slice(0, RELATED_NODE_CAP);
    if (relatedNodes.length === 0) {
      await recordUsage(repoRoot, base);
      return;
    }
    base.hit = true;
    const typeOf = new Map(graph.nodes.map((n2) => [n2.id, n2.node_type]));
    const hitTypes = {};
    for (const id of relatedNodes) {
      const t2 = typeOf.get(id) ?? "unknown";
      hitTypes[t2] = (hitTypes[t2] ?? 0) + 1;
    }
    base.hit_node_types = hitTypes;
    const decisionIds = new Set(graph.nodes.filter((n2) => n2.node_type === "Decision").map((n2) => n2.id));
    const decisions = relatedNodes.filter((id) => decisionIds.has(id));
    const nameOf = new Map(graph.nodes.map((n2) => [n2.id, n2.name]));
    const decisionBriefs = await queryDecisionBriefs(repoRoot, decisions.map((id) => ({ id, summary: nameOf.get(id) ?? id })));
    base.actionable = true;
    await recordUsage(repoRoot, base);
    return {
      related_nodes: relatedNodes,
      ...decisions.length > 0 ? { decisions } : {},
      ...decisionBriefs.length > 0 ? { decision_briefs: decisionBriefs } : {}
    };
  } catch {
    try {
      await recordUsage(repoRoot, base);
    } catch {}
    return;
  }
}

