async function readDiscoveryInput(file) {
  if (file) {
    const f3 = Bun.file(file);
    if (!await f3.exists())
      throw new Error(`candidate file not found: ${file}`);
    return f3.text();
  }
  if (process.stdin.isTTY) {
    throw new Error("coverage discover requires --file <candidates.json> or candidates piped on stdin");
  }
  return Bun.stdin.text();
}
function parseDiscoveryCandidates(text) {
  const raw = JSON.parse(text);
  const list = Array.isArray(raw) ? raw : Array.isArray(raw?.candidates) ? raw.candidates : null;
  if (!list)
    throw new Error('expected a JSON array of candidates or { "candidates": [...] }');
  return list.map((c3, i2) => {
    if (typeof c3 !== "object" || c3 === null)
      throw new Error(`candidate[${i2}] must be an object`);
    const { id, lens, evidence } = c3;
    if (typeof id !== "string" || id.trim().length === 0)
      throw new Error(`candidate[${i2}] needs a non-empty string 'id'`);
    if (typeof lens !== "string" || lens.trim().length === 0)
      throw new Error(`candidate[${i2}] needs a non-empty string 'lens'`);
    if (typeof evidence !== "string" || evidence.trim().length === 0)
      throw new Error(`candidate[${i2}] needs a non-empty string 'evidence'`);
    return { id, lens, evidence };
  });
}
var coverageTaxonomyDiscoverCommand = defineCommand({
  meta: {
    name: "discover",
    description: "Gate host-produced candidate far-field categories (grounded + gap-only) and, with --confirm, add the admits (ac-5/ac-6/ac-7)"
