var changeMapCommand = defineCommand({
  meta: {
    name: "change-map",
    description: "Render the Change Map text notation for a work item (50-change-map \xA72.1)"
  },
  args: {
    "work-item": { type: "string", description: "Work item id", required: true },
    output: {
      type: "string",
      description: "Output format: human|json|mermaid",
      default: "human"
    }
  },
  run: async ({ args }) => {
    const isMermaid = args.output === "mermaid";
    let format = "human";
    if (!isMermaid) {
      try {
        format = parseOutputFormat(args.output);
      } catch (err) {
        writeError(err instanceof Error ? err.message : String(err));
        process.exit(USAGE_ERROR_EXIT);
        return;
      }
    }
    const repoRoot = await resolveRepoRootForCreate();
    const workItem2 = args["work-item"];
    const contract = await new ChangeContractStore(repoRoot).read(workItem2);
    if (!contract) {
      writeError(`change-map: change-contract.json not found for ${workItem2}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let impact;
    try {
      impact = await readJson(localDir(repoRoot, "work-items", workItem2, "impact-graph.json"), acgImpactGraph);
    } catch {
      impact = undefined;
    }
    const reviewStore = new AcgReviewStore(repoRoot);
    const review = await reviewStore.exists(workItem2) ? await reviewStore.get(workItem2) : undefined;
    if (isMermaid) {
      writeHuman(renderMermaid(contract, impact, review));
    } else if (format === "json") {
      writeJson2(summarize(contract, impact, review));
    } else {
      writeHuman(render(contract, impact, review));
    }
  }
});

// src/cli/commands/classify.ts
import { isAbsolute as isAbsolute9, join as join51 } from "path";

// src/core/cleanup-scan.ts
init_cleanup_store();
init_memory_scan();
import { readdir as readdir18, stat as stat8 } from "fs/promises";
import { isAbsolute as isAbsolute8, join as join50, relative as relative14, resolve as resolve12 } from "path";
var SKIP_DIRS3 = new Set([
  "node_modules",
  ".git",
  ".ditto",
  "target",
  "build",
  "dist",
  ".gradle",
  "out",
  "coverage"
]);
var DOC_EXTS = new Set([".md", ".mdx", ".txt", ".rst", ".adoc"]);
function isDocFile(name) {
  const dot = name.lastIndexOf(".");
  if (dot < 0)
    return false;
  return DOC_EXTS.has(name.slice(dot).toLowerCase());
}
async function walkDocs(root, maxDepth = 12) {
  const out = [];
  async function walk(dir, depth) {
    if (depth > maxDepth)
      return;
    let entries;
    try {
      entries = await readdir18(dir, { withFileTypes: true });
    } catch {
      return;
    }
    for (const e2 of entries) {
      const full = join50(dir, e2.name);
      if (e2.isDirectory()) {
        if (!SKIP_DIRS3.has(e2.name))
          await walk(full, depth + 1);
      } else if (e2.isFile() && isDocFile(e2.name)) {
        out.push(full);
      }
    }
  }
  await walk(resolve12(root), 0);
  out.sort();
  return out;
}
function trackedPaths(repoRoot) {
  const proc = Bun.spawnSync(["git", "ls-files"], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (proc.exitCode !== 0)
    return new Set;
  return new Set((proc.stdout?.toString() ?? "").split(`
`).map((l2) => l2.trim()).filter((l2) => l2.length > 0));
}
function docsTouchedByCommits(repoRoot, commits) {
  const out = new Set;
  for (const c3 of commits) {
    const proc = Bun.spawnSync(["git", "show", "--name-only", "--pretty=format:", c3], {
      cwd: repoRoot,
      stdout: "pipe",
      stderr: "pipe"
    });
    if (proc.exitCode !== 0)
      continue;
    for (const l2 of (proc.stdout?.toString() ?? "").split(`
`)) {
      const p = l2.trim();
      if (p.length > 0)
        out.add(p);
    }
  }
  return out;
}
function lastCommitTouchingMs(repoRoot, pathspec) {
  const proc = Bun.spawnSync(["git", "log", "-1", "--format=%ct", "--", pathspec], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (proc.exitCode !== 0)
    return null;
  const secs = Number((proc.stdout?.toString() ?? "").trim());
  return Number.isFinite(secs) && secs > 0 ? secs * 1000 : null;
}
function hasInboundReference(repoRoot, repoRel) {
  const base = repoRel.split("/").pop() ?? repoRel;
  const proc = Bun.spawnSync(["git", "grep", "-F", "-l", "-I", "--", base], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (proc.exitCode !== 0)
    return false;
  const hits = (proc.stdout?.toString() ?? "").split(`
`).map((l2) => l2.trim()).filter((l2) => l2.length > 0 && l2 !== repoRel);
  return hits.length > 0;
}
async function scanCandidates(repoRoot, options) {
  const root = resolve12(repoRoot);
  const absFiles = await walkDocs(root);
  const tracked = trackedPaths(root);
  const scopeCommitDocs = options.scopeCommits && options.scopeCommits.length > 0 ? docsTouchedByCommits(root, options.scopeCommits) : null;
  const candidates = [];
  const excludedProtected = [];
  for (const abs of absFiles) {
    const repoRel = relative14(root, abs).replace(/\\/g, "/");
    if (repoRel.startsWith("..") || isAbsolute8(repoRel))
      continue;
    if (isProtectedPath(repoRel)) {
      excludedProtected.push(repoRel);
      continue;
    }
    const isTracked = tracked.has(repoRel);
    if (options.trackedFilter === "tracked-only" && !isTracked)
      continue;
    if (options.trackedFilter === "untracked-only" && isTracked)
      continue;
    if (options.scopeGlob && !matchesGlob2(repoRel, options.scopeGlob))
      continue;
    if (scopeCommitDocs && !scopeCommitDocs.has(repoRel))
      continue;
    const owning = await findOwningRepo(abs, root);
    const owningRepo = owning === null ? null : relative14(root, owning).replace(/\\/g, "/") || ".";
    const signals = [];
    if (!hasInboundReference(root, repoRel)) {
      signals.push({ kind: "orphan", detail: `no inbound reference to ${repoRel}` });
    }
    const docMtimeMs = (await stat8(abs)).mtimeMs;
    const lastCommitMs = lastCommitTouchingMs(root, repoRel);
    if (lastCommitMs !== null && docMtimeMs < lastCommitMs) {
      signals.push({
        kind: "stale",
        detail: `doc mtime older than its most recent commit (${new Date(lastCommitMs).toISOString()})`
      });
    }
    candidates.push({ path: repoRel, owning_repo: owningRepo, tracked: isTracked, signals });
  }
  return { candidates, excluded_protected: excludedProtected };
}
function matchesGlob2(repoRel, glob) {
  const re = globToRegExp3(glob);
  return re.test(repoRel);
}
function globToRegExp3(glob) {
  let out = "";
  for (let i2 = 0;i2 < glob.length; i2++) {
    const c3 = glob[i2];
    if (c3 === "*") {
      if (glob[i2 + 1] === "*") {
        out += ".*";
        i2++;
      } else {
        out += "[^/]*";
      }
    } else if (c3 === "?") {
      out += "[^/]";
    } else if (".+^${}()|[]\\".includes(c3)) {
      out += `\\${c3}`;
    } else {
      out += c3;
    }
  }
  return new RegExp(`^${out}$`);
}

// src/cli/commands/classify.ts
init_cleanup_store();
init_fs();
init_cleanup_index();
var AUTO_ARCHIVE_ACTIONS = ["quarantine", "absorb-then-discard"];

class AutoCleanupDeleteRefusedError extends Error {
  constructor(action) {
    super(`auto-cleanup path refuses action "${action}": auto/autopilot runs can only archive, never delete (ac-6 fail-closed)`);
    this.name = "AutoCleanupDeleteRefusedError";
  }
}
function autoChainArchiveAction(action) {
  if (AUTO_ARCHIVE_ACTIONS.includes(action)) {
    return action;
  }
  throw new AutoCleanupDeleteRefusedError(action);
}
function parseFormatOrExit(output) {
  try {
    return parseOutputFormat(output);
  } catch (err) {
    writeError(err instanceof Error ? err.message : String(err));
    process.exit(USAGE_ERROR_EXIT);
  }
}
var DEFAULT_CATEGORIES = ["design", "report", "note", "scratch"];
function parseListArg(value) {
  return (value ?? "").split(",").map((s2) => s2.trim()).filter((s2) => s2.length > 0);
}
function parseAggressivenessOrExit(value) {
  const n2 = Number(value);
  if (!Number.isInteger(n2) || n2 < 1 || n2 > 5) {
    writeError(`--aggressiveness/\uC801\uADF9\uC131 must be an integer 1..5; got "${value}"`);
    process.exit(USAGE_ERROR_EXIT);
  }
  return n2;
}
function parseConcurrencyOrExit(value) {
  const n2 = Number(value);
  if (!Number.isInteger(n2) || n2 < 1) {
    writeError(`--concurrency/\uB3D9\uC2DC\uC131 must be a positive integer; got "${value}"`);
    process.exit(USAGE_ERROR_EXIT);
  }
  return n2;
}
function parseTrackedOrExit(value) {
  const parsed = cleanupTrackedFilter.safeParse(value);
  if (!parsed.success) {
    writeError(`--tracked must be one of ${cleanupTrackedFilter.options.join("|")}; got "${value}"`);
    process.exit(USAGE_ERROR_EXIT);
  }
  return parsed.data;
}
function scopeIsCommits(scope) {
  const tokens = scope.split(",").map((s2) => s2.trim()).filter((s2) => s2.length > 0);
  return tokens.length > 0 && tokens.every((t2) => /^[0-9a-f]{7,40}$/i.test(t2));
}
var classifyScan = defineCommand({
  meta: {
    name: "scan",
    description: "Discover candidate docs across the workspace with deterministic lost-authority signals (orphan/stale). Excludes the protected set (ac-4); resolves each doc owning sub-repo (ac-7). The contradiction signal needs judgment \u2192 per-doc agent in the skill, not here."
  },
  args: {
    scope: {
      type: "string",
      description: "\uBC94\uC704 \u2014 gitignore-form glob OR a comma-separated commit-hash list to limit scope",
      required: false
    },
    tracked: {
      type: "string",
      description: `Tracked filter: ${cleanupTrackedFilter.options.join("|")} (default tracked-only)`,
      default: "tracked-only"
    },
    categories: {
      type: "string",
      description: "\uBD84\uB958\uC720\uD615 \u2014 comma-separated doc categories (default all four)",
      required: false
    },
    aggressiveness: {
      type: "string",
      description: "\uC801\uADF9\uC131 \u2014 1 (conservative) \u2026 5 (aggressive); default 3",
      default: "3"
    },
    concurrency: {
      type: "string",
      description: "\uB3D9\uC2DC\uC131 \u2014 worker count the skill fans out at (default 4)",
      default: "4"
    },
    "auto-cleanup": {
      type: "boolean",
      description: "\uC790\uB3D9\uC815\uB9AC \u2014 chain into the archive-only cleanup path after classification (default off; delete never runs on this path, ac-6)",
      default: false
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    const format = parseFormatOrExit(args.output);
    const trackedFilter = parseTrackedOrExit(args.tracked);
    const aggressiveness = parseAggressivenessOrExit(args.aggressiveness);
    const concurrency = parseConcurrencyOrExit(args.concurrency);
    const categories = args.categories === undefined ? [...DEFAULT_CATEGORIES] : parseListArg(args.categories);
    const scope = args.scope;
    const scopeCommits = scope && scopeIsCommits(scope) ? scope.split(",").map((s2) => s2.trim()) : undefined;
    const scopeGlob = scope && !scopeCommits ? scope : undefined;
    const repoRoot = await resolveRepoRootForCreate();
    try {
      const result2 = await scanCandidates(repoRoot, {
        trackedFilter,
        aggressiveness,
        ...scopeGlob ? { scopeGlob } : {},
        ...scopeCommits ? { scopeCommits } : {},
        categories
      });
      const params = {
        tracked_filter: trackedFilter,
        categories,
        auto_cleanup: args["auto-cleanup"],
        concurrency,
        aggressiveness,
        ...scope ? { scope } : {}
      };
      if (format === "json") {
        writeJson2({ params, ...result2 });
      } else {
        writeHuman(`Scanned ${repoRoot}`);
        writeHuman(`  candidates: ${result2.candidates.length}`);
        writeHuman(`  excluded (protected): ${result2.excluded_protected.length}`);
        writeHuman(`  tracked filter: ${trackedFilter}  aggressiveness: ${aggressiveness}`);
        if (args["auto-cleanup"]) {
          writeHuman("  auto-cleanup: ON (archive-only \u2014 delete never runs, ac-6)");
        }
        for (const c3 of result2.candidates) {
          const sig = c3.signals.map((s2) => s2.kind).join(",") || "-";
          writeHuman(`  ${c3.tracked ? "T" : "U"} ${c3.path}	[${sig}]	repo=${c3.owning_repo ?? "."}`);
        }
      }
    } catch (err) {
      writeError(`classify scan failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var classifyCreateRun = defineCommand({
  meta: {
    name: "create-run",
    description: "Create a classify run folder (auto id) with 4 action subfolders + a params snapshot"
  },
  args: {
    params: {
      type: "string",
      description: "JSON snapshot of cleanupRunParams (the scan params this run was invoked with)",
      required: true
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    const format = parseFormatOrExit(args.output);
    let raw;
    try {
      raw = JSON.parse(args.params);
    } catch (err) {
      writeError(`--params is not valid JSON: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const parsed = cleanupRunParams.safeParse(raw);
    if (!parsed.success) {
      writeError("--params failed schema validation:");
      for (const issue of parsed.error.issues) {
        writeError(`  - ${issue.path.join(".") || "(root)"}: ${issue.message}`);
      }
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await resolveRepoRootForCreate();
    try {
      const store = new CleanupStore(repoRoot);
      const runId2 = await store.createRun(parsed.data);
      if (format === "json") {
        writeJson2({ run_id: runId2, run_dir: store.runDir(runId2) });
      } else {
        writeHuman(`Created run ${runId2}`);
        writeHuman(`  dir: ${store.runDir(runId2)}`);
      }
    } catch (err) {
      writeError(`classify create-run failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var classifyStage = defineCommand({
  meta: {
    name: "stage",
    description: "Stage ONE already-decided doc into an action bucket with its basis (>=1 signal). Delegates to CleanupStore.stageDoc; inherits protected (ac-4) and empty-basis (ac-5) refusal. The skill calls this once per doc with the agent decision. With --auto, the auto-cleanup fail-closed guard refuses delete (ac-6)."
  },
  args: {
    "run-id": { type: "string", description: "Target run id (from create-run)", required: true },
    path: {
      type: "string",
      description: "Doc to stage (absolute, or repo-relative to the workspace root)",
      required: true
    },
    action: {
      type: "string",
      description: `Disposition: ${cleanupAction.options.join("|")}`,
      required: true
    },
    summary: { type: "string", description: "Short rationale for the disposition", default: "" },
    basis: {
      type: "string",
      description: "JSON array of basis signals [{kind:orphan|stale|contradiction, detail}]; at least one (ac-5)",
      required: true
    },
    aggressiveness: {
      type: "string",
      description: "\uC801\uADF9\uC131 the decision was made at (1..5)",
      default: "3"
    },
    agent: {
      type: "string",
      description: "Agent/handle that classified this doc",
      required: false
    },
    auto: {
      type: "boolean",
      description: "Auto-cleanup path: enforce archive-only \u2014 refuse delete-candidate/unclassified (ac-6 fail-closed)",
      default: false
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    const format = parseFormatOrExit(args.output);
    const aggressiveness = parseAggressivenessOrExit(args.aggressiveness);
    const actionParsed = cleanupAction.safeParse(args.action);
    if (!actionParsed.success) {
      writeError(`--action must be one of ${cleanupAction.options.join("|")}; got "${args.action}"`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let basisRaw;
    try {
      basisRaw = JSON.parse(args.basis);
    } catch (err) {
      writeError(`--basis is not valid JSON: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const basisParsed = cleanupBasisSignal.array().safeParse(basisRaw);
    if (!basisParsed.success) {
      writeError("--basis failed schema validation:");
      for (const issue of basisParsed.error.issues) {
        writeError(`  - ${issue.path.join(".") || "(root)"}: ${issue.message}`);
      }
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    if (args.auto) {
      try {
        autoChainArchiveAction(actionParsed.data);
      } catch (err) {
        writeError(err instanceof Error ? err.message : String(err));
        process.exit(USAGE_ERROR_EXIT);
        return;
      }
    }
    const repoRoot = await resolveRepoRootForCreate();
    const absPath = isAbsolute9(args.path) ? args.path : join51(repoRoot, args.path);
    try {
      const store = new CleanupStore(repoRoot);
      const entry = await store.stageDoc(args["run-id"], {
        absPath,
        action: actionParsed.data,
        summary: args.summary,
        basis: basisParsed.data,
        aggressiveness,
        ...args.agent ? { agent: args.agent } : {}
      });
      if (format === "json") {
        writeJson2(entry);
      } else {
        writeHuman(`Staged ${entry.original_path} \u2192 ${entry.action}`);
        writeHuman(`  staged_path: ${entry.staged_path}`);
        writeHuman(`  basis: ${entry.basis.map((b2) => b2.kind).join(",")}`);
      }
    } catch (err) {
      if (err instanceof CleanupProtectedPathError || err instanceof CleanupBasisRequiredError) {
        writeError(err.message);
        process.exit(USAGE_ERROR_EXIT);
        return;
      }
      writeError(`classify stage failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
var classifyStatus = defineCommand({
  meta: {
    name: "status",
    description: "Read the index of a classify run (run metadata + per-doc entries)"
  },
  args: {
    "run-id": { type: "string", description: "Run id to read", required: true },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    const format = parseFormatOrExit(args.output);
    const repoRoot = await resolveRepoRootForCreate();
    try {
      const store = new CleanupStore(repoRoot);
      const idx = await store.readIndex(args["run-id"]);
      if (format === "json") {
        writeJson2(idx);
      } else {
        writeHuman(`Run ${idx.run_id} (${idx.created_at})`);
        writeHuman(`  entries: ${idx.entries.length}`);
        for (const e2 of idx.entries) {
          writeHuman(`  ${e2.action}	${e2.original_path}	[${e2.basis.map((b2) => b2.kind).join(",")}]`);
        }
      }
    } catch (err) {
      writeError(`classify status failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
