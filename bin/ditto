import { test as setup } from '@playwright/test';

// ditto scaffold \u2014 replace with real seeding/storageState for your app.
setup('seed', async () => {
  // no-op
});
`;
var e2eAgentsRecordSchema = exports_external.object({
  installed_at: exports_external.string(),
  playwright_version: exports_external.string(),
  loop: exports_external.enum(["claude", "codex"]),
  plan_format_version: exports_external.string(),
  healer: exports_external.string()
}).strict();
var nodeFsSeam = {
  exists: (p2) => Bun.file(p2).exists(),
  readText: (p2) => Bun.file(p2).text(),
  writeText: (p2, c5) => atomicWriteText(p2, c5),
  ensureDir: (p2) => ensureDir(p2),
  backupOnce: (p2) => writeBackupOnce(p2)
};
function resolveLoop(host, explicitLoop) {
  const derived = host === "codex" ? "codex" : "claude";
  if (explicitLoop !== undefined && explicitLoop !== derived) {
    throw new Error(`--host ${host} pins --loop=${derived}; got --loop=${explicitLoop}. Drop --loop or set it to ${derived}.`);
  }
  return derived;
}
function parsePlaywrightVersion(raw) {
  if (raw == null)
    return null;
  const m4 = raw.match(/(\d+)\.(\d+)\.(\d+)/);
  if (!m4)
    return null;
  return {
    major: Number(m4[1]),
    minor: Number(m4[2]),
    patch: Number(m4[3]),
    raw: m4[0]
  };
}
function compareVersion(a4, b3) {
  return a4.major - b3.major || a4.minor - b3.minor || a4.patch - b3.patch;
}
function gatePlaywrightVersion(host, versionOutput) {
  const version = parsePlaywrightVersion(versionOutput);
  if (version === null) {
    return {
      decision: "degrade",
      version: null,
      warn: null,
      message: "Playwright not detected \u2014 not auto-installing (ADR-0018). E2E generation will run in degrade mode until Playwright is installed and `ditto e2e init-agents` is re-run."
    };
  }
  const below = compareVersion(version, PLAYWRIGHT_MIN_VERSION) < 0;
  if (!below) {
    return { decision: "install", version, warn: null, message: null };
  }
  if (host === "codex") {
    return {
      decision: "refuse",
      version,
      warn: null,
      message: `Playwright ${version.raw} < ${PLAYWRIGHT_MIN_VERSION.raw}; the codex loop requires >= ${PLAYWRIGHT_MIN_VERSION.raw}. Upgrade Playwright (e.g. npm i -D @playwright/test@latest) and re-run.`
    };
  }
  return {
    decision: "install",
    version,
    warn: `Playwright ${version.raw} < ${PLAYWRIGHT_MIN_VERSION.raw}; the claude loop will install but generation may be less reliable. Upgrade to >= ${PLAYWRIGHT_MIN_VERSION.raw} when possible.`,
    message: null
  };
}
function mergeMcpServers(existingContent, freshServer = PLAYWRIGHT_TEST_MCP_SERVER) {
  const trimmed = existingContent?.trim();
  const parsed = trimmed && trimmed.length > 0 ? JSON.parse(trimmed) : {};
  const existingServers = parsed.mcpServers && typeof parsed.mcpServers === "object" ? parsed.mcpServers : {};
  return {
    ...parsed,
    mcpServers: { ...existingServers, [PLAYWRIGHT_TEST_MCP_KEY]: freshServer }
  };
}
async function writeMergedMcpJson(mcpPath, freshServer = PLAYWRIGHT_TEST_MCP_SERVER, seam = nodeFsSeam) {
  const exists = await seam.exists(mcpPath);
  const existing = exists ? await seam.readText(mcpPath) : null;
  const merged = mergeMcpServers(existing, freshServer);
  const backupPath = exists ? await seam.backupOnce(mcpPath) : null;
  await seam.ensureDir(dirname12(mcpPath));
  await seam.writeText(mcpPath, `${JSON.stringify(merged, null, 2)}
`);
  return { mcpPath, backupPath, servers: Object.keys(merged.mcpServers) };
}
async function scaffoldIfAbsent(path, content, seam = nodeFsSeam) {
  if (await seam.exists(path))
    return "skipped-exists";
  await seam.ensureDir(dirname12(path));
  await seam.writeText(path, content);
  return "created";
}
function buildE2eAgentsRecord(input) {
  return e2eAgentsRecordSchema.parse({
    installed_at: input.installedAt ?? new Date().toISOString(),
    playwright_version: input.playwrightVersion,
    loop: input.loop,
    plan_format_version: PLAN_FORMAT_VERSION,
    healer: "constrained"
  });
}
function detectVersionSkew(record, expectedPlanFormat = PLAN_FORMAT_VERSION) {
  if (record.plan_format_version !== expectedPlanFormat) {
    return {
      skew: true,
      action: "degrade",
      warn: `e2e-agents.json plan_format_version=${record.plan_format_version} != expected ${expectedPlanFormat}: installed test-agents are stale. Re-run \`ditto e2e init-agents\` before generating; routing to degrade to avoid non-conformant output.`
    };
  }
  return { skew: false, action: "ok", warn: null };
}
async function writeE2eAgentsRecord(path, record, seam = nodeFsSeam) {
  const validated = e2eAgentsRecordSchema.parse(record);
  await seam.ensureDir(dirname12(path));
  await seam.writeText(path, `${JSON.stringify(validated, null, 2)}
`);
}
async function readE2eAgentsRecord(path, seam = nodeFsSeam) {
  if (!await seam.exists(path))
    return null;
  const text = await seam.readText(path);
  return e2eAgentsRecordSchema.parse(JSON.parse(text));
}

// src/core/e2e/spec-postpass.ts
var genStepComment = /^(\s*)\/\/\s*(\d+)\.\s/;
var testOpener = /\btest(?:\.describe)?\s*\(\s*(['"`])(.*?)\1/;
var dslStepLine = /^\s*\d+\.\s+\[([sb]\d+)\]\s*(.*)$/;
var assertionLine = /\bexpect\s*\(/;
function collapseForComment(text) {
  return text.replace(/[\r\n]+/g, " ").trim();
}
function buildDslTextMap(dslOriginal) {
  const body = splitFrontMatter(dslOriginal)?.body ?? dslOriginal;
  const map = new Map;
  for (const line of body.split(`
`)) {
    const m4 = dslStepLine.exec(line);
    if (m4?.[1])
      map.set(m4[1], collapseForComment(m4[2] ?? ""));
  }
  return map;
}
function findCellByTitle(planMap, title) {
  for (const scenario of Object.values(planMap)) {
    for (const [caseName, cell2] of Object.entries(scenario)) {
      if (title.includes(caseName))
        return cell2;
    }
  }
  return;
}
function soleCell(planMap) {
  const scenarios = Object.values(planMap);
  if (scenarios.length !== 1)
    return;
  const cases = Object.values(scenarios[0] ?? {});
  return cases.length === 1 ? cases[0] : undefined;
}
function findAssertionsByTitle(assertions, title) {
  for (const scenario of Object.values(assertions)) {
    for (const [caseName, ids] of Object.entries(scenario)) {
      if (title.includes(caseName))
        return ids;
    }
  }
  return;
}
function soleAssertions(assertions) {
  const scenarios = Object.values(assertions);
  if (scenarios.length !== 1)
    return;
  const cases = Object.values(scenarios[0] ?? {});
  return cases.length === 1 ? cases[0] : undefined;
}
function injectDittoMarkers(input) {
  const { generated, journeyId, header, planMap, assertions, dslOriginal } = input;
  const dslText = buildDslTextMap(dslOriginal);
  const fallback = soleCell(planMap);
  const assertFallback = assertions ? soleAssertions(assertions) : undefined;
  const marker = (indent, stepId) => {
    const text = dslText.get(stepId) ?? "";
    return `${indent}// @step ${journeyId}/${stepId}${text ? ` ${text}` : ""}`;
  };
  let cell2 = fallback;
  let assertList = assertFallback ?? [];
  let assertIdx = 0;
  let injected = 0;
  const out = [];
  for (const line of generated.split(`
`)) {
    const opener = testOpener.exec(line);
    if (opener) {
      const title = opener[2] ?? "";
      cell2 = findCellByTitle(planMap, title) ?? fallback ?? cell2;
      if (assertions)
        assertList = findAssertionsByTitle(assertions, title) ?? assertFallback ?? [];
      assertIdx = 0;
    }
    const step = genStepComment.exec(line);
    if (step) {
      const stepId = cell2?.[step[2] ?? ""];
      if (stepId) {
        out.push(marker(step[1] ?? "", stepId));
        injected++;
      }
      out.push(line);
      continue;
    }
    if (assertions && assertIdx < assertList.length && assertionLine.test(line)) {
      const indent = /^\s*/.exec(line)?.[0] ?? "";
      out.push(marker(indent, assertList[assertIdx++] ?? ""));
      injected++;
      out.push(line);
      continue;
    }
    out.push(line);
  }
  const spec = `${renderGeneratedHeader(header)}
${out.join(`
`)}`;
  const found = new Set(extractStepMarkers(spec));
  const unmatched = [...dslText.keys()].map((id) => `${journeyId}/${id}`).filter((ref) => !found.has(ref));
  return { spec, injected, unmatched };
}

// src/core/e2e/generator.ts
function meetsMinVersion(v2) {
  if (!v2)
    return false;
  const min = PLAYWRIGHT_MIN_VERSION;
  if (v2.major !== min.major)
    return v2.major > min.major;
  if (v2.minor !== min.minor)
    return v2.minor > min.minor;
  return v2.patch >= min.patch;
}
async function defaultReadPlaywrightVersion(repoRoot) {
  try {
    const proc = spawnProviderProcess({
      binary: "bunx",
      args: ["--no-install", "playwright", "--version"],
      repoRoot,
      cwd: ".",
      env: { set: {}, unset: [] }
    });
    const [completion, out] = await Promise.all([
      proc.completion,
      new Response(proc.stdout).text().catch(() => "")
    ]);
    if (completion.exit_code !== 0)
      return null;
    return out.trim() || null;
  } catch {
    return null;
  }
}
async function safe(fn, onError) {
  try {
    return await fn();
  } catch {
    return onError;
  }
}
async function probeGenerator(repoRoot, host, seams = {}) {
  const probeBrowser = seams.probeBrowser ?? probePlaywright;
  const readVersion = seams.readPlaywrightVersion ?? defaultReadPlaywrightVersion;
  const readAgents = seams.readAgentsRecord ?? ((root) => readE2eAgentsRecord(join66(localDir(root), "e2e-agents.json")));
  const probeMcp = seams.probeMcp ?? (async () => true);
  const probe = await safe(() => probeBrowser(repoRoot), {
    available: false,
    reason: "browser probe failed"
  });
  const browser = probe.available;
  const versionOutput = await safe(() => readVersion(repoRoot), null);
  const gate2 = gatePlaywrightVersion(host, versionOutput);
  const playwrightVersionOk = meetsMinVersion(gate2.version);
  const record = await safe(() => readAgents(repoRoot), null);
  const skew = record ? detectVersionSkew(record) : null;
  const agentsInstalled = record !== null && skew !== null && !skew.skew;
  const mcpAvailable = await safe(() => probeMcp(repoRoot, host), false);
  const checks = { browser, playwrightVersionOk, agentsInstalled, mcpAvailable };
  const usable = browser && playwrightVersionOk && agentsInstalled && mcpAvailable;
  if (usable) {
    return {
      usable: true,
      reason: `official generator usable: live browser + Playwright ${gate2.version?.raw ?? "?"} (>= ${PLAYWRIGHT_MIN_VERSION.raw}) + agents installed + MCP available`,
      checks
    };
  }
  const details = [];
  if (!browser)
    details.push(`browser unavailable: ${probe.reason}`);
  if (!playwrightVersionOk) {
    details.push(`Playwright version below required ${PLAYWRIGHT_MIN_VERSION.raw} (got ${gate2.version?.raw ?? "none"})`);
  }
  if (!agentsInstalled) {
    details.push(record === null ? "e2e-agents.json record absent \u2014 run `ditto e2e init-agents`" : skew?.warn ?? "e2e-agents plan-format skew \u2014 re-run `ditto e2e init-agents`");
  }
  if (!mcpAvailable)
    details.push("MCP playwright-test server not available (best-effort probe)");
  return {
    usable: false,
    reason: `official generator unusable \u2014 ${details.join("; ")}`,
    checks
  };
}
async function runGenerator(input, seams) {
  const availability = await probeGenerator(input.repoRoot, input.host, seams);
  if (availability.usable) {
    const raw = await seams.driveOfficialGenerator({
      plan: input.plan,
      planMap: input.planMap,
      repoRoot: input.repoRoot,
      host: input.host
    });
    const { spec, injected, unmatched } = injectDittoMarkers({
      generated: raw,
      journeyId: input.journeyId,
      header: input.header,
      planMap: input.planMap,
      ...input.planAssertions ? { assertions: input.planAssertions } : {},
      dslOriginal: input.dslOriginal
    });
    return {
      spec,
      used_fallback: false,
      availability,
      unverified_acs: [],
      reason: availability.reason,
      specPath: input.specPath,
      injected,
      unmatched
    };
  }
  const fb = generateFallbackSpec({
    probe: { available: false, reason: availability.reason },
    plan: input.plan,
    header: input.header,
    specPath: input.specPath,
    planPath: input.planPath
  });
  return {
    spec: fb.spec ?? "",
    used_fallback: true,
    availability,
    unverified_acs: fb.unverified_acs.length ? fb.unverified_acs : [...BROWSER_EVIDENCE_ACS],
    reason: fb.reason,
    specPath: fb.specPath ?? input.specPath,
    ...fb.warn ? { warn: fb.warn } : {}
  };
}

