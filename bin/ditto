var finalizeCmd2 = defineCommand({
  meta: {
    name: "finalize",
    description: "Compile the working buffer into ADR-0005 per-entity journey/story files + journey DSL (e2e/journeys/*.md). Fail-closed: every conflict/reference gate runs before any write."
  },
  args: {
    workItem: { type: "string", description: "Work item id (wi_*)", required: true },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const repoRoot = await resolveRepoRootForCreate();
    try {
      const result2 = await finalizeAuthoring(repoRoot, { workItemId: args.workItem });
      if (result2.status === "not_started") {
        writeError("journey-authoring was never started for this work item \u2014 run `ditto journey-author start` first");
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      if (format === "json") {
        writeJson2({
          status: result2.status,
          work_item_id: args.workItem,
          journeys: result2.journeys.map((j) => j.id),
          story: result2.story?.id ?? null,
          dsl_paths: result2.dsl_paths,
          superseded: result2.superseded
        });
      } else {
        writeHuman(`Finalized journey-authoring for ${args.workItem}`);
        writeHuman(`  journeys: ${result2.journeys.map((j) => j.id).join(", ") || "(none)"}`);
        if (result2.story)
          writeHuman(`  story:    ${result2.story.id}`);
        writeHuman(`  dsl:      ${result2.dsl_paths.join(", ") || "(none)"}`);
        if (result2.superseded.length > 0) {
          writeHuman(`  superseded: ${result2.superseded.join(", ")}`);
        }
      }
    } catch (err) {
      if (err instanceof IdConflictError) {
        writeError("finalize rejected (id conflict, fail-closed):");
        for (const c5 of err.conflicts)
          writeError(`  - ${c5.id}: ${c5.reason}`);
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      if (err instanceof JourneyReferenceNotFoundError) {
        writeError("finalize rejected (referenced journeys not found, fail-closed):");
        for (const m4 of err.missing)
          writeError(`  - ${m4}`);
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      writeError(`finalize failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
