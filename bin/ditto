var e2eConformance = defineCommand({
  meta: {
    name: "conformance",
    description: "Check DSL step \u2194 generated @step marker traceability + digest freshness"
  },
  args: {
    journey: { type: "string", description: "Path to <slug>.journey.md", required: true },
    "blocks-dir": {
      type: "string",
      description: "Dir with <block-id>.block.md files (default: <journey dir>/blocks)"
    },
    generated: { type: "string", description: "Path to generated <slug>.spec.ts", required: true },
    "support-dir": {
      type: "string",
      description: "Dir with generated support helpers (default: <generated dir>/support)"
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    try {
      const journeyAbs = resolve13(args.journey);
      const generatedAbs = resolve13(args.generated);
      const blocksDir = resolve13(args["blocks-dir"] ?? join63(dirname12(journeyAbs), "blocks"));
      const supportDir = resolve13(args["support-dir"] ?? join63(dirname12(generatedAbs), "support"));
      const journeyText = await readFile14(journeyAbs, "utf8");
      const generatedText = await readFile14(generatedAbs, "utf8");
      const blockTexts = {};
      try {
        for (const name of await readdir19(blocksDir)) {
          if (!name.endsWith(".block.md"))
            continue;
          blockTexts[name.slice(0, -".block.md".length)] = await readFile14(join63(blocksDir, name), "utf8");
        }
      } catch {}
      const supportTexts = [];
      try {
        for (const name of await readdir19(supportDir)) {
          if (!name.endsWith(".ts"))
            continue;
          supportTexts.push(await readFile14(join63(supportDir, name), "utf8"));
        }
      } catch {}
      const report = checkStepConformance({ journeyText, blockTexts, generatedText, supportTexts });
      const repoRoot = await resolveRepoRootForCreate();
      const repoRel = (abs) => relative15(repoRoot, abs).split(sep6).join("/");
      const stale = [];
      const journeyVerdict = await detectStale(journeyAbs, generatedAbs, repoRel(journeyAbs));
      if (journeyVerdict.stale)
        stale.push(`${args.generated}: ${journeyVerdict.reason}`);
      const parsedJourney = parseJourneyDoc(journeyText);
      if (parsedJourney.ok) {
        for (const blockId of parsedJourney.frontMatter.uses_blocks) {
          if (blockTexts[blockId] === undefined)
            continue;
          const helperAbs = join63(supportDir, `${blockId}.block.ts`);
          const blockMdAbs = join63(blocksDir, `${blockId}.block.md`);
          const verdict2 = await detectStale(blockMdAbs, helperAbs, repoRel(blockMdAbs));
          if (verdict2.stale)
            stale.push(`support/${blockId}.block.ts: ${verdict2.reason}`);
        }
      }
      const ok = report.ok && stale.length === 0;
      if (format === "json") {
        writeJson2({ ...report, ok, stale });
      } else {
        writeHuman(`e2e conformance: ${ok ? "OK" : "FAIL"}`);
        writeHuman(`  required: ${report.required.length}, found: ${report.found.length}`);
        for (const ref of report.missing)
          writeHuman(`  missing marker: ${ref}`);
        for (const err of report.errors)
          writeHuman(`  error: ${err}`);
        for (const s2 of stale)
          writeHuman(`  stale: ${s2}`);
      }
      if (!ok)
        process.exit(RUNTIME_ERROR_EXIT);
    } catch (err) {
      writeError(`e2e conformance failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
