var CHUNK_FILE_COUNT = 22;
function chunkSources(sources, chunkSize = CHUNK_FILE_COUNT) {
  const size = Math.max(1, Math.floor(chunkSize));
  const sorted = [...sources].filter((s2) => s2.sensitivity !== "secret").sort((a4, b3) => a4.source_id < b3.source_id ? -1 : a4.source_id > b3.source_id ? 1 : 0);
  const chunks = [];
  for (let i3 = 0;i3 < sorted.length; i3 += size) {
    const idx = chunks.length;
    chunks.push({
      chunk_id: `chunk_${String(idx).padStart(4, "0")}`,
      files: sorted.slice(i3, i3 + size)
    });
  }
  return chunks;
}
var semanticConfidenceKind = memoryConfidenceKind.exclude(["EXTRACTED"]);
var fragmentNodeSchema = exports_external.object({
  id: exports_external.string().min(1).optional(),
  node_type: memoryNodeType,
  name: exports_external.string().min(1),
  source_id: memorySourceId,
  properties: exports_external.record(exports_external.unknown()).optional()
});
var fragmentEdgeSchema = exports_external.object({
  from: exports_external.string().min(1),
  to: exports_external.string().min(1),
  edge_type: memoryEdgeType,
  confidence_kind: semanticConfidenceKind,
  confidence_score: exports_external.number().min(0).max(1),
  source_id: memorySourceId,
  properties: exports_external.record(exports_external.unknown()).optional()
});
var irFragmentSchema = exports_external.object({
  nodes: exports_external.array(fragmentNodeSchema).default([]),
  edges: exports_external.array(fragmentEdgeSchema).default([])
});
var irFragmentsSchema = exports_external.array(irFragmentSchema);
function normalizeConceptLabel(label2) {
  return label2.toLowerCase().replace(/[^a-z0-9]+/g, " ").trim().replace(/\s+/g, " ");
}
function conceptId(label2) {
  return `concept:${normalizeConceptLabel(label2)}`;
}
function canonicalNodeId(node2) {
  if (node2.node_type === "Concept")
    return conceptId(node2.name);
  if (node2.id && node2.id.length > 0)
    return node2.id;
  return `${node2.node_type.toLowerCase()}:${normalizeConceptLabel(node2.name)}`;
}
var KIND_RANK = { INFERRED: 0, AMBIGUOUS: 1 };
var SEMANTIC_RUN_ID2 = "xrun_semantic";
var SCHEMA_VERSION2 = "0.1.0";
function sortById(items) {
  return items.sort((a4, b3) => a4.id < b3.id ? -1 : a4.id > b3.id ? 1 : 0);
}
function mergeIrFragments(fragments) {
  const provenance = (sourceId) => ({
    source_id: sourceId,
    extraction_run_id: SEMANTIC_RUN_ID2,
    extracted_by: "llm",
    schema_version: SCHEMA_VERSION2
  });
  const idRemap = new Map;
  const nodeAcc = new Map;
  const grouped = new Map;
  for (const frag of fragments) {
    for (const fn of frag.nodes) {
      const cid = canonicalNodeId(fn);
      if (fn.id && fn.id !== cid)
        idRemap.set(fn.id, cid);
      const bucket = grouped.get(cid);
      if (bucket)
        bucket.push(fn);
      else
        grouped.set(cid, [fn]);
    }
  }
  for (const [cid, group] of grouped) {
    const ordered = [...group].sort((a4, b3) => {
      const ka = `${a4.id ?? ""}\x00${a4.name}`;
      const kb = `${b3.id ?? ""}\x00${b3.name}`;
      return ka < kb ? -1 : ka > kb ? 1 : 0;
    });
    const winner = ordered[0];
    const collected = {};
    for (const fn of ordered) {
      for (const [k2, v2] of Object.entries(fn.properties ?? {})) {
        if (!(k2 in collected))
          collected[k2] = v2;
      }
    }
    const props = {};
    for (const k2 of Object.keys(collected).sort())
      props[k2] = collected[k2];
    nodeAcc.set(cid, {
      id: cid,
      node_type: winner.node_type,
      name: winner.name,
      properties: props,
      provenance: provenance(winner.source_id)
    });
  }
  const nameToId = new Map;
  for (const node2 of nodeAcc.values()) {
    const key = normalizeConceptLabel(node2.name);
    if (!key)
      continue;
    const existing = nameToId.get(key);
    if (existing === undefined)
      nameToId.set(key, node2.id);
    else if (existing !== node2.id)
      nameToId.set(key, null);
  }
  const remapEndpoint = (raw) => {
    const mapped = idRemap.get(raw);
    if (mapped)
      return mapped;
    if (raw.startsWith("concept:"))
      return conceptId(raw.slice("concept:".length));
    const byName = nameToId.get(normalizeConceptLabel(raw));
    if (byName)
      return byName;
    return raw;
  };
  const edgeAcc = new Map;
  for (const frag of fragments) {
    for (const fe2 of frag.edges) {
      const from = remapEndpoint(fe2.from);
      const to = remapEndpoint(fe2.to);
      const key = `${from}|${fe2.edge_type}|${to}`;
      const incoming = { ...fe2, remappedFrom: from, remappedTo: to };
      const existing = edgeAcc.get(key);
      if (!existing) {
        edgeAcc.set(key, incoming);
        continue;
      }
      const winner = pickConfidence(existing, incoming);
      edgeAcc.set(key, winner);
    }
  }
  const edges = [];
  for (const [key, fe2] of edgeAcc) {
    edges.push({
      id: `edge:${key}`,
      from: fe2.remappedFrom,
      to: fe2.remappedTo,
      edge_type: fe2.edge_type,
      confidence_kind: fe2.confidence_kind,
      confidence_score: fe2.confidence_score,
      properties: fe2.properties ?? {},
      provenance: provenance(fe2.source_id),
      weight: 1,
      requires_review: fe2.confidence_kind === "AMBIGUOUS",
      used_as_evidence: false
    });
  }
  return { nodes: sortById([...nodeAcc.values()]), edges: sortById(edges) };
}
function pickConfidence(a4, b3) {
  const ra = KIND_RANK[a4.confidence_kind];
  const rb = KIND_RANK[b3.confidence_kind];
  if (ra !== rb)
    return ra > rb ? a4 : b3;
  if (a4.confidence_score !== b3.confidence_score) {
    return a4.confidence_score > b3.confidence_score ? a4 : b3;
  }
  return a4.source_id <= b3.source_id ? a4 : b3;
}
function assembleSemanticIr(merged, run2) {
  return {
    schema_version: SCHEMA_VERSION2,
    ir_version: run2.ir_version,
    generated_at: run2.generated_at,
    extraction_run_id: run2.extraction_run_id,
    nodes: merged.nodes,
    edges: merged.edges,
    hyperedges: []
  };
}
function findDanglingEdges(nodes, edges) {
  const ids = new Set(nodes.map((n3) => n3.id));
  return edges.filter((e2) => !ids.has(e2.from) || !ids.has(e2.to)).map((e2) => e2.id);
}

