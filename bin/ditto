function selectStatusField(fieldList) {
  if (typeof fieldList !== "object" || fieldList === null)
    return null;
  const fields = fieldList.fields;
  if (!Array.isArray(fields))
    return null;
  const withOptions = fields.filter((f3) => typeof f3 === "object" && f3 !== null && Array.isArray(f3.options));
  const status = withOptions.find((f3) => typeof f3.name === "string" && f3.name.toLowerCase() === "status") ?? withOptions[0];
  if (!status || typeof status.id !== "string")
    return null;
  const options = status.options.filter((o3) => typeof o3 === "object" && o3 !== null && typeof o3.id === "string" && typeof o3.name === "string").map((o3) => ({ id: o3.id, name: o3.name }));
  return { id: status.id, options };
}
function extractStatusFieldId(fieldList) {
  return selectStatusField(fieldList)?.id ?? null;
}
function buildResultSummary(input) {
