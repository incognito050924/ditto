  forbidden_dependencies: exports_external.array(exports_external.object({ from: exports_external.string().min(1), to: exports_external.string().min(1), reason: exports_external.string().min(1) })).default([]),
  ownership: exports_external.array(exports_external.object({ module: exports_external.string().min(1), owner: exports_external.string().min(1) })).default([]),
  module_invariants: exports_external.array(exports_external.string().min(1)).default([]).describe("Generalizable invariants \u2014 FitnessFunction promotion candidates"),
  conventions: acgConventions.optional()
}).describe("ACG ArchitectureSpec \u2014 layers, surfaces, forbidden deps, conventions");

// src/acg/architecture/propose.ts
function layerOf(repoRelPath) {
  const parts = repoRelPath.split("/");
  return parts[0] === "src" && parts.length > 2 ? parts[1] : undefined;
}
function buildCandidateSpec(obs, producedAt) {
  return acgArchitectureSpec.parse({
    schema_version: "0.1.0",
    kind: "acg.architecture-spec.v1",
    produced_by: "agent",
    produced_at: producedAt,
    layers: Object.fromEntries([...new Set(obs.layers)].sort().map((l2) => [l2, { can_call: [] }])),
    public_surfaces: [...new Set(obs.publicSurfaces)].sort(),
    forbidden_dependencies: [],
    module_invariants: []
  });
}
async function walkTsFiles(repoRoot, dir, acc) {
  let entries;
  try {
    entries = await readdir2(dir, { withFileTypes: true });
  } catch {
    return;
  }
  for (const e2 of entries) {
    if (e2.name === "node_modules" || e2.name.startsWith("."))
      continue;
    const full = join7(dir, e2.name);
    if (e2.isDirectory())
      await walkTsFiles(repoRoot, full, acc);
    else if (/\.[cm]?tsx?$/.test(e2.name) && !/\.(test|spec)\./.test(e2.name))
      acc.push(relative(repoRoot, full));
  }
}
async function observeArchitecture(repoRoot, sourceRoot, edgeAnalyzer) {
  const files = [];
  await walkTsFiles(repoRoot, sourceRoot, files);
  const edges = await edgeAnalyzer.edges({ changedFiles: files, sourceRoot });
  const layers = new Set;
  for (const f3 of files) {
    const l2 = layerOf(f3);
    if (l2)
      layers.add(l2);
  }
  const publicSurfaces = new Set;
  for (const e2 of edges) {
    if (!e2.to.startsWith("src/"))
      continue;
    const fromLayer = layerOf(e2.from);
    const toLayer = layerOf(`${e2.to}.ts`);
    if (fromLayer && toLayer && fromLayer !== toLayer)
      publicSurfaces.add(e2.to);
  }
  return { layers: [...layers], publicSurfaces: [...publicSurfaces] };
}

// src/acg/architecture/ratify.ts
function ratifyCandidateSpec(candidate, opts) {
  if (candidate.produced_by === "user") {
    throw new Error("ratify: spec is already authoritative (produced_by=user) \u2014 nothing to ratify");
  }
  return acgArchitectureSpec.parse({
    ...candidate,
    produced_by: "user",
    produced_at: opts.ratifiedAt,
    forbidden_dependencies: opts.forbidden
  });
}

