          const i2 = this.options.filter(({ value: s2 }) => l2.includes(s2)).map((s2) => o4(s2, "submitted")).join(styleText2("dim", ", ")) || styleText2("dim", "none"), u5 = wrapTextWithPrefix(n3.output, i2, t3 ? `${styleText2("gray", S_BAR)}  ` : "");
          return `${r4}${u5}`;
        }
        case "cancel": {
          const i2 = this.options.filter(({ value: s2 }) => l2.includes(s2)).map((s2) => o4(s2, "cancelled")).join(styleText2("dim", ", "));
          if (i2.trim() === "")
            return `${r4}${styleText2("gray", S_BAR)}`;
          const u5 = wrapTextWithPrefix(n3.output, i2, t3 ? `${styleText2("gray", S_BAR)}  ` : "");
          return `${r4}${u5}${t3 ? `
${styleText2("gray", S_BAR)}` : ""}`;
        }
        case "error": {
          const i2 = t3 ? `${styleText2("yellow", S_BAR)}  ` : "", u5 = this.error.split(`
`).map(($, x2) => x2 === 0 ? `${t3 ? `${styleText2("yellow", S_BAR_END)}  ` : ""}${styleText2("yellow", $)}` : `   ${$}`).join(`
`), s2 = r4.split(`
`).length, g4 = u5.split(`
`).length + 1;
          return `${r4}${i2}${limitOptions({
            output: n3.output,
            options: this.options,
            cursor: this.cursor,
            maxItems: n3.maxItems,
            columnPadding: i2.length,
            rowPadding: s2 + g4,
            style: p2
          }).join(`
${i2}`)}
${u5}
`;
        }
        default: {
          const i2 = t3 ? `${styleText2("cyan", S_BAR)}  ` : "", u5 = r4.split(`
`).length, s2 = formatInstructionFooter(MULTISELECT_INSTRUCTIONS, t3), g4 = s2.join(`
`), $ = s2.length + 1;
          return `${r4}${i2}${limitOptions({
            output: n3.output,
            options: this.options,
            cursor: this.cursor,
            maxItems: n3.maxItems,
            columnPadding: i2.length,
            rowPadding: u5 + $,
            style: p2
          }).join(`
${i2}`)}
${g4}
`;
        }
      }
    }
  }).prompt();
};
var u5 = {
  light: unicodeOr("\u2500", "-"),
  heavy: unicodeOr("\u2501", "="),
  block: unicodeOr("\u2588", "#")
};
