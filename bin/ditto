import { join as join42 } from "path";
class ChangeContractStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  dir(workItemId2) {
    return localDir(this.repoRoot, "work-items", workItemId2);
  }
  path(workItemId2) {
    return join42(this.dir(workItemId2), "change-contract.json");
  }
  async read(workItemId2) {
    try {
      return await readJson(this.path(workItemId2), acgChangeContract);
    } catch {
      return null;
    }
  }
  async write(workItemId2, contract) {
    await ensureDir(this.dir(workItemId2));
    await writeJson(this.path(workItemId2), acgChangeContract, contract);
  }
}

