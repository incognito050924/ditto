class AcgReviewStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  path(workItemId2) {
    return localDir(this.repoRoot, "work-items", workItemId2, "acg-review.json");
  }
  async exists(workItemId2) {
    return Bun.file(this.path(workItemId2)).exists();
  }
  async get(workItemId2) {
    return readJson(this.path(workItemId2), acgReviewGraph);
  }
  async write(workItemId2, graph) {
    return writeJson(this.path(workItemId2), acgReviewGraph, graph);
  }
}

