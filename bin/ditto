import { dirname as dirname12 } from "path";
var DITTO_AGENT_MARKER = "<!-- ditto:playwright-agent v1 -->";
var PLAN_FORMAT_VERSION = "v1";
var PLAYWRIGHT_MIN_VERSION = {
  major: 1,
  minor: 61,
  patch: 0,
  raw: "1.61.0"
};
var PLAYWRIGHT_TEST_MCP_KEY = "playwright-test";
var PLAYWRIGHT_TEST_MCP_SERVER = {
  command: "npx",
  args: ["-y", "@playwright/mcp@latest"]
};
var PLAYWRIGHT_CONFIG_STUB = `${DITTO_AGENT_MARKER}
import { defineConfig } from '@playwright/test';

// ditto scaffold \u2014 safe to edit. Generated specs live in e2e/generated/.
export default defineConfig({
  testDir: 'e2e/generated',
});
`;
