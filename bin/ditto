import { readdir as readdir21, stat as stat10, unlink as unlink4 } from "fs/promises";
import { join as join69 } from "path";
var sessionPointer = exports_external.object({
  schema_version: exports_external.literal("0.1.0"),
  session_id: exports_external.string().min(1),
  work_item_id: workItemId,
  updated_at: exports_external.string().min(1)
});
function safeSessionId(sessionId) {
  return sessionId.replace(/[^a-zA-Z0-9_-]/g, "_");
}
var STALE_SESSION_RETENTION_DAYS = 7;
var STALE_SESSION_RETENTION_MS = STALE_SESSION_RETENTION_DAYS * 24 * 60 * 60 * 1000;

class SessionPointerStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  dir() {
    return localDir(this.repoRoot, "sessions");
  }
  path(sessionId) {
    return join69(this.dir(), `${safeSessionId(sessionId)}.json`);
  }
  async get(sessionId) {
    try {
      const parsed = await readJson(this.path(sessionId), sessionPointer);
      return parsed.work_item_id;
    } catch {
      return null;
    }
  }
  async set(sessionId, id, now = new Date) {
    await ensureDir(localDir(this.repoRoot, "sessions"));
    await writeJson(this.path(sessionId), sessionPointer, {
      schema_version: "0.1.0",
      session_id: sessionId,
      work_item_id: id,
      updated_at: now.toISOString()
    });
  }
  async clear(sessionId) {
    try {
      await unlink4(this.path(sessionId));
    } catch {}
  }
  async sweepStale(now = new Date) {
    let names;
    try {
      names = await readdir21(this.dir());
    } catch {
      return [];
    }
    const swept = [];
    for (const name of names) {
      if (!name.endsWith(".json"))
        continue;
      const path = join69(this.dir(), name);
      let mtimeMs;
      try {
        mtimeMs = (await stat10(path)).mtimeMs;
      } catch {
        continue;
      }
      if (now.getTime() - mtimeMs <= STALE_SESSION_RETENTION_MS)
        continue;
      try {
        await unlink4(path);
        swept.push(path);
      } catch {}
    }
    return swept;
  }
}

