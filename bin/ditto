// src/acg/boundary/boundary.ts
function globToRegExp(glob) {
  let out = "";
  for (let i2 = 0;i2 < glob.length; i2++) {
    const c3 = glob[i2];
    if (c3 === "*") {
      if (glob[i2 + 1] === "*") {
        out += ".*";
        i2++;
      } else {
        out += "[^/]*";
      }
    } else if (".+?^${}()|[]\\".includes(c3)) {
      out += `\\${c3}`;
    } else {
      out += c3;
    }
  }
  return new RegExp(`^${out}$`);
}
function matchesGlob(path, glob) {
  return globToRegExp(glob).test(path);
}
function pathToLayer(path, layers) {
  const segments = path.split("/");
  for (const layer of Object.keys(layers)) {
    if (segments.includes(layer))
      return layer;
  }
  return;
}
function checkEdge(edge, spec) {
  const violations = [];
  for (const rule of spec.forbidden_dependencies) {
    if (matchesGlob(edge.from, rule.from) && matchesGlob(edge.to, rule.to)) {
      violations.push({
        rule: "forbidden_dependency",
        from: edge.from,
        to: edge.to,
        reason: rule.reason
      });
    }
  }
  const fromLayer = pathToLayer(edge.from, spec.layers);
  const toLayer = pathToLayer(edge.to, spec.layers);
  if (fromLayer && toLayer && fromLayer !== toLayer) {
    const canCall = spec.layers[fromLayer]?.can_call ?? [];
    if (!canCall.includes(toLayer)) {
      violations.push({
        rule: "layer",
        from: edge.from,
        to: edge.to,
        reason: `layer '${fromLayer}' may not call '${toLayer}' (can_call: [${canCall.join(", ")}])`
      });
    }
  }
  return violations;
}
function checkBoundary(spec, edges) {
  return edges.flatMap((e2) => checkEdge(e2, spec));
}

// src/acg/internal-packages.ts
init_fs();
var JVM_LANGUAGES = new Set(["java", "kotlin"]);
function isJvmLanguage(language) {
  return JVM_LANGUAGES.has(language);
}
function evaluateInternalPackages(input) {
  if (!isJvmLanguage(input.language)) {
    return {
      decision: "ok",
      reason: "non-JVM language \u2014 sibling-JAR cross_repo guard not applicable"
    };
  }
  const hasGlobs = input.entries.some((e2) => e2.type === "glob");
  const pathEntries = input.entries.filter((e2) => e2.type === "path");
  const uncovered = input.localJars.filter((jar) => !pathEntries.some((p) => globToRegExp(p.value).test(jar)));
  if (input.localJars.length > 0 && (!hasGlobs || uncovered.length > 0)) {
    const why = !hasGlobs ? "no glob entry declares which sibling packages to record as cross_repo" : `local JAR(s) not covered by any path entry: ${uncovered.join(", ")}`;
    return {
      decision: "block",
      reason: `${input.localJars.length} local JAR(s) present but internal_packages has a gap (${why}). Sibling-module impact would be silently dropped. Declare it with 'ditto architecture internal-packages --glob <pkg.**> --path <libs/*.jar>'.`
    };
  }
  if (!hasGlobs) {
    return {
      decision: "warn",
      reason: "JVM analysis without internal_packages glob entries \u2014 cross_repo recording is inactive. " + "Declare it if this module has sibling-module (JAR) dependencies."
    };
  }
  return { decision: "ok", reason: "internal_packages glob declared; local JARs covered" };
}
function withInternalPackages(existing, entries, producedAt) {
  const base = existing ?? acgArchitectureSpec.parse({
    schema_version: "0.1.0",
    kind: "acg.architecture-spec.v1",
    produced_by: "user",
    produced_at: producedAt
  });
  return { ...base, internal_packages: entries };
}
var SKIP_DIRS = new Set([
  "node_modules",
  ".git",
  ".ditto",
  "target",
  "build",
  "dist",
  ".gradle",
  "out"
]);
async function scanLocalJars(root, maxDepth = 6) {
  const out = [];
  async function walk(dir, depth) {
    if (depth > maxDepth)
      return;
    let entries;
    try {
      entries = await readdir5(dir, { withFileTypes: true });
    } catch {
      return;
    }
    for (const e2 of entries) {
      const full = join12(dir, e2.name);
      if (e2.isDirectory()) {
        if (!SKIP_DIRS.has(e2.name))
          await walk(full, depth + 1);
      } else if (e2.isFile() && e2.name.endsWith(".jar")) {
        out.push(relative4(root, full));
      }
    }
  }
  await walk(root, 0);
  return out.sort();
}
async function loadInternalPackages(repoRoot, specArg) {
  if (specArg) {
    return (await readArchitectureSpec(specArg, acgArchitectureSpec)).internal_packages;
  }
  try {
    const spec = await readArchitectureSpec(join12(repoRoot, ".ditto", "architecture-spec.json"), acgArchitectureSpec);
    return spec.internal_packages;
  } catch {
    return [];
  }
}
async function runInternalPackagesGuard(input) {
  if (!isJvmLanguage(input.language)) {
    return {
      decision: "ok",
      reason: "non-JVM language \u2014 sibling-JAR cross_repo guard not applicable"
    };
  }
  const localJars = await scanLocalJars(input.sourceRoot);
  return evaluateInternalPackages({ language: input.language, entries: input.entries, localJars });
}
function parseJvmCodeqlCommand(cmd) {
  if (!/\bditto\b/.test(cmd) || !/\b(impact|boundary)\b/.test(cmd))
    return;
  const lang = cmd.match(/--language[=\s]+(\w+)/);
  if (!lang || lang[1] !== "java" && lang[1] !== "kotlin")
    return;
  const sr = cmd.match(/--source-root[=\s]+(\S+)/);
  return sr ? { sourceRoot: sr[1] } : {};
}

// src/core/codeql/host-deps.ts
init_ditto_paths();
init_fs();
import { existsSync } from "fs";
async function drainStream(stream) {
  return new Response(stream).text();
}
function composeEnv(base, set, unset) {
  const env2 = {};
  for (const [k2, v2] of Object.entries(base))
    if (v2 !== undefined)
      env2[k2] = v2;
  for (const [k2, v2] of Object.entries(set))
    env2[k2] = v2;
  for (const k2 of unset)
    delete env2[k2];
  return env2;
}
function makeRelationDeps() {
  return {
    spawn: ({ binary, args, repoRoot, cwd, env: env2 }) => {
      const proc = Bun.spawn([binary, ...args], {
        cwd: cwd === "." ? repoRoot : cwd,
        env: composeEnv(process.env, env2.set, env2.unset),
        stdout: "pipe",
        stderr: "pipe",
        stdin: "ignore"
      });
      return {
        entrypoint: binary,
        stdout: proc.stdout,
        stderr: proc.stderr,
        completion: proc.exited.then((code) => ({ exit_code: code, model_reported: null }))
      };
    },
    readText: (path) => Bun.file(path).text(),
    fileExists: (path) => Bun.file(path).exists(),
    drain: drainStream,
    writeText: async (path, content) => {
      await Bun.write(path, content);
    },
    ensureDir: (path) => ensureDir(path),
    dirExists: async (path) => existsSync(path)
  };
}
function codeqlCacheDir(repoRoot, language) {
  const res = Bun.spawnSync(["git", "rev-parse", "HEAD"], { cwd: repoRoot });
  const sha = res.exitCode === 0 ? new TextDecoder().decode(res.stdout).trim() : "working-tree";
  return localDir(repoRoot, "cache", "codeql", cacheKey(sha, language));
}

