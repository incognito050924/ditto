// src/core/journey-authoring/decompose.ts
var SEPARATORS = /\s*(?:\uADF8\uB9AC\uACE0|\uADF8\uB2E4\uC74C|\uADF8 \uB2E4\uC74C|->|\u2192|,|\bthen\b|\band\b)\s*/g;
function decomposeIntent(intent) {
  const phrases = intent.split(SEPARATORS).map((p2) => p2.trim()).filter((p2) => p2.length > 0);
  const effective = phrases.length > 0 ? phrases : [intent.trim()];
  const steps = effective.map((phrase, i3) => ({ step_id: `s${i3 + 1}`, intent: phrase }));
  return {
    proposed: true,
    steps,
    note: "\uC81C\uC548\uB41C \uB2E8\uACC4 \uCD08\uC548 \u2014 \uC0AC\uC6A9\uC790\uAC00 WHAT\uC744 \uD655\uC815\uD574\uC57C \uD55C\uB2E4 (\uC790\uB3D9 \uBB3C\uC9C8\uD654\xB7\uC790\uB3D9 \uD655\uC815 \uAE08\uC9C0)"
  };
}
// src/core/journey-authoring/ids.ts
var KEBAB = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
function assertKebabSlug(slug) {
  if (!KEBAB.test(slug)) {
    throw new Error(`slug must be kebab-case ([a-z0-9] joined by single hyphens): "${slug}"`);
  }
}
function journeyId(slug) {
  assertKebabSlug(slug);
  return `jrn-${slug}`;
}
function storyId(slug) {
  assertKebabSlug(slug);
  return `us-${slug}`;
}
function dslSlug(jrnId) {
  return jrnId.replace(/^jrn-/, "");
}
