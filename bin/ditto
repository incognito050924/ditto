// src/schemas/language-ledger.ts
var languageChange, languageLedger;
var init_language_ledger = __esm(() => {
  init_zod();
  init_common();
  languageChange = exports_external.object({
    op: exports_external.enum(["add", "modify", "deprecate", "alias"]).describe("What kind of glossary change this entry records"),
    term: exports_external.string().min(1),
    before: exports_external.string().optional().describe("Prior definition or surface form, if applicable"),
    after: exports_external.string().optional().describe("New definition or surface form, if applicable"),
    rationale: exports_external.string().min(1).describe("Why the change is needed; cite user statement when available"),
    proposed_by: exports_external.string().min(1).describe("User handle or agent profile that proposed it"),
    agreed_with_user: exports_external.boolean().describe("True only after explicit user confirmation; defaults to false on creation"),
    decided_at: isoDateTime.optional()
  }).superRefine((value, ctx) => {
    if (value.agreed_with_user === true && value.decided_at === undefined) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        message: "agreed_with_user=true requires decided_at (confirmation timestamp)",
        path: ["decided_at"]
      });
    }
  }).describe("One change to project language as observed during a work item");
  languageLedger = exports_external.object({
    schema_version: schemaVersion,
    work_item_id: workItemId,
    created_at: isoDateTime,
    updated_at: isoDateTime,
    changes: exports_external.array(languageChange).default([])
  }).describe("Per-work-item record of language negotiations; merged into glossary once agreed");
});

// src/schemas/question-round.ts
var questionProperty, questionScore, scoredQuestion, questionRoundPayload, questionRound;
var init_question_round = __esm(() => {
  init_zod();
  init_common();
  questionProperty = exports_external.enum(["blind-spot", "expansion", "orientation"]).describe("Which good-question property the candidate carries (blind-spot / expansion / orientation)");
  questionScore = exports_external.object({
    consensus: exports_external.number().int().nonnegative().describe("How many generators independently raised this question (necessity signal)"),
