    kind: exports_external.enum(["orphan", "stale", "contradiction"]).describe("Class of signal that motivated the action"),
    detail: exports_external.string().min(1).describe("Human-readable basis for this signal")
  }).describe("A single justification signal for a classification");
  cleanupRunParams = exports_external.object({
    work_item_id: exports_external.string().min(1).optional().describe("\uC791\uC5C5ID this run is scoped to"),
