    auto_cleanup: exports_external.boolean().describe("\uC790\uB3D9\uC815\uB9AC \u2014 whether cleanup ran without per-doc approval"),
    concurrency: exports_external.number().int().positive().describe("\uB3D9\uC2DC\uC131 \u2014 worker count"),
    aggressiveness: exports_external.number().int().min(1).max(5).describe("\uC801\uADF9\uC131 \u2014 1 (conservative) \u2026 5 (aggressive)")
  }).describe("Snapshot of the parameters this classify run was invoked with");
