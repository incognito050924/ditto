// src/core/e2e/conformance.ts
function checkStepConformance(input) {
  const errors3 = [];
  const required = [];
  const journey = parseJourneyDoc(input.journeyText);
  if (!journey.ok) {
    errors3.push(`journey: ${journey.error}`);
  } else {
    if (journey.stepIds.length === 0) {
      errors3.push(`journey "${journey.frontMatter.id}": body declares no step id ([sN]) \u2014 nothing to trace, vacuous pass refused`);
    }
    required.push(...journey.stepIds.map((id) => `${journey.frontMatter.id}/${id}`));
    for (const blockId of journey.frontMatter.uses_blocks) {
      const text = input.blockTexts[blockId];
      if (text === undefined) {
        errors3.push(`block "${blockId}" is declared in uses_blocks but no block file was found`);
        continue;
      }
      const block = parseBlockDoc(text);
      if (!block.ok) {
        errors3.push(`block "${blockId}": ${block.error}`);
        continue;
      }
      if (block.frontMatter.id !== blockId) {
        errors3.push(`block "${blockId}": front-matter id "${block.frontMatter.id}" does not match the uses_blocks reference/filename \u2014 block id and filename stem must be identical`);
        continue;
      }
      if (block.stepIds.length === 0) {
        errors3.push(`block "${blockId}": body declares no step id ([bN]) \u2014 nothing to trace, vacuous pass refused`);
        continue;
      }
      required.push(...block.stepIds.map((id) => `${block.frontMatter.id}/${id}`));
    }
    const body = splitFrontMatter(input.journeyText)?.body ?? "";
    const declared = new Set(journey.frontMatter.uses_blocks);
    for (const called of new Set(extractBlockCalls(body))) {
      if (!declared.has(called)) {
        errors3.push(`block "${called}" is invoked by a \uBE14\uB85D: step but missing from uses_blocks \u2014 declare it (\uC601\uD5A5 \uCD94\uB9BC\uACFC \uBE14\uB85D \uAC8C\uC774\uD2B8\uAC00 \uC774 \uC120\uC5B8\uC744 \uBCF8\uB2E4)`);
      }
    }
    for (const caseName of extractCaseNames(body)) {
      if (!input.generatedText.includes(caseName)) {
        errors3.push(`case "${caseName}" is declared in ## \uCF00\uC774\uC2A4 but not found in the generated spec \u2014 every case must become a test`);
      }
    }
  }
  const found = [
    ...new Set([
      ...extractStepMarkers(input.generatedText),
      ...input.supportTexts.flatMap(extractStepMarkers)
    ])
  ];
  const missing = required.filter((ref) => !found.includes(ref));
  return { ok: errors3.length === 0 && missing.length === 0, required, found, missing, errors: errors3 };
}

// src/core/e2e/failure-verdict.ts
init_dist2();
import { readFile as readFile11 } from "fs/promises";
import { join as join61 } from "path";

// src/schemas/e2e-failure-verdict.ts
init_zod();
var e2eFailureClassification = exports_external.enum(["\uAE30\uB2A5", "\uC2A4\uD06C\uB9BD\uD2B8", "\uD658\uACBD", "flaky"]).describe("User verdict on an e2e failure: \uAE30\uB2A5 \uACB0\uD568 | \uC2A4\uD06C\uB9BD\uD2B8 \uACB0\uD568 | \uD658\uACBD\xB7\uB370\uC774\uD130 | flaky (spec \xA78 4\uBD84\uB958)");
var e2eFailureVerdict = exports_external.object({
  journey_id: exports_external.string().min(1).describe("Journey the failing test maps back to (jrn-\u2026)"),
  case_name: exports_external.string().min(1).describe("Case name from the test title `<journey-id> \xB7 <case>`"),
  classification: e2eFailureClassification,
  confirmed_by_user: exports_external.literal(true).describe("Literal true \u2014 a verdict not confirmed by the user cannot be recorded"),
  basis: exports_external.string().min(1).describe("Why this classification (evidence the user judged on)"),
  decided_at: exports_external.string().min(1).describe("ISO timestamp of the user verdict")
}).describe("One user-confirmed e2e failure verdict (e2e-verdicts.jsonl line)");

// src/core/e2e/failure-verdict.ts
init_ditto_paths();
init_fs();
init_shared();
function verdictsPath(repoRoot, workItemId2) {
  return join61(localDir(repoRoot, "work-items", workItemId2), "e2e-verdicts.jsonl");
}
async function appendFailureVerdict(repoRoot, workItemId2, verdict2) {
  const parsed = e2eFailureVerdict.parse(verdict2);
  await ensureDir(localDir(repoRoot, "work-items", workItemId2));
  const path = verdictsPath(repoRoot, workItemId2);
  const file = Bun.file(path);
  const existing = await file.exists() ? await file.text() : "";
  const prefix = existing.length === 0 || existing.endsWith(`
`) ? existing : `${existing}
`;
  await atomicWriteText(path, `${prefix}${JSON.stringify(parsed)}
`);
  return parsed;
}
async function readFailureVerdicts(repoRoot, workItemId2) {
  const file = Bun.file(verdictsPath(repoRoot, workItemId2));
  if (!await file.exists())
    return [];
  const text = await file.text();
  return text.split(`
`).filter((line) => line.trim().length > 0).map((line) => e2eFailureVerdict.parse(JSON.parse(line)));
}
async function featureFixAllowed(repoRoot, workItemId2, journeyId, caseName) {
  const verdicts = (await readFailureVerdicts(repoRoot, workItemId2)).filter((v2) => v2.journey_id === journeyId && v2.case_name === caseName);
  if (verdicts.length === 0) {
    return {
      allowed: false,
      reason: `${journeyId} \xB7 ${caseName}\uC5D0 \uB300\uD55C \uC0AC\uC6A9\uC790 \uD310\uC815\uC774 \uC5C6\uB2E4 \u2014 \uC2E4\uD328 \uC6D0\uC778 \uBD84\uB958(\uAE30\uB2A5/\uC2A4\uD06C\uB9BD\uD2B8/\uD658\uACBD/flaky) \uD310\uC815 \uC804\uC5D0\uB294 \uAE30\uB2A5 \uCF54\uB4DC\uB97C \uC218\uC815\uD560 \uC218 \uC5C6\uB2E4`
    };
  }
  const latest = verdicts[verdicts.length - 1];
  if (latest.classification === "\uAE30\uB2A5") {
    return {
      allowed: true,
      reason: `\uC0AC\uC6A9\uC790\uAC00 \uAE30\uB2A5 \uACB0\uD568\uC73C\uB85C \uD310\uC815 (${latest.decided_at}): ${latest.basis}`
    };
  }
  return {
    allowed: false,
    reason: `\uCD5C\uADFC \uD310\uC815\uC774 '${latest.classification}' \u2014 \uAE30\uB2A5 \uCF54\uB4DC \uC218\uC815\uC740 \uD5C8\uC6A9\uB418\uC9C0 \uC54A\uB294\uB2E4`
  };
}
async function appendFlakyHistory(journeyFilePath, entry) {
  const text = await readFile11(journeyFilePath, "utf8");
  const split = splitFrontMatter(text);
  if (!split) {
    throw new Error(`${journeyFilePath}: no leading ---\u2026--- front-matter block`);
  }
  const raw = parseYaml(split.frontMatter);
  if (raw === null || typeof raw !== "object" || Array.isArray(raw)) {
    throw new Error(`${journeyFilePath}: front-matter is not a YAML mapping`);
  }
  const record = raw;
  const history = Array.isArray(record.flaky_history) ? record.flaky_history : [];
  record.flaky_history = [...history, flakyHistoryEntry.parse(entry)];
  const valid = journeyFrontMatter.safeParse(record);
  if (!valid.success) {
    throw new Error(`${journeyFilePath}: flaky_history update would break front-matter: ${valid.error.message}`);
  }
  await atomicWriteText(journeyFilePath, `---
${$stringify(record)}---
${split.body}`);
}

// src/core/e2e/journey-digest.ts
import { createHash as createHash8 } from "crypto";
import { readFile as readFile12, readdir as readdir17 } from "fs/promises";
init_dist2();
init_shared();
function sha256Hex3(bytes) {
  return createHash8("sha256").update(bytes).digest("hex");
}
function canonicalDigestText(text) {
  const split = splitFrontMatter(text);
  if (!split)
    return text;
  let raw;
  try {
    raw = parseYaml(split.frontMatter);
  } catch {
    return text;
  }
  if (raw === null || typeof raw !== "object" || Array.isArray(raw))
    return text;
  const { flaky_history: _omitted, ...record } = raw;
  return `---
${$stringify(record)}---
${split.body}`;
}
function computeSourceDigest(text) {
  return sha256Hex3(canonicalDigestText(text));
}
var headerLine = (tag) => new RegExp(`^\\s*\\*\\s*${tag}\\s+(\\S+)\\s*$`, "m");
var generatedMarker = /^\s*(?:\/\/|\/?\*+)?\s*@ditto-generated\s*$/m;
function isDittoGenerated(content) {
  return generatedMarker.test(content);
}
function parseGeneratedHeader(content) {
  if (!isDittoGenerated(content))
    return null;
  const source = headerLine("@ditto-source").exec(content)?.[1];
  const digest = /^\s*\*\s*@ditto-digest\s+sha256:([a-f0-9]{64})\s*$/m.exec(content)?.[1];
  if (!source || !digest)
    return null;
  const journey = headerLine("@ditto-journey").exec(content)?.[1];
  const block = headerLine("@ditto-block").exec(content)?.[1];
  return {
    source,
    digest,
    ...journey ? { journey } : {},
    ...block ? { block } : {}
  };
}
async function detectStale(sourceAbs, generatedAbs, expectedSource) {
  let sourceText;
  try {
    sourceText = await readFile12(sourceAbs, "utf8");
  } catch {
    return { stale: true, reason: `source DSL not readable: ${sourceAbs}` };
  }
  let generated;
  try {
    generated = await readFile12(generatedAbs, "utf8");
  } catch {
    return {
      stale: true,
      reason: `generated file not readable (never generated?): ${generatedAbs}`
    };
  }
  const header = parseGeneratedHeader(generated);
  if (!header) {
    return {
      stale: true,
      reason: "generated file has no @ditto-digest header; freshness unprovable"
    };
  }
  if (expectedSource !== undefined && header.source !== expectedSource) {
    return {
      stale: true,
      reason: `@ditto-source mismatch: header points at ${header.source}, expected ${expectedSource} \u2014 provenance unprovable`
    };
  }
  const canonical = computeSourceDigest(sourceText);
  const raw = sha256Hex3(sourceText);
  if (header.digest !== canonical && header.digest !== raw) {
    return {
      stale: true,
      reason: `digest mismatch: header sha256:${header.digest} \u2260 current source sha256:${canonical} (DSL changed after last generation)`
    };
  }
  return { stale: false, reason: "header digest matches current source" };
}

// src/core/e2e/lifecycle.ts
import { readFile as readFile13, readdir as readdir18, unlink as unlink2 } from "fs/promises";
import { basename as basename2, dirname as dirname11, isAbsolute as isAbsolute8, join as join62, relative as relative14, resolve as resolve12, sep as sep5 } from "path";

// src/schemas/e2e-lifecycle.ts
init_zod();
var e2eLifecycleAction = exports_external.enum(["update", "delete"]).describe("update = mark for regeneration (scripter re-runs); delete = remove journey + derived spec");
var e2eLifecycleDecision = exports_external.object({
  action: e2eLifecycleAction,
  journey_id: exports_external.string().min(1).describe("Journey id (jrn-\u2026)"),
  journey_file: exports_external.string().min(1).describe("Repo-relative .journey.md path"),
  confirmed_by_user: exports_external.literal(true).describe("Literal true \u2014 a lifecycle action not confirmed by the user cannot be recorded"),
  reason: exports_external.string().min(1).optional().describe("Why the test became update/delete-worthy"),
  deleted_files: exports_external.array(exports_external.string()).default([]).describe("Repo-relative files removed (delete action)"),
  preserved_helpers: exports_external.array(exports_external.string()).default([]).describe("Shared block helpers kept because another journey still references them"),
  decided_at: exports_external.string().min(1).describe("ISO timestamp of the user decision")
}).describe("One user-confirmed lifecycle decision (e2e-lifecycle.jsonl line)");

// src/core/e2e/lifecycle.ts
init_ditto_paths();
init_fs();
function lifecycleLedgerPath(repoRoot, workItemId2) {
  return workItemId2 === undefined ? localDir(repoRoot, "e2e-lifecycle.jsonl") : join62(localDir(repoRoot, "work-items", workItemId2), "e2e-lifecycle.jsonl");
}
async function appendDecision(path, decision) {
  const parsed = e2eLifecycleDecision.parse(decision);
  const file = Bun.file(path);
  const existing = await file.exists() ? await file.text() : "";
  const prefix = existing.length === 0 || existing.endsWith(`
`) ? existing : `${existing}
`;
  await atomicWriteText(path, `${prefix}${JSON.stringify(parsed)}
`);
}
var toPosix2 = (p) => p.split(sep5).join("/");
async function readOrNull(path) {
  try {
    return await readFile13(path, "utf8");
  } catch {
    return null;
  }
}
async function runLifecycleAction(repoRoot, req) {
  if (!req.confirmedByUser) {
    return {
      ok: false,
      refusal: "\uAC31\uC2E0\xB7\uC0AD\uC81C\uB294 \uC0AC\uC6A9\uC790 \uD655\uC778\uC744 \uAC70\uCCD0\uC57C \uD55C\uB2E4 \u2014 --confirmed-by-user \uC5C6\uC774 \uAC70\uBD80 (\uC5D0\uC774\uC804\uD2B8 \uB2E8\uB3C5 \uACB0\uC815 \uAE08\uC9C0)"
    };
  }
  const journeyAbs = resolve12(repoRoot, req.journeyFile);
  const repoRel = relative14(resolve12(repoRoot), journeyAbs);
  if (repoRel.startsWith("..") || isAbsolute8(repoRel)) {
    return {
      ok: false,
      refusal: `journey \uACBD\uB85C\uAC00 \uC800\uC7A5\uC18C \uBC16\uC744 \uAC00\uB9AC\uD0A8\uB2E4(${req.journeyFile}) \u2014 \uC218\uBA85\uC8FC\uAE30 \uC9D1\uD589\uC740 \uC800\uC7A5\uC18C \uC548\uC758 \uD30C\uC0DD \uD14C\uC2A4\uD2B8\uC5D0\uB9CC \uC801\uC6A9\uB41C\uB2E4`
    };
  }
  const journeyName = basename2(journeyAbs);
  if (!journeyName.endsWith(".journey.md")) {
    return { ok: false, refusal: `journey \uD30C\uC77C\uC774 \uC544\uB2C8\uB2E4(*.journey.md \uC544\uB2D8): ${req.journeyFile}` };
  }
  const journeyText = await readOrNull(journeyAbs);
  if (journeyText === null) {
    return { ok: false, refusal: `journey \uD30C\uC77C\uC744 \uC77D\uC744 \uC218 \uC5C6\uB2E4: ${req.journeyFile}` };
  }
  const parsed = parseJourneyDoc(journeyText);
  if (!parsed.ok) {
    return { ok: false, refusal: `journey DSL \uD30C\uC2F1 \uC2E4\uD328: ${parsed.error}` };
  }
  const slug = journeyName.slice(0, -".journey.md".length);
  const generatedDir = resolve12(dirname11(journeyAbs), "..", "generated");
  const specAbs = join62(generatedDir, `${slug}.spec.ts`);
  const rel = (abs) => toPosix2(relative14(repoRoot, abs));
  const specText = await readOrNull(specAbs);
  if (specText === null) {
    return {
      ok: false,
      refusal: `generated spec \uBD80\uC7AC(${rel(specAbs)}) \u2014 DSL \uD30C\uC0DD\uBB3C\uC784\uC744 \uD655\uC778\uD560 \uC218 \uC5C6\uC5B4 \uAC70\uBD80\uD55C\uB2E4`
    };
  }
  if (!isDittoGenerated(specText)) {
    return {
      ok: false,
      refusal: `${rel(specAbs)}\uB294 @ditto-generated \uB9C8\uCEE4\uAC00 \uC5C6\uB294 \uC218\uB3D9 \uD30C\uC77C \u2014 \uC218\uBA85\uC8FC\uAE30 \uC9D1\uD589\uC740 DSL \uD30C\uC0DD \uD14C\uC2A4\uD2B8\uC5D0\uB9CC \uC801\uC6A9\uB41C\uB2E4`
    };
  }
  const supportDir = join62(generatedDir, "support");
  const helperOf = (blockId) => join62(supportDir, `${blockId}.block.ts`);
  for (const blockId of parsed.frontMatter.uses_blocks) {
    const helperText = await readOrNull(helperOf(blockId));
    if (helperText !== null && !isDittoGenerated(helperText)) {
      return {
        ok: false,
        refusal: `${rel(helperOf(blockId))}\uB294 @ditto-generated \uB9C8\uCEE4\uAC00 \uC5C6\uB294 \uC218\uB3D9 \uD30C\uC77C \u2014 \uAC70\uBD80\uD55C\uB2E4`
      };
    }
  }
  const journeyId = parsed.frontMatter.id;
  const ledgerPath = lifecycleLedgerPath(repoRoot, req.workItemId);
  const decided_at = new Date().toISOString();
  const base = {
    journey_id: journeyId,
    journey_file: rel(journeyAbs),
    confirmed_by_user: true,
    ...req.reason !== undefined ? { reason: req.reason } : {},
    decided_at
  };
  if (req.action === "update") {
    const stale = await detectStale(journeyAbs, specAbs, rel(journeyAbs));
    await appendDecision(ledgerPath, {
      action: "update",
      ...base,
      deleted_files: [],
      preserved_helpers: []
    });
    return {
      ok: true,
      action: "update",
      journey_id: journeyId,
      deleted_files: [],
      preserved_helpers: [],
      stale,
      ledger_path: ledgerPath
    };
  }
  const headerJourney = /^\s*(?:\/\/|\*)?\s*@ditto-journey\s+(\S+)\s*$/m.exec(specText)?.[1];
  const headerSource = /^\s*(?:\/\/|\*)?\s*@ditto-source\s+(\S+)\s*$/m.exec(specText)?.[1];
  const specIdentifiesJourney = headerJourney !== undefined ? headerJourney === journeyId : headerSource === rel(journeyAbs);
  if (!specIdentifiesJourney) {
    return {
      ok: false,
      refusal: `${rel(specAbs)} \uD5E4\uB354\uAC00 \uC774 journey\uB97C \uAC00\uB9AC\uD0A4\uC9C0 \uC54A\uB294\uB2E4 (@ditto-journey ${headerJourney ?? "\uC5C6\uC74C"} / @ditto-source ${headerSource ?? "\uC5C6\uC74C"} \u2260 ${journeyId} \xB7 ${rel(journeyAbs)}) \u2014 \uC0AD\uC81C \uAC70\uBD80`
    };
  }
  const journeysDir = dirname11(journeyAbs);
  const referencedElsewhere = new Set;
  for (const name of (await readdir18(journeysDir)).filter((n2) => n2.endsWith(".journey.md"))) {
    const otherAbs = join62(journeysDir, name);
    if (otherAbs === journeyAbs)
      continue;
    const other = await readOrNull(otherAbs);
    if (other === null)
      continue;
    const otherParsed = parseJourneyDoc(other);
    if (!otherParsed.ok) {
      for (const b2 of parsed.frontMatter.uses_blocks) {
        if (other.includes(b2))
          referencedElsewhere.add(b2);
      }
      continue;
    }
    for (const b2 of otherParsed.frontMatter.uses_blocks)
      referencedElsewhere.add(b2);
  }
  const deleted = [];
  const preserved = [];
  await unlink2(specAbs);
  deleted.push(rel(specAbs));
  for (const blockId of parsed.frontMatter.uses_blocks) {
    const helperAbs = helperOf(blockId);
    if (await readOrNull(helperAbs) === null)
      continue;
    if (referencedElsewhere.has(blockId)) {
      preserved.push(rel(helperAbs));
    } else {
      await unlink2(helperAbs);
      deleted.push(rel(helperAbs));
    }
  }
  await unlink2(journeyAbs);
  deleted.push(rel(journeyAbs));
  await appendDecision(ledgerPath, {
    action: "delete",
    ...base,
    deleted_files: deleted,
    preserved_helpers: preserved
  });
  return {
    ok: true,
    action: "delete",
    journey_id: journeyId,
    deleted_files: deleted,
    preserved_helpers: preserved,
    ledger_path: ledgerPath
  };
}

// src/cli/commands/e2e.ts
init_fs();
var e2eRunSpec = exports_external.object({
  journey: exports_external.string().min(1),
  url: exports_external.string().min(1),
  steps: exports_external.array(e2eStep).default([]),
  assertions: exports_external.array(exports_external.object({ description: exports_external.string().min(1) })).default([])
});
var e2eRun = defineCommand({
  meta: {
    name: "run",
    description: "Run one browser user journey and write its e2eJourney artifact"
  },
  args: {
    runId: { type: "string", description: "Run id \u2192 .ditto/local/runs/<runId>/", required: true },
    json: {
      type: "string",
      description: "JSON spec: {journey,url,steps,assertions}",
      required: true
    },
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let raw;
    try {
      raw = JSON.parse(args.json);
    } catch (err) {
      writeError(`--json is not valid JSON: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const parsed = e2eRunSpec.safeParse(raw);
    if (!parsed.success) {
      writeError("--json failed schema validation:");
      for (const issue of parsed.error.issues) {
        writeError(`  - ${issue.path.join(".") || "(root)"}: ${issue.message}`);
      }
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    try {
      const repoRoot = await resolveRepoRootForCreate();
      const result2 = await runJourney(repoRoot, args.runId, parsed.data);
      const runDir2 = localDir(repoRoot, "runs", args.runId);
      await mkdir7(runDir2, { recursive: true });
      await atomicWriteText(join63(runDir2, "journey.json"), `${JSON.stringify(result2.journey, null, 2)}
`);
      if (format === "json") {
        writeJson2(result2);
      } else {
        writeHuman(`e2e run ${result2.run_id}: ${result2.journey.result}`);
        writeHuman(`  artifact: .ditto/local/runs/${result2.run_id}/journey.json`);
        if (!result2.probe.available)
          writeHuman(`  (blocked: ${result2.probe.reason})`);
      }
    } catch (err) {
      writeError(`e2e run failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
