    detail: exports_external.string().optional().describe("Free-text executor detail (e.g., stderr excerpt)")
  }).superRefine((value, ctx) => {
    if (value.outcome === "advisory_unverified" && !value.advisory_reason) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        message: "advisory_unverified requires advisory_reason (shape_gate | exec_error | tool_absent) \u2014 degradation must be self-describing, never silent (wi_260706n4w ac-2)",
