// src/core/workspace/clone.ts
init_shared();
import { execFileSync as execFileSync7 } from "child_process";
import { existsSync as existsSync15, lstatSync, realpathSync as realpathSync2 } from "fs";
import { readFile as readFile22, readdir as readdir27, rm as rm6, writeFile as writeFile7 } from "fs/promises";
import { basename as basename7, dirname as dirname21, isAbsolute as isAbsolute17, join as join95, relative as relative23, resolve as resolve28 } from "path";
var LOCAL_CLONE_ENV_FLAG = "DITTO_ALLOW_LOCAL_CLONE";
function localTransportAllowed(env2 = process.env) {
  return env2[LOCAL_CLONE_ENV_FLAG] === "1";
}
var ALLOWED_SCHEME = /^(https:\/\/|git:\/\/|ssh:\/\/|[^\s/]+@[^\s/]+:)/;
var RCE_TRANSPORT = /^(ext|fd)::/i;
function isAllowedCloneUrl(url, allowLocal = false) {
  if (url.length === 0)
    return false;
  if (url.startsWith("-"))
    return false;
  if (RCE_TRANSPORT.test(url))
    return false;
  if (ALLOWED_SCHEME.test(url))
    return true;
  return allowLocal;
}

class WorkspaceContainmentError extends Error {
  dir;
  constructor(dir) {
    super(`repo dir "${dir}" is not strictly under the workspace root \u2014 refusing to write outside it (ADR-0011 session-rooting)`);
    this.dir = dir;
    this.name = "WorkspaceContainmentError";
  }
}
function escapesRoot(rel) {
  return rel === "" || rel === "." || rel.startsWith("..") || isAbsolute17(rel);
}
function realpathNearestExisting(p2) {
  let cur = resolve28(p2);
  const tail = [];
  while (!existsSync15(cur)) {
    const parent = dirname21(cur);
    if (parent === cur)
      return join95(realpathSync2(cur), ...tail);
    tail.unshift(basename7(cur));
    cur = parent;
  }
  return tail.length === 0 ? realpathSync2(cur) : join95(realpathSync2(cur), ...tail);
}
function resolveContainedDir(workspaceRoot, dir) {
  const root = resolve28(workspaceRoot);
  const target = resolve28(root, dir);
  if (escapesRoot(relative23(root, target))) {
    throw new WorkspaceContainmentError(dir);
  }
  if (lstatSync(target, { throwIfNoEntry: false })?.isSymbolicLink()) {
    throw new WorkspaceContainmentError(dir);
  }
  if (escapesRoot(relative23(realpathNearestExisting(root), realpathNearestExisting(target)))) {
    throw new WorkspaceContainmentError(dir);
  }
  return target;
}
var NONINTERACTIVE_GIT = {
  GIT_TERMINAL_PROMPT: "0",
  GIT_SSH_COMMAND: "ssh -o BatchMode=yes -o StrictHostKeyChecking=accept-new"
};
function gitOriginUrl(dir) {
  try {
    const v2 = execFileSync7("git", ["config", "--get", "remote.origin.url"], {
      cwd: dir,
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"]
    }).trim();
    return v2.length > 0 ? v2 : null;
  } catch {
    return null;
  }
}
function normalizeUrl(u6) {
  return u6.replace(/\.git$/, "").replace(/\/+$/, "");
}
async function classifyDir(target, url) {
  if (!await fileExists(target))
    return "empty";
  let entries;
  try {
    entries = await readdir27(target);
  } catch {
    return "foreign";
  }
  if (entries.length === 0)
    return "empty";
  const origin = gitOriginUrl(target);
  if (origin !== null && normalizeUrl(origin) === normalizeUrl(url))
    return "same-url";
  return "foreign";
}
function scrub(err) {
  const raw = err && typeof err === "object" && "stderr" in err && err.stderr ? String(err.stderr) : err instanceof Error ? err.message : String(err);
  return raw.trim().split(`
`)[0] ?? "clone failed";
}
async function installRootGateHook(target, workspaceRoot, hookTemplatePath) {
  const r4 = await installPushGateHook({ projectRoot: target, hookTemplatePath, workspaceRoot });
  return r4.status;
}
async function addToParentGitignore(workspaceRoot, dir) {
  const giPath = join95(workspaceRoot, ".gitignore");
  const entry = `${dir.replace(/\/+$/, "")}/`;
  const bare = dir.replace(/\/+$/, "");
  let cur = "";
  if (await fileExists(giPath))
    cur = await readFile22(giPath, "utf8");
  const lines = cur.split(`
`).map((l2) => l2.trim());
  if (lines.includes(entry) || lines.includes(bare))
    return;
  const next = cur.length === 0 ? `${entry}
` : cur.endsWith(`
`) ? `${cur}${entry}
` : `${cur}
${entry}
`;
  await writeFile7(giPath, next);
}
async function cloneRepoEntry(inp) {
  const { workspaceRoot, dir, url, hookTemplatePath, allowLocal, env: env2 } = inp;
  if (!isAllowedCloneUrl(url, allowLocal)) {
    return {
      dir,
      url,
      status: "refused",
      reason: `url scheme not allowed (only https / ssh / git:// are accepted): ${url}`
    };
  }
  let target;
  try {
    target = resolveContainedDir(workspaceRoot, dir);
  } catch (err) {
    return { dir, url, status: "refused", reason: scrub(err) };
  }
  const state = await classifyDir(target, url);
  if (state === "foreign") {
    return {
      dir,
      url,
      status: "refused",
      reason: `${dir} already holds non-matching content \u2014 refusing to overwrite. Remove it or point the recipe elsewhere.`
    };
  }
  if (state === "same-url") {
    const hook2 = await installRootGateHook(target, workspaceRoot, hookTemplatePath);
    return { dir, url, status: "skipped", reason: "already cloned (same url)", hook: hook2 };
  }
  try {
    execFileSync7("git", ["clone", "--", url, target], {
      env: { ...env2, ...NONINTERACTIVE_GIT },
      stdio: ["ignore", "ignore", "pipe"]
    });
  } catch (err) {
    await rm6(target, { recursive: true, force: true });
    return { dir, url, status: "failed", reason: scrub(err) };
  }
  await addToParentGitignore(workspaceRoot, dir);
  const hook = await installRootGateHook(target, workspaceRoot, hookTemplatePath);
  return { dir, url, status: "cloned", hook };
}
async function syncWorkspace(opts) {
  const env2 = opts.env ?? process.env;
  const allowLocal = opts.allowLocal ?? localTransportAllowed(env2);
  const repos = (opts.recipe.repos ?? []).filter((r4) => typeof r4.url === "string" && r4.url.length > 0);
  const outcomes = [];
  for (const r4 of repos) {
    outcomes.push(await cloneRepoEntry({
      workspaceRoot: opts.workspaceRoot,
      dir: r4.dir,
      url: r4.url,
      hookTemplatePath: opts.hookTemplatePath,
      allowLocal,
      env: env2
    }));
  }
  return { outcomes, anyFailed: outcomes.some((o4) => o4.status === "failed") };
}

// src/cli/commands/workspace.ts
var workspaceSync = defineCommand({
  meta: {
    name: "sync",
    description: "Assemble the multi-repo workspace: clone each recipe repos[] entry that declares a `url` into its `dir` (idempotent \u2014 same-url skip, foreign/dirty dir refused, NEVER overwritten), then install the ROOT-recipe pre-push gate hook into each clone (WS_ROOT pinned to the workspace root). Continues past a failed clone, prints a per-repo summary, exits non-zero if any clone FAILED. Auth is ambient git (public/pre-authed urls only). URL scheme allowlist + dir containment + non-interactive git are enforced."
  },
  args: {
    output: { type: "string", description: "Output format: human|json", default: "human" }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const workspaceRoot = await resolveRepoRootForCreate();
    const recipe2 = await loadResolvedRecipe(workspaceRoot, undefined, (origin, message) => {
      writeError(`recipe (${origin}) ignored \u2014 malformed: ${message}`);
    });
    const hookTemplatePath = defaultHookTemplatePath(resolveResourcesDir());
    try {
      const result2 = await syncWorkspace({ workspaceRoot, recipe: recipe2, hookTemplatePath });
      if (format === "json") {
        writeJson2(result2);
      } else if (result2.outcomes.length === 0) {
        writeHuman("No recipe repos[] entries declare a url \u2014 nothing to sync.");
      } else {
        writeHuman(`Workspace sync (${result2.outcomes.length} repo(s) with a url):`);
        for (const o4 of result2.outcomes) {
          const hook = o4.hook ? `	hook=${o4.hook}` : "";
          const reason = o4.reason ? `	(${o4.reason})` : "";
          writeHuman(`  ${o4.status.toUpperCase()}	${o4.dir}	${o4.url}${hook}${reason}`);
        }
        if (result2.anyFailed) {
          writeHuman("At least one clone FAILED \u2014 re-run after resolving the cause above.");
        }
      }
      if (result2.anyFailed)
        process.exit(RUNTIME_ERROR_EXIT);
    } catch (err) {
      writeError(`workspace sync failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
