var SCAFFOLD_DIRS = [
  join70("local", "work-items"),
  join70("local", "runs"),
  join70("local", "handoff"),
  join70("local", "sessions"),
  join70("local", "logs"),
  join70("local", "cache"),
  "agents",
  "knowledge",
  join70("knowledge", "adr")
];
var DITTO_GITIGNORE = `# DITTO per-developer runtime \u2014 volatile, not for version control.
# Managed by \`ditto init\`; safe to edit.
# Tier \u2462 per-developer (gitignored): everything under local/.
local/
# Tier \u2461 project-global (git-shared): knowledge/ and agents/ stay tracked.
!knowledge/
!agents/
`;
function emptyContext(projectName) {
  return `# ${projectName} \u2014 DITTO Knowledge Context

Durable project knowledge lives under \`.ditto/knowledge/\`. This file is seeded
empty by \`ditto init\`; DITTO's knowledge-update flow appends durable decisions,
agreed terms, and learnings over time.

- glossary: \`glossary.json\`
- decisions: \`adr/\`
`;
}
async function ensureDirTracked(absPath, relPath, created) {
  const existed = await fileExists(absPath);
  await ensureDir(absPath);
  if (!existed)
    created.push(relPath);
}
async function seedFileIfAbsent(absPath, relPath, write, created, skipped) {
  if (await fileExists(absPath)) {
    skipped.push(relPath);
    return false;
  }
  await write();
  created.push(relPath);
  return true;
}
async function initScaffold(repoRoot, now) {
  const dittoDir2 = join70(repoRoot, ".ditto");
  const createdDirs = [];
  const createdFiles = [];
  const skippedFiles = [];
  const glossaryAbs = join70(dittoDir2, "knowledge", "glossary.json");
  const alreadyInitialized = await fileExists(glossaryAbs);
  await ensureDirTracked(dittoDir2, ".ditto", createdDirs);
  for (const sub of SCAFFOLD_DIRS) {
    await ensureDirTracked(join70(dittoDir2, sub), join70(".ditto", sub), createdDirs);
  }
  const projectName = basename3(repoRoot) || "project";
  await seedFileIfAbsent(glossaryAbs, join70(".ditto", "knowledge", "glossary.json"), () => writeJson(glossaryAbs, glossary, {
    schema_version: "0.1.0",
    project_name: projectName,
    updated_at: now.toISOString(),
    entries: []
  }).then(() => {
    return;
  }), createdFiles, skippedFiles);
  const contextAbs = join70(dittoDir2, "knowledge", "CONTEXT.md");
  await seedFileIfAbsent(contextAbs, join70(".ditto", "knowledge", "CONTEXT.md"), () => atomicWriteText(contextAbs, emptyContext(projectName)), createdFiles, skippedFiles);
  const gitignoreAbs = join70(dittoDir2, ".gitignore");
  await seedFileIfAbsent(gitignoreAbs, join70(".ditto", ".gitignore"), () => atomicWriteText(gitignoreAbs, DITTO_GITIGNORE), createdFiles, skippedFiles);
  return { repoRoot, createdDirs, createdFiles, skippedFiles, alreadyInitialized };
}

