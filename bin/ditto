var gitState = exports_external.object({
  head: exports_external.string().regex(/^[a-f0-9]{40}$/, "git head must be a full 40-char sha").describe("Commit sha at the moment of capture"),
  branch: exports_external.string().optional(),
  dirty: exports_external.boolean().describe("Whether the working tree has uncommitted changes"),
  untracked_count: exports_external.number().int().nonnegative().default(0)
}).describe("Snapshot of git state taken before or after a run");
var verification = exports_external.object({
  command: exports_external.string().min(1).describe("Exact command executed to verify outcome"),
  exit_code: exports_external.number().int(),
  duration_ms: exports_external.number().int().nonnegative().optional(),
  output_path: relativePath.optional().describe("Where the verification output is stored as evidence"),
