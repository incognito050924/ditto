function tryGitHeadSha(repoRoot) {
  const proc = Bun.spawnSync(["git", "rev-parse", "HEAD"], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (proc.exitCode !== 0)
    return null;
  const sha = (proc.stdout?.toString() ?? "").trim();
  if (!/^[a-f0-9]{40}$/.test(sha))
    return null;
  return sha;
}

class WorkItemStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  workItemDir(id) {
    return localDir(this.repoRoot, "work-items", id);
  }
  workItemPath(id) {
    return join26(this.workItemDir(id), "work-item.json");
  }
  languageLedgerPath(id) {
    return join26(this.workItemDir(id), "language-ledger.json");
  }
  async exists(id) {
    try {
      await stat2(this.workItemPath(id));
      return true;
    } catch {
      return false;
    }
  }
  async create(input, now = new Date) {
    const id = await generateId("wi", (candidate) => this.exists(candidate));
    const nowIso = now.toISOString();
    const draft = {
      schema_version: "0.1.0",
      id,
      title: input.title,
      source_request: input.source_request,
      goal: input.goal,
      acceptance_criteria: input.acceptance_criteria,
      status: "draft",
      owner_profile: input.owner_profile ?? "workspace-write",
      ...input.parent_id !== undefined ? { parent_id: input.parent_id } : {},
      child_ids: [],
      changed_files: [],
      risks: [],
      runs: [],
      created_at: nowIso,
      updated_at: nowIso
    };
    await ensureDir(join26(this.workItemDir(id), "evidence"));
    const written = await writeJson(this.workItemPath(id), workItem, draft);
    await writeJson(this.languageLedgerPath(id), languageLedger, {
      schema_version: "0.1.0",
      work_item_id: id,
      created_at: nowIso,
      updated_at: nowIso,
      changes: []
    });
    return written;
  }
  async get(id) {
    return readJson(this.workItemPath(id), workItem);
  }
  async update(id, mutator) {
    const current = await this.get(id);
    const next = mutator(current);
    if (next.id !== current.id) {
      throw new Error(`update mutator changed work item id from ${current.id} to ${next.id}`);
    }
    let withSha = next;
    if (next.status === "in_progress" && next.started_at_sha === undefined) {
      const sha = tryGitHeadSha(this.repoRoot);
      if (sha !== null) {
        withSha = { ...next, started_at_sha: sha };
      }
    }
    const withTouched = { ...withSha, updated_at: new Date().toISOString() };
    return writeJson(this.workItemPath(id), workItem, withTouched);
  }
  async close(id, terminal, now = new Date) {
    return this.update(id, (cur) => ({
      ...cur,
      status: terminal,
      closed_at: now.toISOString()
    }));
  }
  async archive(label) {
    if (!/^[A-Za-z0-9._-]+$/.test(label) || label === "." || label === "..") {
      throw new Error(`archive label must be a safe path segment ([A-Za-z0-9._-]+, not '.' or '..'; got: ${label})`);
    }
    const targets = (await this.list()).filter((s2) => s2.status === "done" || s2.status === "abandoned");
    if (targets.length === 0)
      return [];
    const archiveBase = localDir(this.repoRoot, "archive", label);
    await ensureDir(archiveBase);
    for (const t2 of targets) {
      await rename2(this.workItemDir(t2.id), join26(archiveBase, t2.id));
    }
    return targets.map((t2) => t2.id);
  }
  async list() {
    const base = localDir(this.repoRoot, "work-items");
    let entries;
    try {
      entries = await readdir8(base);
    } catch {
      return [];
    }
    const summaries = [];
    for (const name of entries) {
      const dir = join26(base, name);
      let s2;
      try {
        s2 = await stat2(dir);
      } catch {
        continue;
      }
      if (!s2.isDirectory())
        continue;
      try {
        const item = await readJson(join26(dir, "work-item.json"), workItem);
        summaries.push({
          id: item.id,
          title: item.title,
          status: item.status,
          updated_at: item.updated_at
        });
      } catch {}
    }
    summaries.sort((a2, b2) => a2.updated_at < b2.updated_at ? 1 : -1);
    return summaries;
  }
  async appendJsonlAtPath(path, jsonLine) {
    await ensureDir(dirname8(path));
    const file = Bun.file(path);
    const existing = await file.exists() ? await file.text() : "";
    const trimmedExisting = existing.endsWith(`
`) || existing.length === 0 ? existing : `${existing}
`;
    await atomicWriteText(path, `${trimmedExisting}${jsonLine}
`);
  }
  async appendEvidenceJsonl(workItemId2, filename, jsonLine) {
    return this.appendJsonlAtPath(join26(this.workItemDir(workItemId2), "evidence", filename), jsonLine);
  }
  async appendCommandLogLine(workItemId2, jsonLine) {
    return this.appendEvidenceJsonl(workItemId2, "commands.jsonl", jsonLine);
  }
  async appendEditLogLine(workItemId2, jsonLine) {
    return this.appendEvidenceJsonl(workItemId2, "edits.jsonl", jsonLine);
  }
  metricsPath(workItemId2) {
    return join26(this.workItemDir(workItemId2), "metrics.jsonl");
  }
  async appendMetricLine(workItemId2, jsonLine) {
    return this.appendJsonlAtPath(this.metricsPath(workItemId2), jsonLine);
  }
  async readMetrics(workItemId2) {
    const file = Bun.file(this.metricsPath(workItemId2));
    if (!await file.exists())
      return [];
    const text = await file.text();
    return text.split(`
`).filter((line) => line.trim().length > 0).map((line) => intentMetric.parse(JSON.parse(line)));
  }
  techSpecRoundsPath(workItemId2) {
    return join26(this.workItemDir(workItemId2), "tech-spec-rounds.jsonl");
  }
  async appendTechSpecRoundLine(workItemId2, jsonLine) {
    return this.appendJsonlAtPath(this.techSpecRoundsPath(workItemId2), jsonLine);
  }
  async readTechSpecRounds(workItemId2) {
    const file = Bun.file(this.techSpecRoundsPath(workItemId2));
    if (!await file.exists())
      return [];
    const text = await file.text();
    return text.split(`
`).filter((line) => line.trim().length > 0).map((line) => techSpecRound.parse(JSON.parse(line)));
  }
}
var acceptanceCriterionInputSchema = exports_external.object({
  id: exports_external.string().min(1),
  statement: exports_external.string().min(1)
}).passthrough();

// src/core/tech-spec.ts
var SPEC_SECTIONS = [
  { id: "feature", title: "\uAE30\uB2A5" },
  { id: "summary", title: "\uC694\uC57D" },
  { id: "background", title: "\uBC30\uACBD" },
  { id: "goals", title: "\uBAA9\uD45C" },
  { id: "non-goals", title: "\uBE44\uBAA9\uD45C" },
  { id: "acceptance-criteria", title: "\uC644\uB8CC \uC870\uAC74" },
  { id: "risks", title: "\uC704\uD5D8" },
  { id: "plan", title: "\uACC4\uD68D" },
  { id: "impact", title: "\uC601\uD5A5\uB3C4" },
  { id: "rejected-alternatives", title: "\uAE30\uAC01\uB41C \uB300\uC548" },
  { id: "milestones", title: "\uB9C8\uC77C\uC2A4\uD1A4" },
  { id: "interview-log", title: "\uC778\uD130\uBDF0 \uAE30\uB85D" },
  { id: "post-build", title: "\uBE4C\uB4DC \uD6C4 \uCC98\uB9AC" }
];
var COMPILE_INPUT_SECTIONS = [
  "summary",
  "goals",
  "non-goals",
  "acceptance-criteria",
  "risks"
];
var FACTUAL_SECTIONS = ["background", "impact"];
var EVIDENCE_KINDS = new Set(["test", "diff", "doc", "browser", "log"]);
function headingText(line) {
  return line.replace(/^##\s+/, "").replace(/^\d+\.\s*/, "").trim();
}
function sectionIdFor(heading) {
  for (const s2 of SPEC_SECTIONS) {
    if (heading.startsWith(s2.title))
      return s2.id;
  }
  return null;
}
function normalizeBody(body) {
  return body.replace(/\r\n/g, `
`).split(`
`).map((l2) => l2.trimEnd()).join(`
`).replace(/^\n+/, "").replace(/\n+$/, "");
}
function parseSpecSections(markdown) {
  const lines = markdown.replace(/\r\n/g, `
`).split(`
`);
  const sections = new Map;
  const duplicates = [];
  let current = null;
  let buf = [];
  const flush = () => {
    if (current === null)
      return;
    const body = normalizeBody(buf.join(`
`));
    if (sections.has(current))
      duplicates.push(current);
    else
      sections.set(current, body);
  };
  for (const line of lines) {
    if (line.startsWith("## ")) {
      flush();
      current = sectionIdFor(headingText(line));
      buf = [];
    } else if (current !== null) {
      buf.push(line);
    }
  }
  flush();
  return { sections, duplicates };
}
function computeSpecDigest(markdown) {
  const { sections } = parseSpecSections(markdown);
  const hash = createHash3("sha256");
  for (const id of COMPILE_INPUT_SECTIONS) {
    hash.update(`${id}
${sections.get(id) ?? ""}\x00`);
  }
  return hash.digest("hex");
}
function listItems(body) {
  return body.split(`
`).map((l2) => l2.trim()).filter((l2) => /^([-*]|\d+\.)\s+/.test(l2)).map((l2) => l2.replace(/^([-*]|\d+\.)\s+/, "").trim());
}
function tableRows(body) {
  const rows = body.split(`
`).map((l2) => l2.trim()).filter((l2) => l2.startsWith("|")).map((l2) => l2.replace(/^\|/, "").replace(/\|$/, "").split("|").map((c3) => c3.trim()));
  return rows.filter((cells, i2) => i2 > 0 && !cells.every((c3) => /^:?-+:?$/.test(c3) || c3 === ""));
}
function compileSpecDoc(markdown) {
  const { sections, duplicates } = parseSpecSections(markdown);
  const reasons = [];
  for (const dup of duplicates) {
    if (COMPILE_INPUT_SECTIONS.includes(dup)) {
      const title = SPEC_SECTIONS.find((s2) => s2.id === dup)?.title ?? dup;
      reasons.push(`\uC139\uC158 "${title}"\uC774 \uC911\uBCF5 \uC815\uC758\uB428 \u2014 \uCEF4\uD30C\uC77C \uC6D0\uBCF8\uC774 \uBAA8\uD638\uD568`);
    }
  }
  for (const id of COMPILE_INPUT_SECTIONS) {
    const title = SPEC_SECTIONS.find((s2) => s2.id === id)?.title ?? id;
    const body = sections.get(id);
    if (body === undefined)
      reasons.push(`\uD544\uC218 \uC139\uC158 \uB204\uB77D: "${title}"`);
    else if (body === "")
      reasons.push(`\uD544\uC218 \uC139\uC158\uC774 \uBE44\uC5B4 \uC788\uC74C: "${title}"`);
  }
  if (reasons.length > 0)
    return { status: "rejected", reasons };
  const summary = sections.get("summary");
  const goalsBody = sections.get("goals");
  const nonGoalsBody = sections.get("non-goals");
  const acBody = sections.get("acceptance-criteria");
  const risksBody = sections.get("risks");
  const acceptance_criteria = [];
  const seenIds = new Set;
  for (const cells of tableRows(acBody)) {
    const [id, statement, evidenceCell] = [cells[0] ?? "", cells[1] ?? "", cells[2] ?? ""];
    if (!id || !statement) {
      reasons.push(`\uC644\uB8CC \uC870\uAC74 \uD45C\uC758 \uD589\uC774 \uBD88\uC644\uC804\uD568: "${cells.join(" | ")}"`);
      continue;
    }
    if (seenIds.has(id)) {
      reasons.push(`\uC644\uB8CC \uC870\uAC74 id \uC911\uBCF5: ${id}`);
      continue;
    }
    seenIds.add(id);
    const kinds = evidenceCell.split(/[^a-z]+/i).filter((t2) => t2.length > 0);
    const invalid = kinds.filter((k2) => !EVIDENCE_KINDS.has(k2.toLowerCase()));
    if (kinds.length === 0 || invalid.length > 0) {
      reasons.push(`\uC644\uB8CC \uC870\uAC74 ${id}\uC758 evidence \uC885\uB958\uAC00 enum(test|diff|doc|browser|log) \uBC16: "${evidenceCell}"`);
      continue;
    }
    acceptance_criteria.push({
      id,
      statement,
      verdict: "unverified",
      evidence: [],
      evidence_required: kinds.map((k2) => k2.toLowerCase())
    });
  }
  if (acceptance_criteria.length === 0 && reasons.length === 0) {
    reasons.push("\uC644\uB8CC \uC870\uAC74 \uD45C\uC5D0 \uD589\uC774 \uC5C6\uC74C \u2014 AC\uAC00 \uC774 \uBB38\uC11C\uC758 \uD0A4\uC2A4\uD1A4\uC774\uB2E4");
  }
  if (reasons.length > 0)
    return { status: "rejected", reasons };
  const unknowns = tableRows(risksBody).filter((cells) => /unknown/i.test(cells[1] ?? "")).map((cells) => cells[0] ?? "").filter((s2) => s2.length > 0);
  return {
    status: "compiled",
    fields: {
      goal: summary.trim(),
      in_scope: listItems(goalsBody).length > 0 ? listItems(goalsBody) : [goalsBody],
      out_of_scope: listItems(nonGoalsBody).length > 0 ? listItems(nonGoalsBody) : [nonGoalsBody],
      acceptance_criteria,
      unknowns
    },
    digest: computeSpecDigest(markdown)
  };
}
var recordSectionPayload = exports_external.object({
  section: exports_external.object({
    id: specSectionId,
    review: specReviewState.default("pending"),
    evidence: exports_external.array(specGroundingEvidence).default([])
  })
}).superRefine((val, ctx) => {
  if (FACTUAL_SECTIONS.includes(val.section.id) && val.section.evidence.length === 0) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      path: ["section", "evidence"],
      message: `\uC0AC\uC2E4 \uC139\uC158 "${val.section.id}"\uC740 \uADFC\uAC70 \uC870\uD68C \uC99D\uAC70(memory projection_id \uB610\uB294 ACG \uC0B0\uCD9C\uBB3C \uACBD\uB85C)\uAC00 \uC2A4\uD0A4\uB9C8 \uD544\uC218\uB2E4 \u2014 \uC99D\uAC70 \uC5C6\uC774 \uAE30\uB85D\uD560 \uC218 \uC5C6\uC74C (ac-9)`
    });
  }
});
async function startTechSpec(repoRoot, input) {
  const nowIso = (input.now ?? new Date).toISOString();
  return new TechSpecStore(repoRoot).write({
    schema_version: "0.1.0",
    work_item_id: input.workItemId,
    doc_path: input.docPath,
    mode: input.mode ?? "stepwise",
    sections: [],
    question_config: input.questionConfig ?? resolveQuestionConfig({}),
    finalized: null,
    updated_at: nowIso
  });
}
async function recordSection(repoRoot, input) {
  const store = new TechSpecStore(repoRoot);
  const state = await store.get(input.workItemId);
  const nowIso = (input.now ?? new Date).toISOString();
  const record = {
    id: input.payload.section.id,
    review: input.payload.section.review,
    evidence: input.payload.section.evidence,
    recorded_at: nowIso
  };
  const idx = state.sections.findIndex((s2) => s2.id === record.id);
  const sections = idx === -1 ? [...state.sections, record] : state.sections.map((s2, i2) => i2 === idx ? record : s2);
  return store.write({ ...state, sections, updated_at: nowIso });
}
var recordRoundPayload = techSpecRoundPayload;
async function recordRound(repoRoot, input) {
  const store = new WorkItemStore(repoRoot);
  if (!await store.exists(input.workItemId)) {
    throw new Error(`work item ${input.workItemId} not found`);
  }
  const record = techSpecRound.parse({
    ts: (input.now ?? new Date).toISOString(),
    work_item_id: input.workItemId,
    ...input.payload
  });
  await store.appendTechSpecRoundLine(input.workItemId, JSON.stringify(record));
  return record;
}
async function nextRound(repoRoot, input) {
  const techStore = new TechSpecStore(repoRoot);
  if (!await techStore.exists(input.workItemId)) {
    throw new Error(`tech-spec was never started for ${input.workItemId} \u2014 run 'ditto tech-spec start' first`);
  }
  const cfg = (await techStore.get(input.workItemId)).question_config;
  const rounds = await new WorkItemStore(repoRoot).readTechSpecRounds(input.workItemId);
  const rounds_so_far = rounds.length;
  const questions_so_far = rounds.reduce((n2, r3) => n2 + r3.selected.length, 0);
  const roundCapHit = cfg.max_rounds > 0 && rounds_so_far >= cfg.max_rounds;
  const questionCapHit = cfg.max_questions > 0 && questions_so_far >= cfg.max_questions;
  const cap_reason = roundCapHit ? "max_rounds" : questionCapHit ? "max_questions" : null;
  return {
    round: rounds_so_far + 1,
    generators: cfg.generators,
    threshold: cfg.threshold,
    granularity: cfg.granularity,
    generator_effort: cfg.generator_effort,
    gate_mode: cfg.gate_mode,
    count_hint: cfg.count_hint,
    max_rounds: cfg.max_rounds,
    max_questions: cfg.max_questions,
    rounds_so_far,
    questions_so_far,
    cap_reached: cap_reason !== null,
    cap_reason
  };
}
var finalizeTechSpecPayload = exports_external.object({
  risk: exports_external.object({
    non_local: exports_external.boolean().default(false),
    irreversible: exports_external.boolean().default(false),
    unaudited: exports_external.boolean().default(false)
  }).default({ non_local: false, irreversible: false, unaudited: false }),
  approved_source: exports_external.enum(["approved_spec", "issue", "prd", "user"]).optional(),
  user_confirmation: userConfirmation
});
async function finalizeTechSpec(repoRoot, input) {
  const specStore = new TechSpecStore(repoRoot);
  if (!await specStore.exists(input.workItemId))
    return { status: "not_started" };
  const state = await specStore.get(input.workItemId);
  let markdown;
  try {
    markdown = await readFile2(join27(repoRoot, state.doc_path), "utf8");
  } catch {
    return { status: "doc_missing", doc_path: state.doc_path };
  }
  const compiled = compileSpecDoc(markdown);
  if (compiled.status === "rejected") {
    return { status: "compile_rejected", reasons: compiled.reasons };
  }
  const interviews = new InterviewStore(repoRoot);
  if (await interviews.exists(input.workItemId)) {
    const gate2 = interviewReadinessGate(await interviews.get(input.workItemId));
    if (!gate2.pass)
      return { status: "interview_not_ready", gate: gate2 };
  }
  if (!input.payload.user_confirmation.confirmed)
    return { status: "not_confirmed" };
  const items = new WorkItemStore(repoRoot);
  const workItem2 = await items.get(input.workItemId);
  const intent = {
    schema_version: "0.1.0",
    work_item_id: input.workItemId,
    source_request: workItem2.source_request,
    goal: compiled.fields.goal,
    in_scope: compiled.fields.in_scope,
    out_of_scope: compiled.fields.out_of_scope,
    acceptance_criteria: compiled.fields.acceptance_criteria,
    unknowns: compiled.fields.unknowns,
    follow_up_candidates: [],
    question_policy: "ask_only_if_user_only_can_answer",
    source_digest: { doc_path: state.doc_path, sha256: compiled.digest }
  };
  const writtenIntent = await new IntentStore(repoRoot).write(intent);
  await items.update(input.workItemId, (current) => ({
    ...current,
    acceptance_criteria: compiled.fields.acceptance_criteria.map((ac) => ({
      id: ac.id,
      statement: ac.statement,
      verdict: ac.verdict,
      evidence: ac.evidence
    })),
    goal: compiled.fields.goal
  }));
  const nowIso = (input.now ?? new Date).toISOString();
  const recorded = new Map(state.sections.map((s2) => [s2.id, s2.review]));
  const finalizedState = await specStore.write({
    ...state,
    finalized: {
      at: nowIso,
      digest: compiled.digest,
      review_coverage: SPEC_SECTIONS.map((s2) => ({
        id: s2.id,
        review: recorded.get(s2.id) ?? "pending"
      }))
    },
    updated_at: nowIso
  });
  const refreshedItem = await items.get(input.workItemId);
  const risk = input.payload.risk;
  const boot = await bootstrapAutopilot(repoRoot, {
    workItem: refreshedItem,
    intent: writtenIntent,
    risk,
    ...input.payload.approved_source ? { approvedSource: input.payload.approved_source } : {},
    ...input.now ? { now: input.now } : {}
  });
  if (boot.status !== "created") {
    throw new Error(`spec compiled but bootstrapAutopilot failed (${boot.status}): ${boot.reasons.join("; ")}`);
  }
  return {
    status: "finalized",
    intent: writtenIntent,
    autopilot: boot.graph,
    state: finalizedState
  };
}

// src/core/autopilot-loop.ts
function isMutatingNode(node2) {
  return isMutatingOwner(node2.owner);
}
async function specDigestStale(repoRoot, workItemId2) {
  const intentStore = new IntentStore(repoRoot);
  if (!await intentStore.exists(workItemId2))
    return null;
  const intent = await intentStore.get(workItemId2);
  if (!intent.source_digest)
    return null;
  const { doc_path, sha256: sha2562 } = intent.source_digest;
  let doc;
  try {
    doc = await readFile3(join28(repoRoot, doc_path), "utf8");
  } catch {
    doc = null;
  }
  if (doc !== null && computeSpecDigest(doc) === sha2562)
    return null;
  return {
    action: "blocked",
    blocked_node_ids: [],
    reason: doc === null ? `spec document ${doc_path} is missing but intent.json was compiled from it \u2014 restore the document or re-run \`ditto tech-spec finalize\` (ac-6)` : `spec document ${doc_path} changed after finalize (source_digest mismatch) \u2014 re-run \`ditto tech-spec finalize\` to re-compile intent.json before executing (ac-6)`
  };
}
async function nextNode(repoRoot, workItemId2) {
  const aps = new AutopilotStore(repoRoot);
  const graph = await aps.get(workItemId2);
  if (graph.approval_gate.status === "rejected") {
    const rb = rollbackOnRejection(graph);
    const rolledBack = graph.nodes.filter((n2) => n2.status === "running").map((n2) => n2.id);
    await aps.write(workItemId2, { ...graph, nodes: rb.nodes });
    return { action: "rollback", reason: rb.reason, rolled_back_node_ids: rolledBack };
  }
  const staleSpec = await specDigestStale(repoRoot, workItemId2);
  if (staleSpec)
    return staleSpec;
  const ready = selectReadyNodes(graph.nodes);
  if (ready.length === 0) {
    if (allNodesTerminal(graph)) {
      const all_passed = graph.nodes.every((n2) => n2.status === "passed");
      return {
        action: "done",
        all_passed,
        reason: all_passed ? "all nodes passed \u2014 completion judgment owed: graph done \u2260 acceptance criteria closed; run completion to close each AC with the collected evidence (\xA76.8)" : "all nodes terminal but \u22651 node failed \u2014 completion will judge partial/fail; run completion judgment (\xA76.8)"
      };
    }
    const running = graph.nodes.some((n2) => n2.status === "running");
    if (!running) {
      const blocked = graph.nodes.filter((n2) => n2.status === "blocked");
      if (blocked.length > 0) {
        const decisions = await aps.readDecisions(workItemId2);
        const lastReason = (id) => decisions.filter((d2) => d2.node_id === id).at(-1)?.reason;
        const detail = blocked.map((n2) => {
          const why = lastReason(n2.id);
          return why ? `${n2.id} \u2014 ${why}` : n2.id;
        }).join("; ");
        return {
          action: "blocked",
          blocked_node_ids: blocked.map((n2) => n2.id),
          reason: `blocked on a user-owned decision (\xA74.3): ${detail}`
        };
      }
    }
    return {
      action: "waiting",
      reason: "no ready node: dependencies unmet or a node is still running"
    };
  }
  const workItem2 = await new WorkItemStore(repoRoot).get(workItemId2);
  const scopeOf = (n2) => n2.file_scope ?? workItem2.changed_files;
  const runningClaims = graph.nodes.filter((n2) => n2.status === "running" && isMutatingNode(n2)).map((n2) => ({ id: `__running__${n2.id}`, file_scope: scopeOf(n2) }));
  const { dispatch } = fileOverlapGate([
    ...runningClaims,
    ...ready.map((n2) => ({ id: n2.id, file_scope: scopeOf(n2) }))
  ]);
  const admitted = dispatch.map((d2) => ready.find((n2) => n2.id === d2.id)).filter((n2) => n2 !== undefined);
  if (admitted.length === 0) {
    return { action: "waiting", reason: "all ready nodes deferred by the file-overlap gate" };
  }
  const gate2 = mutationGate(graph);
  const isWaveEligible = (n2) => n2.owner !== "driver" && n2.owner !== "main-session" && (!isMutatingNode(n2) || gate2.allowed);
  let unknownMutatingAdmitted = false;
  const waveEligible = admitted.filter((n2) => {
    if (!isWaveEligible(n2))
      return false;
    if (!isMutatingNode(n2))
      return true;
    if (n2.file_scope !== undefined)
      return true;
    if (unknownMutatingAdmitted)
      return false;
    unknownMutatingAdmitted = true;
    return true;
  });
  const leases = new ActiveNodeLeaseStore(repoRoot);
  const now = new Date;
  if (waveEligible.length >= 2) {
    const catalog2 = await loadVariantCatalog(repoRoot);
    const spawns = [];
    for (const node2 of waveEligible) {
      await aps.updateNode(workItemId2, node2.id, (n2) => ({
        ...n2,
        status: nodeTransition(n2.status, "dispatch")
      }));
      await leases.set({
        node_id: node2.id,
        work_item_id: workItemId2,
        file_scope: scopeOf(node2),
        scope_source: node2.file_scope !== undefined ? "declared" : "derived",
        created_at: now.toISOString()
      });
      const candidates2 = selectVariantCandidates(catalog2, node2.owner, scopeOf(node2), node2.agent_hint);
      const memory2 = await warmStartMemoryContext(repoRoot, node2, workItem2, { now });
      spawns.push({
        node_id: node2.id,
        owner: node2.owner,
        packet: buildDelegationPacket(node2, workItem2, candidates2, scopeOf(node2), memory2)
      });
    }
    return { action: "spawn_wave", spawns };
  }
  const chosen = admitted[0];
  if (!chosen) {
    return { action: "waiting", reason: "all ready nodes deferred by the file-overlap gate" };
  }
  if (chosen.owner === "driver") {
    await aps.updateNode(workItemId2, chosen.id, (n2) => ({
      ...n2,
      status: nodeTransition(n2.status, "dispatch")
    }));
    return {
      action: "cleanup",
      node_id: chosen.id,
      reason: `deterministic cleanup step (${chosen.kind}): run \`autopilot cleanup\` (irreversible git \u2192 explicit approval)`
    };
  }
  if (chosen.owner === "main-session") {
    await aps.updateNode(workItemId2, chosen.id, (n2) => ({
      ...n2,
      status: nodeTransition(n2.status, "dispatch")
    }));
    return {
      action: "main_session",
      node_id: chosen.id,
      reason: `main-session step (${chosen.kind}): run the ditto:e2e-author skill inline (user dialogue), then record-result`
    };
  }
  if (isMutatingNode(chosen) && !gate2.allowed) {
    return { action: "present_plan", reason: gate2.reason };
  }
  await aps.updateNode(workItemId2, chosen.id, (n2) => ({
    ...n2,
    status: nodeTransition(n2.status, "dispatch")
  }));
  await leases.set({
    node_id: chosen.id,
    work_item_id: workItemId2,
    file_scope: scopeOf(chosen),
    scope_source: chosen.file_scope !== undefined ? "declared" : "derived",
    created_at: now.toISOString()
  });
  const catalog = await loadVariantCatalog(repoRoot);
  const candidates = selectVariantCandidates(catalog, chosen.owner, scopeOf(chosen), chosen.agent_hint);
  const memory = await warmStartMemoryContext(repoRoot, chosen, workItem2, { now });
  return {
    action: "spawn",
    node_id: chosen.id,
    owner: chosen.owner,
    packet: buildDelegationPacket(chosen, workItem2, candidates, scopeOf(chosen), memory)
  };
}
var recordResultPayload = exports_external.object({
  node_id: exports_external.string().min(1),
  result_text: exports_external.string().describe("The owner subagent's full final text (fed to the G7 guard)"),
  outcome: exports_external.enum(["pass", "fail"]).describe("Caller judgment; pass is overridden if non-contentful"),
  failure_class: exports_external.enum(["fixable", "wrong_approach", "blocked_external", "user_decision_needed"]).optional().describe("Required when outcome=fail; the caller-supplied classification"),
  evidence_refs: exports_external.array(evidenceRef).optional().describe("Evidence pointers gathered on pass"),
  ac_verdicts: exports_external.array(exports_external.object({ criterion_id: exports_external.string().min(1), verdict, notes: exports_external.string().optional() })).optional().describe("A judging node's per-AC verdicts (verifier/e2e). The node still records a single " + "pass/fail outcome, but a verify node can pass *as a node* while judging one criterion " + "partial/fail; persisting the per-AC verdicts here keeps `autopilot complete` from " + "over-closing that criterion to pass (false-green; claim \u2260 proof)."),
  changed_files: exports_external.array(relativePath).optional().describe("Repo-relative paths this node changed (#1). On a contentful pass they are unioned " + "into the work item changed_files so `autopilot complete` reads them without a manual " + "pin. The expected reporter is a mutating node (implementer/refactorer)."),
  reason: exports_external.string().optional().describe("2\u20133 line rationale recorded in the decision log"),
  generated_nodes: exports_external.array(nodeProposal).optional().describe("Subgraph this node generated (A-3). Promoted to the graph via addNodes on a " + "contentful pass; a planner/design node uses this to grow the graph past the seed."),
  has_findings: exports_external.boolean().optional().describe("Reviewer/security verdict that findings remain (A-2). On a contentful review- or " + "security-node pass, true splices a forward fix+re-check round (\xA72.4) under the " + "convergence budget, false/absent closes the loop. Ignored for other node kinds."),
  tidy_bug_found: exports_external.boolean().optional().describe("Tidy failure policy (80-plan \xA78, WU-3 ac-4). On a `refactor` (tidy) node FAIL, " + "true means the tidy pass uncovered a real defect in the implementation. The " + "engine then returns the implement node the tidy stage roots on to pending \u2014 it " + "does NOT fix the bug here and does NOT retry the tidy node in place (the fix " + "belongs to the implement node). Ignored for non-refactor nodes / on pass."),
  plan_brief: exports_external.object({
    change_surface: exports_external.array(relativePath),
    interface_changes: exports_external.array(exports_external.string()).default([]),
    dod: exports_external.array(exports_external.string()).default([]),
    test_scenarios: exports_external.array(exports_external.string()).default([]),
    tier_inputs: exports_external.object({
      changedFileCount: exports_external.number().int().nonnegative(),
      interfaceChanged: exports_external.boolean(),
      risk: exports_external.object({
        non_local: exports_external.boolean(),
        irreversible: exports_external.boolean(),
        unaudited: exports_external.boolean()
      }),
      large: exports_external.boolean()
    })
  }).optional().describe("A plan-stage (design/planner) node's pre-mortem coverage brief + tier inputs. On a " + "contentful design pass it populates approval_gate.{plan_brief,change_surface,status} " + "via producePlanGate (brief hard-gate, \xA77.2). Ignored for non-design nodes."),
  decision_conflicts: exports_external.array(decisionConflict).optional().describe("The planner's declared ADR conflicts (ADR-0020 D3 producer). On a contentful design " + "pass a non-empty list is written to the decision-conflict carrier so an intent " + "conflict front-loads the approval gate (prevention) and the Stop hook re-checks it " + "(catch). Absent/empty \u21D2 no carrier written (backward compat). Ignored for non-design.")
}).superRefine((value, ctx) => {
  if (value.outcome === "fail" && value.failure_class === undefined) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      path: ["failure_class"],
      message: "failure_class is required when outcome=fail"
    });
  }
}).describe("One node result \u2014 caller judgment that the deterministic floor then enforces");
async function spliceTidyStage(repoRoot, workItemId2, implementNode, aps) {
  const wi = await new WorkItemStore(repoRoot).get(workItemId2);
  const diffStat = wi.started_at_sha ? collectTidyDiffStat(repoRoot, wi.started_at_sha) : { files: [] };
  const graph = await aps.get(workItemId2);
  const plan = planTidyOnImplementPass({
    implementNodeId: implementNode.id,
    diffStat,
    acceptanceIds: implementNode.acceptance_refs,
    existingNodeIds: graph.nodes.map((n2) => n2.id)
  });
  await writeTidyClassification(repoRoot, workItemId2, plan.classification);
  if (plan.nodes.length === 0)
    return [];
  await aps.addNodes(workItemId2, plan.nodes);
  return plan.nodes.map((n2) => n2.id);
}
var GATE_TIMEOUT_MS = 3000;
var GATE_CONCURRENCY = 4;
var GATE_FILE_CAP = 24;
async function surfaceLspDiagnostics(repoRoot, workItemId2, changedFiles) {
  const targets = changedFiles.map((file) => ({ file, language: lspLanguageForPath(file) })).filter((t2) => t2.language !== null);
  const serverByLang = new Map;
  const checkable = targets.filter(({ language }) => {
    let ok = serverByLang.get(language);
    if (ok === undefined) {
      ok = resolveServer(language) !== null;
      serverByLang.set(language, ok);
    }
    return ok;
  });
  if (checkable.length === 0)
    return [];
  const checked = checkable.slice(0, GATE_FILE_CAP);
  const truncated = checkable.length - checked.length;
  const surfaced = [];
  for (let i2 = 0;i2 < checked.length; i2 += GATE_CONCURRENCY) {
    const batch = await Promise.all(checked.slice(i2, i2 + GATE_CONCURRENCY).map(async ({ file, language }) => {
      const diags = await getDiagnostics(join28(repoRoot, file), {
        language,
        timeoutMs: GATE_TIMEOUT_MS
      });
      const errors3 = diags.filter((d2) => d2.severity === "error");
      return errors3.length > 0 ? { file, diagnostics: errors3 } : null;
    }));
    for (const r3 of batch)
      if (r3)
        surfaced.push(r3);
  }
  try {
    await ensureDir(localDir(repoRoot, "work-items", workItemId2));
    await atomicWriteText(localDir(repoRoot, "work-items", workItemId2, "lsp-diagnostics.json"), `${JSON.stringify({
      schema_version: "0.1.0",
      advisory: true,
      checked: checked.length,
      truncated,
      files: surfaced
    }, null, 2)}
`);
  } catch {}
  return surfaced;
}
async function planRequiresDecisionApproval(repoRoot, workItemId2) {
  let text;
  try {
    text = await readFile3(localDir(repoRoot, "work-items", workItemId2, "decision-conflict.json"), "utf8");
  } catch {
    return false;
  }
  try {
    const parsed = decisionConflictCarrier.safeParse(JSON.parse(text));
    return parsed.success && decisionConflictRequiresApproval(parsed.data.conflicts);
  } catch {
    return false;
  }
}
async function recordResult(repoRoot, input) {
  const aps = new AutopilotStore(repoRoot);
  const graph = await aps.get(input.workItemId);
  const intents = new IntentStore(repoRoot);
  const allowedAcceptanceIds = await intents.exists(input.workItemId) ? new Set((await intents.get(input.workItemId)).acceptance_criteria.map((c3) => c3.id)) : undefined;
  const node2 = graph.nodes.find((n2) => n2.id === input.payload.node_id);
  if (!node2) {
    throw new Error(`node ${input.payload.node_id} not found in autopilot graph for ${input.workItemId}`);
  }
  if (node2.status !== "running") {
    throw new Error(`node ${node2.id} is not running (status=${node2.status}); call next-node first to dispatch it`);
  }
  await new ActiveNodeLeaseStore(repoRoot).removeByNode(input.workItemId, node2.id);
  const guard = guardChildResult(input.payload.result_text);
  let contentful = guard.contentful;
  let outcome = input.payload.outcome;
  let failureClass = input.payload.failure_class;
  let guardReason = input.payload.reason ?? "";
  if (!guard.contentful) {
    outcome = "fail";
    failureClass = "fixable";
    guardReason = guard.reason;
  }
  if (contentful && outcome === "pass") {
    const mut = guardMutatingEvidence(node2.owner, input.payload.outcome, input.payload.changed_files ?? []);
    if (!mut.contentful) {
      contentful = false;
      outcome = "fail";
      failureClass = "fixable";
      guardReason = mut.reason;
    }
  }
  if (contentful && outcome === "pass" && node2.kind === "design" && input.payload.plan_brief !== undefined) {
    const coverageRan = await new CoverageStore(repoRoot).exists(input.workItemId);
    if (!coverageRan) {
      contentful = false;
      outcome = "fail";
      failureClass = "fixable";
      guardReason = "design pass carried plan_brief but no coverage.json exists \u2014 run the pre-mortem coverage sweep (coverage-next \u2192 coverage-round until dry) before closing the plan stage (claim \u2260 proof)";
    }
  }
  if (contentful && outcome === "pass") {
    const acGuard = guardAcClosingEvidence({
      outcome: input.payload.outcome,
      ac_verdicts: input.payload.ac_verdicts ?? [],
      evidence_refs: input.payload.evidence_refs ?? []
    });
    if (!acGuard.contentful) {
      contentful = false;
      outcome = "fail";
      failureClass = "fixable";
      guardReason = acGuard.reason;
    }
  }
  if (outcome === "pass") {
    if (node2.kind === "design" && input.payload.decision_conflicts !== undefined && input.payload.decision_conflicts.length > 0) {
      await ensureDir(localDir(repoRoot, "work-items", input.workItemId));
      await writeJson(localDir(repoRoot, "work-items", input.workItemId, "decision-conflict.json"), decisionConflictCarrier, {
        schema_version: "0.1.0",
        mode: "autopilot",
        conflicts: input.payload.decision_conflicts
      });
    }
    if ((node2.kind === "review" || node2.kind === "security") && input.payload.has_findings === true) {
      const plan = planForwardReexpansion({
        reviewNode: node2,
        hasFindings: true,
        round: forwardRound(node2.id),
        budget: graph.caps.converge_rounds
      });
      if (plan.decision === "expand") {
        await aps.addNodes(input.workItemId, plan.nodes, allowedAcceptanceIds);
        await aps.updateNode(input.workItemId, node2.id, (n2) => ({
          ...n2,
          status: nodeTransition(n2.status, "pass"),
          evidence_refs: input.payload.evidence_refs ?? n2.evidence_refs
        }));
        return {
          node_id: node2.id,
          status: "passed",
          outcome: "pass",
          guard_contentful: true,
          decision: null,
          failure_class: null,
          cap_exceeded: false,
          reason: guardReason,
          promoted_node_ids: plan.nodes.map((n2) => n2.id),
          superseded_node_ids: []
        };
      }
      const reason = plan.decision === "escalate" ? plan.reason : guardReason;
      await aps.updateNode(input.workItemId, node2.id, (n2) => ({
        ...n2,
        status: nodeTransition(n2.status, "block")
      }));
      await aps.appendDecision(input.workItemId, {
        ts: (input.now ?? new Date).toISOString(),
        node_id: node2.id,
        failure_class: "user_decision_needed",
        decision: "escalate",
        reason,
        attempts: node2.attempts
      });
      return {
        node_id: node2.id,
        status: "blocked",
        outcome: "fail",
        guard_contentful: true,
        decision: "escalate",
        failure_class: "user_decision_needed",
        cap_exceeded: true,
        reason,
        promoted_node_ids: [],
        superseded_node_ids: []
      };
    }
    const proposals = input.payload.generated_nodes ?? [];
    let promotedNodeIds = [];
    let supersededNodeIds = [];
    if (proposals.length > 0) {
      const promoted = proposalsToNodes(proposals);
      await aps.addNodes(input.workItemId, promoted, allowedAcceptanceIds);
      promotedNodeIds = promoted.map((n2) => n2.id);
      const grown = await aps.get(input.workItemId);
      supersededNodeIds = supersededByPromotion(grown.nodes, node2.id, promoted);
      if (supersededNodeIds.length > 0) {
        await aps.removeNodes(input.workItemId, supersededNodeIds);
      }
    }
    let designEvidenceRefs;
    if (node2.kind === "design" && input.payload.plan_brief !== undefined) {
      const pb = input.payload.plan_brief;
      const requireApproval = await planRequiresDecisionApproval(repoRoot, input.workItemId);
      const patch = producePlanGate({
        changeSurface: pb.change_surface,
        brief: {
          interface_changes: pb.interface_changes,
          dod: pb.dod,
          test_scenarios: pb.test_scenarios
        },
        tierInputs: pb.tier_inputs,
        requireApproval
      });
      const current = await aps.get(input.workItemId);
      await aps.write(input.workItemId, {
        ...current,
        approval_gate: {
          ...current.approval_gate,
          status: patch.status,
          change_surface: patch.change_surface,
          plan_brief: patch.plan_brief
        }
      });
      const coverageStore = new CoverageStore(repoRoot);
      if (await coverageStore.exists(input.workItemId)) {
        const caller = input.payload.evidence_refs ?? [];
        const coverageRel = coverageStore.relMapPath(input.workItemId);
        if (!caller.some((e2) => e2.path === coverageRel)) {
          designEvidenceRefs = [
            ...caller,
            {
              kind: "file",
              path: coverageRel,
              summary: "pre-mortem coverage sweep artifact (plan-stage close)"
            }
          ];
        }
      }
    }
    await aps.updateNode(input.workItemId, node2.id, (n2) => ({
      ...n2,
      status: nodeTransition(n2.status, "pass"),
      evidence_refs: designEvidenceRefs ?? input.payload.evidence_refs ?? n2.evidence_refs,
      ac_verdicts: input.payload.ac_verdicts ?? n2.ac_verdicts
    }));
    const reported = input.payload.changed_files ?? [];
    if (reported.length > 0) {
      await new WorkItemStore(repoRoot).update(input.workItemId, (w2) => {
        const existing = new Set(w2.changed_files);
        const additions = reported.filter((p) => !existing.has(p));
        return additions.length > 0 ? { ...w2, changed_files: [...w2.changed_files, ...additions] } : w2;
      });
    }
    let lspAdvisory;
    if (isMutatingNode(node2) && reported.length > 0) {
      const surfaced = await surfaceLspDiagnostics(repoRoot, input.workItemId, reported);
      if (surfaced.length > 0)
        lspAdvisory = surfaced;
    }
    if (node2.kind === "implement") {
      const tidyPromoted = await spliceTidyStage(repoRoot, input.workItemId, node2, aps);
      promotedNodeIds = [...promotedNodeIds, ...tidyPromoted];
    }
    return {
      node_id: node2.id,
      status: "passed",
      outcome: "pass",
      guard_contentful: true,
      decision: null,
      failure_class: null,
      cap_exceeded: false,
      reason: guardReason,
      promoted_node_ids: promotedNodeIds,
      superseded_node_ids: supersededNodeIds,
      ...lspAdvisory ? { lsp_advisory: lspAdvisory } : {}
    };
  }
  if (contentful && node2.kind === "refactor" && input.payload.tidy_bug_found === true) {
    const implementDep = graph.nodes.find((n2) => node2.depends_on.includes(n2.id) && n2.kind === "implement");
    const reason = implementDep !== undefined ? `tidy found a bug \u2014 returning implement node ${implementDep.id} to pending (not fixing here, not retrying the tidy node in place) (ac-4)` : "tidy found a bug but no implement node found in depends_on \u2014 tidy node failed without reopening (ac-4)";
    await aps.updateNode(input.workItemId, node2.id, (n2) => ({
      ...n2,
      status: nodeTransition(n2.status, "fail")
    }));
    if (implementDep !== undefined) {
      await aps.updateNode(input.workItemId, implementDep.id, (n2) => ({
        ...n2,
        status: nodeTransition(n2.status, "reopen")
      }));
    }
    await aps.appendDecision(input.workItemId, {
      ts: (input.now ?? new Date).toISOString(),
      node_id: node2.id,
      failure_class: "fixable",
      decision: "escalate",
      reason,
      attempts: node2.attempts
    });
    return {
      node_id: node2.id,
      status: "failed",
      outcome: "fail",
      guard_contentful: contentful,
      decision: "escalate",
      failure_class: "fixable",
      cap_exceeded: false,
      reason,
      promoted_node_ids: [],
      superseded_node_ids: []
    };
  }
  const klass = failureClass;
  const { decision, cap_exceeded } = decideOnFailure(klass, node2.attempts, graph.caps);
  let event;
  let attempts = node2.attempts;
  switch (decision) {
    case "retry":
      event = "retry";
      attempts = { ...node2.attempts, fix: node2.attempts.fix + 1 };
      break;
    case "switch_approach":
      event = "retry";
      attempts = { ...node2.attempts, switch: node2.attempts.switch + 1 };
      break;
    default:
      event = cap_exceeded ? "fail" : "block";
      break;
  }
  const nextStatus = nodeTransition(node2.status, event);
  await aps.updateNode(input.workItemId, node2.id, (n2) => ({
    ...n2,
    status: nodeTransition(n2.status, event),
    attempts
  }));
  await aps.appendDecision(input.workItemId, {
    ts: (input.now ?? new Date).toISOString(),
    node_id: node2.id,
    failure_class: klass,
    decision,
    reason: guardReason || `${klass} \u2192 ${decision}`,
    attempts
  });
  return {
    node_id: node2.id,
    status: nextStatus,
    outcome: "fail",
    guard_contentful: contentful,
    decision,
    failure_class: klass,
    cap_exceeded,
    reason: guardReason,
    promoted_node_ids: [],
    superseded_node_ids: []
  };
}

// src/core/cite-gate.ts
init_ditto_paths();
import { readFile as readFile4, readdir as readdir9 } from "fs/promises";
import { join as join29 } from "path";
var CITE_RE = /\bdecision:|\bADR-\d/i;
var ABSTAIN_RE = /\babstain|none\s+(?:of\s+the\s+)?(?:governing\s+)?decisions?\s+apply|none\s+apply/i;
function evidenceText(node2) {
  return node2.evidence_refs.map((e2) => [e2.summary, e2.command, e2.path].filter(Boolean).join(" ")).join(" ");
}
function citedOrAbstained(node2) {
  const text = evidenceText(node2);
  return CITE_RE.test(text) || ABSTAIN_RE.test(text);
}
async function checkCiteGate(repoRoot, input) {
  const report = await readUsageReport(repoRoot, input.workItemId);
  const pushedNodeIds = [
    ...new Set(report.records.filter((r3) => r3.actionable).map((r3) => r3.node_id))
  ].sort();
  if (pushedNodeIds.length === 0) {
    return { verdict: "skip", pushed_node_ids: [], warnings: [] };
  }
  const byId = new Map(input.graph.nodes.map((n2) => [n2.id, n2]));
  const warnings = [];
  for (const id of pushedNodeIds) {
    const node2 = byId.get(id);
    if (!node2 || !citedOrAbstained(node2)) {
      warnings.push({
        node_id: id,
        message: `\uB178\uB4DC ${id}\uB294 \uAC70\uBC84\uB2DD \uACB0\uC815 push\uB97C \uBC1B\uC558\uC73C\uB098 \uCD9C\uB825\uC774 \uACB0\uC815\uC744 \uC778\uC6A9(cite)\uD558\uC9C0\uB3C4 \uBA85\uC2DC\uC801\uC73C\uB85C \uAE30\uAD8C(abstain)\uD558\uC9C0\uB3C4 \uC54A\uC558\uB2E4 \u2014 \uACB0\uC815 \uBB34\uC2DC \uAC00\uB2A5\uC131(advisory, ac-2)`
      });
    }
  }
  return {
    verdict: warnings.length > 0 ? "warning" : "pass",
    pushed_node_ids: pushedNodeIds,
    warnings
  };
}
function crossValidateCite(cite, measurement, options = {}) {
  const rate = measurement.reproposal_rate;
  const baseline = options.baseline_reproposal_rate;
  let combined;
  if (cite.verdict !== "pass") {
    combined = "not-applicable";
  } else if (baseline === undefined) {
    combined = "cannot-confirm";
  } else if (rate <= baseline) {
    combined = "confirmed";
  } else {
    combined = "cited-but-unvalidated";
  }
  return {
    combined,
    cite_verdict: cite.verdict,
    reproposal_rate: rate,
    ...baseline !== undefined ? { baseline_reproposal_rate: baseline } : {},
    advisory: true
  };
}
function conflictsFromHits(pushedNodeIds, report) {
  return report.reproposal_hits.map((h2) => {
    const node_id = pushedNodeIds[h2.candidate_index] ?? "?";
    return {
      node_id,
      adr_id: h2.adr_id,
      rejected_alternative: h2.item,
      matched_token: h2.matched_token,
      message: `\uB178\uB4DC ${node_id} \uCD9C\uB825\uC774 ${h2.adr_id}\uAC00 \uAE30\uAC01\uD55C \uB300\uC548 "${h2.item.slice(0, 60)}"\uC744(\uB97C) \uC7AC\uC81C\uC548\uD560 \uC218 \uC788\uC74C (matched: "${h2.matched_token}", advisory\xB7FN\uC6B0\uC120)`
    };
  });
}
async function loadAdrBodies(repoRoot) {
  const adrDir = join29(dittoDir(repoRoot), "knowledge", "adr");
  let names;
  try {
    names = (await readdir9(adrDir)).filter((n2) => n2.endsWith(".md")).sort();
  } catch {
    return [];
  }
  return Promise.all(names.map(async (n2) => ({ id: n2, body: await readFile4(join29(adrDir, n2), "utf8") })));
}
async function detectActiveConflicts(repoRoot, input) {
  const report = await readUsageReport(repoRoot, input.workItemId);
  const pushedNodeIds = [
    ...new Set(report.records.filter((r3) => r3.actionable).map((r3) => r3.node_id))
  ].sort();
  if (pushedNodeIds.length === 0)
    return [];
  const byId = new Map(input.graph.nodes.map((n2) => [n2.id, n2]));
  const candidates = pushedNodeIds.map((id) => {
    const node2 = byId.get(id);
    return node2 ? evidenceText(node2) : "";
  });
  const adrs = await loadAdrBodies(repoRoot);
  return conflictsFromHits(pushedNodeIds, measureHallucination(adrs, candidates));
}

// src/core/coverage-loop.ts
init_ditto_paths();
function dryCounterPath(repoRoot, workItemId2) {
  return localDir(repoRoot, "runs", workItemId2, "coverage-dry-counter");
}
async function readDryCounter(repoRoot, workItemId2) {
  const file = Bun.file(dryCounterPath(repoRoot, workItemId2));
  if (!await file.exists())
    return 0;
  const n2 = Number.parseInt((await file.text()).trim(), 10);
  return Number.isFinite(n2) && n2 >= 0 ? n2 : 0;
}
async function writeDryCounter(repoRoot, workItemId2, n2) {
  await Bun.write(dryCounterPath(repoRoot, workItemId2), String(n2));
}
function rootNode(label) {
  return {
    id: "cov-root",
    parent_id: null,
    label,
    origin: "seed",
    depth_weight: 1,
    state: "open",
    children: []
  };
}
async function originalIntent(repoRoot, workItemId2) {
  const intents = new IntentStore(repoRoot);
  if (await intents.exists(workItemId2)) {
    return (await intents.get(workItemId2)).goal;
  }
  const items = new WorkItemStore(repoRoot);
  if (await items.exists(workItemId2)) {
    return (await items.get(workItemId2)).title;
  }
  return workItemId2;
}
async function nextCoverageNode(args) {
  const { repoRoot, workItemId: workItemId2 } = args;
  const store = new CoverageStore(repoRoot);
  let map;
  if (await store.exists(workItemId2)) {
    map = await store.getMap(workItemId2);
  } else {
    const intent2 = await originalIntent(repoRoot, workItemId2);
    map = {
      schema_version: "0.1.0",
      work_item_id: workItemId2,
      root_id: "cov-root",
      nodes: [rootNode(intent2)]
    };
    await store.writeMap(workItemId2, map);
  }
  const dryCounter = await readDryCounter(repoRoot, workItemId2);
  if (isCoverageTerminated(map, dryCounter)) {
    return { action: "dry", terminated: true };
  }
  const ready = selectReadyCoverageNodes(map);
  const node2 = ready[0];
  if (node2 === undefined) {
    return {
      action: "interrogate",
      node: rootNode(map.nodes[0]?.label ?? workItemId2),
      judgeInput: buildJudgeInput({
        node: map.nodes[0] ?? rootNode(workItemId2),
        originalIntent: await originalIntent(repoRoot, workItemId2),
        crossCuttingConstraints: []
      }),
      tier: args.tierInputs ? selectCoverageTier(args.tierInputs) : "standard",
      dryCounter
    };
  }
  const intent = await originalIntent(repoRoot, workItemId2);
  return {
    action: "interrogate",
    node: { ...node2 },
    judgeInput: buildJudgeInput({
      node: node2,
      originalIntent: intent,
      crossCuttingConstraints: []
    }),
    tier: args.tierInputs ? selectCoverageTier(args.tierInputs) : "standard",
    dryCounter
  };
}
function enforceClose(map, node2, state, signals) {
  const reasons = [];
  const gate2 = coverageClosureGate(map, node2.id, state);
  if (!gate2.pass)
    reasons.push(...gate2.reasons);
  if (state === "resolved" && signals.neutrality === undefined) {
    reasons.push(`neutrality axis required for resolved close of ${node2.id}: axis_signals.neutrality absent`);
  }
  const neutralityOk = signals.neutrality === undefined || COVERAGE_AXIS_MECHANISMS.neutrality.enforce(signals.neutrality);
  if (!neutralityOk) {
    reasons.push(`neutrality axis rejected ${node2.id}: Opponent did not run or verdict blocked`);
  }
  if (signals.balance !== undefined) {
    const balanceOk = COVERAGE_AXIS_MECHANISMS.balance.enforce(node2, signals.balance);
    if (!balanceOk) {
      reasons.push(`balance axis rejected ${node2.id}: achieved depth below depth_weight floor`);
    }
  }
  if (signals.priority !== undefined) {
    const priorityOk = COVERAGE_AXIS_MECHANISMS.priority.enforce(node2, signals.priority);
    if (!priorityOk) {
      reasons.push(`priority axis rejected ${node2.id}: high-priority node still shallow`);
    }
  }
  if (signals.temporalBaseline !== undefined && signals.temporalCurrent !== undefined) {
    const temporalOk = COVERAGE_AXIS_MECHANISMS.temporal.enforce(signals.temporalBaseline, signals.temporalCurrent);
    if (!temporalOk) {
      reasons.push(`temporal axis rejected ${node2.id}: surface diverged from frozen baseline`);
    }
  }
  return reasons;
}
async function recordCoverageRound(args) {
  const { repoRoot, workItemId: workItemId2, payload } = args;
  const store = new CoverageStore(repoRoot);
  let map = await store.getMap(workItemId2);
  const children = [...payload.derived_nodes ?? [], ...payload.discovered_nodes ?? []];
  for (const child of children) {
    map = addNode(map, {
      id: child.id,
      parent_id: child.parent_id,
      label: child.label,
      origin: child.origin,
      depth_weight: child.depth_weight,
      state: "open",
      children: []
    });
  }
  const prevCounter = await readDryCounter(repoRoot, workItemId2);
  const nextCounter = recordDryRound(prevCounter, {
    admissibleBranchesAdded: payload.admissibleBranchesAdded
  });
  await writeDryCounter(repoRoot, workItemId2, nextCounter);
  let closed = false;
  let reasons = [];
  if (payload.close_as !== undefined) {
    const node2 = map.nodes.find((n2) => n2.id === payload.node_id);
    if (node2 === undefined) {
      reasons = [`unknown coverage node id: ${payload.node_id}`];
    } else {
      reasons = enforceClose(map, node2, payload.close_as, payload.axis_signals ?? {});
      if (reasons.length === 0) {
        map = closeNode(map, payload.node_id, payload.close_as);
        closed = true;
      }
    }
  }
  await store.writeMap(workItemId2, map);
  if (isCoverageTerminated(map, nextCounter)) {
    const delta = args.dialogDelta ?? {};
    const closedItems = map.nodes.filter((n2) => n2.state !== "open").map((n2) => ({ id: n2.id, label: n2.label, state: n2.state }));
    const openItems = map.nodes.filter((n2) => n2.state === "open").map((n2) => ({ id: n2.id, label: n2.label, state: n2.state }));
    const stage = args.stage ?? "plan";
    const dialogInput = {
      workItemId: workItemId2,
      userQa: delta.userQa ?? [],
      selfAnswers: delta.selfAnswers ?? [],
      assumptions: delta.assumptions ?? [],
      closedItems: delta.closedItems ?? closedItems,
      openItems: delta.openItems ?? openItems,
      kind: stage === "intent" ? "intent-dialog" : "plan-dialog"
    };
    const markdown = serializePlanDialog(dialogInput);
    if (stage === "intent") {
      await store.writeIntentDialog(workItemId2, markdown);
    } else {
      await store.writePlanDialog(workItemId2, markdown);
    }
    const dialogFile = stage === "intent" ? "intent-dialog.md" : "plan-dialog.md";
    return {
      terminated: true,
      brief: args.brief ?? { interface_changes: [], dod: [], test_scenarios: [] },
      ...args.tierInputs ? { tierInputs: args.tierInputs } : {},
      planDialogPath: `.ditto/local/runs/${workItemId2}/${dialogFile}`
    };
  }
  return { terminated: false, closed, reasons, dryCounter: nextCounter };
}

