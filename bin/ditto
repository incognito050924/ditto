        writeError("readiness gate passed (1\uCC28) but the user confirmation is missing (2\uCC28 \uAC8C\uC774\uD2B8) \u2014 pass --statement");
        process.exit(RUNTIME_ERROR_EXIT);
        return;
      }
      if (format === "json") {
        writeJson2({
          work_item_id: result2.intent.work_item_id,
          intent_path: `.ditto/local/work-items/${result2.intent.work_item_id}/intent.json`,
          source_digest: result2.intent.source_digest,
          autopilot_id: result2.autopilot.autopilot_id,
          acceptance_criteria: result2.intent.acceptance_criteria.map((ac) => ac.id)
        });
      } else {
        writeHuman(`Compiled design doc \u2192 intent for ${result2.intent.work_item_id}`);
        writeHuman(`  source_digest: ${result2.intent.source_digest?.sha256 ?? "(none)"}`);
        writeHuman(`  autopilot:     ${result2.autopilot.autopilot_id}`);
        writeHuman(`  acceptance:    ${result2.intent.acceptance_criteria.map((ac) => ac.id).join(", ")}`);
      }
    } catch (err) {
      writeError(`finalize-from-doc failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});
