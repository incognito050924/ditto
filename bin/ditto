var reviewKind = exports_external.enum([
  "plan-check",
  "verifier",
  "code-reviewer",
  "security-reviewer",
  "e2e-reviewer",
  "cross-provider-reviewer"
]).describe("Which evaluator lane produced this output");
var finding = exports_external.object({
  severity,
  file: relativePath.optional(),
  location: exports_external.string().optional().describe("Line range or symbol; free-form because not all reviewers are code-based"),
  reason: exports_external.string().min(1),
  suggested_fix: exports_external.string().optional()
}).describe("A single concrete observation from the reviewer");
var reviewerOutput = exports_external.object({
  schema_version: schemaVersion,
  id: reviewId,
  work_item_id: workItemId,
  kind: reviewKind,
  reviewer: exports_external.string().min(1).describe("Identifier of the reviewing profile/agent; not the generator"),
  different_provider_than_generator: exports_external.boolean().describe("True if reviewer ran on a different provider or model family than the generator"),
  started_at: isoDateTime,
  ended_at: isoDateTime.optional(),
  verdict,
  evidence: exports_external.array(evidenceRef).default([]),
  findings: exports_external.array(finding).default([]),
  unverified: exports_external.array(exports_external.object({
    item: exports_external.string().min(1),
    reason: exports_external.string().min(1)
  })).default([]),
  recommended_next_action: exports_external.string().min(1).describe("A single concrete next step; not a list of options"),
  review_not_run_reason: exports_external.string().optional().describe("Set when verdict could not be produced due to budget/availability")
}).superRefine((value, ctx) => {
  if (value.verdict === "unverified" && !value.review_not_run_reason && value.evidence.length === 0) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "verdict=unverified requires either evidence or review_not_run_reason",
      path: ["review_not_run_reason"]
    });
  }
  if (value.different_provider_than_generator === true && value.evidence.length === 0) {
    ctx.addIssue({
      code: exports_external.ZodIssueCode.custom,
      message: "different_provider_than_generator=true requires non-empty evidence",
      path: ["evidence"]
    });
  }
}).describe("Output contract for any reviewer/evaluator lane");

// src/cli/util.ts
import { stderr, stdout as stdout2 } from "process";

class InvalidOutputFormatError extends Error {
  value;
  constructor(value) {
    super(`invalid --output value "${value}"; expected one of: human, json`);
    this.value = value;
    this.name = "InvalidOutputFormatError";
  }
}
function parseOutputFormat(value) {
  if (value === undefined)
    return "human";
  if (value === "human" || value === "json")
    return value;
  throw new InvalidOutputFormatError(value);
}
function writeJson2(value) {
  stdout2.write(`${JSON.stringify(value, null, 2)}
`);
}
function writeHuman(text) {
  stdout2.write(text.endsWith(`
`) ? text : `${text}
`);
}
function writeError(text) {
  stderr.write(text.endsWith(`
`) ? text : `${text}
`);
}
var USAGE_ERROR_EXIT = 65;
var RUNTIME_ERROR_EXIT = 1;
function extractDashDashTail(argv2 = process.argv) {
  const idx = argv2.indexOf("--");
  if (idx === -1)
    return null;
  return argv2.slice(idx + 1);
}

// src/cli/commands/acg-review.ts
var acgReviewCommand = defineCommand({
  meta: {
    name: "acg-review",
    description: "Project a reviewer-output into the acg_review ledger (.ditto/local/work-items/<wi>/acg-review.json)"
  },
  args: {
    from: {
      type: "string",
      description: "Path to the reviewer-output JSON to project",
      required: true
    },
    "work-item": {
      type: "string",
      description: "Work item id to write the ledger under; defaults to reviewer-output.work_item_id",
      required: false
    },
    output: {
      type: "string",
      description: "Output format: human|json",
      default: "human"
    }
  },
  run: async ({ args }) => {
    let format;
    try {
      format = parseOutputFormat(args.output);
    } catch (err) {
      writeError(err instanceof Error ? err.message : String(err));
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    let parsedOutput;
    try {
      const raw = await Bun.file(args.from).text();
      parsedOutput = reviewerOutput.parse(JSON.parse(raw));
    } catch (err) {
      writeError(`acg-review: cannot read a valid reviewer-output from ${args.from}: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(USAGE_ERROR_EXIT);
      return;
    }
    const workItemId2 = args["work-item"] ?? parsedOutput.work_item_id;
    try {
      const graph = projectReviewerOutputToAcgReview(parsedOutput);
      const store = new AcgReviewStore(await resolveRepoRootForCreate());
      await store.write(workItemId2, graph);
      const highRiskUnevidenced = graph.files.filter((f3) => f3.risk === "high" && f3.evidence === undefined).length;
      if (format === "json") {
        writeJson2({
          work_item_id: workItemId2,
          files: graph.files.length,
          human_review_set: graph.human_review_set.length,
          high_risk_without_evidence: highRiskUnevidenced
        });
      } else {
        writeHuman(`wrote acg-review.json for ${workItemId2}: ${graph.files.length} file(s), ${highRiskUnevidenced} high-risk without evidence`);
      }
    } catch (err) {
      writeError(`acg-review: failed to write ledger: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});

