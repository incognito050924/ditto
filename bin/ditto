// src/cli/commands/doctor.ts
import { homedir as homedir7 } from "os";
import { join as join60 } from "path";

// src/core/capability-inventory.ts
init_shared();
import { join as join53 } from "path";
var REQUIRED_CAPABILITIES = ["instructions", "permissions", "mcp", "surface"];
async function codexPluginNeedsUserAction(repoRoot) {
  const raw = asRecord(await readJsonIfExists(join53(repoRoot, ".ditto", "local", "codex-plugin-status.json")).catch(() => null));
  if (!raw || raw.plugin !== "ditto" || raw.status !== "needs_user_action")
    return null;
  const commands = Array.isArray(raw.commands) ? raw.commands.filter((command) => typeof command === "string") : [];
  return commands;
}
async function collectCapabilityInventory(adapters, repoRoot) {
  const hosts = [];
  const findings = [];
  for (const adapter of adapters) {
    const caps = adapter.capabilities;
    for (const capability of REQUIRED_CAPABILITIES) {
      if (caps[capability] !== true) {
        findings.push({
          host: adapter.id,
          kind: "missing_required",
          capability,
          message: `host "${adapter.id}" does not support required capability "${capability}"`
        });
      }
    }
    const inventory = await adapter.loadSurfaceInventory(repoRoot);
    const registered = inventory.localSurfaces.filter((entry) => entry.kind === "hook").map((entry) => entry.id);
    const declared = caps.hooks;
    const registeredSet = new Set(registered);
    const declaredSet = new Set(declared);
    for (const event of declared) {
      if (!registeredSet.has(event)) {
        findings.push({
          host: adapter.id,
          kind: "declared_hook_not_registered",
          capability: event,
          message: `host "${adapter.id}" declares hook "${event}" but it is not registered`
        });
      }
    }
    for (const event of registered) {
      if (!declaredSet.has(event)) {
        findings.push({
          host: adapter.id,
          kind: "registered_hook_not_declared",
          capability: event,
          message: `host "${adapter.id}" registers hook "${event}" but it is not declared`
        });
      }
    }
    if (adapter.id === "codex") {
      const commands = await codexPluginNeedsUserAction(repoRoot);
      if (commands) {
        findings.push({
          host: adapter.id,
          kind: "codex_plugin_needs_user_action",
          capability: "plugin-enabled",
          message: `Codex plugin files are prepared, but DITTO is not marked enabled in CODEX_HOME. Run: ${commands.join(" && ")}`
        });
      }
    }
    hosts.push({
      host: adapter.id,
      capabilities: {
        hooks: [...caps.hooks],
        instructions: caps.instructions,
        permissions: caps.permissions,
        mcp: caps.mcp,
        surface: caps.surface
      },
      hook_events: registered
    });
  }
  return { hosts, finding_count: findings.length, findings };
}

// src/core/codeql/install.ts
import { existsSync as existsSync6 } from "fs";
import { mkdir as mkdir6 } from "fs/promises";
import { homedir as homedir6 } from "os";
import { join as join54 } from "path";
function detectPlatform(os = process.platform) {
  switch (os) {
    case "darwin":
      return "osx64";
    case "linux":
      return "linux64";
    case "win32":
      return "win64";
    default:
      return null;
  }
}
function bundleUrl(platform2) {
  return `https://github.com/github/codeql-cli-binaries/releases/latest/download/codeql-${platform2}.zip`;
}
var DEFAULT_INSTALL_DIR = join54(homedir6(), ".local", "share", "ditto", "codeql");
var DEFAULT_BIN_DIR = join54(homedir6(), ".local", "bin");
function managedBinary(installDir, platform2) {
  return join54(installDir, "codeql", platform2 === "win64" ? "codeql.exe" : "codeql");
}
function manualInstructions(platform2) {
  const lines = [
    "gh extensions install github/gh-codeql && gh codeql set-version latest   # gh CLI\uAC00 \uC788\uC73C\uBA74 \uAC00\uC7A5 \uAC04\uB2E8"
  ];
  if (platform2) {
    lines.push(`# \uB610\uB294 \uBC88\uB4E4 \uC9C1\uC811: ${bundleUrl(platform2)} \uB97C \uBC1B\uC544 \uC555\uCD95 \uD574\uC81C \uD6C4 codeql/ \uB97C PATH\uC5D0 \uCD94\uAC00`);
  } else {
    lines.push("# \uB610\uB294 \uBC88\uB4E4 \uC9C1\uC811: https://github.com/github/codeql-cli-binaries/releases/latest");
  }
  return lines;
}
async function installCodeqlCli(deps) {
  const existing = await deps.resolveExisting();
  if (existing) {
    return {
      status: "already-present",
      binary: existing,
      message: `codeql already installed at ${existing}; nothing to do`
    };
  }
  const platform2 = deps.platform();
  if (!platform2) {
    return {
      status: "unsupported-platform",
      message: `${process.platform}\uC740(\uB294) codeql \uBC88\uB4E4 \uC790\uB3D9 \uC124\uCE58\uB97C \uC9C0\uC6D0\uD558\uC9C0 \uC54A\uB294\uB2E4. \uC218\uB3D9 \uC124\uCE58\uD558\uB77C.`,
      manual: manualInstructions(null)
    };
  }
  await deps.ensureDir(deps.installDir);
  await deps.ensureDir(deps.binDir);
  const zip = join54(deps.installDir, `codeql-${platform2}.zip`);
  const url = bundleUrl(platform2);
  const fail = (why, stderr2) => ({
    status: "failed",
    message: `${why}${stderr2 ? `: ${stderr2.trim()}` : ""}`,
    manual: manualInstructions(platform2)
  });
  const dl = await deps.run("curl", ["-fsSL", "--retry", "3", "-o", zip, url]);
  if (dl.exit_code !== 0)
    return fail(`codeql \uB2E4\uC6B4\uB85C\uB4DC \uC2E4\uD328 (curl exit=${dl.exit_code ?? "null"})`, dl.stderr);
  let ex = await deps.run("unzip", ["-q", "-o", zip, "-d", deps.installDir]);
  if (ex.exit_code !== 0) {
    ex = await deps.run("tar", ["-xf", zip, "-C", deps.installDir]);
    if (ex.exit_code !== 0)
      return fail("codeql \uCD94\uCD9C \uC2E4\uD328 (unzip/tar \uB458 \uB2E4 \uC2E4\uD328)", ex.stderr);
  }
  const binary = managedBinary(deps.installDir, platform2);
  if (!deps.fileExists(binary))
    return fail("\uCD94\uCD9C\uC740 \uB410\uC73C\uB098 codeql \uB7F0\uCC98\uB97C \uCC3E\uC9C0 \uBABB\uD588\uB2E4");
  if (platform2 === "win64") {
    return {
      status: "installed",
      binary,
      message: `codeql installed at ${binary} \u2014 ${join54(deps.installDir, "codeql")}\uB97C PATH\uC5D0 \uCD94\uAC00\uD558\uB77C.`
    };
  }
  const link = join54(deps.binDir, "codeql");
  const ln = await deps.run("ln", ["-sf", binary, link]);
  if (ln.exit_code !== 0)
    return fail(`\uC2EC\uB9C1\uD06C \uC2E4\uD328 (ln exit=${ln.exit_code ?? "null"})`, ln.stderr);
  if (!deps.fileExists(link))
    return fail(`\uC124\uCE58 \uB2E8\uACC4\uB294 \uB05D\uB0AC\uC73C\uB098 ${link}\uB97C \uD655\uC778\uD558\uC9C0 \uBABB\uD588\uB2E4`);
  const pathHint = deps.pathIncludes(deps.binDir) ? "" : ` \u2014 \uB2E8 ${deps.binDir}\uAC00 PATH\uC5D0 \uC5C6\uB2E4. PATH\uC5D0 \uCD94\uAC00\uD574\uC57C codeql\uC774 \uC7A1\uD78C\uB2E4.`;
  return { status: "installed", binary: link, message: `codeql installed at ${link}${pathHint}` };
}
var defaultInstallDeps = {
  platform: () => detectPlatform(),
  resolveExisting: async () => {
    const bin = process.env.CODEQL_BIN;
    if (bin && existsSync6(bin))
      return bin;
    const onPath = Bun.which("codeql");
    if (onPath)
      return onPath;
    const gh = join54(homedir6(), ".local", "share", "gh", "extensions", "gh-codeql");
    if (existsSync6(gh))
      return gh;
    const platform2 = detectPlatform();
    if (platform2) {
      const managed = managedBinary(DEFAULT_INSTALL_DIR, platform2);
      if (existsSync6(managed))
        return managed;
    }
    return null;
  },
  run: async (binary, args) => {
    const proc = Bun.spawn([binary, ...args], {
      stdout: "ignore",
      stderr: "pipe",
      stdin: "ignore"
    });
    const [exit_code, stderr2] = await Promise.all([
      proc.exited,
      new Response(proc.stderr).text().catch(() => "")
    ]);
    return { exit_code, stderr: stderr2 };
  },
  installDir: DEFAULT_INSTALL_DIR,
  binDir: DEFAULT_BIN_DIR,
  ensureDir: async (dir) => {
    await mkdir6(dir, { recursive: true });
  },
  fileExists: (p) => existsSync6(p),
  pathIncludes: (dir) => (process.env.PATH ?? "").split(":").includes(dir)
};

// src/core/completion-coverage-doctor.ts
import { readdir as readdir15 } from "fs/promises";
import { join as join55 } from "path";
init_ditto_paths();
init_fs();
function isClosed2(ac) {
  const hasEvidence = (ac.evidence?.length ?? 0) > 0 || (ac.evidence_records?.length ?? 0) > 0;
  return ac.verdict === "pass" && hasEvidence;
}
async function listArchived(repoRoot) {
  const base = localDir(repoRoot, "archive");
  let labels;
  try {
    labels = await readdir15(base);
  } catch {
    return [];
  }
  const out = [];
  for (const label2 of labels) {
    let ids;
    try {
      ids = await readdir15(join55(base, label2));
    } catch {
      continue;
    }
    for (const id of ids) {
      try {
        const item = await readJson(join55(base, label2, id, "work-item.json"), workItem);
        out.push({ id, title: item.title, status: item.status, updated_at: item.updated_at });
      } catch {}
    }
  }
  return out;
}
async function readArchivedCompletion(repoRoot, label2, id) {
  const path = localDir(repoRoot, "archive", label2, id, "completion.json");
  if (!await Bun.file(path).exists())
    return null;
  try {
    return await readJson(path, completionContract);
  } catch {
    return null;
  }
}
function defaultCompletionCoverageDeps(repoRoot) {
  const workItems = new WorkItemStore(repoRoot);
  const completions = new CompletionStore(repoRoot);
  const archiveLabelOf = new Map;
  return {
    listWorkItems: async () => {
      const active = await workItems.list();
      const base = localDir(repoRoot, "archive");
      let labels = [];
      try {
        labels = await readdir15(base);
      } catch {
        labels = [];
      }
      for (const label2 of labels) {
        try {
          for (const id of await readdir15(join55(base, label2)))
            archiveLabelOf.set(id, label2);
        } catch {}
      }
      const archived = await listArchived(repoRoot);
      return [...active, ...archived];
    },
    readCompletion: async (id) => {
      const label2 = archiveLabelOf.get(id);
      if (label2)
        return readArchivedCompletion(repoRoot, label2, id);
      return await completions.exists(id) ? completions.get(id) : null;
    }
  };
}
function buildRow(summary, completion) {
  const acceptance = completion?.acceptance ?? [];
  const total = acceptance.length;
  const closed = acceptance.filter(isClosed2).length;
  return {
    work_item_id: summary.id,
    title: summary.title,
    status: summary.status,
    has_completion: completion !== null,
    total_acceptance: total,
    closed_acceptance: closed,
    coverage: total === 0 ? 0 : closed / total
  };
}
function totalsOf(rows) {
  const totalAcceptance = rows.reduce((s2, r3) => s2 + r3.total_acceptance, 0);
  const closedAcceptance = rows.reduce((s2, r3) => s2 + r3.closed_acceptance, 0);
  return {
    work_items: rows.length,
    with_completion: rows.filter((r3) => r3.has_completion).length,
    total_acceptance: totalAcceptance,
    closed_acceptance: closedAcceptance,
    coverage: totalAcceptance === 0 ? 0 : closedAcceptance / totalAcceptance
  };
}
async function collectCompletionCoverageReport(deps) {
  const summaries = await deps.listWorkItems();
  const rows = [];
  for (const summary of summaries) {
    const completion = await deps.readCompletion(summary.id);
    rows.push(buildRow(summary, completion));
  }
  return { rows, totals: totalsOf(rows) };
}

// src/core/distribution-doctor.ts
import { existsSync as existsSync7, readFileSync as readFileSync3 } from "fs";
import { join as join57 } from "path";

// src/core/build-stamp.ts
import { createHash as createHash7 } from "crypto";
import { readFileSync as readFileSync2, readdirSync } from "fs";
import { join as join56 } from "path";
var STAMP_PREFIX = "//# ditto-src-stamp=";
function listSourceFiles(repoRoot, rel = "src") {
  const out = [];
  const entries = readdirSync(join56(repoRoot, rel), { withFileTypes: true });
  for (const e2 of entries) {
    const childRel = `${rel}/${e2.name}`;
    if (e2.isDirectory())
      out.push(...listSourceFiles(repoRoot, childRel));
    else if (e2.isFile() && e2.name.endsWith(".ts"))
      out.push(childRel);
  }
  return out.sort();
}
function computeSourceStamp(repoRoot) {
  const h2 = createHash7("sha256");
  for (const rel of listSourceFiles(repoRoot)) {
    h2.update(rel);
    h2.update("\x00");
    h2.update(readFileSync2(join56(repoRoot, rel)));
    h2.update("\x00");
  }
  return h2.digest("hex");
}
function readEmbeddedStamp(bundleText) {
  const idx = bundleText.lastIndexOf(STAMP_PREFIX);
  if (idx === -1)
    return null;
  const m2 = bundleText.slice(idx + STAMP_PREFIX.length).match(/^[a-f0-9]{64}/);
  return m2 ? m2[0] : null;
}

// src/core/distribution-doctor.ts
var ALLOW_RULE = "Bash(ditto:*)";
var AXIS_CONTRACTS = [
  {
    axis: "Hooks",
    contract: "self-contained binary built + fresh (matches src/) + hooks.json registered",
    requires: ["binary_built", "binary_fresh", "hooks_registered"]
  },
  {
    axis: "Skills",
    contract: "plugin surface present + CLI on PATH",
    requires: ["plugin_surface_present", "binary_on_path"]
  },
  {
    axis: "Agents",
    contract: "plugin surface present + CLI on PATH + target State",
    requires: ["plugin_surface_present", "binary_on_path", "target_initialized"]
  },
  {
    axis: "State",
    contract: "explicit `ditto init` scaffold",
    requires: ["target_initialized"]
  }
];
function evaluateDistribution(checks) {
  const axes = AXIS_CONTRACTS.map((a2) => {
    const missing = a2.requires.filter((k2) => !checks[k2]);
    return { ...a2, satisfied: missing.length === 0, missing };
  });
  return { checks, axes, finding_count: axes.filter((a2) => !a2.satisfied).length };
}
function readJsonObject(path) {
  if (!existsSync7(path))
    return {};
  const text = readFileSync3(path, "utf8").trim();
  if (!text)
    return {};
  try {
    const parsed = JSON.parse(text);
    return parsed && typeof parsed === "object" ? parsed : {};
  } catch {
    return {};
  }
}
function defaultDistributionDeps(targetRoot, pluginRoot) {
  return {
    pluginRoot,
    targetRoot,
    whichDitto: () => Bun.which("ditto"),
    readProjectSettings: () => readJsonObject(join57(targetRoot, ".claude", "settings.json")),
    exists: (p) => existsSync7(p),
    readText: (p) => {
      try {
        return readFileSync3(p, "utf8");
      } catch {
        return null;
      }
    },
    sourceStamp: computeSourceStamp
  };
}
function pluginSurfacePresent(pluginRoot, exists) {
  return exists(join57(pluginRoot, ".claude-plugin", "plugin.json")) && exists(join57(pluginRoot, "skills")) && exists(join57(pluginRoot, "agents"));
}
function allowlisted(settings) {
  const permissions = settings.permissions;
  const allow = permissions && typeof permissions === "object" ? permissions.allow : undefined;
  return Array.isArray(allow) && allow.includes(ALLOW_RULE);
}
function binaryFresh(deps, binaryName) {
  if (!deps.exists(join57(deps.pluginRoot, "src")))
    return true;
  const text = deps.readText(join57(deps.pluginRoot, "bin", binaryName));
  if (text === null)
    return false;
  const embedded = readEmbeddedStamp(text);
  if (embedded === null)
    return false;
  try {
    return embedded === deps.sourceStamp(deps.pluginRoot);
  } catch {
    return false;
  }
}
function collectDistributionChecks(deps) {
  const binaryName = "ditto";
  return {
    binary_built: deps.exists(join57(deps.pluginRoot, "bin", binaryName)),
    binary_fresh: binaryFresh(deps, binaryName),
    hooks_registered: deps.exists(join57(deps.pluginRoot, "hooks", "hooks.json")),
    plugin_surface_present: pluginSurfacePresent(deps.pluginRoot, deps.exists),
    binary_on_path: deps.whichDitto() !== null,
    target_initialized: deps.exists(join57(deps.targetRoot, ".ditto", "knowledge", "glossary.json")),
    allowlisted: allowlisted(deps.readProjectSettings())
  };
}
function collectDistributionReport(deps) {
  return evaluateDistribution(collectDistributionChecks(deps));
}

// src/core/doctor-fix.ts
import { join as join58 } from "path";

// src/core/managed-resource.ts
init_fs();
import { copyFile } from "fs/promises";
var START_RE_G = /<!--\s*ditto:managed:start\s+source=[^\s]+\s+sha256=[a-f0-9]{64}\s*-->/g;
var END_RE_G = /<!--\s*ditto:managed:end\s*-->/g;
function locateBlock(content) {
  const starts = [...content.matchAll(START_RE_G)];
  const ends = [...content.matchAll(END_RE_G)];
  if (starts.length === 0 && ends.length === 0)
    return null;
  if (starts.length !== 1 || ends.length !== 1)
    return "corrupted";
  const startMatch = starts[0];
  const endMatch = ends[0];
  if (startMatch?.index === undefined || endMatch?.index === undefined)
    return "corrupted";
  if (endMatch.index < startMatch.index)
    return "corrupted";
  return { start: startMatch.index, end: endMatch.index + endMatch[0].length };
}
function buildManagedBlock(managedBody, source = "AGENTS.md") {
  const body = normalizeInstructionText(managedBody);
  const sha2562 = normalizedSha256(managedBody);
  const bodyWithBreak = body.endsWith(`
`) ? body : `${body}
`;
  return `<!-- ditto:managed:start source=${source} sha256=${sha2562} -->
${bodyWithBreak}${MANAGED_END}`;
}
function upsertManagedBlock(originalContent, managedBody, source = "AGENTS.md") {
  const block = buildManagedBlock(managedBody, source);
  const bounds = locateBlock(originalContent);
  if (bounds === "corrupted")
    return { kind: "corrupted", original: originalContent };
  if (bounds === null) {
    if (originalContent.length === 0)
      return { kind: "ok", content: `${block}
` };
    const separator = originalContent.endsWith(`
`) ? `
` : `

`;
    return { kind: "ok", content: `${originalContent}${separator}${block}
` };
  }
  const next = `${originalContent.slice(0, bounds.start)}${block}${originalContent.slice(bounds.end)}`;
  return { kind: "ok", content: next };
}
function stripManagedBlock(content) {
  const bounds = locateBlock(content);
  if (bounds === "corrupted")
    return { kind: "corrupted", original: content };
  if (bounds === null)
    return { kind: "ok", content };
  const before = content.slice(0, bounds.start);
  const after = content.slice(bounds.end);
  const beforeTail = before.match(/\n*$/)?.[0] ?? "";
  const afterHead = after.match(/^\n*/)?.[0] ?? "";
  let seam = beforeTail + afterHead;
  if (seam.length >= 3)
    seam = `

`;
  const next = before.slice(0, before.length - beforeTail.length) + seam + after.slice(afterHead.length);
  return { kind: "ok", content: next };
}
var BACKUP_SUFFIX = ".ditto_bak";
async function writeBackupOnce(targetPath) {
  const bakPath = `${targetPath}${BACKUP_SUFFIX}`;
  if (await Bun.file(bakPath).exists())
    return null;
  if (!await Bun.file(targetPath).exists())
    return null;
  await copyFile(targetPath, bakPath);
  return bakPath;
}
async function applyManagedFile(targetPath, managedBody, source = "AGENTS.md") {
  const exists = await Bun.file(targetPath).exists();
  const current = exists ? await Bun.file(targetPath).text() : "";
  const merged = upsertManagedBlock(current, managedBody, source);
  if (merged.kind === "corrupted")
    return { kind: "corrupted", path: targetPath };
  const backupPath = await writeBackupOnce(targetPath);
  await atomicWriteText(targetPath, merged.content);
  return { kind: "ok", path: targetPath, backupPath };
}

// src/core/settings-allowlist.ts
init_fs();
init_shared();
import { readFile as readFile10 } from "fs/promises";
var ALLOW_RULE2 = "Bash(ditto:*)";
function addAllowRule(settings) {
  const perms = settings.permissions ?? {};
  const allow = Array.isArray(perms.allow) ? perms.allow : [];
  const nextAllow = allow.includes(ALLOW_RULE2) ? allow : [...allow, ALLOW_RULE2];
  return { ...settings, permissions: { ...perms, allow: nextAllow } };
}
function removeAllowRule(settings) {
  const perms = settings.permissions;
  if (!perms || !Array.isArray(perms.allow))
    return settings;
  return {
    ...settings,
    permissions: { ...perms, allow: perms.allow.filter((r3) => r3 !== ALLOW_RULE2) }
  };
}
async function readSettings(settingsPath) {
  if (!await fileExists(settingsPath))
    return {};
  const text = (await readFile10(settingsPath, "utf8")).trim();
  return text ? JSON.parse(text) : {};
}
async function writeSettings(settingsPath, settings) {
  await atomicWriteText(settingsPath, `${JSON.stringify(settings, null, 2)}
`);
}
async function allowlistSettingsFile(settingsPath) {
  const settings = await readSettings(settingsPath);
  await writeSettings(settingsPath, addAllowRule(settings));
}
async function unallowlistSettingsFile(settingsPath) {
  if (!await fileExists(settingsPath))
    return;
  const settings = await readSettings(settingsPath);
  await writeSettings(settingsPath, removeAllowRule(settings));
}

// src/core/doctor-fix.ts
function classifyReversible(targetPath, homeDir) {
  const globalRoot = join58(homeDir, ".claude");
  return !(targetPath === globalRoot || targetPath.startsWith(`${globalRoot}/`));
}
function planInstructionFixes(findings, homeDir) {
  const seen = new Set;
  const items = [];
  for (const finding2 of findings) {
    if (finding2.host !== "claude-code")
      continue;
    if (seen.has(finding2.path))
      continue;
    seen.add(finding2.path);
    items.push({
      kind: "instruction-projection",
      reversible: classifyReversible(finding2.path, homeDir),
      targetPath: finding2.path,
      describe: `re-project managed block in ${finding2.path} (${finding2.kind})`
    });
  }
  return items;
}
async function applyDoctorFixes(deps, items) {
  const applied = [];
  const skipped = [];
  for (const item of items) {
    if (!item.reversible) {
      const ok = await deps.confirmNonReversible(item);
      if (!ok) {
        skipped.push(item);
        continue;
      }
    }
    if (item.kind === "instruction-projection") {
      const res = await deps.syncProjection();
      if (res.applied)
        applied.push(item);
    } else {
      const res = await deps.ensureAllowlist();
      if (res.applied)
        applied.push(item);
    }
  }
  return { applied, skipped, nothingToFix: items.length === 0 };
}
function defaultDoctorFixDeps(repoRoot, homeDir) {
  return {
    repoRoot,
    homeDir,
    confirmNonReversible: async () => false,
    syncProjection: async () => {
      const path = join58(repoRoot, "CLAUDE.md");
      const backupPath = await writeBackupOnce(path);
      const result2 = await syncClaudeCodeProjection(repoRoot);
      const applied = result2.action === "created" || result2.action === "updated";
      return { applied, backupPath };
    },
    ensureAllowlist: async () => {
      await allowlistSettingsFile(join58(repoRoot, ".claude", "settings.json"));
      return { applied: true };
    }
  };
}

