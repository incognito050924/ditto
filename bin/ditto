});

// src/schemas/work-item.ts
var gitSha40, verificationMethod, codePointerMapsTo, acOracle, acceptanceCriterion, workItemWorktree, severityLevel, riskNote, followUp, declaredRisk, githubIssueLink, reEntry, workItem, workItemEventBase, workItemStatusEventPayload, workItemVerdictEventPayload, workItemGithubPostEventPayload, workItemClaimEventPayload, workItemEvent;
var init_work_item = __esm(() => {
  init_zod();
  init_common();
  init_coverage();
  gitSha40 = exports_external.string().regex(/^[a-f0-9]{40}$/, "git sha must be 40 lowercase hex characters").describe("Full 40-char git commit sha");
  verificationMethod = exports_external.enum(["dynamic_test", "static_scan", "soft_judgment"]).describe("Re-evaluability class of the oracle (ADR-0024 \xA73.1: hard\xB7dynamic / hard\xB7static / soft\xB7judgment). Distinct from evidenceRequiredKind (intent.ts), which is the kind of evidence, not its re-evaluability.");
  codePointerMapsTo = /^[^\s]+\.[A-Za-z0-9]+:[^\s]+$/;
  acOracle = exports_external.object({
    verification_method: verificationMethod,
    maps_to: exports_external.string().min(1).describe("AC, file:line, intent, or doc the oracle anchors to (same vocabulary as dialectic maps_to)"),
    direction: exports_external.enum(["forward", "backward"]).describe("forward = post-change final state; backward = current-code finding (ADR-0024 \xA73.0)"),
    pattern: exports_external.string().min(1).optional().describe("Fixed-string token claimed ABSENT under maps_to (mode=absence). Decidable iff single non-whitespace token within the length cap (coverage.ts ORACLE_PATTERN_TOKEN_RE / ORACLE_PATTERN_MAX_LENGTH)"),
    mode: oracleMode.optional().describe("presence = cited file:line anchor exists; absence = pattern does not occur under maps_to (wi_260706n4w)")
  }).superRefine((value, ctx) => {
    if (value.direction === "forward" && codePointerMapsTo.test(value.maps_to)) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        message: "forward oracle must be re-evaluable: a code-pointer maps_to (file:line / symbol) drifts on change \u2014 use direction=backward for a current-code finding (ADR-0024 \xA73.0)",
        path: ["maps_to"]
      });
    }
  }).describe("Per-AC oracle: re-evaluable verification method + anchor target (ADR-0024 \xA73)");
  acceptanceCriterion = exports_external.object({
    id: exports_external.string().min(1).describe("Stable id within the work item (e.g., ac-1)"),
    statement: exports_external.string().min(1).describe("Single observable behavior in user-facing terms"),
    verdict: verdict.default("unverified"),
    evidence: exports_external.array(evidenceRef).default([]),
    oracle: acOracle.optional(),
    superseded: exports_external.array(exports_external.object({
      statement: exports_external.string().min(1).describe("The prior (graded) statement that was replaced"),
      reason: exports_external.string().min(1).describe("Why the prior criterion was superseded")
    })).optional(),
    evidence_required: exports_external.array(evidenceRequiredKind).optional()
  }).describe("One acceptance criterion with its verification verdict");
  workItemWorktree = exports_external.object({
    owning_repo: exports_external.string().min(1).describe("'.' for the workspace repo, else the sub-repo path relative to the workspace root"),
    worktree_path: relativePath.describe("Worktree checkout path, relative to the workspace repo root"),
    branch: exports_external.string().min(1).describe("Branch checked out in this worktree")
  }).describe("One git worktree+branch DITTO created for a work item (one per owning repo)");
  severityLevel = exports_external.enum(["info", "low", "medium", "high", "critical"]);
  riskNote = exports_external.object({
    description: exports_external.string().min(1),
    severity: severityLevel.default("low"),
    mitigation: exports_external.string().optional()
  }).describe("Outstanding risk that did not block completion but remains relevant");
  followUp = exports_external.object({
    kind: exports_external.enum(["bug", "idea"]).describe("bug = a defect materialized into a tracked WI; idea = a candidate only"),
    note: exports_external.string().min(1).describe("What was discovered"),
    severity: severityLevel.optional(),
    self_caused: exports_external.boolean().optional().describe("True if this regression was introduced by the source work item itself"),
    materialized_wi: workItemId.optional().describe("The tracked work item this bug was materialized into (kind=bug only)"),
    resolved: exports_external.boolean().optional().describe("True once the follow-up has been addressed")
  }).describe("A discovered follow-up (bug/idea) captured on the work item");
  declaredRisk = exports_external.object({
    non_local: exports_external.boolean().optional(),
    irreversible: exports_external.boolean().optional(),
    unaudited: exports_external.boolean().optional()
  }).describe("Work-item-declared risk flags (gates.ts RiskAxes vocabulary)");
  githubIssueLink = exports_external.object({
    repo: exports_external.string().min(1).describe("owner/name of the repo that owns the issue"),
    number: exports_external.number().int().describe("Issue number within the repo"),
    node_id: exports_external.string().optional().describe("GraphQL node id of the issue"),
    project_item_id: exports_external.string().optional().describe("Projects v2 item id once the issue is added to a board"),
    posted_decision_ids: exports_external.array(exports_external.string()).optional().describe("Decision-log ids already posted to this issue (G8 post idempotency)"),
    claimed_branch: exports_external.string().min(1).optional().describe("Branch name THIS session claimed the issue on (branch-grain occupancy)"),
    posted_claim_markers: exports_external.array(exports_external.string()).optional().describe("Claim markers already posted to this issue (claim-post idempotency)")
  }).describe("Singular GitHub issue this work item is linked to (1 WI \u2194 1 issue, v1)");
  reEntry = exports_external.object({
    command: exports_external.string().optional().describe("Concrete next command to resume work"),
    fresh_evidence_needed: exports_external.array(exports_external.string()).default([]).describe("What new evidence must be gathered before the next attempt"),
    owner: exports_external.string().optional().describe("Profile or human handle expected to resume")
  }).describe("Instructions for resuming a partial/unverified/blocked work item");
  workItem = exports_external.object({
    schema_version: schemaVersion,
    id: workItemId,
    title: exports_external.string().min(1).max(200),
    source_request: exports_external.string().min(1).describe("Verbatim or close-paraphrase of the original user request"),
    goal: exports_external.string().min(1).describe("Observable outcome stated in project terms; not a list of steps"),
    acceptance_criteria: exports_external.array(acceptanceCriterion).min(1),
    status: workItemStatus.default("draft"),
    owner_profile: profileName.default("workspace-write"),
    parent_id: workItemId.optional().describe("Parent work item if this is a child task"),
    child_ids: exports_external.array(workItemId).default([]),
    changed_files: exports_external.array(relativePath).default([]),
    worktrees: exports_external.array(workItemWorktree).default([]),
    autopilot_exempt: exports_external.boolean().optional().describe("Allow closing on completion.json alone without going through autopilot"),
    declared_risk: declaredRisk.optional(),
    promoted_to_heavy: exports_external.boolean().optional().describe("Marked for the heavy (deep-interview) path via `work promote`"),
    follow_ups: exports_external.array(followUp).optional(),
    discovered_by: workItemId.optional().describe("Work item whose discovered bug materialized this one (provenance, not hierarchy)"),
    follows: workItemId.optional().describe("Predecessor work item this one continues from (chain lineage, not the parent_id tree)"),
    github_issue: githubIssueLink.optional(),
    risks: exports_external.array(riskNote).default([]),
    re_entry: reEntry.optional(),
    runs: exports_external.array(runId).default([]),
    handoff_path: relativePath.optional(),
    language_overrides: relativePath.optional().describe("Path to language.md if this work item modifies the glossary"),
    started_at_sha: gitSha40.optional().describe("Git HEAD sha at the time this work item transitioned draft \u2192 in_progress; used as default base for handoff diff collection"),
    created_at: isoDateTime,
    updated_at: isoDateTime,
    closed_at: isoDateTime.optional()
  }).superRefine((value, ctx) => {
    const needsReEntry = ["partial", "unverified", "blocked"].includes(value.status);
    if (!needsReEntry)
      return;
    if (!value.re_entry) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        message: `status=${value.status} requires re_entry with command or fresh_evidence_needed`,
        path: ["re_entry"]
      });
      return;
    }
    const hasCommand = typeof value.re_entry.command === "string" && value.re_entry.command.length > 0;
    const hasEvidence = value.re_entry.fresh_evidence_needed.length > 0;
    if (!hasCommand && !hasEvidence) {
      ctx.addIssue({
        code: exports_external.ZodIssueCode.custom,
        message: `status=${value.status} requires re_entry.command or non-empty re_entry.fresh_evidence_needed`,
        path: ["re_entry"]
      });
    }
  }).describe("Authoritative state for a single DITTO work item");
  workItemEventBase = {
    schema_version: schemaVersion,
    work_item_id: workItemId,
    seq: exports_external.number().int().nonnegative().describe("Per-writer monotonic sequence; (seq,actor) orders"),
    actor: exports_external.string().min(1).describe("Writer identity (profile/session); (seq,actor) order tiebreak"),
    event_id: exports_external.string().min(1).describe("Content-hash dedupe key (idempotent re-append)"),
    ts: isoDateTime.describe("When the event was written; informational only, not an ordering key")
  };
  workItemStatusEventPayload = exports_external.object({
    to: workItemStatus,
    closed_at: isoDateTime.nullable().optional().describe("Set on terminal; null clears on reopen")
  }).describe("status event payload (\xA71.1)");
  workItemVerdictEventPayload = exports_external.object({
    criterion_id: exports_external.string().min(1).describe("The AC id this verdict is for"),
    verdict,
    evidence: exports_external.array(evidenceRef).default([])
  }).describe("AC verdict event payload (\xA71.1)");
  workItemGithubPostEventPayload = exports_external.object({
    posted_decision_id: exports_external.string().optional().describe("Decision-log id posted to the issue"),
    posted_claim_marker: exports_external.string().optional().describe("Claim marker posted to the issue"),
    claimed_branch: exports_external.string().optional().describe("Branch this post claimed the issue on")
  }).describe("github_post idempotency event payload (\xA71.1 / C5)");
  workItemClaimEventPayload = exports_external.object({
    claimed_branch: exports_external.string().optional().describe("Branch claiming/releasing the issue"),
    posted_claim_marker: exports_external.string().optional().describe("Claim marker this event claims/releases")
  }).describe("claim / claim_release event payload (\xA71.1 / C5)");
  workItemEvent = exports_external.discriminatedUnion("kind", [
    exports_external.object({
      ...workItemEventBase,
      kind: exports_external.literal("status"),
      payload: workItemStatusEventPayload
    }),
    exports_external.object({
      ...workItemEventBase,
      kind: exports_external.literal("verdict"),
      payload: workItemVerdictEventPayload
    }),
    exports_external.object({
      ...workItemEventBase,
      kind: exports_external.literal("github_post"),
      payload: workItemGithubPostEventPayload
    }),
    exports_external.object({
      ...workItemEventBase,
      kind: exports_external.literal("claim"),
      payload: workItemClaimEventPayload
    }),
    exports_external.object({
      ...workItemEventBase,
      kind: exports_external.literal("claim_release"),
      payload: workItemClaimEventPayload
    })
  ]).describe("One entry of the committed per-event immutable work-item log (wi_2607069bk \xA72.1)");
});

// src/core/id.ts
import { randomBytes } from "crypto";
function randomSuffix(length) {
  const bytes = randomBytes(length);
  let out = "";
  for (let i2 = 0;i2 < length; i2++) {
    const byte = bytes[i2] ?? 0;
    out += SUFFIX_CHARSET[byte % SUFFIX_CHARSET.length] ?? "a";
  }
  return out;
}
async function generateId(prefix, existsCheck, options = {}) {
  const now = options.now ?? new Date;
  const maxAttempts = options.maxAttempts ?? 8;
  const yy = String(now.getUTCFullYear() % 100).padStart(2, "0");
  const mm = String(now.getUTCMonth() + 1).padStart(2, "0");
  const dd = String(now.getUTCDate()).padStart(2, "0");
  const datePart = `${yy}${mm}${dd}`;
  const randomLen = Math.max(SUFFIX_LENGTH - datePart.length, 3);
  for (let attempt = 0;attempt < maxAttempts; attempt++) {
    const candidate = `${prefix}_${datePart}${randomSuffix(randomLen)}`;
    if (!await existsCheck(candidate))
      return candidate;
  }
  throw new Error(`failed to generate unique ${prefix}_ id after ${maxAttempts} attempts; likely a clock or RNG issue`);
}
var SUFFIX_LENGTH = 9, SUFFIX_CHARSET = "abcdefghijklmnopqrstuvwxyz0123456789";
var init_id = () => {};

// src/core/work-item-store.ts
import { createHash } from "crypto";
import { open, readdir as readdir2, rename, stat as stat2 } from "fs/promises";
import { dirname as dirname2, join as join6 } from "path";
function tryGitHeadSha(repoRoot) {
  const proc = Bun.spawnSync(["git", "rev-parse", "HEAD"], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (proc.exitCode !== 0)
    return null;
  const sha = (proc.stdout?.toString() ?? "").trim();
  if (!/^[a-f0-9]{40}$/.test(sha))
    return null;
  return sha;
}
function rollUpStem(members) {
  const nonTerminal = members.filter((m2) => !TERMINAL_STEM_STATUSES.includes(m2.status));
  if (nonTerminal.length > 0)
    return "open";
  return members.every((m2) => m2.status === "done") ? "done" : "partial";
}
function orderStemMembers(members, all) {
  const depthOf = (mid) => {
    let d2 = 0;
    let cur = mid;
    const seen = new Set([cur]);
    for (;; ) {
      const f3 = all.get(cur)?.follows;
      if (f3 === undefined || !members.has(f3) || seen.has(f3))
        break;
      seen.add(f3);
      cur = f3;
      d2++;
    }
    return d2;
  };
  return [...members].sort((a2, b2) => {
    const da = depthOf(a2);
    const db = depthOf(b2);
    if (da !== db)
      return da - db;
    const ca = all.get(a2)?.created_at ?? "";
    const cb = all.get(b2)?.created_at ?? "";
    if (ca !== cb)
      return ca < cb ? -1 : 1;
    return a2 < b2 ? -1 : 1;
  });
}
function computeStemViews(items) {
  const all = new Map;
  for (const it of items)
    all.set(it.id, it);
  const successors = new Map;
  for (const it of items) {
    if (it.follows !== undefined && all.has(it.follows)) {
      const bucket = successors.get(it.follows) ?? [];
      bucket.push(it.id);
      successors.set(it.follows, bucket);
    }
  }
  const result = new Map;
  const visited = new Set;
  for (const start of all.keys()) {
    if (visited.has(start))
      continue;
    const members = new Set;
    const queue2 = [start];
    while (queue2.length > 0) {
      const cur = queue2.pop();
      if (cur === undefined || members.has(cur))
        continue;
      members.add(cur);
      visited.add(cur);
      const node = all.get(cur);
      if (node?.follows !== undefined && all.has(node.follows))
        queue2.push(node.follows);
      for (const s2 of successors.get(cur) ?? [])
        queue2.push(s2);
    }
    const ordered = orderStemMembers(members, all);
    const memberList = ordered.map((mid) => {
      const node = all.get(mid);
      return {
        id: mid,
        status: node?.status ?? "draft",
        ...node?.follows !== undefined ? { follows: node.follows } : {}
      };
    });
    const view = { members: memberList, rolled_up: rollUpStem(memberList) };
    for (const mid of members)
      result.set(mid, view);
  }
  return result;
}
function blockingFollowUp(item) {
  return (item.follow_ups ?? []).find((f3) => f3.kind === "bug" && f3.self_caused === true && f3.resolved !== true && f3.severity !== undefined && DONE_BLOCKING_SEVERITIES.includes(f3.severity));
}
function pushReadiness(item, stem) {
  const reasons = [];
  const notPass = item.acceptance_criteria.filter((c3) => c3.verdict !== "pass");
  if (notPass.length > 0) {
    reasons.push(`acceptance criteria not all pass: ${notPass.map((c3) => `${c3.id}=${c3.verdict}`).join(", ")}`);
  }
  const noCommandEvidence = item.acceptance_criteria.filter((c3) => !c3.evidence.some((e2) => e2.kind === "command"));
  if (noCommandEvidence.length > 0) {
    reasons.push(`acceptance criteria lack real (command-kind) evidence: ${noCommandEvidence.map((c3) => c3.id).join(", ")}`);
  }
  const blocking = blockingFollowUp(item);
  if (blocking) {
    reasons.push(`unresolved self-caused ${blocking.severity}-severity follow-up: "${blocking.note}"`);
  }
  if (stem !== undefined && stem.members.length > 1 && stem.rolled_up !== "done") {
    reasons.push(`stem chain not fully done (rolled_up=${stem.rolled_up})`);
  }
  return { ready: reasons.length === 0, reasons };
}
function isTerminalStatus(s2) {
  return TERMINAL_STATUSES.has(s2);
}
function compareWorkItemEvents(a2, b2) {
  if (a2.seq !== b2.seq)
    return a2.seq - b2.seq;
  if (a2.actor !== b2.actor)
    return a2.actor < b2.actor ? -1 : 1;
  if (a2.event_id !== b2.event_id)
    return a2.event_id < b2.event_id ? -1 : 1;
  return 0;
}
function stableStringify(value) {
  if (Array.isArray(value))
    return `[${value.map(stableStringify).join(",")}]`;
  if (value !== null && typeof value === "object") {
    const obj = value;
    const keys = Object.keys(obj).sort();
    return `{${keys.map((k2) => `${JSON.stringify(k2)}:${stableStringify(obj[k2])}`).join(",")}}`;
  }
  return JSON.stringify(value);
}
function computeEventId(kind, actor, seq, payload) {
  return createHash("sha256").update(stableStringify({ kind, actor, seq, payload })).digest("hex");
}
function foldGithubIssue(record, ordered) {
  if (record.github_issue === undefined)
    return;
  const hasGithubEvents = ordered.some((e2) => e2.kind === "github_post" || e2.kind === "claim" || e2.kind === "claim_release");
  if (!hasGithubEvents)
    return record.github_issue;
  const decisionIds = new Set(record.github_issue.posted_decision_ids ?? []);
  const claimMarkers = new Set(record.github_issue.posted_claim_markers ?? []);
  let claimedBranch = record.github_issue.claimed_branch;
  for (const e2 of ordered) {
    if (e2.kind === "github_post") {
      if (e2.payload.posted_decision_id)
        decisionIds.add(e2.payload.posted_decision_id);
      if (e2.payload.posted_claim_marker)
        claimMarkers.add(e2.payload.posted_claim_marker);
      if (e2.payload.claimed_branch)
        claimedBranch = e2.payload.claimed_branch;
    } else if (e2.kind === "claim") {
      if (e2.payload.posted_claim_marker)
        claimMarkers.add(e2.payload.posted_claim_marker);
      if (e2.payload.claimed_branch)
        claimedBranch = e2.payload.claimed_branch;
    } else if (e2.kind === "claim_release") {
      if (e2.payload.posted_claim_marker)
        claimMarkers.delete(e2.payload.posted_claim_marker);
      if (e2.payload.claimed_branch && claimedBranch === e2.payload.claimed_branch) {
        claimedBranch = undefined;
      }
    }
  }
  const {
    posted_decision_ids: _pd,
    posted_claim_markers: _pc,
    claimed_branch: _cb,
    ...coords
  } = record.github_issue;
  return {
    ...coords,
    ...decisionIds.size > 0 ? { posted_decision_ids: [...decisionIds] } : {},
    ...claimMarkers.size > 0 ? { posted_claim_markers: [...claimMarkers] } : {},
    ...claimedBranch !== undefined ? { claimed_branch: claimedBranch } : {}
  };
}
function recordGithubIssueForWrite(next, rawRecord) {
  if (next.github_issue === undefined)
    return next;
  const {
    posted_decision_ids: _pd,
    posted_claim_markers: _pc,
    claimed_branch: _cb,
    ...coords
  } = next.github_issue;
  const base = rawRecord?.github_issue;
  return {
    ...next,
    github_issue: {
      ...coords,
      ...base?.posted_decision_ids ? { posted_decision_ids: base.posted_decision_ids } : {},
      ...base?.posted_claim_markers ? { posted_claim_markers: base.posted_claim_markers } : {},
      ...base?.claimed_branch ? { claimed_branch: base.claimed_branch } : {}
    }
  };
}
function reduceWorkItem(record, events) {
  const byId = new Map;
  for (const e2 of events)
    if (!byId.has(e2.event_id))
      byId.set(e2.event_id, e2);
  const ordered = [...byId.values()].sort(compareWorkItemEvents);
  let status = record.status;
  let closedAt = record.closed_at;
  let sawStatusEvent = false;
  let latestTs = record.updated_at;
  for (const e2 of ordered) {
    if (e2.ts > latestTs)
      latestTs = e2.ts;
    if (e2.kind !== "status")
      continue;
    if (isTerminalStatus(status) && isTerminalStatus(e2.payload.to))
      continue;
    sawStatusEvent = true;
    status = e2.payload.to;
    closedAt = e2.payload.closed_at ?? undefined;
  }
  const verdicts = new Map;
  for (const e2 of ordered) {
    if (e2.kind !== "verdict")
      continue;
    verdicts.set(e2.payload.criterion_id, {
      verdict: e2.payload.verdict,
      evidence: e2.payload.evidence
    });
  }
  const acceptance_criteria = record.acceptance_criteria.map((ac) => {
    const v2 = verdicts.get(ac.id);
    return v2 ? { ...ac, verdict: v2.verdict, evidence: v2.evidence } : ac;
  });
  const githubIssue = foldGithubIssue(record, ordered);
  const { closed_at: _rc, github_issue: _rg, ...restRecord } = record;
  const effectiveClosedAt = sawStatusEvent ? isTerminalStatus(status) ? closedAt : undefined : record.closed_at;
  const assembled = {
    ...restRecord,
    status,
    acceptance_criteria,
    updated_at: latestTs,
    ...effectiveClosedAt !== undefined ? { closed_at: effectiveClosedAt } : {},
    ...githubIssue !== undefined ? { github_issue: githubIssue } : {}
  };
  return workItem.parse(assembled);
}

class WorkItemStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  workItemDir(id) {
    return localDir(this.repoRoot, "work-items", id);
  }
  workItemPath(id) {
    return join6(this.workItemDir(id), "work-item.json");
  }
  languageLedgerPath(id) {
    return join6(this.workItemDir(id), "language-ledger.json");
  }
  recordPath(id) {
    return join6(committedWorkItemDir(this.repoRoot, id), "record.json");
  }
  eventsDir(id) {
    return join6(committedWorkItemDir(this.repoRoot, id), "events");
  }
  async readRecord(id) {
    if (!await Bun.file(this.recordPath(id)).exists())
      return null;
    return readJson(this.recordPath(id), workItem);
  }
  async readEvents(id) {
    let names;
    try {
      names = await readdir2(this.eventsDir(id));
    } catch {
      return [];
    }
    const events = [];
    const corrupt = [];
    for (const name of names) {
      if (!name.endsWith(".json"))
        continue;
      const path = join6(this.eventsDir(id), name);
      try {
        events.push(await readJson(path, workItemEvent));
      } catch {
        corrupt.push(path);
      }
    }
    if (corrupt.length > 0)
      throw new WorkItemEventCorruptError(id, corrupt.sort());
    return events;
  }
  async appendEvent(id, actor, kind, payload) {
    const events = await this.readEvents(id);
    const seq = events.reduce((max, e2) => Math.max(max, e2.seq), -1) + 1;
    const eventId = computeEventId(kind, actor, seq, payload);
    const validated = workItemEvent.parse({
      schema_version: "0.1.0",
      work_item_id: id,
      seq,
      actor,
      event_id: eventId,
      ts: new Date().toISOString(),
      kind,
      payload
    });
    await ensureDir(this.eventsDir(id));
    const safeActor = actor.replace(/[^A-Za-z0-9._-]/g, "_");
    const fileName = `${String(seq).padStart(6, "0")}.${safeActor}.${eventId.slice(0, 12)}.json`;
    const path = join6(this.eventsDir(id), fileName);
    let handle;
    try {
      handle = await open(path, "wx");
    } catch (err) {
      if (err.code === "EEXIST")
        return;
      throw err;
    }
    try {
      await handle.writeFile(`${JSON.stringify(validated, null, 2)}
`, "utf8");
    } finally {
      await handle.close();
    }
  }
  async emitTransitionEvents(id, prev, next) {
    const actor = next.owner_profile;
    const statusChanged = prev.status !== next.status || (prev.closed_at ?? null) !== (next.closed_at ?? null);
    if (statusChanged) {
      await this.appendEvent(id, actor, "status", {
        to: next.status,
        closed_at: next.closed_at ?? null
      });
    }
    const prevAc = new Map(prev.acceptance_criteria.map((c3) => [c3.id, c3]));
    for (const ac of next.acceptance_criteria) {
      const before = prevAc.get(ac.id);
      if (before === undefined)
        continue;
      const changed = before.verdict !== ac.verdict || JSON.stringify(before.evidence) !== JSON.stringify(ac.evidence);
      if (changed) {
        await this.appendEvent(id, actor, "verdict", {
          criterion_id: ac.id,
          verdict: ac.verdict,
          evidence: ac.evidence
        });
      }
    }
  }
  async writeMirror(id, item) {
    await writeJson(this.workItemPath(id), workItem, item);
  }
  committedArchiveDir(label, id) {
    return join6(dittoDir(this.repoRoot), "work-items-archive", label, id);
  }
  async exists(id) {
    if (await Bun.file(this.recordPath(id)).exists())
      return true;
    try {
      await stat2(this.workItemPath(id));
      return true;
    } catch {
      return false;
    }
  }
  async ensureMigrated(id) {
    if (await Bun.file(this.recordPath(id)).exists())
      return;
    if (!await Bun.file(this.workItemPath(id)).exists())
      return;
    const legacy = await readJson(this.workItemPath(id), workItem);
    await writeJson(this.recordPath(id), workItem, legacy);
    await this.appendEvent(id, legacy.owner_profile, "status", {
      to: legacy.status,
      closed_at: legacy.closed_at ?? null
    });
  }
  async create(input, now = new Date) {
    const id = await generateId("wi", (candidate) => this.exists(candidate));
    const nowIso = now.toISOString();
    const draft = {
      schema_version: "0.1.0",
      id,
      title: input.title,
      source_request: input.source_request,
      goal: input.goal,
      acceptance_criteria: input.acceptance_criteria,
      status: "draft",
      owner_profile: input.owner_profile ?? "workspace-write",
      ...input.parent_id !== undefined ? { parent_id: input.parent_id } : {},
      ...input.declared_risk !== undefined ? { declared_risk: input.declared_risk } : {},
      ...input.discovered_by !== undefined ? { discovered_by: input.discovered_by } : {},
      ...input.follows !== undefined ? { follows: input.follows } : {},
      child_ids: [],
      changed_files: [],
      risks: [],
      runs: [],
      created_at: nowIso,
      updated_at: nowIso
    };
    const record = await writeJson(this.recordPath(id), workItem, draft);
    await this.appendEvent(id, record.owner_profile, "status", { to: "draft" });
    await writeJson(this.languageLedgerPath(id), languageLedger, {
      schema_version: "0.1.0",
      work_item_id: id,
      created_at: nowIso,
      updated_at: nowIso,
      changes: []
    });
    const reduced = await this.get(id);
    await this.writeMirror(id, reduced);
    return reduced;
  }
  async get(id) {
    const record = await this.readRecord(id);
    if (record === null) {
      return readJson(this.workItemPath(id), workItem);
    }
    return reduceWorkItem(record, await this.readEvents(id));
  }
  async update(id, mutator) {
    await this.ensureMigrated(id);
    const current = await this.get(id);
    const rawRecord = await this.readRecord(id);
    const next = mutator(current);
    if (next.id !== current.id) {
      throw new Error(`update mutator changed work item id from ${current.id} to ${next.id}`);
    }
    let withSha = next;
    if (next.status === "in_progress" && next.started_at_sha === undefined) {
      const sha = tryGitHeadSha(this.repoRoot);
      if (sha !== null) {
        withSha = { ...next, started_at_sha: sha };
      }
    }
    const withTouched = { ...withSha, updated_at: new Date().toISOString() };
    const validated = workItem.parse(withTouched);
    await this.emitTransitionEvents(id, current, validated);
    await writeJson(this.recordPath(id), workItem, recordGithubIssueForWrite(validated, rawRecord));
    const reduced = await this.get(id);
    await this.writeMirror(id, reduced);
    return reduced;
  }
  async appendGithubEvent(id, kind, payload) {
    const actor = (await this.get(id)).owner_profile;
    await this.appendEvent(id, actor, kind, payload);
    await this.writeMirror(id, await this.get(id));
  }
  async recordGithubPost(id, payload) {
    await this.appendGithubEvent(id, "github_post", payload);
  }
  async recordClaim(id, payload) {
    await this.appendGithubEvent(id, "claim", payload);
  }
  async releaseClaim(id, payload) {
    await this.appendGithubEvent(id, "claim_release", payload);
  }
  async close(id, terminal, now = new Date) {
    return this.update(id, (cur) => {
      if (cur.status === "done" || cur.status === "abandoned") {
        throw new Error(`work ${id} is already ${cur.status} (terminal); reopen first (ditto work reopen ${id}) before re-closing`);
      }
      return {
        ...cur,
        status: terminal,
        closed_at: now.toISOString()
      };
    });
  }
  async reopen(id) {
    return this.update(id, (cur) => {
      if (cur.status !== "done" && cur.status !== "abandoned") {
        throw new Error(`work ${id} is ${cur.status} (not terminal); reopen only applies to a done/abandoned WI`);
      }
      const { closed_at: _dropped, ...rest } = cur;
      return { ...rest, status: "in_progress" };
    });
  }
  async park(id, status, reEntry2) {
    return this.update(id, (cur) => ({
      ...cur,
      status,
      re_entry: reEntry2
    }));
  }
  async chainAncestors(id) {
    const out = [];
    const seen = new Set([id]);
    let cur = await this.get(id);
    while (cur.follows !== undefined) {
      const next = cur.follows;
      if (seen.has(next))
        break;
      seen.add(next);
      out.push(next);
      if (!await this.exists(next))
        break;
      cur = await this.get(next);
    }
    return out;
  }
  async stem(id) {
    await this.get(id);
    const items = [];
    let sawId = false;
    for (const s2 of await this.list()) {
      const item = await this.get(s2.id);
      if (item.id === id)
        sawId = true;
      items.push({
        id: item.id,
        status: item.status,
        created_at: item.created_at,
        ...item.follows !== undefined ? { follows: item.follows } : {}
      });
    }
    if (!sawId) {
      const item = await this.get(id);
      items.push({
        id: item.id,
        status: item.status,
        created_at: item.created_at,
        ...item.follows !== undefined ? { follows: item.follows } : {}
      });
    }
    const views = computeStemViews(items);
    return views.get(id) ?? { members: [{ id, status: "draft" }], rolled_up: "open" };
  }
  async listCommittedRecords() {
    const base = join6(dittoDir(this.repoRoot), "work-items");
    let entries;
    try {
      entries = await readdir2(base);
    } catch {
      return [];
    }
    const items = [];
    for (const name of entries) {
      try {
        if (!(await stat2(join6(base, name))).isDirectory())
          continue;
        const record = await this.readRecord(name);
        if (record === null)
          continue;
        items.push(reduceWorkItem(record, await this.readEvents(name)));
      } catch {}
    }
    return items;
  }
  async archive(label) {
    if (!/^[A-Za-z0-9._-]+$/.test(label) || label === "." || label === "..") {
      throw new Error(`archive label must be a safe path segment ([A-Za-z0-9._-]+, not '.' or '..'; got: ${label})`);
    }
    const targets = (await this.list()).filter((s2) => s2.status === "done" || s2.status === "abandoned");
    if (targets.length === 0)
      return [];
    const runArchiveBase = localDir(this.repoRoot, "archive", label);
    await ensureDir(runArchiveBase);
    for (const t2 of targets) {
      if (await Bun.file(this.recordPath(t2.id)).exists()) {
        const dest = this.committedArchiveDir(label, t2.id);
        await ensureDir(dirname2(dest));
        await rename(committedWorkItemDir(this.repoRoot, t2.id), dest);
      }
      try {
        await rename(this.workItemDir(t2.id), join6(runArchiveBase, t2.id));
      } catch (err) {
        if (err.code !== "ENOENT")
          throw err;
      }
    }
    return targets.map((t2) => t2.id);
  }
  async collectWorkItemIds() {
    const ids = new Set;
    for (const base of [
      join6(dittoDir(this.repoRoot), "work-items"),
      localDir(this.repoRoot, "work-items")
    ]) {
      let entries;
      try {
        entries = await readdir2(base);
      } catch {
        continue;
      }
      for (const name of entries) {
        try {
          if ((await stat2(join6(base, name))).isDirectory())
            ids.add(name);
        } catch {}
      }
    }
    return ids;
  }
  async listAll() {
    const items = [];
    for (const id of await this.collectWorkItemIds()) {
      try {
        items.push(await this.get(id));
      } catch {}
    }
    return items;
  }
  async list() {
    const ids = await this.collectWorkItemIds();
    const summaries = [];
    for (const id of ids) {
      try {
        const item = await this.get(id);
        summaries.push({
          id: item.id,
          title: item.title,
          status: item.status,
          updated_at: item.updated_at
        });
      } catch {}
    }
    summaries.sort((a2, b2) => a2.updated_at < b2.updated_at ? 1 : -1);
    return summaries;
  }
  async reconcile(id) {
    const dir = this.eventsDir(id);
    const parseable = [];
    const unparseable = [];
    let names = [];
    try {
      names = await readdir2(dir);
    } catch {
      names = [];
    }
    for (const name of names) {
      if (!name.endsWith(".json"))
        continue;
      const path = join6(dir, name);
      try {
        parseable.push(await readJson(path, workItemEvent));
      } catch {
        unparseable.push(path);
      }
    }
    const record = await this.readRecord(id);
    let headStatus = null;
    let headClosedAt;
    if (record !== null) {
      const reduced = reduceWorkItem(record, parseable);
      headStatus = reduced.status;
      headClosedAt = reduced.closed_at;
    } else if (await Bun.file(this.workItemPath(id)).exists()) {
      const legacy = await readJson(this.workItemPath(id), workItem);
      headStatus = legacy.status;
      headClosedAt = legacy.closed_at;
    }
    return {
      id,
      head_status: headStatus,
      ...headClosedAt !== undefined ? { head_closed_at: headClosedAt } : {},
      event_count: parseable.length,
      unparseable_events: unparseable.sort()
    };
  }
  async appendJsonlAtPath(path, jsonLine) {
    await ensureDir(dirname2(path));
    const file = Bun.file(path);
    const existing = await file.exists() ? await file.text() : "";
    const trimmedExisting = existing.endsWith(`
`) || existing.length === 0 ? existing : `${existing}
`;
    await atomicWriteText(path, `${trimmedExisting}${jsonLine}
`);
  }
  async appendEvidenceJsonl(workItemId2, filename, jsonLine) {
    return this.appendJsonlAtPath(join6(this.workItemDir(workItemId2), "evidence", filename), jsonLine);
  }
  async appendCommandLogLine(workItemId2, jsonLine) {
    return this.appendEvidenceJsonl(workItemId2, "commands.jsonl", jsonLine);
  }
  async appendEditLogLine(workItemId2, jsonLine) {
    return this.appendEvidenceJsonl(workItemId2, "edits.jsonl", jsonLine);
  }
  metricsPath(workItemId2) {
    return join6(this.workItemDir(workItemId2), "metrics.jsonl");
  }
  async appendMetricLine(workItemId2, jsonLine) {
    return this.appendJsonlAtPath(this.metricsPath(workItemId2), jsonLine);
  }
  async readMetrics(workItemId2) {
    const file = Bun.file(this.metricsPath(workItemId2));
    if (!await file.exists())
      return [];
    const text = await file.text();
    return text.split(`
`).filter((line) => line.trim().length > 0).map((line) => intentMetric.parse(JSON.parse(line)));
  }
  questionRoundsPath(workItemId2) {
    return join6(this.workItemDir(workItemId2), "question-rounds.jsonl");
  }
  async appendQuestionRoundLine(workItemId2, jsonLine) {
    return this.appendJsonlAtPath(this.questionRoundsPath(workItemId2), jsonLine);
  }
  async readQuestionRounds(workItemId2) {
    const file = Bun.file(this.questionRoundsPath(workItemId2));
    if (!await file.exists())
      return [];
    const text = await file.text();
    return text.split(`
`).filter((line) => line.trim().length > 0).map((line) => questionRound.parse(JSON.parse(line)));
  }
}
