// src/core/memory-store.ts
import { createHash as createHash4 } from "crypto";
import { open as open2, readdir as readdir10 } from "fs/promises";
import { dirname as dirname6, join as join25 } from "path";

class MemorySourceStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  dir() {
    return join25(dittoDir(this.repoRoot), "memory", "sources");
  }
  path(id) {
    return join25(this.dir(), `${id}.json`);
  }
  async exists(id) {
    return Bun.file(this.path(id)).exists();
  }
  async get(id) {
    return readJson(this.path(id), memorySource);
  }
  async write(source) {
    return writeJson(this.path(source.source_id), memorySource, source);
  }
  async list() {
    let entries;
    try {
      entries = await readdir10(this.dir());
    } catch {
      return [];
    }
    const out = [];
    for (const name of entries) {
      if (!name.endsWith(".json"))
        continue;
      try {
        out.push(await readJson(join25(this.dir(), name), memorySource));
      } catch {}
    }
    return out;
  }
}

class MemoryEventStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  dir() {
    return join25(dittoDir(this.repoRoot), "memory", "events");
  }
  path(id) {
    return join25(this.dir(), `${id}.json`);
  }
  async append(event) {
    const validated = memoryEvent.parse(event);
    const path = this.path(validated.event_id);
    await ensureDir(dirname6(path));
    let handle;
    try {
      handle = await open2(path, "wx");
    } catch (err) {
      if (err.code === "EEXIST") {
        throw new MemoryEventExistsError(validated.event_id);
      }
      throw err;
    }
    try {
      await handle.writeFile(`${JSON.stringify(validated, null, 2)}
`, "utf8");
    } finally {
      await handle.close();
    }
    return validated;
  }
  async get(id) {
    return readJson(this.path(id), memoryEvent);
  }
  async list() {
    let entries;
    try {
      entries = await readdir10(this.dir());
    } catch {
      return [];
    }
    const out = [];
    for (const name of entries) {
      if (!name.endsWith(".json"))
        continue;
      try {
        out.push(await readJson(join25(this.dir(), name), memoryEvent));
      } catch {}
    }
    out.sort((a2, b2) => {
      if (a2.created_at !== b2.created_at)
        return a2.created_at < b2.created_at ? -1 : 1;
      return a2.event_id < b2.event_id ? -1 : 1;
    });
    return out;
  }
}

class MemoryGraphIrStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  path() {
    return localDir(this.repoRoot, "memory", "ir", "graph-ir.json");
  }
  async read() {
    if (!await Bun.file(this.path()).exists())
      return null;
    return readJson(this.path(), memoryGraphIr);
  }
  async write(ir) {
    return writeJson(this.path(), memoryGraphIr, ir);
  }
}

class MemoryProjectionStore {
  repoRoot;
  constructor(repoRoot) {
    this.repoRoot = repoRoot;
  }
  dir() {
    return localDir(this.repoRoot, "memory", "projections");
  }
  manifestPath() {
    return join25(this.dir(), "manifest.json");
  }
  servingPath() {
    return join25(this.dir(), "graph.json");
  }
  wikiDir() {
    return join25(this.dir(), "wiki");
  }
  async readManifest() {
    if (!await Bun.file(this.manifestPath()).exists())
      return null;
    return readJson(this.manifestPath(), memoryProjectionManifest);
  }
  async writeManifest(m2) {
    return writeJson(this.manifestPath(), memoryProjectionManifest, m2);
  }
  async writeServing(graph) {
    await atomicWriteText(this.servingPath(), `${JSON.stringify(graph, null, 2)}
`);
    return graph;
  }
  async readServing() {
    if (!await Bun.file(this.servingPath()).exists())
      return null;
    return JSON.parse(await Bun.file(this.servingPath()).text());
  }
  async writeWiki(name, markdown) {
    await atomicWriteText(join25(this.wikiDir(), name), markdown);
  }
}
function sha256Hex(content) {
  return createHash4("sha256").update(content).digest("hex");
}
var MemoryEventExistsError;
var init_memory_store = __esm(() => {
  init_memory_event();
  init_memory_graph_ir();
  init_memory_projection_manifest();
  init_memory_source();
  init_ditto_paths();
  init_fs();
  MemoryEventExistsError = class MemoryEventExistsError extends Error {
    eventId;
    constructor(eventId) {
      super(`memory event ${eventId} already exists; events are immutable (append-only)`);
      this.eventId = eventId;
      this.name = "MemoryEventExistsError";
    }
  };
});

// src/core/memory-scan.ts
import { readdir as readdir11 } from "fs/promises";
import { isAbsolute as isAbsolute2, join as join26, relative as relative7, resolve as resolve3, sep as sep3 } from "path";
function classifyType(name) {
  const dot = name.lastIndexOf(".");
  if (dot < 0)
    return;
  return EXT_TYPE.get(name.slice(dot).toLowerCase());
}
function sourceIdForPath(repoRelativePath) {
  return `src_${sha256Hex(repoRelativePath).slice(0, 12)}`;
}
function gitHeadSha(repoRoot) {
  const proc = Bun.spawnSync(["git", "rev-parse", "HEAD"], {
    cwd: repoRoot,
    stdout: "pipe",
    stderr: "pipe"
  });
  if (proc.exitCode !== 0)
    return null;
  const sha = (proc.stdout?.toString() ?? "").trim();
  return /^[a-f0-9]{40}$/.test(sha) ? sha : null;
}
async function findOwningRepo(absPath, rootingRoot) {
  let current = resolve3(absPath);
  const root = resolve3(rootingRoot);
  while (true) {
    if (await fileExists(join26(current, ".git")))
      return current;
    if (current === root)
      return null;
    const parent = resolve3(current, "..");
    if (parent === current)
      return null;
    if (!resolve3(current).startsWith(root + sep3) && resolve3(current) !== root)
      return null;
    current = parent;
  }
}
async function walkFiles(root, maxDepth = 12) {
  const out = [];
  async function walk(dir, depth) {
    if (depth > maxDepth)
      return;
    let entries;
    try {
      entries = await readdir11(dir, { withFileTypes: true });
    } catch {
      return;
    }
    for (const e2 of entries) {
      const full = join26(dir, e2.name);
      if (e2.isDirectory()) {
        if (!SKIP_DIRS2.has(e2.name))
          await walk(full, depth + 1);
      } else if (e2.isFile() && classifyType(e2.name) !== undefined) {
        out.push(full);
      }
    }
  }
  await walk(resolve3(root), 0);
  out.sort();
  return out;
}
async function scanSources(repoRoot, options = {}) {
  const root = resolve3(repoRoot);
  const sourceRoot = resolve3(options.sourceRoot && isAbsolute2(options.sourceRoot) ? options.sourceRoot : join26(root, options.sourceRoot ?? "."));
  const now = (options.now ?? new Date).toISOString();
  const store = new MemorySourceStore(root);
  const existing = new Map;
  for (const s2 of await store.list())
    existing.set(s2.source_id, s2);
  const files = await walkFiles(sourceRoot);
  const headCache = new Map;
  const rootHead = gitHeadSha(root);
  headCache.set(root, rootHead);
  const scanned = [];
  const added = [];
  const changed = [];
  const unchanged = [];
  for (const abs of files) {
    const repoRelative = relative7(root, abs);
    if (repoRelative.startsWith("..") || isAbsolute2(repoRelative))
      continue;
    const sourceType = classifyType(abs);
    if (sourceType === undefined)
      continue;
    const content = await Bun.file(abs).text();
    const contentHash = sha256Hex(content);
    const sourceId = sourceIdForPath(repoRelative);
    const owningRepo = await findOwningRepo(abs, root);
    const isOwnRoot = owningRepo === null || resolve3(owningRepo) === root;
    let head;
    if (isOwnRoot) {
      head = rootHead;
    } else {
      const key = resolve3(owningRepo);
      if (!headCache.has(key))
        headCache.set(key, gitHeadSha(key));
      head = headCache.get(key) ?? null;
    }
    const revision = head ?? `snapshot:${contentHash.slice(0, 16)}`;
    const prior = existing.get(sourceId);
    const source = {
      schema_version: "0.1.0",
      source_id: sourceId,
      source_type: sourceType,
      path: repoRelative,
      content_hash: contentHash,
      captured_at: now,
      revision,
      sensitivity: prior?.sensitivity ?? "internal",
      word_count: content.split(/\s+/).filter((w2) => w2.length > 0).length,
      ...isOwnRoot ? {} : { repo: relative7(root, owningRepo) },
      ...head ? { git_commit: head } : {}
    };
    let status;
    if (!prior)
      status = "added";
    else if (prior.content_hash !== contentHash)
      status = "changed";
    else
      status = "unchanged";
    if (status === "unchanged") {
      scanned.push({ source: prior, status });
      unchanged.push(sourceId);
      continue;
    }
    await store.write(source);
    scanned.push({ source, status });
    if (status === "added")
      added.push(sourceId);
    else
      changed.push(sourceId);
  }
  return { scanned, added, changed, unchanged };
}
var SKIP_DIRS2, EXT_TYPE;
var init_memory_scan = __esm(() => {
  init_shared();
  init_memory_store();
  SKIP_DIRS2 = new Set([
    "node_modules",
    ".git",
    ".ditto",
    "target",
    "build",
    "dist",
    ".gradle",
    "out",
    "coverage"
  ]);
  EXT_TYPE = new Map([
    [".ts", "code"],
    [".tsx", "code"],
    [".js", "code"],
    [".jsx", "code"],
    [".mjs", "code"],
    [".cjs", "code"],
    [".py", "code"],
    [".java", "code"],
    [".kt", "code"],
    [".go", "code"],
    [".rs", "code"],
    [".md", "markdown"],
    [".mdx", "markdown"]
  ]);
});

// src/schemas/cleanup-index.ts
var cleanupAction, cleanupTrackedFilter, cleanupBasisSignal, cleanupRunParams, cleanupEntry, cleanupIndex;
var init_cleanup_index = __esm(() => {
  init_zod();
  init_common();
  cleanupAction = exports_external.enum(["delete-candidate", "quarantine", "absorb-then-discard", "unclassified"]).describe("Disposition of a classified doc; matches the action subfolder name");
  cleanupTrackedFilter = exports_external.enum(["tracked-only", "include-untracked", "untracked-only"]).describe("Which git-tracking status of files the run classifies");
