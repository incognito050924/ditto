// src/core/init-scaffold.ts
init_fs();
init_shared();
var SCAFFOLD_DIRS = [
  join76("local", "work-items"),
  join76("local", "runs"),
  join76("local", "handoff"),
  join76("local", "sessions"),
  join76("local", "logs"),
  join76("local", "cache"),
  "agents",
  "knowledge",
  join76("knowledge", "adr")
];
var DITTO_GITIGNORE = `# DITTO per-developer runtime \u2014 volatile, not for version control.
# Managed by \`ditto init\`; safe to edit.
# Tier \u2462 per-developer (gitignored): everything under local/.
local/
# Tier \u2461 project-global (git-shared): knowledge/ and agents/ stay tracked.
!knowledge/
!agents/
`;
function emptyContext(projectName) {
  return `# ${projectName} \u2014 DITTO Knowledge Context

Durable project knowledge lives under \`.ditto/knowledge/\`. This file is seeded
empty by \`ditto init\`; DITTO's knowledge-update flow appends durable decisions,
agreed terms, and learnings over time.

- glossary: \`glossary.json\`
- decisions: \`adr/\`
`;
}
async function ensureDirTracked(absPath, relPath, created) {
  const existed = await fileExists(absPath);
  await ensureDir(absPath);
  if (!existed)
    created.push(relPath);
}
async function seedFileIfAbsent(absPath, relPath, write, created, skipped) {
  if (await fileExists(absPath)) {
    skipped.push(relPath);
    return false;
  }
  await write();
  created.push(relPath);
  return true;
}
async function initScaffold(repoRoot, now) {
  const dittoDir2 = join76(repoRoot, ".ditto");
  const createdDirs = [];
  const createdFiles = [];
  const skippedFiles = [];
  const glossaryAbs = join76(dittoDir2, "knowledge", "glossary.json");
  const alreadyInitialized = await fileExists(glossaryAbs);
  await ensureDirTracked(dittoDir2, ".ditto", createdDirs);
  for (const sub of SCAFFOLD_DIRS) {
    await ensureDirTracked(join76(dittoDir2, sub), join76(".ditto", sub), createdDirs);
  }
  const projectName = basename5(repoRoot) || "project";
  await seedFileIfAbsent(glossaryAbs, join76(".ditto", "knowledge", "glossary.json"), () => writeJson(glossaryAbs, glossary, {
    schema_version: "0.1.0",
    project_name: projectName,
    updated_at: now.toISOString(),
    entries: []
  }).then(() => {
    return;
  }), createdFiles, skippedFiles);
  const contextAbs = join76(dittoDir2, "knowledge", "CONTEXT.md");
  await seedFileIfAbsent(contextAbs, join76(".ditto", "knowledge", "CONTEXT.md"), () => atomicWriteText(contextAbs, emptyContext(projectName)), createdFiles, skippedFiles);
  const gitignoreAbs = join76(dittoDir2, ".gitignore");
  await seedFileIfAbsent(gitignoreAbs, join76(".ditto", ".gitignore"), () => atomicWriteText(gitignoreAbs, DITTO_GITIGNORE), createdFiles, skippedFiles);
  return { repoRoot, createdDirs, createdFiles, skippedFiles, alreadyInitialized };
}

// src/cli/commands/init.ts
var initCommand = defineCommand({
  meta: {
    name: "init",
    description: "Scaffold a .ditto/ workspace in the target project (idempotent)"
  },
  args: {
    dir: {
      type: "string",
      required: false,
      description: "Target directory; defaults to the nearest .ditto/.git root or cwd"
    },
    output: { type: "string", default: "human", description: "Output format: human|json" }
  },
  run: async ({ args }) => {
    try {
      const format = parseOutputFormat(args.output);
      const repoRoot = args.dir ? resolve21(args.dir) : await resolveRepoRootForCreate();
      const result2 = await initScaffold(repoRoot, new Date);
      if (format === "json") {
        writeJson2(result2);
        return;
      }
      if (result2.alreadyInitialized) {
        writeHuman(`.ditto/ already initialized at ${result2.repoRoot}`);
      } else {
        writeHuman(`initialized .ditto/ at ${result2.repoRoot}`);
      }
      writeHuman(`dirs: ${result2.createdDirs.length} created \xB7 files: ${result2.createdFiles.length} created, ${result2.skippedFiles.length} kept`);
      for (const path of result2.createdFiles)
        writeHuman(`  + ${path}`);
      for (const path of result2.skippedFiles)
        writeHuman(`  = ${path} (kept)`);
    } catch (err) {
      writeError(`init failed: ${err instanceof Error ? err.message : String(err)}`);
      process.exit(RUNTIME_ERROR_EXIT);
    }
  }
});

