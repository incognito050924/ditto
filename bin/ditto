// src/schemas/common.ts
var isoDateTime, workItemId, runId, reviewId, autopilotId, profileName, declarerRole, providerName, verdict, workItemStatus, severity, sha256, relativePath, evidenceRef, evidenceRequiredKind, uncertaintyItem, schemaVersion;
var init_common = __esm(() => {
  init_zod();
  isoDateTime = exports_external.string().datetime({ offset: true }).describe("RFC 3339 / ISO 8601 datetime with timezone offset");
  workItemId = exports_external.string().regex(/^wi_[a-z0-9]{8,}$/, "work item id must start with wi_ followed by 8+ lowercase alphanumerics").describe("Stable identifier for a work item");
  runId = exports_external.string().regex(/^run_[a-z0-9]{8,}$/, "run id must start with run_ followed by 8+ lowercase alphanumerics").describe("Stable identifier for a single provider run");
  reviewId = exports_external.string().regex(/^rv_[a-z0-9]{8,}$/, "review id must start with rv_ followed by 8+ lowercase alphanumerics").describe("Stable identifier for a reviewer output");
  autopilotId = exports_external.string().regex(/^orch_[a-z0-9]{8,}$/, "autopilot id must start with orch_ followed by 8+ lowercase alphanumerics").describe("Stable identifier for an autopilot graph (orchestrator run)");
  profileName = exports_external.enum(["read-only", "workspace-write", "networked", "reviewer", "isolated"]).describe("Execution profile that determines permission and network policy");
  declarerRole = exports_external.enum(["main", "planner", "implementer", "verifier", "reviewer", "researcher", "synthesizer"]).describe("Agent role that authored a completion claim (who judged), distinct from the execution profile (how it ran)");
  providerName = exports_external.enum(["codex", "claude-code", "opencode", "openagent", "other"]).describe("Provider host that executes the run");
  verdict = exports_external.enum(["pass", "partial", "fail", "unverified"]).describe("Acceptance verdict for a criterion or review");
  workItemStatus = exports_external.enum(["draft", "in_progress", "blocked", "partial", "unverified", "done", "abandoned"]).describe("Current lifecycle status of a work item");
  severity = exports_external.enum(["info", "low", "medium", "high", "critical"]).describe("Finding severity");
  sha256 = exports_external.string().regex(/^[a-f0-9]{64}$/, "sha256 must be 64 lowercase hex characters").describe("Lowercase hex sha256 hash");
  relativePath = exports_external.string().min(1).refine((s2) => !s2.startsWith("/") && !s2.includes(".."), {
    message: "must be repo-relative without parent traversal"
  }).describe("Repo-relative path; absolute paths and .. traversal are rejected");
  evidenceRef = exports_external.object({
    kind: exports_external.enum(["command", "file", "artifact", "url", "note"]),
    path: relativePath.optional(),
    url: exports_external.string().url().optional(),
    command: exports_external.string().optional(),
    sha256: sha256.optional(),
    lines: exports_external.object({ start: exports_external.number().int().positive(), end: exports_external.number().int().positive() }).optional(),
    summary: exports_external.string().max(2000).optional()
  }).describe("Pointer to evidence stored outside the manifest itself");
  evidenceRequiredKind = exports_external.enum(["test", "diff", "browser", "doc", "log"]).describe("Kind of evidence required to verify an acceptance criterion");
  uncertaintyItem = exports_external.object({
    item: exports_external.string().min(1).describe("What is unresolved / was not verified"),
    reason: exports_external.string().min(1).describe("Why it remains open / why verification did not happen")
  }).describe("A single declared uncertainty: what is unresolved and why");
  schemaVersion = exports_external.literal("0.1.0").describe("Version of the DITTO schema set this document conforms to");
});

// src/core/ditto-paths.ts
import { join as join5 } from "path";
function dittoDir(repoRoot) {
  return join5(repoRoot, ".ditto");
}
function localDir(repoRoot, ...segments) {
  return join5(repoRoot, ".ditto", "local", ...segments);
}
function committedWorkItemDir(repoRoot, id) {
  return join5(dittoDir(repoRoot), "work-items", id);
}
