        process.exit(USAGE_ERROR_EXIT);
        return;
      }
    }
    const repoRoot = await resolveRepoRootForCreate();
    const sourceStore = new MemorySourceStore(repoRoot);
    let hasCodeSource = false;
    for (const id of sources) {
