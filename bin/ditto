    kind: acgEvidenceKind,
    ref: exports_external.string().optional().describe("e2e \u2192 JourneyRun (acg.journey-run.v1) reference")
  }).optional().describe("Evidence; may be omitted when unresolved=true"),
  unresolved: exports_external.boolean().default(false).describe("Evidence-absence marker (OBJ-53). NOT an evidenceRef.kind \u2014 a separate flag")
}).superRefine((value, ctx) => {
