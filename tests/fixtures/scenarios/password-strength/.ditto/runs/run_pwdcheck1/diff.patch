new file mode 100644
--- /dev/null
+++ b/src/auth/password-policy.ts
@@ -0,0 +1,18 @@
+export type PolicyViolation = 'min_length' | 'character_class';
+
+export function checkPassword(pw: string): PolicyViolation[] {
+  const violations: PolicyViolation[] = [];
+  if (pw.length < 12) violations.push('min_length');
+  if (!/[A-Za-z]/.test(pw) || !/[0-9]/.test(pw)) violations.push('character_class');
+  return violations;
+}
+
+export function violationMessage(violations: PolicyViolation[]): string {
+  if (violations.length === 0) return '';
+  return 'password does not meet policy';
+}
