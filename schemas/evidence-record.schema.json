{
  "$ref": "#/definitions/evidence-record",
  "definitions": {
    "evidence-record": {
      "type": "object",
      "properties": {
        "ref": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "command",
                "file",
                "artifact",
                "url",
                "note"
              ]
            },
            "path": {
              "type": "string",
              "minLength": 1,
              "description": "Repo-relative path; absolute paths and .. traversal are rejected"
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "command": {
              "type": "string"
            },
            "sha256": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$",
              "description": "Lowercase hex sha256 hash"
            },
            "lines": {
              "type": "object",
              "properties": {
                "start": {
                  "type": "integer",
                  "exclusiveMinimum": 0
                },
                "end": {
                  "type": "integer",
                  "exclusiveMinimum": 0
                }
              },
              "required": [
                "start",
                "end"
              ],
              "additionalProperties": false
            },
            "summary": {
              "type": "string",
              "maxLength": 2000
            }
          },
          "required": [
            "kind"
          ],
          "additionalProperties": false,
          "description": "Pointer to evidence stored outside the manifest itself"
        },
        "captured_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "freshness": {
          "type": "string",
          "enum": [
            "fresh",
            "stale"
          ],
          "description": "Whether the captured evidence still reflects the current state"
        },
        "stale_reason": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Why the evidence is stale; required when freshness=stale, null when fresh"
        },
        "portability": {
          "type": "string",
          "enum": [
            "committed",
            "local-artifact"
          ],
          "description": "Whether the raw artifact travels with the repo (committed) or only exists in the capturing clone/session (local-artifact)"
        },
        "artifact_available": {
          "type": "boolean",
          "description": "True when the raw artifact can be opened in this clone/session"
        },
        "exit_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Process exit code for command evidence; null for non-command kinds"
        },
        "key_lines": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Excerpt lines that make the evidence judgeable without the raw artifact"
        }
      },
      "required": [
        "ref",
        "captured_at",
        "freshness",
        "portability",
        "artifact_available"
      ],
      "additionalProperties": false,
      "description": "Evidence freshness/portability sidecar wrapping an evidenceRef"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
