{
  "$ref": "#/definitions/acg-semantic-compatibility",
  "definitions": {
    "acg-semantic-compatibility": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Version of the DITTO schema set this document conforms to"
        },
        "kind": {
          "type": "string",
          "const": "acg.semantic-compatibility.v1"
        },
        "work_item_id": {
          "type": "string",
          "pattern": "^wi_[a-z0-9]{8,}$",
          "description": "Stable identifier for a work item"
        },
        "produced_by": {
          "type": "string",
          "enum": [
            "agent",
            "user"
          ],
          "description": "Who produced this ACG artifact"
        },
        "produced_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "change": {
          "type": "object",
          "properties": {
            "before": {
              "type": "string",
              "minLength": 1
            },
            "after": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "before",
            "after"
          ],
          "additionalProperties": false
        },
        "old_meaning": {
          "type": "string",
          "minLength": 1,
          "description": "Domain meaning the old signature expressed"
        },
        "business_assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Implicit assumptions callers depended on"
        },
        "compatibility": {
          "type": "string",
          "enum": [
            "compatible",
            "additive",
            "breaking"
          ]
        },
        "characterization": {
          "type": "object",
          "properties": {
            "exists": {
              "type": "boolean"
            },
            "test_ref": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "candidate": {
              "type": [
                "string",
                "null"
              ],
              "default": null,
              "description": "Generated candidate when no behavior test exists"
            }
          },
          "required": [
            "exists"
          ],
          "additionalProperties": false
        },
        "verdict": {
          "type": "object",
          "properties": {
            "type_safe": {
              "type": "boolean"
            },
            "semantic_safe": {
              "type": "string",
              "enum": [
                "yes",
                "no",
                "unverified"
              ]
            },
            "intended_breaking": {
              "type": "boolean"
            },
            "reproducibility": {
              "type": "object",
              "properties": {
                "model_version": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Pinned judge model id (e.g. claude-opus-4-8)"
                },
                "prompt_hash": {
                  "type": "string"
                },
                "votes": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "required": [
                "model_version"
              ],
              "additionalProperties": false,
              "description": "Pinned judge model for an LLM meaning judgment; required when semantic_safe=yes"
            }
          },
          "required": [
            "type_safe",
            "semantic_safe"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "schema_version",
        "kind",
        "work_item_id",
        "produced_by",
        "produced_at",
        "change",
        "old_meaning",
        "compatibility",
        "verdict"
      ],
      "additionalProperties": false,
      "description": "ACG SemanticCompatibility — type vs meaning split verdict"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
