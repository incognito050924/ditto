{
  "$ref": "#/definitions/memory-event",
  "definitions": {
    "memory-event": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Version of the DITTO schema set this document conforms to"
        },
        "event_id": {
          "type": "string",
          "pattern": "^memevt_[a-z0-9_-]{4,}$",
          "description": "Stable identifier for one append-only memory event"
        },
        "event_type": {
          "type": "string",
          "enum": [
            "decision",
            "observation",
            "preference",
            "review_outcome",
            "analysis",
            "correction"
          ],
          "description": "What kind of memory this event records"
        },
        "actor": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "user",
                "agent"
              ]
            },
            "role": {
              "type": "string",
              "minLength": 1,
              "description": "agent role when kind=agent, e.g. reviewer"
            }
          },
          "required": [
            "kind"
          ],
          "additionalProperties": false,
          "description": "Who authored the event"
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected",
            "superseded"
          ],
          "description": "Review lifecycle; only approved events feed projections (report §10)",
          "default": "pending"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^src_[a-z0-9_-]{4,}$",
            "description": "Stable identifier for a raw source captured into memory"
          },
          "default": [],
          "description": "source ids grounding this event"
        },
        "confidence_kind": {
          "type": "string",
          "enum": [
            "EXTRACTED",
            "INFERRED",
            "AMBIGUOUS"
          ],
          "description": "Provenance class of a relation: EXTRACTED (explicit in source), INFERRED (deduced), AMBIGUOUS (uncertain — review only)",
          "default": "EXTRACTED"
        },
        "sensitivity": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "secret"
          ],
          "description": "Disclosure class of a source or memory event",
          "default": "internal"
        },
        "approved_by": {
          "type": "string",
          "minLength": 1
        },
        "decided_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "supersedes": {
          "type": "string",
          "pattern": "^memevt_[a-z0-9_-]{4,}$",
          "description": "Stable identifier for one append-only memory event"
        }
      },
      "required": [
        "schema_version",
        "event_id",
        "event_type",
        "actor",
        "text",
        "created_at"
      ],
      "additionalProperties": false,
      "description": "Append-only memory event — SoT for knowledge not reconstructable from raw source (report §3.2)"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
