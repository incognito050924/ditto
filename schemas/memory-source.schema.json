{
  "$ref": "#/definitions/memory-source",
  "definitions": {
    "memory-source": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Version of the DITTO schema set this document conforms to"
        },
        "source_id": {
          "type": "string",
          "pattern": "^src_[a-z0-9_-]{4,}$",
          "description": "Stable identifier for a raw source captured into memory"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "code",
            "markdown",
            "spec",
            "note",
            "log",
            "chat",
            "image",
            "other"
          ],
          "description": "Kind of raw source"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Repo-relative path for file-backed sources"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Location for url-backed sources"
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "Hash of the captured content; drives stale detection"
        },
        "captured_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "revision": {
          "type": "string",
          "minLength": 1,
          "description": "git commit, file mtime, or snapshot id identifying this source version"
        },
        "git_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$",
          "description": "Full git commit sha, when the source is git-managed"
        },
        "sensitivity": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "secret"
          ],
          "description": "Disclosure class of a source or memory event",
          "default": "internal"
        },
        "word_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "schema_version",
        "source_id",
        "source_type",
        "content_hash",
        "captured_at",
        "revision"
      ],
      "additionalProperties": false,
      "description": "Manifest entry for one raw source — the mutable reality memory projects from (report §3.1)"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
