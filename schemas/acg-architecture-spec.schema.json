{
  "$ref": "#/definitions/acg-architecture-spec",
  "definitions": {
    "acg-architecture-spec": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Version of the DITTO schema set this document conforms to"
        },
        "kind": {
          "type": "string",
          "const": "acg.architecture-spec.v1"
        },
        "produced_by": {
          "type": "string",
          "enum": [
            "agent",
            "user"
          ],
          "description": "Who produced this ACG artifact"
        },
        "produced_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "layers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "can_call": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              }
            },
            "additionalProperties": false
          },
          "default": {},
          "description": "Layer name → allowed call targets"
        },
        "public_surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "internal_packages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "glob",
                  "path"
                ]
              },
              "value": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "type",
              "value"
            ],
            "additionalProperties": false,
            "description": "Internal sibling-module descriptor — `glob`: package-name glob for cross_repo classification; `path`: repo-relative glob locating the local sibling artifact (JAR) for the JVM guard"
          },
          "default": [],
          "description": "Internal sibling-module descriptors. `glob` entries are package-name globs (e.g. \"kr.co.ecoletree.boxwood.domain.**\"): a statically unresolved dep (NOT fromSource) whose package matches one is a sibling module absent from this single-module DB → recorded as ImpactGraph.unresolved{cross_repo}; non-matching packages are third-party (Spring/JDK) and ignored. `path` entries are repo-relative globs locating the local sibling artifacts (e.g. \"**/libs/*.jar\"): the JVM guard blocks when such a JAR exists but the declaration has a gap (no glob, or a JAR not covered by a path entry)."
        },
        "forbidden_dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from": {
                "type": "string",
                "minLength": 1
              },
              "to": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "from",
              "to",
              "reason"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "ownership": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "module": {
                "type": "string",
                "minLength": 1
              },
              "owner": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "module",
              "owner"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "module_invariants": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Generalizable invariants — FitnessFunction promotion candidates"
        },
        "conventions": {
          "type": "object",
          "properties": {
            "formatter": {
              "type": "object",
              "properties": {
                "cmd": {
                  "type": "string",
                  "minLength": 1
                },
                "on_violation": {
                  "type": "string",
                  "enum": [
                    "block",
                    "warn"
                  ],
                  "default": "block"
                }
              },
              "required": [
                "cmd"
              ],
              "additionalProperties": false
            },
            "linter": {
              "type": "object",
              "properties": {
                "cmd": {
                  "type": "string",
                  "minLength": 1
                },
                "on_violation": {
                  "type": "string",
                  "enum": [
                    "block",
                    "warn"
                  ],
                  "default": "block"
                }
              },
              "required": [
                "cmd"
              ],
              "additionalProperties": false
            },
            "naming": {
              "type": "object",
              "properties": {
                "rule": {
                  "type": "string",
                  "minLength": 1
                },
                "evaluator": {
                  "type": "string",
                  "enum": [
                    "deterministic",
                    "llm_judged"
                  ]
                }
              },
              "required": [
                "rule",
                "evaluator"
              ],
              "additionalProperties": false
            },
            "approved_patterns": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": []
            },
            "exceptions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "rule": {
                    "type": "string",
                    "minLength": 1
                  },
                  "path": {
                    "type": "string",
                    "minLength": 1
                  },
                  "reason": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "rule",
                  "path",
                  "reason"
                ],
                "additionalProperties": false
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "description": "Style/quality consistency policy — deterministic enforcement substrate (§1.1(1))"
        }
      },
      "required": [
        "schema_version",
        "kind",
        "produced_by",
        "produced_at"
      ],
      "additionalProperties": false,
      "description": "ACG ArchitectureSpec — layers, surfaces, forbidden deps, conventions"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
