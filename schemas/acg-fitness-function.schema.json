{
  "$ref": "#/definitions/acg-fitness-function",
  "definitions": {
    "acg-fitness-function": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Version of the DITTO schema set this document conforms to"
        },
        "kind": {
          "type": "string",
          "const": "acg.fitness-function.v1"
        },
        "produced_by": {
          "type": "string",
          "enum": [
            "agent",
            "user"
          ],
          "description": "Who produced this ACG artifact"
        },
        "produced_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable slug, e.g. ff-backend-sb-version-single"
        },
        "statement": {
          "type": "string",
          "minLength": 1,
          "description": "Property to keep (human-readable)"
        },
        "fitness_kind": {
          "type": "string",
          "enum": [
            "architectural",
            "dependency",
            "semantic",
            "coverage",
            "consistency",
            "performance",
            "duplication",
            "complexity",
            "user_journey"
          ]
        },
        "evaluator": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "deterministic",
                "llm_judged",
                "executed"
              ]
            },
            "spec": {
              "type": "string",
              "minLength": 1,
              "description": "deterministic: command/query; llm_judged: judge prompt"
            },
            "reproducibility": {
              "type": "object",
              "properties": {
                "model_version": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Pinned judge model id (e.g. claude-opus-4-8)"
                },
                "prompt_hash": {
                  "type": "string"
                },
                "votes": {
                  "type": "integer",
                  "minimum": 1
                },
                "tie_break": {
                  "type": "string",
                  "enum": [
                    "fail_closed",
                    "fail_open",
                    "escalate"
                  ]
                },
                "input_fixing": {
                  "type": "string"
                }
              },
              "required": [
                "model_version"
              ],
              "additionalProperties": false,
              "description": "llm_judged reproducibility fixing (OBJ-07)"
            },
            "execution": {
              "type": "object",
              "properties": {
                "environment": {
                  "type": "string"
                },
                "timeout_s": {
                  "type": "integer",
                  "exclusiveMinimum": 0
                },
                "retries": {
                  "type": "integer",
                  "minimum": 0
                },
                "flake_policy": {
                  "type": "string",
                  "enum": [
                    "quarantine",
                    "fail",
                    "retry"
                  ]
                },
                "selection": {
                  "type": "string",
                  "enum": [
                    "per_change",
                    "risk_tiered",
                    "sampled",
                    "periodic"
                  ]
                },
                "budget": {
                  "type": "string"
                }
              },
              "additionalProperties": false,
              "description": "mode=executed policy: flaky/cost handling (OBJ-18)"
            }
          },
          "required": [
            "mode",
            "spec"
          ],
          "additionalProperties": false
        },
        "baseline": {
          "type": "object",
          "properties": {
            "metric": {
              "type": "string"
            },
            "scope": {
              "type": "string"
            },
            "threshold": {
              "type": "number"
            },
            "comparator": {
              "type": "string",
              "enum": [
                "lte",
                "gte",
                "eq"
              ]
            },
            "violation_identity": {
              "type": "string",
              "description": "Key that identifies the same violation across snapshots"
            },
            "snapshot": {
              "type": "string",
              "description": "Identifier set/count at introduction — existing debt"
            },
            "delta_only": {
              "type": "boolean"
            },
            "window": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "description": "Existing-debt baseline for incremental enforcement (OBJ-03/21)"
        },
        "cadence": {
          "type": "object",
          "properties": {
            "per_change": {
              "type": "boolean",
              "default": false
            },
            "periodic": {
              "type": "string",
              "enum": [
                "none",
                "daily",
                "weekly",
                "on_release"
              ],
              "default": "none"
            }
          },
          "additionalProperties": false
        },
        "on_violation": {
          "type": "string",
          "enum": [
            "block",
            "warn",
            "track"
          ]
        },
        "source_change": {
          "type": "string",
          "pattern": "^wi_[a-z0-9]{8,}$",
          "description": "work item/ChangeContract that promoted this"
        }
      },
      "required": [
        "schema_version",
        "kind",
        "produced_by",
        "produced_at",
        "id",
        "statement",
        "fitness_kind",
        "evaluator",
        "cadence",
        "on_violation"
      ],
      "additionalProperties": false,
      "description": "ACG FitnessFunction — continuous fitness predicate"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
