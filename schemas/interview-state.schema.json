{
  "$ref": "#/definitions/interview-state",
  "definitions": {
    "interview-state": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Version of the DITTO schema set this document conforms to"
        },
        "work_item_id": {
          "type": "string",
          "pattern": "^wi_[a-z0-9]{8,}$",
          "description": "Stable identifier for a work item"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "converged",
            "deferred",
            "aborted"
          ],
          "description": "Lifecycle of the deep interview"
        },
        "started_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "dimensions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "critical": {
                "type": "boolean",
                "default": false
              },
              "state": {
                "type": "string",
                "enum": [
                  "unknown",
                  "partial",
                  "resolved"
                ],
                "description": "Resolution state of one ambiguity dimension"
              },
              "ambiguity": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "resolved_by": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "notes": {
                "type": "string",
                "default": ""
              }
            },
            "required": [
              "id",
              "state",
              "ambiguity"
            ],
            "additionalProperties": false,
            "description": "One ambiguity dimension tracked during the interview"
          },
          "default": []
        },
        "readiness": {
          "type": "object",
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "critical_unresolved": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "gate": {
              "type": "string",
              "enum": [
                "blocked",
                "ready"
              ]
            }
          },
          "required": [
            "score",
            "threshold",
            "gate"
          ],
          "additionalProperties": false
        },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "asked_at": {
                "type": "string",
                "format": "date-time",
                "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
              },
              "dimension": {
                "type": "string",
                "minLength": 1
              },
              "question": {
                "type": "string",
                "minLength": 1
              },
              "why_matters": {
                "type": "string",
                "minLength": 1,
                "description": "What changes depending on the answer"
              },
              "info_gain_estimate": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ],
                "description": "Estimated information gain of a question"
              },
              "self_answer_attempts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "source": {
                      "type": "string",
                      "enum": [
                        "code",
                        "docs",
                        "repo-artifact",
                        "web",
                        "memory"
                      ],
                      "description": "Where the agent tried to answer the question before asking the user"
                    },
                    "result": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Evidence found, or the reason the source did not resolve it"
                    }
                  },
                  "required": [
                    "source",
                    "result"
                  ],
                  "additionalProperties": false,
                  "description": "One self-answer attempt that must precede asking the user (§6.2)"
                },
                "default": []
              },
              "answer": {
                "type": "string"
              },
              "answer_kind": {
                "type": "string",
                "enum": [
                  "user",
                  "assumption"
                ]
              },
              "ambiguity_delta": {
                "type": "number"
              }
            },
            "required": [
              "id",
              "asked_at",
              "dimension",
              "question",
              "why_matters",
              "info_gain_estimate"
            ],
            "additionalProperties": false,
            "description": "One asked question with its self-answer attempts and outcome"
          },
          "default": []
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "statement": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "enum": [
                  "finding",
                  "hypothesis",
                  "taste"
                ],
                "description": "What the item is; backing-less claims are hypothesis, not finding"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ],
                "description": "Confidence in a claim; backing-less claims must be low"
              },
              "because_no_answer_to": {
                "type": "string",
                "minLength": 1,
                "description": "Question id left unanswered"
              }
            },
            "required": [
              "statement",
              "label",
              "confidence",
              "because_no_answer_to"
            ],
            "additionalProperties": false,
            "description": "Assumption recorded when a question was not answered (§6.9)"
          },
          "default": []
        },
        "exit": {
          "type": "object",
          "properties": {
            "reason": {
              "type": "string",
              "enum": [
                "readiness_met",
                "diminishing_returns",
                "user_deferred",
                "user_owned_decision",
                "cap_reached"
              ]
            },
            "question_cap": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "questions_asked": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "reason",
            "question_cap",
            "questions_asked"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "schema_version",
        "work_item_id",
        "status",
        "started_at",
        "updated_at",
        "readiness",
        "exit"
      ],
      "additionalProperties": false,
      "description": "Deep interview sidecar tracking ambiguity dimensions and readiness (§6.3)"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
