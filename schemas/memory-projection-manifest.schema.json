{
  "$ref": "#/definitions/memory-projection-manifest",
  "definitions": {
    "memory-projection-manifest": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Version of the DITTO schema set this document conforms to"
        },
        "projection_id": {
          "type": "string",
          "pattern": "^proj_[a-z0-9_-]{4,}$",
          "description": "Stable identifier for one projection generation"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "graph_ir_version": {
          "type": "string",
          "pattern": "^ir_[a-z0-9_-]{4,}$",
          "description": "Stable identifier for one Graph IR snapshot"
        },
        "wiki_version": {
          "type": "string",
          "minLength": 1
        },
        "serving_version": {
          "type": "string",
          "minLength": 1
        },
        "extractor_versions": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          },
          "default": {},
          "description": "extractor name -> version, e.g. { ast: ast-v1, semantic: semantic-v1 }"
        },
        "source_revisions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source_id": {
                "type": "string",
                "pattern": "^src_[a-z0-9_-]{4,}$",
                "description": "Stable identifier for a raw source captured into memory"
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "hash": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$",
                "description": "Lowercase hex sha256 hash"
              },
              "revision": {
                "type": "string",
                "minLength": 1
              },
              "git_commit": {
                "type": "string",
                "pattern": "^[a-f0-9]{40}$"
              }
            },
            "required": [
              "source_id",
              "hash",
              "revision"
            ],
            "additionalProperties": false,
            "description": "Which source version this projection reflects"
          },
          "default": []
        },
        "memory_event_until": {
          "type": "string",
          "pattern": "^memevt_[a-z0-9_-]{4,}$",
          "description": "latest event id reflected in this projection"
        },
        "dirty_sources": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^src_[a-z0-9_-]{4,}$",
            "description": "Stable identifier for a raw source captured into memory"
          },
          "default": [],
          "description": "sources whose current hash differs from this projection"
        }
      },
      "required": [
        "schema_version",
        "projection_id",
        "generated_at",
        "graph_ir_version"
      ],
      "additionalProperties": false,
      "description": "Lineage contract: what inputs a projection was built from, so freshness is cheap to judge (report §3.4)"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
