{
  "$ref": "#/definitions/acg-assurance-snapshot",
  "definitions": {
    "acg-assurance-snapshot": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Version of the DITTO schema set this document conforms to"
        },
        "kind": {
          "type": "string",
          "const": "acg.assurance-snapshot.v1"
        },
        "produced_by": {
          "type": "string",
          "enum": [
            "agent",
            "user"
          ],
          "description": "Who produced this ACG artifact"
        },
        "produced_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "at": {
          "type": "string",
          "format": "date-time",
          "description": "Evaluation time"
        },
        "trigger": {
          "type": "string",
          "enum": [
            "per_change",
            "periodic"
          ]
        },
        "change_ref": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^wi_[a-z0-9]{8,}$",
              "description": "Stable identifier for a work item"
            },
            {
              "type": "null"
            }
          ],
          "description": "per_change → the work item",
          "default": null
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "function_id": {
                "type": "string",
                "minLength": 1,
                "description": "FitnessFunction.id"
              },
              "outcome": {
                "type": "string",
                "enum": [
                  "pass",
                  "fail",
                  "skip"
                ]
              },
              "violations": {
                "type": "integer",
                "minimum": 0,
                "description": "Violation count (display/trend)"
              },
              "new_violations": {
                "type": "integer",
                "minimum": 0,
                "description": "Count not in baseline.snapshot — delta_only blocking basis"
              },
              "violation_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "description": "violation_identity set at this point — enables cross-snapshot delta recompute (OBJ-32)"
              },
              "new_violation_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "description": "violation_ids not in baseline.snapshot — legacy vs new, audited mechanically"
              }
            },
            "required": [
              "function_id",
              "outcome"
            ],
            "additionalProperties": false,
            "description": "One fitness function evaluation result at a point in time"
          },
          "default": []
        }
      },
      "required": [
        "schema_version",
        "kind",
        "produced_by",
        "produced_at",
        "at",
        "trigger"
      ],
      "additionalProperties": false,
      "description": "ACG AssuranceSnapshot — fitness evaluation time-series unit"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
