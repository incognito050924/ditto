{
  "$ref": "#/definitions/acg-journey-spec",
  "definitions": {
    "acg-journey-spec": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Version of the DITTO schema set this document conforms to"
        },
        "kind": {
          "type": "string",
          "const": "acg.journey-spec.v1"
        },
        "produced_by": {
          "type": "string",
          "enum": [
            "agent",
            "user"
          ],
          "description": "Who produced this ACG artifact"
        },
        "produced_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "id": {
          "type": "string",
          "pattern": "^jrn-[a-z0-9]+(?:-[a-z0-9]+)*$",
          "description": "Stable journey identifier (jrn-<kebab>) other schemas reference (e.g. jrn-process-run)"
        },
        "status": {
          "type": "string",
          "enum": [
            "spec_first",
            "awaiting_validation",
            "validated",
            "superseded"
          ],
          "description": "Journey lifecycle status (spec_first → awaiting_validation → validated | superseded)"
        },
        "story_id": {
          "type": "string",
          "pattern": "^us-[a-z0-9]+(?:-[a-z0-9]+)*$",
          "description": "Back-link to the story (us- id) this journey belongs to (traceability anchor)"
        },
        "title": {
          "type": "string"
        },
        "owner": {
          "type": "string",
          "minLength": 1,
          "description": "Product owner of the journey — freshness/judgment subject"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step_id": {
                "type": "string",
                "minLength": 1
              },
              "intent": {
                "type": "string",
                "minLength": 1,
                "description": "What the user achieves at this step"
              },
              "expected_outcome": {
                "type": "string"
              }
            },
            "required": [
              "step_id",
              "intent"
            ],
            "additionalProperties": false,
            "description": "One step of a journey, with a stable step_id"
          },
          "default": []
        },
        "surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Code/product surfaces (route/component/endpoint) this journey touches"
        },
        "fixtures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "evidence_requirement": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "e2e",
                "screen",
                "manual"
              ]
            },
            "must_pass_steps": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": []
            }
          },
          "required": [
            "kind"
          ],
          "additionalProperties": false
        },
        "freshness": {
          "type": "object",
          "properties": {
            "last_validated": {
              "type": "string",
              "format": "date-time"
            },
            "stale_after_days": {
              "type": "integer",
              "exclusiveMinimum": 0
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "schema_version",
        "kind",
        "produced_by",
        "produced_at",
        "id",
        "owner",
        "evidence_requirement"
      ],
      "additionalProperties": false,
      "description": "ACG JourneySpec — first-class user-journey catalog entry"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
