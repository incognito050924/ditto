{
  "$ref": "#/definitions/prism-issue-map",
  "definitions": {
    "prism-issue-map": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Version of the DITTO schema set this document conforms to"
        },
        "work_item_id": {
          "type": "string",
          "pattern": "^wi_[a-z0-9]{8,}$",
          "description": "Stable identifier for a work item"
        },
        "tree": {
          "type": "object",
          "properties": {
            "schema_version": {
              "type": "string",
              "const": "0.1.0",
              "description": "Version of the DITTO schema set this document conforms to"
            },
            "work_item_id": {
              "type": "string",
              "pattern": "^wi_[a-z0-9]{8,}$",
              "description": "Stable identifier for a work item"
            },
            "root_id": {
              "type": "string",
              "minLength": 1,
              "description": "Id of the root node (user original intent)"
            },
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "parent_id": {
                    "anyOf": [
                      {
                        "type": "string",
                        "minLength": 1
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "description": "Parent node id; null for the root"
                  },
                  "label": {
                    "type": "string",
                    "minLength": 1
                  },
                  "origin": {
                    "type": "string",
                    "enum": [
                      "seed",
                      "derived",
                      "discovered"
                    ],
                    "description": "How a coverage node entered the tree (§3.2)"
                  },
                  "depth_weight": {
                    "type": "number",
                    "description": "Estimated needed depth (§4.4)"
                  },
                  "state": {
                    "type": "string",
                    "enum": [
                      "open",
                      "resolved",
                      "user_owned",
                      "out_of_scope"
                    ],
                    "description": "Closure state of a coverage node (§3.3)"
                  },
                  "children": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "default": [],
                    "description": "Child node ids (flat array + parent_id represents the tree/DAG)"
                  },
                  "close_reason": {
                    "type": "string",
                    "description": "Recorded justification when the node is closed in a non-resolved state — a skip/deferral must be justified, never silent (§8-2, ac-2)"
                  },
                  "residual_risk": {
                    "type": "string",
                    "description": "The surviving risk a non-resolved close leaves behind (out_of_scope/user_owned) — distinct from close_reason (WHY skipped); this names WHAT RISK survives the skip. Required for a non-resolved close, recorded on the node (surviving-risk self-description gap)"
                  },
                  "disposition": {
                    "type": "string",
                    "enum": [
                      "code-verify",
                      "user-intent",
                      "runtime-post-impl"
                    ],
                    "description": "Disposition route of a category node; absent = DEFAULT_COVERAGE_DISPOSITION"
                  }
                },
                "required": [
                  "id",
                  "parent_id",
                  "label",
                  "origin",
                  "depth_weight",
                  "state"
                ],
                "additionalProperties": false,
                "description": "One node in the coverage scope tree (§3.1)"
              },
              "default": []
            },
            "intensity": {
              "type": "string",
              "enum": [
                "light",
                "standard",
                "full"
              ],
              "description": "Entry intensity override (ac-4) persisted on the first seed so the tier and termination depth K stay consistent across every round without the caller re-passing it (§8-4)"
            }
          },
          "required": [
            "schema_version",
            "work_item_id",
            "root_id"
          ],
          "additionalProperties": false,
          "description": "Coverage map sidecar (coverage.json) — additive dynamic-growth scope tree (§9)"
        },
        "severities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "node_id": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "enum": [
                  "critical",
                  "noncritical"
                ],
                "description": "Prism node severity — critical nodes gate minimal-launch (MODEL-2)"
              },
              "demotion_reason": {
                "type": "string",
                "description": "Explicit justification recorded on a critical→noncritical demotion (MODEL-2)"
              }
            },
            "required": [
              "node_id",
              "severity"
            ],
            "additionalProperties": false,
            "description": "One code-gated per-node severity assignment (MODEL-2)"
          },
          "default": [],
          "description": "Per-node severity authority state (MODEL-2)"
        },
        "notified_at": {
          "type": "string",
          "format": "date-time",
          "description": "When minimal-launch was announced (one-shot; retracted on regression, ac-4)"
        }
      },
      "required": [
        "schema_version",
        "work_item_id",
        "tree"
      ],
      "additionalProperties": false,
      "description": "Prism issue map — coverage tree + severity authority + launch notification (oi1)"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
