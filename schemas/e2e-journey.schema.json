{
  "$ref": "#/definitions/e2e-journey",
  "definitions": {
    "e2e-journey": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Version of the DITTO schema set this document conforms to"
        },
        "journey": {
          "type": "string",
          "minLength": 1,
          "description": "User journey name"
        },
        "journey_id": {
          "type": "string",
          "minLength": 1,
          "description": "ACG JourneySpec.id this run realizes (D4; distinct from `journey` name)"
        },
        "work_item_id": {
          "type": "string",
          "pattern": "^wi_[a-z0-9]{8,}$",
          "description": "Work item this journey run belongs to (D4)"
        },
        "url": {
          "type": "string",
          "minLength": 1,
          "description": "Target URL or dev-server entry under test"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "minLength": 1,
                "description": "User action performed, e.g. \"click Login\""
              },
              "target": {
                "type": "string",
                "description": "Selector/URL/element the action targets"
              },
              "expectation": {
                "type": "string",
                "description": "What should be observable after the action"
              }
            },
            "required": [
              "action"
            ],
            "additionalProperties": false,
            "description": "One step in the user journey"
          },
          "default": []
        },
        "assertions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string",
                "minLength": 1,
                "description": "What is being asserted about the journey"
              },
              "satisfied": {
                "type": "boolean",
                "description": "Whether the assertion held when the journey ran"
              }
            },
            "required": [
              "description",
              "satisfied"
            ],
            "additionalProperties": false,
            "description": "A checked assertion about the journey outcome"
          },
          "default": []
        },
        "result": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "blocked"
          ],
          "description": "Journey outcome: pass, fail (assertion/step failed), or blocked (could not run)"
        },
        "artifacts": {
          "type": "object",
          "properties": {
            "screenshots": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Repo-relative path under .ditto/runs/<id>/"
                  },
                  "sha256": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$",
                    "description": "Lowercase hex sha256 hash"
                  }
                },
                "required": [
                  "path"
                ],
                "additionalProperties": false,
                "description": "Pointer to a captured artifact (path + optional hash; raw stays under .ditto/runs)"
              },
              "default": []
            },
            "trace": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Repo-relative path under .ditto/runs/<id>/"
                    },
                    "sha256": {
                      "type": "string",
                      "pattern": "^[a-f0-9]{64}$",
                      "description": "Lowercase hex sha256 hash"
                    }
                  },
                  "required": [
                    "path"
                  ],
                  "additionalProperties": false,
                  "description": "Pointer to a captured artifact (path + optional hash; raw stays under .ditto/runs)"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Pointer to a captured artifact (path + optional hash; raw stays under .ditto/runs)",
              "default": null
            },
            "console": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Repo-relative path under .ditto/runs/<id>/"
                    },
                    "sha256": {
                      "type": "string",
                      "pattern": "^[a-f0-9]{64}$",
                      "description": "Lowercase hex sha256 hash"
                    }
                  },
                  "required": [
                    "path"
                  ],
                  "additionalProperties": false,
                  "description": "Pointer to a captured artifact (path + optional hash; raw stays under .ditto/runs)"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Pointer to a captured artifact (path + optional hash; raw stays under .ditto/runs)",
              "default": null
            },
            "network": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string",
                      "minLength": 1,
                      "description": "Repo-relative path under .ditto/runs/<id>/"
                    },
                    "sha256": {
                      "type": "string",
                      "pattern": "^[a-f0-9]{64}$",
                      "description": "Lowercase hex sha256 hash"
                    }
                  },
                  "required": [
                    "path"
                  ],
                  "additionalProperties": false,
                  "description": "Pointer to a captured artifact (path + optional hash; raw stays under .ditto/runs)"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Pointer to a captured artifact (path + optional hash; raw stays under .ditto/runs)",
              "default": null
            }
          },
          "additionalProperties": false,
          "description": "Captured browser artifacts (§10)",
          "default": {}
        },
        "reproduction": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Reproduction steps; required when result=fail (설계서 §10 \"실패 시 재현 절차\")"
        }
      },
      "required": [
        "schema_version",
        "journey",
        "url",
        "result"
      ],
      "additionalProperties": false,
      "description": "A browser user-journey verification result (§10)"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
