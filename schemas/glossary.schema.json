{
  "$ref": "#/definitions/glossary",
  "definitions": {
    "glossary": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1.0",
          "description": "Version of the DITTO schema set this document conforms to"
        },
        "project_name": {
          "type": "string",
          "minLength": 1
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
        },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "term": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80,
                "description": "Canonical surface form of the term as used with the user"
              },
              "aliases": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "default": [],
                "description": "Other surface forms users or agents have used; self-check matches them too"
              },
              "definition": {
                "type": "string",
                "minLength": 1,
                "maxLength": 800,
                "description": "What the term means in this project; written so an outsider can understand"
              },
              "examples": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Concrete usage examples"
              },
              "not_to_be_confused_with": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Adjacent terms that have caused confusion"
              },
              "status": {
                "type": "string",
                "enum": [
                  "proposed",
                  "agreed",
                  "deprecated"
                ],
                "description": "Lifecycle of a glossary entry",
                "default": "agreed"
              },
              "forbidden_abbreviations": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Abbreviations that self-check should reject in user-facing output"
              },
              "proposed_at": {
                "type": "string",
                "format": "date-time",
                "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
              },
              "agreed_at": {
                "type": "string",
                "format": "date-time",
                "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
              },
              "deprecated_at": {
                "type": "string",
                "format": "date-time",
                "description": "RFC 3339 / ISO 8601 datetime with timezone offset"
              }
            },
            "required": [
              "term",
              "definition"
            ],
            "additionalProperties": false,
            "description": "One ubiquitous-language entry shared between user and agents"
          },
          "default": []
        }
      },
      "required": [
        "schema_version",
        "project_name",
        "updated_at"
      ],
      "additionalProperties": false,
      "description": "Machine-readable view of .ditto/knowledge/CONTEXT.md"
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
